#
# Machine dependent make include file for LINUX - optimized version
# 

CC=CC
F77=f77
AR=ar
LINK=$(CC)
MAKE=make
RM=rm
RANLIB=echo
#
# flags
#
#
# Machine dependent flags:
#
ABI    =  
#
OPT    = -c -xO4 -w
#
ADDHEAD = 
CFLAGS2 = $(ABI) $(OPT) $(UNDER) $(ADDHEAD)   -instances=static
#-verbose=template
LINKFLAGS2 = 
