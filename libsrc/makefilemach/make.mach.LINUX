#
# Machine dependent make include file for LINUX - optimized version
# 
OPT=-O3 -mcpu=pentium
#
F77=g77 $(OPT)
CC=g++ 
CPLUSPLUS=$(CC)
AR=ar
LINK=$(CC)
MAKE=make
RM=rm
RANLIB=ranlib
#
# Machine dependent flags:
#
CFLAGS1=  -c $(OPT) -DMEMTRACE
CFLAG_EXE= 
FLAG_MKSHLIB = -g -v -shared 
ARFLAGS = r 
#
UNDER  = -DFORTRANDOUBLEUNDERSCORE
LINKFLAGS = 

syslib := -lm -lc 

