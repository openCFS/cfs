# =============================================================================
# Machine dependent make include file for LINUX - optimized version
# =============================================================================


# -----------------------------------------------------------------------------
# SYSTEM ARCHITECTURE
#
# Setting this is a must, since this parameter is required for finding the
# includes & libraries of other packages
# -----------------------------------------------------------------------------
ARCH = LINUXg

# -----------------------------------------------------------------------------
# UTILITIES
#
# Which program do we use for compiling, linking, etc.
# -----------------------------------------------------------------------------

CC     = g++ 
AR     = ar
LINK   = $(CC)
MAKE   = make
RM     = rm
RANLIB = ranlib


# -----------------------------------------------------------------------------
# ARCHIVER FLAGS
#
# Set flags for archive generation.
# -----------------------------------------------------------------------------

ARFLAGS = r 


# -----------------------------------------------------------------------------
# COMPILER FLAGS
#
# Set compiler flags. These must be assembled into the parameter
# CFLAGS_MACHINE, which is added to the compilation option for normal source
# code files together with the global options CFLAGS_GLOBAL generated by
# Makefile.option.
#
# MODEDEBUG ... for enabling debug output in certain modules
# DEBUG ....... global debug and warning options
# STANDARD .... the rest
# -----------------------------------------------------------------------------

# MODDEBUG = -DDEBUG_XMLPARAMHANDLER
MODEDEBUG =
DEBUG    = -Wno-long-long -Wno-comment -DTRACE=10 -ggdb -pg \
           -DCHECK_INDEX -DCHECK_INITIALIZED -DDEBUG -DMEMTRACE -DDEBUGFULL
STANDARD = -ansi -Wall -pedantic

CFLAG_EXE      =
CFLAGS_MACHINE = $(STANDARD) $(DEBUG) $(MODEDEBUG)


# -----------------------------------------------------------------------------
# BLAS and LAPACK
#
# Set libraries for linking against LAPACK and BLAS and determine whether this
# is necessary.
# -----------------------------------------------------------------------------

BLASLIB = -lblas
LAPACKLIB = -llapack

LAPACK_INSTALLDIR = -L/home/data/proj/SoftwareLibraries/LAPACK/LINUX/lib

ifeq "$(LINK_LAPACK)" "yes"
BLASLAPACK = $(LAPACKLIB) $(BLASLIB) -lg2c
LIBDIR_BLASLAPACK = $(LAPACK_INSTALLDIR)
else
ifeq "$(LINK_BLAS)" "yes"
BLASLAPACK = $(BLASLIB) -lg2c
LIBDIR_BLASLAPACK = $(LAPACK_INSTALLDIR)
else
BLASLAPACK =
LIBDIR_BLASLAPACK =
endif
endif


# -----------------------------------------------------------------------------
# LINKING
#
# Assemble machine-dependent linker flags (LFLAGS_MACHINE) and system libraries
# against which we must link (syslib). We can also specify additional linking
# options for generation of the executable via LFLAGS_EXE.
# -----------------------------------------------------------------------------

syslib = -lm -lc $(BLASLAPACK) $(LIBDIR_BLASLAPACK)
LFLAGS_MACHINE = -pg
LFLAGS_EXE =
