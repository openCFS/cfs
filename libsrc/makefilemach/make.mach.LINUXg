#
# Machine dependent make include file for LINUX: debugger version
# 
F77=g77 -g
CC=g++ -g
CPLUSPLUS=$(CC)
AR=ar
LINK=$(CC)
MAKE=make
RM=rm
RANLIB=ranlib
#
# Machine dependent flags:
#
UNDER  = -DFORTRANDOUBLEUNDERSCORE
CFLAGS1 = -ansi -DDEBUG -DTRACE 
#CFLAGS2 = -DTRACE
