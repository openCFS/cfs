#
# Machine dependent make include file for LINUX - optimized version
# 
OPT= 
#
F77=g77 $(OPT)
CC=g++ 
CPLUSPLUS=$(CC)
AR=ar
LINK=$(CC)
MAKE=make
RM=rm
RANLIB=ranlib
#
# Machine dependent flags:
#
CFLAGS1= -pg -g -c -DTRACE -DDEBUG
CFLAG_EXE= -g
FLAG_MKSHLIB = -g -v -shared 
ARFLAGS = r 
#
UNDER  = -DFORTRANDOUBLEUNDERSCORE
LINKFLAGS = -pg 

syslib := -lm -lc 

