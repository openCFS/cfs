#
# make machine dependent inlcude file: optimized on SGI
#
CC=CC
F77=f77
AR=ar
LINK=CC
MAKE=make
RM=rm
RANLIB=echo
#
# flags
#
# Machine dependent flags:
#
ABI    = 
#
OPT    = 
LNO    = 
UNDER  = 
#
#CFLAGS1 = -v -LANG::std -n32 -c $(INCL) 
#FLAG_MKSHLIB = -v -LANG::std -n32 -ptused -prelink -shared
#
#CFLAGS2 = -n32 -D TRACE -D DEBUG -w -I. -I/usr/include/X11 -I/usr/include/CC -I/usr/include
#
CFLAGS1 = -LANG:std -n32 -g -prelink -ptused -w -D TRACE -D DEBUG -D GRIDLIB
CFLAG_EXE=  -LANG:std -n32 -g -w
#
#ifeq "$(TYPEOFLIB)" "SHARED"
#LINKFLAGS2=-shared 
#else
#LINKFLAGS2 := -static
#endif
#
FLAG_MKSHLIB = -LANG:std -n32 -g -ptused -prelink -shared
#
# Flag for function tracing
ifneq "$(TRACE)" "0"
TRACEFLAGS=-DTRACE=$(TRACE)
endif
