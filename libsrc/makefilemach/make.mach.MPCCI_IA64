# =============================================================================
# Machine dependent make include file for LINUX - optimized version
# =============================================================================


# -----------------------------------------------------------------------------
# SYSTEM ARCHITECTURE
#
# Setting this is a must, since this parameter is required for finding the
# includes & libraries of other packages
# -----------------------------------------------------------------------------
ARCH = LINUX


# -----------------------------------------------------------------------------
# UTILITIES
#
# Which program do we use for compiling, linking, etc.
# -----------------------------------------------------------------------------

CC     = /opt/MpCCI/mpcci-3.0.3-sdk-linux-ia64-glibc23/bin/cciCC
AR     = ar
LINK   = $(CC)
MAKE   = make
RM     = rm
RANLIB = ranlib


# -----------------------------------------------------------------------------
# ARCHIVER FLAGS
#
# Set flags for archive generation.
# -----------------------------------------------------------------------------

ARFLAGS = r 


# -----------------------------------------------------------------------------
# COMPILER FLAGS
#
# Set compiler flags. These must be assembled into the parameter
# CFLAGS_MACHINE, which is added to the compilation option for normal source
# code files together with the global options CFLAGS_GLOBAL generated by
# Makefile.option.
# -----------------------------------------------------------------------------

PROFILE  = -DPROFILING
OPT      = -O3
STANDARD = -ansi -pedantic -Wno-long-long -Wno-comments

CFLAG_EXE      = $(OPT)
CFLAGS_MACHINE = $(OPT) $(STANDARD) $(PROFILE)


# -----------------------------------------------------------------------------
# BLAS and LAPACK
#
# Set libraries for linking against LAPACK and BLAS and determine whether this
# is necessary.
# -----------------------------------------------------------------------------

BLASLIB = -lblas
LAPACKLIB = -llapack

ifeq "$(LINK_LAPACK)" "yes"
BLASLAPACK = $(LAPACKLIB) $(BLASLIB) -lg2c
else
ifeq "$(LINK_BLAS)" "yes"
BLASLAPACK = $(BLASLIB) -lg2c
else
BLASLAPACK =
endif
endif

LIBDIR_MPCCI = -L/opt/MpCCI/mpcci-3.0.3-sdk-linux-ia64-glibc23/lib
LIBDIR_MPICH = -L/opt/MpCCI/mpich-1.2.6-intel81/lib

# -----------------------------------------------------------------------------
# ARPACK
#
# Set library for linking against ARPACK.
# -----------------------------------------------------------------------------
ifeq "$(ARPACK)" "yes"
LIB_ARPACK = -larpack
endif

# -----------------------------------------------------------------------------
# LINKING
#
# Assemble machine-dependent linker flags (LFLAGS_MACHINE) and system libraries
# against which we must link (syslib). We can also specify additional linking
# options for generation of the executable via LFLAGS_EXE.
# -----------------------------------------------------------------------------

#syslib = -lm -lc $(BLASLAPACK) -lcci -lmpich -lg2c -Xlinker -R -Xlinker /opt/intel9/ia64_fc_9.0-024/lib -L/opt/intel9/ia64_fc_9.0-024/lib -lifcore -Xlinker -R -Xlinker /opt/intel_cc_81-026/lib
syslib = -lm -lc $(LIB_ARPACK) $(BLASLAPACK) -lcci -lmpich -lg2c -Xlinker -R -Xlinker /opt/intel_cc_81-026/lib -L/opt/intel_cc_81-026/lib
LFLAGS_MACHINE = $(LIBDIR_MPCCI) $(LIBDIR_MPICH)
LFLAGS_EXE = -Wl,-rpath -Wl,/usr/lib
