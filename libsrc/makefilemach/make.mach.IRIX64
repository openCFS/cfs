# =============================================================================
# Machine dependent make include file for IRIX64 - optimized version
# =============================================================================


# -----------------------------------------------------------------------------
# SYSTEM ARCHITECTURE
#
# Setting this is a must, since this parameter is required for finding the
# includes & libraries of other packages
# -----------------------------------------------------------------------------
ARCH = IRIX64


# -----------------------------------------------------------------------------
# UTILITIES
#
# Which program do we use for compiling, linking, etc.
# -----------------------------------------------------------------------------
CC     = CC
AR     = ar
LINK   = $(CC)
MAKE   = gmake
RM     = rm
RANLIB = echo


# -----------------------------------------------------------------------------
# APPLICATION BINARY INTERFACE
#
# The application binary interface must be one of -332, -o32, -n32, -64.
# For IRIX64  we of course chose the 64-bit option
# -----------------------------------------------------------------------------
ABI = -64


# -----------------------------------------------------------------------------
# ARCHIVER FLAGS
#
# Set flags for archive generation.
# -----------------------------------------------------------------------------
ARFLAGS = r


# -----------------------------------------------------------------------------
# COMPILER FLAGS
#
# We generate the folling set of compiler flags:
#
# SUPP ..... we want to suppress certain compiler warnings
# TEMPL .... flags related to template instantiation
# OPT ...... optimisation flags
# ASTD ..... options for ANSI/ISO compatibility
#
# Set compiler flags. These must be assembled into the parameter
# CFLAGS_MACHINE, which is added to the compilation option for normal source
# code files together with the global options CFLAGS_GLOBAL generated by
# Makefile.option.
# -----------------------------------------------------------------------------
SUPP  = -woff1681,1682
TEMPL = -ptused -no_prelink -no_auto_include 
OPT   = -O3 -r12000 -LNO -DEXPR_TEMPLATES
ASTD  = -LANG:std 

CFLAG_EXE      = $(OPT)
CFLAGS_MACHINE = $(ASTD) $(TEMPL) $(SUPP) $(OPT)


# -----------------------------------------------------------------------------
# BLAS and LAPACK
#
# Set libraries for linking against LAPACK and BLAS and determine whether this
# is necessary.
# -----------------------------------------------------------------------------
ifeq "$(LINK_LAPACK)" "yes"
BLASLAPACK = -lscs
else
ifeq "$(LINK_BLAS)" "yes"
BLASLAPACK = -lscs
else
BLASLAPACK =
endif
endif


# -----------------------------------------------------------------------------
# LINKING
#
# Assemble machine-dependent linker flags (LFLAGS_MACHINE) and system libraries
# against which we must link (syslib). We can also specify additional linking
# options for generation of the executable via LFLAGS_EXE.
# -----------------------------------------------------------------------------
syslib = -lmx -lCio -lC $(BLASLAPACK)
LFLAGS_MACHINE = $(ABI)
LFLAGS_EXE = $(ABI)
