# move the library files
FILE(GLOB ALL_OPENBLAS_LIBRARIES
  "@openblas_install@/lib64/*"
)
FILE(COPY ${ALL_OPENBLAS_LIBRARIES} DESTINATION "@CMAKE_CURRENT_BINARY_DIR@/lib64/@CFS_ARCH_STR@")

# move the include files
FILE(GLOB ALL_OPENBLAS_INCLUDES
  "@openblas_install@/include/*"
)
FILE(COPY ${ALL_OPENBLAS_INCLUDES} DESTINATION "@CMAKE_CURRENT_BINARY_DIR@/include")
