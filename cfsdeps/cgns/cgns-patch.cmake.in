set(cgns_source  "@cgns_source@")
SET(CFS_SOURCE_DIR "@CFS_SOURCE_DIR@")
SET(CFS_CXX_COMPILER_NAME "@CFS_CXX_COMPILER_NAME@")
SET(CFS_DISTRO "@CFS_DISTRO@")

INCLUDE("${CFS_SOURCE_DIR}/cmake_modules/CFS_macros.cmake")

SET(patches
  # It should be possible to select .ccm* files from the cgnsview
  # file open dialog.
  "cgnsview-ccmio.patch"
  "cgns-cmake-policy.patch"
  "cgns-install-target.patch"

  # Previously the TCL file function was used to split path entries
  # the .cgns file for display in the TK GUI. This can cause problems
  # if parts of the .cgns hierarchy contain entries named after input
  # files. This is e.g. the case for .cgns files generated by the
  # ANSYS Workbench mesher, which names its zones after the path to
  # an .uns file. We now split paths using the TCL split function 
  # with just slashes as split characters.
  "cgnstools-tree-file2.patch"

  # Allow the specification of relative paths to a CGNS file on the
  # command line of cgnsview and cgnsplot by generating an absolute
  # path internally.
  "cgnstools-allow-relpaths-on-cmdline.patch"
  )

IF(CFS_DISTRO STREQUAL "MACOSX")
  LIST(APPEND patches
    "cgns-cmake-mac.patch"
    "cgns-arch-mac.patch"
    "cgns-osx-opengl.patch"
    )
ENDIF(CFS_DISTRO STREQUAL "MACOSX")

LIST(APPEND patches "cgns-hdf5.patch")
LIST(APPEND patches "cgns-adjust-install-paths.patch")

APPLY_PATCHES("${patches}" "${CFS_SOURCE_DIR}/cfsdeps/cgns")
