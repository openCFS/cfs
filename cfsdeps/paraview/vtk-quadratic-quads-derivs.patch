+  int i, j;
+  double functionDerivs[12];
+  double elemNodes[6][3];
+  double *J[3], J0[3], J1[3], J2[3];
+  double *JI[3], JI0[3], JI1[3], JI2[3];
+
+  for(unsigned i = 0; i<6; i++) {
+    this->Points->GetPoint(i, elemNodes[i]);
