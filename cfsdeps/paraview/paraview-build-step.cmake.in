SET(paraview_source "@paraview_source@")

SET(CFS_BINARY_DIR "@CFS_BINARY_DIR@")
SET(CFS_ARCH_STR "@CFS_ARCH_STR@")
SET(CFS_ARCH "@CFS_ARCH@")
SET(CMAKE_MAKE_PROGRAM "@CMAKE_MAKE_PROGRAM@")

SET(ENV{LD_LIBRARY_PATH} "${paraview_source}-superbuild-build/lib")

SET(BUILD_CMD
  "${CMAKE_MAKE_PROGRAM}"
)

EXECUTE_PROCESS(
  COMMAND ${BUILD_CMD}
  WORKING_DIRECTORY "${paraview_source}-superbuild-build"
#  ERROR_FILE paraview-build.out
#  OUTPUT_FILE paraview-build.out
  RESULT_VARIABLE rv
  )
