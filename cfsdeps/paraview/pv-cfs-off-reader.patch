+
+int vtkNACSReader::CanReadFile(const char* fname) {
+  
+  // Try to "load" the file (which internally just opens the mesh group)
+  // to see, if this is a true NACS HDF5 file. 
+  std::string fileName = std::string(fname);
+  H5NACS::Hdf5Reader temp; 
+  try {
+    temp.LoadFile( fileName );
+    // If this succeeds, we assume that this is a true NACS HDF5 file.
+    return true;
+  } catch (...) {
+    return false;
+  }
+}
