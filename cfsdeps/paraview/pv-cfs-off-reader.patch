+
+    void GetNativeData( std::string * data) {
+      for( unsigned int i = 0; i < numElems_; i++ ) {
+        data[i].assign( buffer_[i]);
+      }
+    }
+
+    void SetNativeData( const std::string& t ) {
+      CleanUp();
+      buffer_ = new const char*[1];
+      buffer_[0] = t.c_str();
+      size_ = sizeof( char* );
+      numElems_ = 1;
+      isSet_ = true;
+    }
+
+    void SetNativeData( const std::string* t, unsigned int size  ) {
+      CleanUp();
+      buffer_ = new const char*[size];
+      for( unsigned int i = 0; i < size; i ++ ) {
+        buffer_[i] = t[i].c_str();
+      }
+      size_ = sizeof( char* );
+      numElems_ = size;
+      isSet_ = true;
+    }
+
+    void CleanUp() {
+      if( buffer_ ) {
+        delete[] buffer_;
+      }
+      buffer_ = NULL;
+      size_ = 0;
+      numElems_ = 0;
+      isSet_ = false;
+    }
+
+    ~HdfTypeConversion() 
+    {
+      CleanUp();
+      delete stdType_;
+      delete nativeType_;
+    }
+    
+  };
