+  void Hdf5Reader::GetResult( unsigned int sequenceStep,
+                              unsigned int stepNum,
+                              shared_ptr<Result> result,
+                              bool isHistory ) {
+    
+    if( !isHistory ) {
+      GetMeshResult( sequenceStep, stepNum, result);
+    } else {
+      GetHistResult( sequenceStep, stepNum, result );      
