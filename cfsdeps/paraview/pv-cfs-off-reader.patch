+void vtkCFSReader::GenFreqUnitSuffix(double freq, std::string& suffix) {
+  std::stringstream sstr;
+  std::vector<std::string> freqUnits;
+
+  freqUnits.push_back("nHz");
+  freqUnits.push_back("muHz");
+  freqUnits.push_back("mHz");
+  freqUnits.push_back("Hz");
+  freqUnits.push_back("kHz");
+  freqUnits.push_back("MHz");
+  freqUnits.push_back("GHz");
+  freqUnits.push_back("THz");
+  freqUnits.push_back("PHz");
+  freqUnits.push_back("EHz");
+  freqUnits.push_back("ZHz");
+  freqUnits.push_back("YHz");
+
+  DBG_OUT( "Generating frequency suffix for value " << freq );
+  
+  double absFreq = std::abs(freq);
+  int i, j;
+  for(i = 8; i >= -3; i-- ) {
+    DBG_OUT(" i = " << i);
+    double res = pow(1000.0, (double)i);
+
+    int val = (int)(absFreq / res);
+    int rem = floor(fmod(absFreq, res));
+    DBG_OUT(" res = " << res);
+    DBG_OUT(" rem = " << rem);
+    DBG_OUT(" val = " << val);
+
+    // generate suffix in case a remainder > 0 is generated
+    // or we have reached the last loop ("Hz").
+    if(val || i == -3 ) {
+      if(rem) {
+        for(j=1; j<i; j++) {
+          std::cout << rem << std::endl; 
+          rem /= 1000;
+        }
+      }
+                    
+      sstr << val << "." << rem << " " << freqUnits[i+3];
+      suffix = sstr.str();
+      sstr.clear(); sstr.str("");
+      break;
+    }
+  }
+}
