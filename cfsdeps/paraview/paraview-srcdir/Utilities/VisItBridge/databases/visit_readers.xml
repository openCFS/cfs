    <SourceProxy name="VisItTecplotBinaryReaderCore" class="vtkVisItTecplotBinaryReader"
      base_proxygroup="internal_readers" base_proxyname="VisItReaderBase">
      <Documentation
        long_help="Reads a subset of the Tecplot binary file format">
        Note this reader is automatically generated from wrapping a third party reader. For more information on the reader see https://wci.llnl.gov/codes/visit
        The default file extension is .plt
      </Documentation>
     <Hints>
       <ReaderFactory extensions="plt"
                      file_description="Tecplot Binary Files (VisIt)" />
     </Hints>
    </SourceProxy>

    <SourceProxy name="VisItTecplotReaderCore" class="vtkVisItTecplotReader"
      base_proxygroup="internal_readers" base_proxyname="VisItReaderBase">
      <Documentation
        long_help="Reads a subset of the ASCII Tecplot file format">
        Note this reader is automatically generated from wrapping a third party reader. For more information on the reader see https://wci.llnl.gov/codes/visit
        The default file extensions are .tp, .dat and .tec
      </Documentation>
     <Hints>
       <ReaderFactory extensions="tec TEC Tec tp TP dat"
                      file_description="Tecplot Files (VisIt)" />
     </Hints>
    </SourceProxy>

#ifdef VISIT_BUILD_READER_Silo
    <SourceProxy name="VisItSiloReaderCore" class="vtkVisItSiloReader"
      base_proxygroup="internal_readers" base_proxyname="VisItReaderBase">
