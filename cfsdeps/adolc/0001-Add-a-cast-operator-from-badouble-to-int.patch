From 7446e718543ac8c4a449e8c1b6d03c7b0ebcdf60 Mon Sep 17 00:00:00 2001
From: Benjamin Jurgelucks <bjurgel@darwin.math.uni-paderborn.de>
Date: Tue, 26 Jan 2016 13:24:57 +0100
Subject: [PATCH] Add a cast operator from badouble to int

Signed-off-by: Benjamin Jurgelucks <bjurgel@darwin.math.uni-paderborn.de>
---
 ADOL-C/include/adolc/adouble.h | 1 +
 ADOL-C/src/adouble.cpp         | 6 ++++++
 2 files changed, 7 insertions(+)

diff --git a/ADOL-C/include/adolc/adouble.h b/ADOL-C/include/adolc/adouble.h
index 747da79..0be4d73 100644
--- a/ADOL-C/include/adolc/adouble.h
+++ b/ADOL-C/include/adolc/adouble.h
@@ -111,6 +111,7 @@ public:
     explicit operator double();
     explicit operator double const&();
     explicit operator double&&();
+    explicit operator int();
     void setValue ( const double );
     /* badouble& operator = ( const adouble& );
        !!! olvo 991210: was the same as badouble-assignment */
diff --git a/ADOL-C/src/adouble.cpp b/ADOL-C/src/adouble.cpp
index b76ebdf..99a6119 100644
--- a/ADOL-C/src/adouble.cpp
+++ b/ADOL-C/src/adouble.cpp
@@ -237,6 +237,12 @@ badouble::operator double() {
     return ADOLC_GLOBAL_TAPE_VARS.store[loc()];
 }
 
+badouble::operator int() {
+    ADOLC_OPENMP_THREAD_NUMBER;
+    ADOLC_OPENMP_GET_THREAD_NUMBER;
+    return (int)ADOLC_GLOBAL_TAPE_VARS.store[loc()];
+}
+
 void badouble::setValue( const double x ) {
     ADOLC_OPENMP_THREAD_NUMBER;
     ADOLC_OPENMP_GET_THREAD_NUMBER;
-- 
2.1.4

