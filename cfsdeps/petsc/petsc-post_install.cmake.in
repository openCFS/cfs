# we copy only include and lib

# we don't need the share/petsc stuff with datafiles, examples, matlab, saws and xml 
FILE(REMOVE_RECURSE "@PETSC_INSTALL@/share/")

# we don't need the bin stuff
FILE(REMOVE_RECURSE "@PETSC_INSTALL@/bin/")

# copy remaining lib and include from install dir to the target.
FILE(COPY "@PETSC_INSTALL@/" DESTINATION "@CMAKE_CURRENT_BINARY_DIR@/")

# this directory shall now be also fine for zipping