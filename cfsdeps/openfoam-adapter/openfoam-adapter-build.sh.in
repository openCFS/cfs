#!/bin/bash
# Build the preCICE OpenFOAM adapter inside the OpenFOAM environment.
# Generated from cfsdeps/openfoam-adapter/openfoam-adapter-build.sh.in - do not edit,
# can be re-run manually.
cd "@DEPS_SOURCE@" || exit 1

if [ -n "@OPENFOAM_MPI_BINDIR@" ]; then
  export PATH="@OPENFOAM_MPI_BINDIR@:$PATH"
fi

# detach from the outer cfs make: wmake only parallelizes when MAKEFLAGS is empty
# (see cfsdeps/openfoam/openfoam-build.sh.in for the full story)
unset MAKEFLAGS MFLAGS MAKELEVEL

# etc/bashrc can return non-zero for harmless reasons
set +e
source "@OPENFOAM_DIR@/etc/bashrc"
set -e

# preCICE of this cfs build (libprecice.pc generated by External_PRECICE.cmake)
export PKG_CONFIG_PATH="@CMAKE_BINARY_DIR@/lib/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"
# install straight into OpenFOAM's lib dir: solvers then find the adapter with
# the plain OpenFOAM environment, no FOAM_USER_LIBBIN in $HOME involved
export PRECICE_OPENFOAM_TARGET_DIR="$FOAM_LIBBIN"
export WM_NCOMPPROCS=@CFS_DEPS_BUILD_THREADS@

./Allclean   # first, in case of leftovers accidentally committed to the repo
./Allwmake

# Allwmake exits 0 even when its ldd check found unresolved symbols - verify here
test -s "$FOAM_LIBBIN/libpreciceAdapterFunctionObject.so"
if grep -qE "undefined symbol" ldd.log 2>/dev/null; then
  echo "ERROR: libpreciceAdapterFunctionObject.so has undefined symbols (see ldd.log)"
  exit 1
fi
echo "OpenFOAM adapter build OK: $FOAM_LIBBIN/libpreciceAdapterFunctionObject.so"
