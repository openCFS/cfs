set(ARPACK_source  "@ARPACK_source@")
SET(CFS_SOURCE_DIR "@CFS_SOURCE_DIR@")
SET(CFS_FORTRAN_COMPILER_NAME "@CFS_FORTRAN_COMPILER_NAME@")

EXECUTE_PROCESS(
  COMMAND ${CMAKE_COMMAND} -E copy_if_different "${CFS_SOURCE_DIR}/cfsdeps/arpack/CMakeLists.txt" "${ARPACK_source}/CMakeLists.txt"
)

EXECUTE_PROCESS(
  COMMAND ${CMAKE_COMMAND} -E copy_directory "${ARPACK_source}-download" "${ARPACK_source}"
)

EXECUTE_PROCESS(
  COMMAND ${CMAKE_COMMAND} -E copy_directory "${ARPACK_source}-patches" "${ARPACK_source}"
)

SET(patches
  "arpack-2.1-redhat.patch";
)

IF(CFS_FORTRAN_COMPILER_NAME STREQUAL "GNU")
  set(patches
    ${patches}
    "arpack-gfortran-etime-intrinsic.patch"
    )
ENDIF(CFS_FORTRAN_COMPILER_NAME STREQUAL "GNU")

IF(CFS_FORTRAN_COMPILER_NAME STREQUAL "IFORT")
  set(patches
    ${patches}
    "arpack-ifort-cpu_time.patch"
    )
ENDIF(CFS_FORTRAN_COMPILER_NAME STREQUAL "IFORT")


foreach(patch IN LISTS patches)
  MESSAGE("Applying patch ${patch}")
  EXECUTE_PROCESS(
    COMMAND patch -p0 -i "${CFS_SOURCE_DIR}/cfsdeps/arpack/${patch}"
    )
endforeach(patch)
