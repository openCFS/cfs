set(ARPACK_source  "@ARPACK_source@")
SET(CFS_SOURCE_DIR "@CFS_SOURCE_DIR@")
SET(CFS_FORTRAN_COMPILER_NAME "@CFS_FORTRAN_COMPILER_NAME@")

INCLUDE("${CFS_SOURCE_DIR}/cmake_modules/CFS_macros.cmake")

EXECUTE_PROCESS(
  COMMAND ${CMAKE_COMMAND} -E copy_if_different "${CFS_SOURCE_DIR}/cfsdeps/arpack/CMakeLists.txt" "${ARPACK_source}/CMakeLists.txt"
)

# Generate C/C++ compatible arpack version header.
FILE(READ "SRC/version.h" lines)

foreach(line IN LISTS lines)
#  MESSAGE("line: ${line}")

  STRING(REPLACE "VERSION_NUMBER ' "
    "ARPACK_VERSION_NUMBER '" line
    ${line})

  STRING(REPLACE "VERSION_DATE   ' "
    "ARPACK_VERSION_DATE   '" line
    ${line})

  STRING(REPLACE
    "'"  "\""
    line
    ${line})    

  foreach(part IN LISTS line)
    LIST(APPEND OUTPUT "${part}")
  endforeach(part)
endforeach(line)

FILE(WRITE "SRC/arpack_version.h" "${OUTPUT}")

IF(CFS_FORTRAN_COMPILER_NAME STREQUAL "IFORT")
  set(patches
    ${patches}
    "arpack-ifort-cpu_time.patch"
    )
ENDIF(CFS_FORTRAN_COMPILER_NAME STREQUAL "IFORT")

APPLY_PATCHES("${patches}" "${CFS_SOURCE_DIR}/cfsdeps/arpack")
