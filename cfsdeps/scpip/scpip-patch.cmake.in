set(scpip_source  "@scpip_source@")
SET(CFS_SOURCE_DIR "@CFS_SOURCE_DIR@")
SET(CFS_DISTRO "@CFS_DISTRO@")

INCLUDE("${CFS_SOURCE_DIR}/cmake_modules/CFS_macros.cmake")

EXECUTE_PROCESS(
  COMMAND ${CMAKE_COMMAND} -E copy_if_different 
  "${CFS_SOURCE_DIR}/cfsdeps/scpip/CMakeLists.txt"
  "${scpip_source}/CMakeLists.txt"
)

SET(patches
    "scpip-gfortran.patch"
    "scpip-dum2.patch"
)

APPLY_PATCHES("${patches}" "${CFS_SOURCE_DIR}/cfsdeps/scpip")
