# Perform install for all modules by going into each module's build directory and call make/nmake/ninja install
# See root CMakeLists.txt. Generated via suitesparse_install.cmake.in
include(CMakePrintHelpers)

set(INSTALL_TARGETS "@INSTALL_LIST@")

foreach(ITEM ${INSTALL_TARGETS})
  cmake_print_variables(ITEM)
  execute_process(
    COMMAND ${CMAKE_COMMAND} --build . --target install
    WORKING_DIRECTORY ${ITEM} 
    COMMAND_ECHO STDOUT )              
endforeach()
