SET(CFS_SOURCE_DIR "@CFS_SOURCE_DIR@")

INCLUDE("${CFS_SOURCE_DIR}/cmake_modules/CFS_macros.cmake")

SET(patches
  # Patch for adding basic CMake support to SuiteSparse
  # http://www.zeuux.com/group/scipython/bbs/content/52045/
  "suitesparse-cmake.patch"
  # Patch for adding CFS++ specifics to CMake for SuiteSparse
  "suitesparse-cmake-for-cfs.patch"
)

APPLY_PATCHES("${patches}" "${CFS_SOURCE_DIR}/cfsdeps/suitesparse")
