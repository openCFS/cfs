set(CFS_SOURCE_DIR  "@CFS_SOURCE_DIR@")
set(DEPS_PREFIX  "@DEPS_PREFIX@")
set(PACKAGE_NAME "@PACKAGE_NAME@")

include("${CFS_SOURCE_DIR}/cmake_modules/CFS_macros.cmake")

assert_set(DEPS_PREFIX)
assert_set(PACKAGE_NAME)

file(COPY "${CFS_SOURCE_DIR}/cfsdeps/${PACKAGE_NAME}/CMakeLists.txt" DESTINATION "${DEPS_PREFIX}/src/${PACKAGE_NAME}")
file(COPY "${CFS_SOURCE_DIR}/cfsdeps/${PACKAGE_NAME}/suitesparse_install.cmake.in" DESTINATION "${DEPS_PREFIX}/src/${PACKAGE_NAME}")
