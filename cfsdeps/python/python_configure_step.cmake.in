if(UNIX)
  set(ENV{LD_LIBRARY_PATH} "@python_build@/lib")

 #  include("@ParaViewSuperBuild_CMAKE_BINARY_DIR@/paraview_common_environment.cmake")

  set(library_param --enable-shared)

  if(APPLE)
    set(library_param --enable-framework=@python_build@)
  endif()

  SET(ENV{CC} "@CMAKE_C_COMPILER@")
  SET(ENV{CFLAGS} "@CFLAGS@")
  SET(ENV{CXX} "@CMAKE_CXX_COMPILER@")
  SET(ENV{CXXFLAGS} "@CFLAGS@")

  EXECUTE_PROCESS(
    COMMAND sh configure --prefix=@python_install@ ${library_param} --enable-unicode=ucs2
    WORKING_DIRECTORY "@python_source@"
    RESULT_VARIABLE rv
    )
endif()
