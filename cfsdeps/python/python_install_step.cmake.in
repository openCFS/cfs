if(UNIX)
#  include("@ParaViewSuperBuild_CMAKE_BINARY_DIR@/paraview_common_environment.cmake")

  if(APPLE)
    set(ENV{DYLD_LIBRARY_PATH} "@python_build@/lib")
  else(APPLE)
    set(ENV{LD_LIBRARY_PATH} "@python_build@/lib")
  endif(APPLE)

  EXECUTE_PROCESS(
    COMMAND make install
    WORKING_DIRECTORY "@python_source@"
    )

  EXECUTE_PROCESS(
    COMMAND @python_build@/bin/python setup.py install
    WORKING_DIRECTORY "@python_build@"
    RESULT_VARIABLE rv
    )

  # write install manifest, needed for ZIP_TO_CACHE 
  SET(FILES_TO_INSTALL "@CMAKE_CURRENT_BINARY_DIR@/bin/2to3;@CMAKE_CURRENT_BINARY_DIR@/bin/idle;@CMAKE_CURRENT_BINARY_DIR@/bin/smtpd.py;@CMAKE_CURRENT_BINARY_DIR@/bin/pydoc")
  FILE(GLOB_RECURSE FILES_TO_INSTALL_TMP FOLLOW_SYMLINKS "@CMAKE_CURRENT_BINARY_DIR@/bin/python*")
  SET(FILES_TO_INSTALL "${FILES_TO_INSTALL};${FILES_TO_INSTALL_TMP}")
  FILE(GLOB_RECURSE FILES_TO_INSTALL_TMP FOLLOW_SYMLINKS "@CMAKE_CURRENT_BINARY_DIR@/lib/python*/*")
  SET(FILES_TO_INSTALL "${FILES_TO_INSTALL};${FILES_TO_INSTALL_TMP}")
  FILE(GLOB_RECURSE FILES_TO_INSTALL_TMP FOLLOW_SYMLINKS "@CMAKE_CURRENT_BINARY_DIR@/include/python*/*")
  SET(FILES_TO_INSTALL "${FILES_TO_INSTALL};${FILES_TO_INSTALL_TMP}")
  FILE(GLOB_RECURSE FILES_TO_INSTALL_TMP FOLLOW_SYMLINKS "@CMAKE_CURRENT_BINARY_DIR@/lib64/*python*")
  SET(FILES_TO_INSTALL "${FILES_TO_INSTALL};${FILES_TO_INSTALL_TMP}")
  FILE(GLOB_RECURSE FILES_TO_INSTALL_TMP FOLLOW_SYMLINKS "@CMAKE_CURRENT_BINARY_DIR@/lib64/python*/*")
  SET(FILES_TO_INSTALL "${FILES_TO_INSTALL};${FILES_TO_INSTALL_TMP}")
  FILE(GLOB_RECURSE FILES_TO_INSTALL_TMP FOLLOW_SYMLINKS "@CMAKE_CURRENT_BINARY_DIR@/share/python*")
  SET(FILES_TO_INSTALL "${FILES_TO_INSTALL};${FILES_TO_INSTALL_TMP}")

  FOREACH(IFILE ${FILES_TO_INSTALL})
    FILE(APPEND "@CMAKE_CURRENT_BINARY_DIR@/cfsdeps/python/src/python-build/install_manifest.txt" "${IFILE}\n")
  ENDFOREACH()

endif()
