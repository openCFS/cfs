#!/bin/sh
gmp_source="@gmp_source@"

CFS_BINARY_DIR="@CFS_BINARY_DIR@"
CFS_ARCH_STR="@CFS_ARCH_STR@"
LIB_SUFFIX="@LIB_SUFFIX@"
ABI=@ABI@

CC="@CMAKE_C_COMPILER@"
CXX="@CMAKE_CXX_COMPILER@"
CFLAGS="@CFLAGS@"
CXXFLAGS="${CFLAGS}@"

export CC CXX CFLAGS

cd "${gmp_source}" && \
sh ./configure \
  --prefix="${CFS_BINARY_DIR}" \
  --bindir="${CFS_BINARY_DIR}/bin/${CFS_ARCH_STR}" \
  --libdir="${CFS_BINARY_DIR}/${LIB_SUFFIX}/${CFS_ARCH_STR}" \
  --includedir="${CFS_BINARY_DIR}/include" \
  --enable-shared=no \
  --enable-cxx \
  ABI=${ABI}
