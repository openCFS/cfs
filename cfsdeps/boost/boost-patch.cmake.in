SET(CFS_SOURCE_DIR "@CFS_SOURCE_DIR@")
SET(CFS_CXX_COMPILER_NAME "@CFS_CXX_COMPILER_NAME@")

INCLUDE("${CFS_SOURCE_DIR}/cmake_modules/CFS_macros.cmake")

SET(patches
  "boost-multi_array.patch"
  "boost-lexical_cast-format-string.patch"
  # Prevent warning message related to the unordered map detail implementation. See
  #    # https://svn.boost.org/trac/boost/ticket/6370
  "boost-unordered-table.patch"
)

IF(CFS_CXX_COMPILER_NAME STREQUAL "ICC")
  SET(patches
    "${patches}"
    # The following patch fixes a bug regarding a missing function
    # __builtin_signbit. This patch replaces the use of this internal
    # function by a plain if-statement. There is already a bug description at intel:
    #    http://secure-software.intel.com/en-us/forums/showthread.php?t=98532
    # As soon as there is an official patch available, we should incorporate it here.
    "boost-intel-signbit-intrinsic.patch"
    "boost-intel-fpclassify.patch"
    )
ENDIF(CFS_CXX_COMPILER_NAME STREQUAL "ICC")

APPLY_PATCHES("${patches}" "${CFS_SOURCE_DIR}/cfsdeps/boost")
