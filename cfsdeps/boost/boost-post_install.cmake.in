FILE(GLOB ALL_BOOST_LIBRARIES
  "@BOOST_install@/lib/*"
)
FILE(COPY ${ALL_BOOST_LIBRARIES} DESTINATION "@CMAKE_CURRENT_BINARY_DIR@/@LIB_SUFFIX@")

IF(WIN32)
  FILE(GLOB ALL_BOOST_INCLUDES
      "@BOOST_install@/include/boost-@BOOST_MAJOR_VER@_@BOOST_MINOR_VER@/boost/*"
  )
ELSE(WIN32)
  FILE(GLOB ALL_BOOST_INCLUDES
    "@BOOST_install@/include/boost/*"
  )
ENDIF(WIN32)
# copy data from install dir to the target (lib64 and include)
#FILE(COPY "@BOOST_install@/" DESTINATION "@CMAKE_CURRENT_BINARY_DIR@/")
FILE(COPY ${ALL_BOOST_INCLUDES} DESTINATION "@CMAKE_CURRENT_BINARY_DIR@/include/boost")
