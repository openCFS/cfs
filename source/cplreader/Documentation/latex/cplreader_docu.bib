@TECHREPORT{Kaltenbacher2005,
  author = {M. Kaltenbacher and M.Escobar and I. Ali and S. Becker},
  title = {Finite Element Formulation of {Lighthill's} Analogy},
  institution = {Chair of Sensor Technology, Erlangen},
  year = {2005},
  abstract = {We propose a hybrid approach for the computation of ﬂow induced sound
	by applying a Large Eddy Simulation (LES) to the ﬂow ﬁeld and solving
	the inhomogeneous wave equation according to Lighthill’s acoustic
	analogy within a post-processing step. In a ﬁrst step, the ﬂow ﬁeld
	is computed by ANSYS-CFX using the Scale Adaptive Simulation (SAS).
	In a second step an enhanced Finite-Element (FE) method is solving
	the inhomogeneous acoustic wave equation. To preserve the total acoustic
	energy in the ﬂow ﬁeld, we compute the right hand side of the FE-formulation
	on the ﬁne ﬂow grid to obtain so called acoustic nodal loads. These
	scalar quantity is then interpolated to the coarser acoustic grid
	by a conservative technique.
	
	The applicability of the developed calculation scheme will be demonstrated
	by the computation of the noise generated by a ﬂow around a square
	cylinder.},
  booktitle = {LSE Report},
  file = {:papers/Kaltenbacher_2005.pdf:PDF},
  owner = {strieben},
  timestamp = {2008.07.17}
}

