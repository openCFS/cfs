#include <string>
#include <sstream>
#include <exception>

#include <boost/cstdint.hpp>

namespace CoupledField 
{
  class Exception : public std::exception
  {
  public:
    Exception( const Exception* reason,
               const char* const fileName = "NO_FILENAME", 
               const unsigned int lineNum = 0,
               const char* const message = "NO_MESSAGE") throw ()
    {
        std::ostringstream ostream;
        
        if( fileName != "" ) {
            ostream << "\nIn file '" << fileName << "'";
        }
        
        if( lineNum != 0 ) {
            ostream << " at line " << lineNum << std::endl;
        }
        
        ostream << "\n";
        
        ostream << message << std::endl;
        
        what_ = ostream.str();
    }
    
    virtual ~Exception() throw() {};

    virtual const char * what() const throw ()
    {
        return what_.c_str();
    }

  private:
    std::string what_;
  };

#define EXCEPTION(STR){                                                 \
    std::ostringstream ostr;                                            \
    ostr << STR;                                                        \
    Exception ex__(NULL, __FILE__, __LINE__, ostr.str().c_str());  \
    throw ex__;                                                         \
  }

