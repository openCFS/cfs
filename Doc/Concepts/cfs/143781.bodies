!!!277925.cpp!!!	noOfElements() : int
  int res = 0;
  res += triangle.size();
  res += quadrangle.size();
  res += tetrahedron.size();
  res += octahedron.size();
  res += hexahedron.size();
  res += prism.size();
  res += pyramid.size();

  return res;
