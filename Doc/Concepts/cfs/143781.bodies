!!!281765.cpp!!!	forEachElement(inout f : T) : void
  typedef std::list<Element*>::iterator ElmI;

  std::list<Element*>** lt = getElementList();
  int type = 0;
  while (lt[type]) {
    for (ElmI p = lt[type]->begin(); p != lt[type]->end(); ++p)
    {
      // call functor
      f(*p);
    }
    // next element type
    type++;
  }

