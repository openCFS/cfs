# This is a single test case to be called via nightly_test.cmake.
#
# You may test this script alone via ctest [-VV] -S  <test>.ctest
#
# see nightly_test. or https://cfs.mdmt.tuwien.ac.at/trac/wiki/NightlyBuilds for more help
#
#-----------------------------------------------------------------------------
# Do the stuff common for all tests on this machine
#-----------------------------------------------------------------------------
include("${CMAKE_CURRENT_LIST_DIR}/init_test.cmake")
INIT_TEST()

##############################################################################
#
# Define what is beeing tested (compiler & config)
#
#  * Adapt here to define specific configs
#  * All non-standard configs should be represented in the build name,
#    e.g. Trunk DISABLE_OPTIMIZATION UBUNTU ...
#
##############################################################################

# set the compiler environment
SET_COMPILER_ENV("GCC-7")

# set build name
set(BUILDTYPE "RELEASE")
set(CTEST_BUILD_NAME "trunk MINIMAL ${DIST} ${REV} ${CXX_ID} ${CXX_VERSION} ${BUILDTYPE}")

# set the default initial cache for nighly tests
INIT_CACHE(CTEST_INITIAL_CACHE) 
# set additional config options : all possible options switched off ...
SET(CTEST_INITIAL_CACHE
  "${CTEST_INITIAL_CACHE}
   DEBUG:BOOL=OFF
   CMAKE_BUILD_TYPE:STRING=${BUILDTYPE}
   TESTSUITE_DIR:STRING=${NIGHTLY_TESTSUITE_DIR}
   CFS_DEPS_PRECOMPILED:BOOL=ON
   USE_COMSOL:BOOL=OFF
   USE_GIDPOST:BOOL=OFF
   USE_GMV:BOOL=OFF
   USE_GMSH:BOOL=OFF
   USE_UNV:BOOL=OFF
   USE_ENSIGHT:BOOL=OFF
   USE_ANSYSRST:BOOL=OFF
   USE_PARDISO:BOOL=OFF
   USE_ARPACK:BOOL=OFF
   USE_ILUPACK:BOOL=OFF
   USE_SUITESPARSE:BOOL=OFF
   USE_LIS:BOOL=OFF
   USE_SUPERLU:BOOL=OFF
   USE_CGNS:BOOL=OFF
   USE_METIS:BOOL=OFF
   USE_CGAL:BOOL=OFF
   USE_FLANN:BOOL=OFF
   USE_OPENMP:BOOL=OFF
   CFS_DEPS_CACHE_DIR:PATH=${NIGHTLY_CACHE_DIR}
   BUILDNAME:STRING=${CTEST_BUILD_NAME}")

#-----------------------------------------------------------------------------
# Update, Configure, Build & Test
#-----------------------------------------------------------------------------
DO_TESTING()
