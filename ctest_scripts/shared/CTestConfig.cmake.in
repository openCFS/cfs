# The CTestConfig.cmake file is necessary for nightly builds (only)
# It is configured via WRITE_CTEST_CONFIG() from test_macros.cmakle

if(NOT CFS_macros)
  include("${CMAKE_CURRENT_LIST_DIR}../../CFS_macros.cmake")
endif()

SET(CTEST_PROJECT_NAME "CFS")
SET(CTEST_NIGHTLY_START_TIME "00:00:00 CET")

SET(CTEST_DROP_METHOD "http")
# CFS_DS_CDASH_DROP_SITE is set in DevelopmentServer.cmak
SET(CTEST_DROP_SITE "@CFS_DS_CDASH_DROP_SITE@")
SET(CTEST_DROP_LOCATION "/cdash/submit.php?project=CFS")
SET(CTEST_DROP_SITE_CDASH TRUE)

# CTEST_SOURCE_DIRECTORY and CTEST_BINARY_DIRECTORY shall already be set
if(NOT CTEST_SOURCE_DIRECTORY)
  message("CTEST_SOURCE_DIRECTORY shall already be set, fallback to CFS_SOURCE_DIR=@CFS_SOURCE_DIR@") 
  set(CTEST_SOURCE_DIRECTORY "@CFS_SOURCE_DIR@")
endif()
if(NOT CTEST_BINARY_DIRECTORY)  
  message("CTEST_BINARY_DIRECTORY shall already be set, fallback to CFS_BINARY_DIR=@CFS_BINARY_DIR@")
  set(CTEST_BINARY_DIRECTORY "@CFS_BINARY_DIR@")
endif()

if(NOT CTEST_BUILD_NAME)
  set(CTEST_BUILD_NAME "@CFS_GIT_COMMIT@ on @DIST@ @REV@ with @CXX_ID@ @CXX_VERSION@")
endif()
if(NOT CTEST_SITE)
  set(CTEST_SITE "@CFS_BUILD_HOST@")
endif()  
if(NOT CTEST_CMAKE_GENERATOR)
  set(CTEST_CMAKE_GENERATOR "@CMAKE_GENERATOR@")
endif()  
