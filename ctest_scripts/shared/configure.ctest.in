include("@CMAKE_CURRENT_BINARY_DIR@/CTestConfig.cmake")

MESSAGE("Start dashboard in mode '${CFS_TESTSUITE_MODEL}' ...")
CTEST_START("${CFS_TESTSUITE_MODEL}")

# sometimes we need two configure runs
MESSAGE("Configure - run 1")
CTEST_CONFIGURE(BUILD "${CTEST_BINARY_DIRECTORY}" RETURN_VALUE res)
MESSAGE("Configure - run 2")
CTEST_CONFIGURE(BUILD "${CTEST_BINARY_DIRECTORY}" RETURN_VALUE res)

MESSAGE("Submit as ${CTEST_BUILD_NAME}")
CTEST_SUBMIT(RETURN_VALUE res)

MESSAGE("All done!") 
