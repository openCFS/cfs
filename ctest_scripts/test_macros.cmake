MACRO(TEMP_NAME fname)

  # =========================================================================
  #
  #  Create temp file name.
  #
  # =========================================================================

  if(${ARGC} GREATER 1) # Have to escape ARGC to correctly compare
    set(_base ${ARGV1})
  else(${ARGC} GREATER 1)
    set(_base ".cmake-tmp")
  endif(${ARGC} GREATER 1)
  set(_counter 0)
  while(EXISTS "${_base}${_counter}")
    math(EXPR _counter "${_counter} + 1")
  endwhile(EXISTS "${_base}${_counter}")
  set(${fname} "${_base}${_counter}")
endmacro()



MACRO(EVAL expr)

  # =========================================================================
  #
  #  Evaluate expression
  #  Suggestion from the Wiki: http://cmake.org/Wiki/CMake/Language_Syntax
  #  Unfortunately, no built-in stuff for this:
  #  http://public.kitware.com/Bug/view.php?id=4034
  #
  # =========================================================================

  temp_name(_fname)
  file(WRITE ${_fname} "${expr}")
  include(${_fname})
  file(REMOVE ${_fname})
endmacro()



MACRO(GET_CTEST_BINARY_DIRECTORY TEST_NAME)

  # =========================================================================
  #
  #  Determine location of binary directory of a test.
  #
  # =========================================================================

  FILE(STRINGS "${SITE_DIR}/${TEST_NAME}.ctest" FSTR)

  FOREACH(LINE IN LISTS FSTR)
    IF(LINE MATCHES "SET\\(CTEST_BINARY_DIRECTORY")
      SET(CTEST_BINARY_DIRECTORY_STR "${LINE}")
    ENDIF()
  ENDFOREACH()

#  EXECUTE_PROCESS(
#    COMMAND mktemp -t nightly_test_XXXX
#    WORKING_DIRECTORY "."
#    OUTPUT_VARIABLE TMPFILE
#    RESULT_VARIABLE RETVAL
#    )
#  STRING(REPLACE "\n" "" TMPFILE "${TMPFILE}")

#  MESSAGE("TMPFILE ${TMPFILE}")

#  FILE(WRITE "${TMPFILE}" "${CTEST_BINARY_DIRECTORY_STR}")

#  INCLUDE("${TMPFILE}")
  STRING(REPLACE "\$ENV{" "\\\$ENV{" CTEST_BINARY_DIRECTORY_STR "${CTEST_BINARY_DIRECTORY_STR}")
  MESSAGE(STATUS "CTEST_BINARY_DIRECTORY_STR ${CTEST_BINARY_DIRECTORY_STR}")
  EVAL("${CTEST_BINARY_DIRECTORY_STR}")
  FILE(TO_CMAKE_PATH "${CTEST_BINARY_DIRECTORY}" CTEST_BINARY_DIRECTORY)
  MESSAGE(STATUS "CTEST_BINARY_DIRECTORY ${CTEST_BINARY_DIRECTORY}")

#  FILE(REMOVE "${TMPFILE}")
ENDMACRO()



