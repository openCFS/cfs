Cell["\<\
Define an Ansatz for the function (including its first derivatives)\
\>", "Text",
 CellChangeTimes->{{3.919500359448319*^9, 
  3.919500389086405*^9}},ExpressionUUID->"80f711bb-0ecc-4ecc-b381-\
bf17e735db6c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Ansatz", "[", 
   RowBox[{"var_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Flatten", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"var", "@@", "coords"}], "->", 
      RowBox[{"Plus", "@@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Symbol", "[", 
           RowBox[{
            RowBox[{"SymbolName", "[", "var", "]"}], "<>", 
            RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "*", 
          RowBox[{"Symbol", "[", 
           RowBox[{"\"\<N\>\"", "<>", 
            RowBox[{"ToString", "[", "i", "]"}]}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"var", "@@", "coords"}], ",", "coord"}], "]"}], "->", 
        RowBox[{"Plus", " ", "@@", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Symbol", "[", 
             RowBox[{
              RowBox[{"SymbolName", "[", "var", "]"}], "<>", 
              RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "*", 
            RowBox[{"Symbol", "[", 
             RowBox[{"\"\<N\>\"", "<>", 
              RowBox[{"ToString", "[", "i", "]"}], "<>", "\"\<D\>\"", "<>", 
              RowBox[{"ToString", "[", "coord", "]"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"coord", ",", "coords"}], "}"}]}], "]"}]}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Ansatz", "[", 
  RowBox[{"v", ",", "2"}], "]"}]}], "Input",
 CellChangeTimes->{{3.919495800213944*^9, 3.919495832820376*^9}, {
