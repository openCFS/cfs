<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org">
  
  <fileFormats>
    <output>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

<domain geometryType="3d">
    <regionList>
     <region name="mech" material="Ti6Al4V"/> 
    </regionList>
  </domain>

  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      <mechanic subType="3d">
        <regionList> <region name="mech"/> </regionList>
        
        <bcsAndLoads>
          <periodic master="top" slave="bottom" dof="x" quantity="mechDisplacement" />
          <periodic master="top" slave="bottom" dof="y" quantity="mechDisplacement" />
           <periodic master="top" slave="bottom" dof="z" quantity="mechDisplacement"/>
           <periodic master="front" slave="back" dof="x" quantity="mechDisplacement"/>
           <periodic master="front" slave="back" dof="y" quantity="mechDisplacement"/>
          <periodic master="front" slave="back" dof="z" quantity="mechDisplacement"/>
          <periodic master="left" slave="right" dof="x" quantity="mechDisplacement"/>
          <periodic master="left" slave="right" dof="y" quantity="mechDisplacement"/>         
          <periodic master="left" slave="right" dof="z" quantity="mechDisplacement"/>
          <!-- dirichletHom name="center" dof="x"/>
          <dirichletHom name="center" dof="y"/ -->
        </bcsAndLoads>
        
        <storeResults/>
      </mechanic>
    </pdeList>
    <linearSystems>
      <system>
        <solverList>
          <pardiso/>
        </solverList>
      </system>
    </linearSystems>
</sequenceStep>
 
  <loadErsatzMaterial file="0-0-0.dens.xml" set="last" force_region="mech"/>
  
  <optimization>
    <costFunction type="homTensor" task="minimize" multiple_excitation="true">
      <multipleExcitation type="homogenizationTestStrains" />
    </costFunction>

    <!-- constraint type="homTensor" bound="equal" coord="all" log_delta="true" >
      <tensor dim1="3" dim2="3">
        <real>
             15.00   0.05  0.0000
             0.05  1.00  0.0000
             0.0000   0.0000  0.01
        </real>
      </tensor>      
    </constraint-->
    <!--<constraint name="homogenizationTensor" type="equal" coord="21" mode="observation" />-->
    
    
       <optimizer type="evaluate" maxIterations="1"/>
    <ersatzMaterial method="simp" material="mechanic">
      <regions>
        <region name="mech"/>
      </regions>
      <design name="density" initial="1" lower="1e-9" upper="1" region="mech"/>
      <transferFunction type="identity" application="mech" design="density"/> 
    </ersatzMaterial>
  </optimization> 	  

</cfsSimulation>

