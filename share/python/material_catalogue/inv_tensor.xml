<cfsSimulation xmlns="http://www.cfs++.org">
  
  
  <fileFormats>
   <output> 
      <gid directory="." />
      <hdf5 directory="." />
 </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList> <region name="mech" material="99lines"/> </regionList>
    <!-- nodeList>
      <nodes name="center"> <coord x="0.0" y="0.0"/> </nodes>
   </nodeList -->
  </domain>

  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      <mechanic subType="planeStrain">
        <regionList> <region name="mech"/> </regionList>
        
        <bcsAndLoads>
          <periodic master="top" slave="bottom" dof="x" quantity="mechDisplacement"/>
          <periodic master="top" slave="bottom" dof="y" quantity="mechDisplacement"/>
          <periodic master="left" slave="right" dof="x" quantity="mechDisplacement"/>
          <periodic master="left" slave="right" dof="y" quantity="mechDisplacement"/>
          <!-- dirichletHom name="center" dof="x"/>
          <dirichletHom name="center" dof="y"/ -->
        </bcsAndLoads>
        
        <storeResults>
          <elemResult type="mechPseudoDensity">  <allRegions/> </elemResult>
          <elemResult type="physicalPseudoDensity"> <allRegions/> </elemResult>
        </storeResults>
      </mechanic>
    </pdeList>

<linearSystems>
      <system>
        <solverList>
          <pardiso/>
        </solverList>
      </system>
    </linearSystems></sequenceStep>
  
  
  <optimization log="[problem]">
    <costFunction type="homTensor" task="minimize" multiple_excitation="true">
      <multipleExcitation type="homogenizationTestStrains" />
    </costFunction>
    <optimizer type="evaluate" maxIterations="100" >
<!--      <snopt>
        <option type="integer" name="verify_level" value="3"/>
      </snopt>-->      
    </optimizer>
    <ersatzMaterial method="simp" material="mechanic" region="mech">
      <design name="density" initial="1.0" lower="1e-9" upper="1" region="mech" />
      <transferFunction type="identity" application="mech" design="density"/>
      <!-- export/ -->
    </ersatzMaterial>
  </optimization> 	  

</cfsSimulation>

