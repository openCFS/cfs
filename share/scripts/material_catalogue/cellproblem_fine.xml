<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org">  
  <fileFormats>
   <output> 
      <gid directory="."/>
      <hdf5 directory="."/>
 </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
  
  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="99lines"/>
    </regionList>
  </domain>
  
  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>
        
        <bcsAndLoads>
        </bcsAndLoads>
        
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <elemResult type="mechPseudoDensity">  
            <allRegions/>
          </elemResult>
          <elemResult type="physicalPseudoDensity">  
            <allRegions/>
          </elemResult>
          <regionResult type="mechEnergy">
            <allRegions/>
          </regionResult>
        </storeResults>
      </mechanic>
      
    </pdeList>
    
     <linearSystems>
      <system name="mechanic">
        <exportLinSys format="matrix-market" stiffness="true"/>
        <solver type="cg" precond="noPrecond" > 
          <cg> <maxIter>1</maxIter></cg>
        </solver>

        
      </system>
    </linearSystems>
    
  </sequenceStep>
  
