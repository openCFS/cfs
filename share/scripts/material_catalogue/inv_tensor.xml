<cfsSimulation xmlns="http://www.cfs++.org">
  
  
  <fileFormats>
   <output> 
      <gid directory="." />
      <hdf5 directory="." />
 </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList> <region name="mech" material="99lines"/> </regionList>
    <!-- nodeList>
      <nodes name="center"> <coord x="0.0" y="0.0"/> </nodes>
   </nodeList -->
  </domain>

  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      <mechanic subType="planeStress">
        <regionList> <region name="mech"/> </regionList>
        
        <bcsAndLoads>
          <periodic master="top" slave="bottom" dof="x" />
          <periodic master="top" slave="bottom" dof="y" />
          <periodic master="left" slave="right" dof="x" />
          <periodic master="left" slave="right" dof="y" />
          <!-- dirichletHom name="center" dof="x"/>
          <dirichletHom name="center" dof="y"/ -->
        </bcsAndLoads>
        
        <storeResults>
          <elemResult type="mechPseudoDensity">  <allRegions/> </elemResult>
          <elemResult type="physicalPseudoDensity"> <allRegions/> </elemResult>
        </storeResults>
      </mechanic>
    </pdeList>

    <linearSystems>
      <system name="mechanic"> <solver type="pardiso"/> </system>
    </linearSystems>    
  </sequenceStep>
  
  
  <optimization log="[problem]">
    <costFunction type="volume" task="minimize" multiple_excitation="true">
      <stopping queue="100"/>
      <multipleExcitation type="homogenizationTestStrains" />
    </costFunction>

    <constraint type="homTensor" bound="equal" coord="all" log_delta="true" >
      <tensor dim1="3" dim2="3">
        <real>
             15.00   0.05  0.0000
             0.05  1.00  0.0000
             0.0000   0.0000  0.01
        </real>
      </tensor>      
    </constraint>
    <!--<constraint name="homogenizationTensor" type="equal" coord="21" mode="observation" />-->
    
    
<!--     <constraint type="slope" mode="constraint" value="0.33" bound="upperBound" /> -->
    <constraint type="volume" mode="observation" physical="true" />
    <constraint type="greyness" mode="observation"/>
    <constraint type="greyness" mode="observation" physical="true" />    
    
    <optimizer type="evaluate" maxIterations="100" >
<!--      <snopt>
        <option type="integer" name="verify_level" value="3"/>
      </snopt>-->      
    </optimizer>
    <ersatzMaterial method="simp" material="mechanic" region="mech">
      <design name="density" initial="1.0" lower="0.000001" upper="1" region="mech" />
      <transferFunction type="simp" application="mech" design="density" param="1"/>
      <!-- export/ -->
    </ersatzMaterial>
  </optimization> 	  

</cfsSimulation>

