<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org"> 
  <fileFormats>
   <output> 
      <gid directory="."/>
      <hdf5 directory="."/>
 </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
 
  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="99lines"/>
    </regionList>
  </domain>
 
  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
   
    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>
       
        <bcsAndLoads>
          <dirichletInhom name="bottom" dof="x" value="0.0"/>
          <dirichletInhom name="bottom" dof="y" value="0."/>
          <dirichletInhom name="right" dof="x" value="0.0"/>
          <dirichletInhom name="right" dof="y" value="0."/>
          <dirichletInhom name="top" dof="x" value="0.0"/>
          <dirichletInhom name="top" dof="y" value="0.25*(1.-x)*(1.+y)"/>
          <dirichletInhom name="left" dof="x" value="0.0"/>
          <dirichletInhom name="left" dof="y" value="0.25*(1.-x)*(1.+y)"/>
        </bcsAndLoads>
       
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <elemResult type="mechPseudoDensity"> 
            <allRegions/>
          </elemResult>
          <elemResult type="physicalPseudoDensity"> 
            <allRegions/>
          </elemResult>
          <regionResult type="mechEnergy">
            <allRegions/>
          </regionResult>
        </storeResults>
      </mechanic>
     
    </pdeList>
   
     <linearSystems>
      <system name="mechanic">
        <solver type="pardiso"/>
      </system>
    </linearSystems>
   
  </sequenceStep>
 
