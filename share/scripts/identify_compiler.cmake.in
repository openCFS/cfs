# -*- mode: cmake; coding: utf-8; indent-tabs-mode: nil; -*-
# kate: indent-width 2; encoding utf-8; auto-brackets on;
# kate: mixedindent on; indent-mode cstyle; line-numbers on;
# kate: syntax cmake; replace-tabs on; background-color #D1EBFF;
# kate: remove-trailing-space on; bracket-highlight-color #ff00ff;

SET(CMAKE_C_COMPILER "@CMAKE_C_COMPILER@")
SET(CMAKE_CXX_COMPILER "@CMAKE_CXX_COMPILER@")
SET(CMAKE_Fortran_COMPILER "@CMAKE_Fortran_COMPILER@")

SET(CFS_SOURCE_DIR "@CFS_SOURCE_DIR@")
SET(CFS_BINARY_DIR "@CFS_BINARY_DIR@")

SET(COMPILER "@COMPILER@")
SET(SOURCE "@IDENTIFY_COMPILER_SRC@")

SET(COMPILER_ID_FILE "@COMPILER_ID_FILE@")
FILE(WRITE "${COMPILER_ID_FILE}" "")
IF(NOT COMPILER)
  IF(SOURCE STREQUAL "IdentifyCCompiler.c")
    SET(COMPILER "${CMAKE_C_COMPILER}")
  ELSEIF(SOURCE STREQUAL "IdentifyCXXCompiler.cpp")
    SET(COMPILER "${CMAKE_CXX_COMPILER}")
  ELSEIF(SOURCE STREQUAL "IdentifyFortranCompiler.F90")
    SET(COMPILER "${CMAKE_Fortran_COMPILER}")
  ENDIF(SOURCE STREQUAL "IdentifyCCompiler.c")
ENDIF(NOT COMPILER)

# MESSAGE("COMPILER ${COMPILER}")
# MESSAGE("SOURCE ${SOURCE}")

EXECUTE_PROCESS(
  COMMAND "${CMAKE_COMMAND}"
    -E copy_if_different
    "${CFS_SOURCE_DIR}/share/scripts/${SOURCE}"
    "${CFS_BINARY_DIR}/tmp/${SOURCE}"
  WORKING_DIRECTORY "${CFS_BINARY_DIR}/tmp"
  OUTPUT_VARIABLE COMPILER_OUTPUT
  ERROR_VARIABLE COMPILER_ERROR
  RESULT_VARIABLE rv
  )

EXECUTE_PROCESS(
  COMMAND "${COMPILER}" -E "${SOURCE}"
  WORKING_DIRECTORY "${CFS_BINARY_DIR}/tmp"
  OUTPUT_VARIABLE COMPILER_OUTPUT
  ERROR_VARIABLE COMPILER_ERROR
  RESULT_VARIABLE rv
  )

IF(NOT rv EQUAL 0)
  MESSAGE(FATAL_ERROR "Compiler ${COMPILER} could not be identified!\n\n${COMPILER_ERROR}")
ENDIF(NOT rv EQUAL 0)

SET(COMPILER_OUTPUT_ICC
"
# 1 \"IdentifyCCompiler.c\"




 

# 84 \"IdentifyCCompiler.c\"

CMAKE_COMPILER_ID Intel
CC_ID ICC
CC_VERSION 1000 20070614
CC_GCC_VERSION 4 . 2 . 0
")

SET(COMPILER_OUTPUT_ICPC
"
# 1 \"IdentifyCXXCompiler.cpp\"




 



 

# 80 \"IdentifyCXXCompiler.cpp\"

CMAKE_COMPILER_ID Intel
CXX_ID ICC
CXX_VERSION 1000 20070614
CXX_GCC_VERSION 4 . 2 . 0
")

SET(COMPILER_OUTPUT_IFORT
"
# 1 \"IdentifyFortranCompiler.F90\"
!     Identify the compiler




# 33


!     Identify the platform

   PRINT *, 'INFO:platform[Linux]'
# 90


CMAKE_COMPILER_ID Intel
FC_ID IFORT
FC_VERSION 1000 20070614
")

# SET(COMPILER_OUTPUT "${COMPILER_OUTPUT_IFORT}")

STRING(REPLACE "\n"
  ";" COMPILER_OUTPUT
  ${COMPILER_OUTPUT})

# MESSAGE("${rv} ${COMPILER_OUTPUT}")

foreach(line IN LISTS COMPILER_OUTPUT)
#  MESSAGE("line: ${line}")

  IF(line MATCHES "^CC_ID ")
    STRING(REPLACE "CC_ID "
      "" CC_ID
      ${line})
#    MESSAGE("CC_ID: ${CC_ID}")
  ENDIF(line MATCHES "^CC_ID ")

  IF(line MATCHES "^CC_VERSION ")
    STRING(REPLACE "CC_VERSION "
      "" CC_VERSION
      ${line})
#    MESSAGE("CC_VERSION: ${CC_VERSION}")
  ENDIF(line MATCHES "^CC_VERSION ")
 
 
  IF(line MATCHES "^CC_GCC_VERSION ")
    STRING(REPLACE "CC_GCC_VERSION "
      "" CC_GCC_VERSION
      ${line})
#    MESSAGE("CC_GCC_VERSION: ${CC_GCC_VERSION}")
  ENDIF(line MATCHES "^CC_GCC_VERSION ")

  IF(line MATCHES "^CXX_ID ")
    STRING(REPLACE "CXX_ID "
      "" CXX_ID
      ${line})
#    MESSAGE("CXX_ID: ${CXX_ID}")
  ENDIF(line MATCHES "^CXX_ID ")

  IF(line MATCHES "^CXX_VERSION ")
    STRING(REPLACE "CXX_VERSION "
      "" CXX_VERSION
      ${line})
#    MESSAGE("CXX_VERSION: ${CXX_VERSION}")
  ENDIF(line MATCHES "^CXX_VERSION ")

  IF(line MATCHES "^CXX_GCC_VERSION ")
    STRING(REPLACE "CXX_GCC_VERSION "
      "" CXX_GCC_VERSION
      ${line})
#    MESSAGE("CXX_GCC_VERSION: ${CXX_GCC_VERSION}")
  ENDIF(line MATCHES "^CXX_GCC_VERSION ")

  IF(line MATCHES "^FC_ID ")
    STRING(REPLACE "FC_ID "
      "" FC_ID
      ${line})
#    MESSAGE("FC_ID: ${FC_ID}")
  ENDIF(line MATCHES "^FC_ID ")

  IF(line MATCHES "^FC_VERSION ")
    STRING(REPLACE "FC_VERSION "
      "" FC_VERSION
      ${line})
    # MESSAGE("FC_VERSION: ${FC_VERSION}")
  ENDIF(line MATCHES "^FC_VERSION ")

endforeach(line)

IF(CC_ID)

  STRING(REPLACE " "
    "" CC_GCC_VERSION
    ${CC_GCC_VERSION})

  IF(CXX_ID STREQUAL "GCC" OR
     CXX_ID STREQUAL "OPEN64" OR
     CXX_ID STREQUAL "CLANG")
    STRING(REPLACE " "
      "" CC_VERSION
      ${CC_VERSION})
    STRING(REGEX REPLACE "\\.$"
      "" CC_VERSION
      ${CC_VERSION})
  ELSEIF(CC_ID STREQUAL "ICC")

    STRING(REPLACE " "
      ";" ICC_VERSION_LIST
      ${CC_VERSION})
    LIST(GET ICC_VERSION_LIST 0 ICCVER)
    LIST(GET ICC_VERSION_LIST 1 ICCDATE)

#    MESSAGE("ICCVER: ${ICCVER}")
#    MESSAGE("ICCDATE: ${ICCDATE}")

    MATH(EXPR ICC_MAJOR_VERSION "${ICCVER} / 100")
    MATH(EXPR ICC_MINOR_VERSION "(${ICCVER} % 100) / 10")

    SET(CC_VERSION "${ICC_MAJOR_VERSION}.${ICC_MINOR_VERSION} ${ICCDATE}")
  ELSEIF(CC_ID STREQUAL "MSVC")

    MESSAGE("CC_ID: ${CC_ID}")
    STRING(REGEX REPLACE "([0-9][0-9])$" ".\\1" CC_VERSION "${CC_VERSION}")
    MESSAGE("CC_VERSION: ${CC_VERSION}")

  ELSE()
    MESSAGE(FATAL_ERROR "C compiler '${COMPILER}' not supported!")
  ENDIF()

#  MESSAGE("CC_ID: ${CC_ID}")
#  MESSAGE("CC_VERSION: ${CC_VERSION}")
#  MESSAGE("CC_GCC_VERSION: ${CC_GCC_VERSION}")

  FILE(APPEND "${COMPILER_ID_FILE}" "SET(CC_ID \"${CC_ID}\")\n")
  FILE(APPEND "${COMPILER_ID_FILE}" "SET(CC_VERSION \"${CC_VERSION}\")\n")
  FILE(APPEND "${COMPILER_ID_FILE}" "SET(CC_GCC_VERSION \"${CC_GCC_VERSION}\")\n")

ENDIF(CC_ID)


IF(CXX_ID)

  STRING(REPLACE " "
    "" CXX_GCC_VERSION
    ${CXX_GCC_VERSION})

  IF(CXX_ID STREQUAL "GCC" OR
     CXX_ID STREQUAL "OPEN64" OR
     CXX_ID STREQUAL "CLANG")
    STRING(REPLACE " "
      "" CXX_VERSION
      ${CXX_VERSION})
    STRING(REGEX REPLACE "\\.$"
      "" CXX_VERSION
      ${CXX_VERSION})
  ELSEIF(CXX_ID STREQUAL "ICC")

    STRING(REPLACE " "
      ";" ICC_VERSION_LIST
      ${CXX_VERSION})
    LIST(GET ICC_VERSION_LIST 0 ICCVER)
    LIST(GET ICC_VERSION_LIST 1 ICCDATE)

#    MESSAGE("ICCVER: ${ICCVER}")
#    MESSAGE("ICCDATE: ${ICCDATE}")

    MATH(EXPR ICC_MAJOR_VERSION "${ICCVER} / 100")
    MATH(EXPR ICC_MINOR_VERSION "(${ICCVER} % 100) / 10")

    SET(CXX_VERSION "${ICC_MAJOR_VERSION}.${ICC_MINOR_VERSION} ${ICCDATE}")
  ELSEIF(CXX_ID STREQUAL "MSVC")

    # MESSAGE("CXX_ID: ${CXX_ID}")
    STRING(REGEX REPLACE "([0-9][0-9])$" ".\\1" CXX_VERSION "${CXX_VERSION}")
    # MESSAGE("CXX_VERSION: ${CXX_VERSION}")

  ELSE()
    MESSAGE(FATAL_ERROR "CXX compiler '${COMPILER}' not supported!")
  ENDIF()

#  MESSAGE("CXX_ID: ${CXX_ID}")
#  MESSAGE("CXX_VERSION: ${CXX_VERSION}")
#  MESSAGE("CXX_GCC_VERSION: ${CXX_GCC_VERSION}")

  FILE(APPEND "${COMPILER_ID_FILE}" "SET(CXX_ID \"${CXX_ID}\")\n")
  FILE(APPEND "${COMPILER_ID_FILE}" "SET(CXX_VERSION \"${CXX_VERSION}\")\n")
  FILE(APPEND "${COMPILER_ID_FILE}" "SET(CXX_GCC_VERSION \"${CXX_GCC_VERSION}\")\n")

ENDIF(CXX_ID)


IF(FC_ID)

  IF(FC_ID STREQUAL "GNU" OR
      FC_ID STREQUAL "OPEN64")
    STRING(REPLACE " "
      "" FC_VERSION
      ${FC_VERSION})
    STRING(REGEX REPLACE "\\.$"
      "" FC_VERSION
      ${FC_VERSION})
  ELSEIF(FC_ID STREQUAL "IFORT")

    STRING(REPLACE " "
      ";" FC_VERSION_LIST
      ${FC_VERSION})
    LIST(GET FC_VERSION_LIST 0 IFORTVER)
    LIST(GET FC_VERSION_LIST 1 IFORTDATE)

#    SET(IFORTVER 9999)

    # Some Intel 12.x define __ICC and __INTEL_COMPILER to be 9999 therefore
    # we read the output of $COMPILER --version
    IF(IFORTVER EQUAL 9999)
	EXECUTE_PROCESS(
	  COMMAND "${COMPILER}" --version
	  WORKING_DIRECTORY "${CFS_BINARY_DIR}/tmp"
	  OUTPUT_VARIABLE COMPILER_OUTPUT
	  ERROR_VARIABLE COMPILER_ERROR
	  RESULT_VARIABLE rv
	  )
	
	IF(NOT rv EQUAL 0)
	  MESSAGE(FATAL_ERROR "A problem occurred while checking Intel Fortran compiler version.")
	ENDIF(NOT rv EQUAL 0)

#	SET(COMPILER_OUTPUT "ifort (IFORT) 12.1.0 20111011\n")

	STRING(REPLACE "\n"
	  ";" COMPILER_OUTPUT
	  ${COMPILER_OUTPUT})
	LIST(GET COMPILER_OUTPUT 0 VERSION_HEADER)
	STRING(REPLACE "."
	  "" VERSION_HEADER
	  ${VERSION_HEADER})
	STRING(REPLACE " "
	  ";" VERSION_HEADER
	  ${VERSION_HEADER})
	LIST(GET VERSION_HEADER 2 IFORTVER)
	LIST(GET VERSION_HEADER 3 IFORTDATE)

    ENDIF(IFORTVER EQUAL 9999)

#    MESSAGE("IFORTVER: ${IFORTVER}")
#    MESSAGE("IFORTDATE: ${IFORTDATE}")

    MATH(EXPR IFORT_MAJOR_VERSION "${IFORTVER} / 100")
    MATH(EXPR IFORT_MINOR_VERSION "(${IFORTVER} % 100) / 10")

    SET(FC_VERSION "${IFORT_MAJOR_VERSION}.${IFORT_MINOR_VERSION} ${IFORTDATE}")
  ELSE()
    MESSAGE(FATAL_ERROR "Fortran compiler '${COMPILER}' not supported!")
  ENDIF()

#  MESSAGE("FC_ID: ${FC_ID}")
#  MESSAGE("FC_VERSION: ${FC_VERSION}")

  FILE(APPEND "${COMPILER_ID_FILE}" "SET(FC_ID \"${FC_ID}\")\n")
  FILE(APPEND "${COMPILER_ID_FILE}" "SET(FC_VERSION \"${FC_VERSION}\")\n")

  IF(FC_ID STREQUAL "OPEN64")
    FILE(APPEND "${COMPILER_ID_FILE}" "SET(CMAKE_Fortran_COMPILER_ID \"PathScale\")")
  ENDIF()
ENDIF(FC_ID)
