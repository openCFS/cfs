#!/bin/sh

ExitFail () {
    echo "An error occurred running: "$1
    exit 1;
}

# Configure variables using CMake
CFS_BINARY_DIR="@CFS_BINARY_DIR@"
CC='@CMAKE_C_COMPILER@'

MKL_ROOT_DIR="@MKL_ROOT_DIR@"
MKL_COMPILER_ID="@MKL_COMPILER_ID@"
MKL_ARCH_ID="@MKL_ARCH_ID@"
MKL_THREADING_ID="@MKL_THREADING_ID@"
MKL_SOLVERMAKEFILE="@MKL_SOLVERMAKEFILE@"

# compile a test program
mkdir -p source || ExitFail "4"
SRC="source/dss_sym_c.c"
printf %s "\
#include<stdio.h>
#include<stdlib.h>
#include<math.h>
#include <mkl_service.h>
#ifndef mkl_get_version
#define MKL_Get_Version MKLGetVersion
#define MKL_Free_Buffers MKL_FreeBuffers
#endif

MKL_INT main() {
    MKLVersion ver;
    MKL_Get_Version(&ver);
    printf(\"\nSET(MKL_MAJOR_VERSION %d)\n\", ver.MajorVersion);
    printf(\"\nSET(MKL_MINOR_VERSION %d)\n\", ver.MinorVersion);
    printf(\"\nSET(MKL_UPDATE %d)\n\n\", ver.UpdateVersion);
    MKL_Free_Buffers();

    exit(0);
}" > $SRC || ExitFail  "5"

echo "SOLVER = dss_sym_c" > solverc.lst

cat $MKL_SOLVERMAKEFILE > makefile.orig

cat $MKL_SOLVERMAKEFILE | \
  sed "s|CC = [gi]cc|CC = $CC|" | \
  sed "s|COMPILER = [gi]cc|COMPILER = $CC|" | \
  sed "s|MKLROOT[ ]\+=[ ]\+\.\./\.\.|MKLROOT = $MKL_ROOT_DIR|" \
  > makefile

# set make command
makecmd="make F=$MKL_COMPILER_ID compiler=$MKL_COMPILER_ID $MKL_ARCH_ID threading=$MKL_THREADING_ID function=dss_sym_c"
# run the make command
$makecmd > out.txt 2>&1 || ExitFail "cd $(pwd); $makecmd"
cat _results/*/dss_sym_c.res || ExitFail "10"

# grep only for the line with for the '*lib' dir
# there is a simlilar output in the so-dir too
cmdline=$(sed -e :a -e '/\\$/N; s/\\\n//; ta' out.txt | egrep $CC'.+lib/dss_sym_c' )

# read the link line
PRINT=0
echo
echo "SET(MKL_BLAS_LIB"
for item in $cmdline; do 

    # If we come  across the first -L or  -Wl,--start-group directives, we
    # need to start our printout.
    START=$(echo $item | sed 's|\(-L\)\(.*\)|\1|')
    if [ "$START" = "-L" -o "$START" = "-Wl,--start-group" -a "$PRINT" = "0" ]; then
        PRINT=1
    fi

    # If we come across the -o switch printout has to turned off.
    END=$(echo $item | sed 's|\(-o\)\(.*\)|\1|')
    if [ "$END" = "-o" -a "$PRINT" = "1" ]; then
        PRINT=0
    fi

    if [ "$PRINT" = "1" ]; then
#         echo '---->'$item
        if [ "$(echo $item | grep solver)" = "" ]; then
            if [ "$(echo $item | grep lapack)" = "" ]; then
                for BASEDIR in $BASEDIRS; do
                    ARCH="$BASEDIR/lib$(echo $item | sed 's|-l||').a"
                    if [ -f "$ARCH" ]; then
                        item="$ARCH"
                    fi
                done

                # Replace double quotes with nothing, since we properly
                # integrate them afterwards.

                OUT=$(echo $item | sed 's|"||g')
                echo "  \"$OUT\"" 
            else
                LAPACKLIB=$(echo $item | sed 's|"||g')
            fi
        else
            SOLVERLIB=$(echo $item | sed 's|"||g')
        fi
    fi

    # On Mac OS X the libraries are not enclosed in begin and end
    # group statements.
    if [ "$PRINT" = "0" ]; then
        if [ "$(echo $item | sed 's|\(.*\)\(libmkl_\)\(.*\)|\2|')" = "libmkl_" ]; then
            OUT=$(echo $item | sed 's|"||g')
            echo "  \"$OUT\"" 
        fi
    fi
done
echo "  CACHE FILEPATH \"MKL BLAS.\")"
echo

# get the dir of the libiomp5.so, and properly resolve symlinks
# fails for macOS as the file is here libiomp5.dylib but who wants to fix the regex below!?
OMP_DIR=$(echo $cmdline | sed 's|\(.\+\)-L\([^ ]*\)[ ]\+-liomp5.\+|\2|' | sed 's|"||g')
MKL_OMP_DIR=$(readlink -f $OMP_DIR)
echo "set(MKL_OMP_DIR "
echo $MKL_OMP_DIR
echo "  CACHE FILEPATH \"directory og the iomp5 library\")"
