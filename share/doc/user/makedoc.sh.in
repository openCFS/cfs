#!/bin/bash

MODE=$1

function clean {
    echo "==================================="
    echo " Cleaning up user doc directory..."
    echo "==================================="

    cd @CMAKE_CURRENT_SOURCE_DIR@

    rm -fv */*.aux
    rm -fv */*.toc
    rm -fv */*.pdf
    rm -fv */*.log
    rm -fv */*.blg
    rm -fv */*.out
    rm -fv */*.tpt

    echo "==================================="
    echo " Done cleaning up!"
    echo "==================================="
}

function build {

    echo "==================================="
    echo " Generating advanced pre/post docu."
    echo "==================================="

    cd @CMAKE_CURRENT_SOURCE_DIR@/advPrePostManual
    DOCUMENT=advPrePostManual

    # Apply syntax coloring to files in sources directory
    sources/pygmentize.sh $PWD/sources $PWD

    @PDFLATEX_COMPILER@ $DOCUMENT
    @BIBTEX_COMPILER@   $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT
    thumbpdf $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT

    cd @CMAKE_CURRENT_SOURCE_DIR@

    echo "==================================="
    echo " Generating XML-REFERENCE document"
    echo "==================================="

    cd @CMAKE_CURRENT_SOURCE_DIR@/xmlFile
    DOCUMENT=xmlReference

    # make copy of tex files and make syntax coloring
    texFiles=`ls *.tex`
    for f in $texFiles;
    do
      cp $f ${f%.*}-save.tex
      ./dopygment.py tex $f
    done

    # add pygments tex style to own files
    cat style.tex >> mycommands.tex

    @PDFLATEX_COMPILER@ $DOCUMENT
    @BIBTEX_COMPILER@   $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT
    thumbpdf $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT

    # move back files
    for f in $texFiles ;
    do
      mv ${f%.*}-save.tex $f
    done

    cd @CMAKE_CURRENT_SOURCE_DIR@

    echo "==================================="
    echo " Generating XML-Material document"
    echo "==================================="

    cd @CMAKE_CURRENT_SOURCE_DIR@/matFile
    DOCUMENT=matRef

    @PDFLATEX_COMPILER@ $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT

    cd @CMAKE_CURRENT_SOURCE_DIR@

    echo "==================================="
    echo " Generating Scripting docu."
    echo "==================================="

    cd @CMAKE_CURRENT_SOURCE_DIR@/scripting
    DOCUMENT=scripting

    @PDFLATEX_COMPILER@ $DOCUMENT
    @PDFLATEX_COMPILER@ $DOCUMENT

    cd @CMAKE_CURRENT_SOURCE_DIR@

    echo ""
    echo "==================================="
    echo " User documentation generated!"
    echo "==================================="
    echo ""
    echo " Documentation has been generated in:"
    echo ""
    echo " @CMAKE_CURRENT_SOURCE_DIR@/"
    echo " |-- advPrePostManual"
    echo " |   \`-- advPrePostManual.pdf"
    echo " |-- matFile"
    echo " |   \`-- matRef.pdf"
    echo " |-- scripting"
    echo " |   \`-- scripting.pdf"
    echo " \`-- xmlFile"
    echo "     \`-- xmlReference.pdf"
    echo ""

}

function buildhtml {

    echo "============================================="
    echo " Generating XML-REFERENCE HTML documentation"
    echo "============================================="

    cd @CMAKE_CURRENT_SOURCE_DIR@/xmlFile
    DOCUMENT=xmlReference

    # make copy of tex files and make syntax coloring
    texFiles=`ls *.tex`
    for f in $texFiles;
    do
      cp $f ${f%.*}-save.tex
      ./dopygment.py html $f
    done

    # call tex4ht to create html documentation
    htlatex $DOCUMENT "$DOCUMENT.cfg" "-dhtml/" "-dhtml/"

    # add css-style from pygmetns to the one of tex4ht
    cat style.css >> html/xmlReference.css

    # copy picture-subdirectory to html directory
    cp -r pics/ html/

    # move back files
    for f in $texFiles ;
    do
      mv ${f%.*}-save.tex $f
    done

    # remove obselete files in base-directory
    rm *.html *.css *.idv *.lg

    cd @CMAKE_CURRENT_SOURCE_DIR@

    echo ""
    echo "================================"
    echo " HTML documentation generated!"
    echo "================================"
    echo ""
    echo " Documentation has been generated in:"
    echo ""
    echo " @CMAKE_CURRENT_SOURCE_DIR@/"
    echo " |-- xmlFile"
    echo "     \`-- html"
    echo "          \`-- xmlReference.html"
    echo ""

}

case "$MODE" in
    build)
	build
        ;;
    build-html)
        buildhtml
        ;;
    rebuild)
	clean
	build
        ;;
    clean)
	clean
        ;;
    *)
        echo "Usage: `basename $0` [ build | build-html | rebuild | clean ]"
	exit 1
        ;;
esac
