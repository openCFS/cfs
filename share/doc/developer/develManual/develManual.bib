@MASTERSTHESIS{Triebenbacher2006,
  author = {Triebenbacher, Simon},
  title = {Nonmatching Grids for Computational Acoustics},
  school = {University Erlangen-Nuremberg},
  year = {2006},
  month = {January},
  abstract = {The numerical simulation of coupled acoustic problems often poses
	problems due to the varying demands for spatial discretisation in
	different regions of the computational domain. This is the case,
	for example, when computing the noise field generated by a fluid
	flow. The spatial region where the fluid flow takes place has to
	be discretised with a very fine resolution for being able to capture
	the relevant features of the flow. The computation of the emitted
	acoustic waves can be performed using a much coarser spatial discretisation.
	
	
	To overcome this problem traditionally two methods can be applied.
	The first option is to discretise the computational domain with a
	uniformly fine mesh. This approach guarantees a physically correct
	solution for the fluid flow and acoustic problems. The disadvantage
	of this procedure is the uneconomically high computational cost for
	solving the problem. This might even make the computation unfeasible.
	The second approach that can be followed is to add transition elements
	between the fine and the coarse mesh. The transition elements may
	however induce an approximation error. Despite this disadvantage
	the problem can then be solved with a justifiable computational effort.
	
	
	Taking into account that both methods have considerable disadvantages
	one might come up with the idea to apply independent discretisations
	to the different regions of the computational domain. As a result
	nonmatching interfaces between the regions would have to be properly
	handled, as they would be introduced by using such 'per-domain' discretisations.
	
	
	Following this very approach an implementation of a so-called mortar
	finite element method is developed in this thesis.},
  file = {:thesis/master.ps:PostScript},
  owner = {strieben},
  timestamp = {2007.08.14}
}

