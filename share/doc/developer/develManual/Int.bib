@MASTERSTHESIS{Hueppe2007,
  author = {Andreas H\"uppe},
  title = {Spectral Finite Elements for Wave Equations},
  school = {University Erlangen-Nuremberg},
  year = {2007},
  abstract = {The term spectral element method, as introduced by Patera in [12],
	refers to the concept of combining the good convergence features
	of classical spectral methods with the local character of a nite
	element method (FEM). The key concept is to
	
	dene and evaluate orthogonal polynomials of degree N locally on the
	element. The common denominator between spectral methods and spectral
	element methods is the type of polynomial functions. The drawback
	of using higher order shape functions, lies in the fact, that large
	systems of equations are generated.
	
	
	One approach to weaken the disadvantages of spectral elements is introduced
	in this thesis. A smart choice of the discrete functional spaces,
	leads to huge storage savings and easily solvable equation systems.
	This concept was introduced by Gary C.
	
	Cohan in his book "Higher Order Numerical Methods for Transient Wave
	Equations". The method provides the opportunity to simulate waves
	by an approximation of their governing equations. E.g., in the eld
	of acoustics, the system of rst order partial
	
	dierential equations, built by the Euler and the continuity equation.
	This feature enables many possible extensions. Amongst others for
	aeroacoustic problems. This motivates a detailed analysis.
	
	
	Initially, the thesis in hand gives a survey to the theoretical aspects
	of mixed variational formulations and spectral element methods. The
	second part shows the application of the introduced concepts to the
	acoustic wave equation. In doing so,
	
	the semi discrete system of equations is derived. The implementation
	of the method is verifed afterwards with a harmonic simulation. For
	this setup, it is also possible to give the accumulated discretization
	error for the spectral element method. Even
	
	for a very poor space discretizations, with, e.g., three elements
	per wavelength, the error with respect of the analytical solution
	is in the range of 10Ã´Â€Â€Â€e-6. In the last part of the thesis,
	the non-dissipative leapfrog time discretization is introduced. After
	an
	
	application to the wave equation, the behavior of the scheme is investigated
	with two transient examples. Subsequently, a practical approach for
	the choice of the simulation parameters is presented. In the last
	section, the good behavior of spectral
	
	elements on distorted meshes is shown.},
  file = {:JabRef_Int/2007/thesis/master_ahueppe.pdf:PDF},
  owner = {simon},
  timestamp = {2008.11.17}
}

