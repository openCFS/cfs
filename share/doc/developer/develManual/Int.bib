@INCOLLECTION{kaltenbacher08:2,
  author = {G. Cohen and A. Hauck and M. Kaltenbacher and T. Otsuru},
  title = {Different Types of Finite Elements},
  booktitle = {Computational Acoustics of Noise Propagation in Fluids},
  publisher = {Springer-Verlag},
  year = {2008},
  editor = {S. Marburg and B. Nolte},
  chapter = {2},
  pages = {57--88},
  address = {Berlin Heidelberg},
  note = {ISBN 978-3-540-77447-1},
  abstract = {Our contribution concentrates on the numerical solution of acoustic
	wave
	
	problems applying the Finite Element Method (FEM). After a short
	
	introduction, we provide a detailed discussion about the concepts
	of
	
	FEM and apply it to the acoustic wave equation. We will introduce
	the
	
	standard (Lagrangian) FE basis functions for approximating the
	
	continuous acoustic pressure as well as the possibility to utilize
	
	spline functions. In a second part we focus on two methods to improve
	the
	
	accuracy of the FE solution: (i) increase the order of the FE basis
	
	functions (p-FEM) and (ii) introduce spectral FEM to a mixed
	
	formulation of the wave equation.},
  file = {:JabRef_Int/2008/BookChapter_FEM_Acoustics.pdf:PDF},
  owner = {makalten}
}

