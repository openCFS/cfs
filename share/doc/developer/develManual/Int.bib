@MASTERSTHESIS{Zoerner2007,
  author = {Stefan Z\"orner},
  title = {Finite Elemente h\"oherer Ordnung f\"ur ein System von Reaktions-Diffusionsgleichungen
	zur Simulation des Ausheizprozesses in der optischen Lithografie},
  school = {Universit\"at Erlangen-N\"urnberg},
  year = {2007},
  type = {Diplomarbeit},
  abstract = {Da die Bausteine von integrierten Schaltungen kontinuierlich verkleinert
	werden, wachsen die Anforderungen an die Herstellung und somit an
	die Lithografieverfahren. Ausgiebige Experimente von unterschiedlichen
	Techniken und Auswirkungen von Fehlern sind sehr kostspielig und
	aufwendig. Die rechnergest\"utzte Simulation erm\"oglicht es, in
	kurzer Zeit mit geringen Kostenaufwand intensive Tests durchzuf\"uhren.
	
	
	Diese Arbeit befasst sich mit der Simulation des Ausheizschrittes
	in der optischen Lithografie. In diesem Prozessschritt wird der Wafer
	mit dem belichteten Fotolack erhitzt. Die wesentlichen Bestandteile
	des Fotolackes werden n\"aher betrachtet, um ein mathematisches Modell
	zu erstellen, welches das Ausheizen beschreibt. Dieses Modell, das
	einem System von Reaktions-Diffusionsgleichungen entspricht, wird
	schrittweise in die Finite-Elemente-Formulierung umgewandelt. Dies
	ist der Schwerpunkt dieser Arbeit. Die Zeitableitung wird mit einem
	BDF-Verfahren diskretisiert, und iterative Verfahren werden zur L\"osung
	der diskreten Gleichung verwendet. Beschr\"ankt man sich auf Fotolacke
	mit bestimmten chemischen Eigenschaften so leiten sich zwei weitere
	mathematische Modelle ab. Im Vergleich zum urspr\"unglichen Modell
	kann bei diesen Modellen eine gr\"obere Zeitdiskretisierung gew\"ahlt
	werden. Zus\"atzlich wird das Douglas-Gunn-Verfahren (ADI-Verfahren)
	zum Vergleich vorgestellt. Die unterschiedlichen Verfahren wurden
	implementiert und getestet. Die Ergebnisse zeigen, eine gute \"Ubereinstimmung
	der verschiedenen Modelle und Verfahren.},
  file = {:JabRef_Int/2007/thesis/diplom_szoerner.pdf:PDF},
  owner = {simon},
  timestamp = {2008.11.17}
}

