@ARTICLE{Triebenbacher2010b,
  author = {S. Triebenbacher and M. Kaltenbacher and B. Flemisch and B. Wohlmuth},
  title = {Applications of the Mortar Finite Element Method in Vibroacoustics
	and Flow Induced Noise Computations},
  journal = {Acta Acustica united with Acustica},
  year = {2010},
  volume = {96},
  pages = {536-553(18)},
  month = {May/June},
  abstract = {The Mortar Finite Element Method allows the coupling of two or more
	sub-domains with quite different mesh sizes. We exploit this capability
	and apply it to real engineering applications in vibroacoustics and
	aeroacustics. Therewith, we gain the flexibility to choose for each
	sub-domain an optimal grid. At the nonconforming interfaces appropriate
	coupling conditions ensure that the physical constraints are captured
	accurately. With this enhanced method we can couple along the interface
	the mechanical with the acoustic field as in the case of vibroacoustics
	and furthermore, we can also couple the same physical field, e.g.
	acoustics, computed on different grids. The applications will clearly
	demonstrate the superiority of the Mortar Finite Element Method over
	the standard Finite Element Method both concerning the flexibility
	for the mesh generation as well as the computational time.},
  comment = {(publisded)},
  doi = {doi:10.3813/AAA.918305},
  file = {Endgueltige Version:JabRef_Int/2010/ActaAcustica2011_Mortar.pdf:PDF;Mit Korrekturen von Simon Triebenbacher:JabRef_Int/2010/trieben_korrektur_simon.pdf:PDF;Unkorrigierte Version vom Verlag:JabRef_Int/2010/trieben.pdf:PDF},
  owner = {simon},
  timestamp = {2010.01.13},
  url = {http://www.ingentaconnect.com/content/dav/aaua/2010/00000096/00000003/art00013}
}

@INPROCEEDINGS{Triebenbacher2009,
  author = {Simon Triebenbacher and Manfred Kaltenbacher and Bernd Flemisch and
	Barbara Wohlmuth},
  title = {Nonmatching Grids for Modelling Piezo-Based Smart Materials},
  booktitle = {Proceedings of CMAS 2009, Bratislava, Slovakia},
  year = {2009},
  month = {June 30 - July 3},
  abstract = {Vibrating structures like electric power transformers are responsible
	for the generation of noise. Due to increasing levels of environmental
	noise, regulations require a substantial decrease of noise. Electro-mechanical
	actuators based on piezoelectric materials have therefore become
	important devices for the control of sound generated by vibrating
	structures. The modelling of these devices by the standard Finite
	Element Method poses problems, due to the fact that the relatively
	small patches attached to the vibrating structure make a modification
	of the whole computational grid necessary. By using the Mortar Finite
	Element Method, we can Ã¢Â€Â˜glueÃ¢Â€Â™ separate meshes for the patches
	to the mesh of the vibrating structure without having to require
	the meshes to geometrically match.},
  file = {:papers/paper_cmas2009.pdf:PDF},
