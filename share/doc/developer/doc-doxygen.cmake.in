SET(CMAKE_CURRENT_BINARY_DIR "@CMAKE_CURRENT_BINARY_DIR@")
SET(CMAKE_CURRENT_SOURCE_DIR "@CMAKE_CURRENT_SOURCE_DIR@")

INCLUDE("${CMAKE_CURRENT_BINARY_DIR}/../doc-common.cmake")

MESSAGE(STATUS "Building Doxygen documentation...")

SET(DOXY_DIR "${CMAKE_CURRENT_BINARY_DIR}/html") 
SET(DOXYGEN_EXECUTABLE "@DOXYGEN_EXECUTABLE@")
SET(DOXY_CONFIG "@DOXY_CONFIG@")

TODAY(DATE)

CONFIGURE_FILE(
  "${CMAKE_CURRENT_SOURCE_DIR}/DoxygenConfig/headerTemplate.html"
  "${CMAKE_CURRENT_BINARY_DIR}/DoxygenConfig/header.html"
  @ONLY )
CONFIGURE_FILE(
  "${CMAKE_CURRENT_SOURCE_DIR}/DoxygenConfig/footerTemplate.html"
  "${CMAKE_CURRENT_BINARY_DIR}/DoxygenConfig/footer.html"
  @ONLY )


EXECUTE_PROCESS(
  COMMAND "${DOXYGEN_EXECUTABLE}" "${DOXY_CONFIG}"
  )

