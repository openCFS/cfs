SET(CMAKE_COMMAND "@CMAKE_COMMAND@")
SET(CMAKE_CURRENT_BINARY_DIR "@CMAKE_CURRENT_BINARY_DIR@")
SET(CMAKE_CURRENT_SOURCE_DIR "@CMAKE_CURRENT_SOURCE_DIR@")

INCLUDE("${CMAKE_CURRENT_SOURCE_DIR}/../../../cmake_modules/DevelopmentServer.cmake")

MESSAGE(STATUS "Building Doxygen documentation...")

SET(DOXY_HTML_DIR "${CMAKE_CURRENT_BINARY_DIR}/doxygen/html") 
SET(DOXY_LATEX_DIR "${CMAKE_CURRENT_BINARY_DIR}/doxygen/latex") 
SET(DOXYGEN_EXECUTABLE "@DOXYGEN_EXECUTABLE@")
SET(DOXY_CONFIG "@DOXY_CONFIG@")
SET(PYGMENTS_EXE "pygmentize")
SET(PYGMENTS_STYLE "trac")
SET(PYG_OPTIONS -O linenos=True,linenostep=1,style=${PYGMENTS_STYLE})
SET(CFS_VERSION "@CFS_VERSION@")

CONFIGURE_FILE(
  "${CMAKE_CURRENT_SOURCE_DIR}/doxygen/config/header.html.in"
  "${CMAKE_CURRENT_BINARY_DIR}/doxygen/header.html"
  @ONLY )
CONFIGURE_FILE(
  "${CMAKE_CURRENT_SOURCE_DIR}/doxygen/config/footer.html.in"
  "${CMAKE_CURRENT_BINARY_DIR}/doxygen/footer.html"
  @ONLY )
CONFIGURE_FILE(
  "${CMAKE_CURRENT_SOURCE_DIR}/doxygen/config/cfsDoxygenLayout.xml.in"
  "${CMAKE_CURRENT_BINARY_DIR}/doxygen/cfsDoxygenLayout.xml"
  @ONLY )
CONFIGURE_FILE(
  "${CMAKE_CURRENT_SOURCE_DIR}/doxygen/config/latexHeader.tex.in"
  "${CMAKE_CURRENT_BINARY_DIR}/doxygen/latexHeader.tex"
  @ONLY )

EXECUTE_PROCESS(
  COMMAND "${DOXYGEN_EXECUTABLE}" "${DOXY_CONFIG}"
  )

FILE(MAKE_DIRECTORY "${DOXY_HTML_DIR}/images")


# Write Pygments HTML CSS style file
EXECUTE_PROCESS(
  COMMAND "${PYGMENTS_EXE}" -f html -S ${PYGMENTS_STYLE} -O linenos
  OUTPUT_VARIABLE PYGMENTS_CSS
  )

FILE(WRITE "${DOXY_HTML_DIR}/pygments.css" "${PYGMENTS_CSS}")

FILE(WRITE "${DOXY_HTML_DIR}/../snippets/pygments_test.html" "<div id=\"franzgeorg\" class=\"fragment\">")
FILE(APPEND "${DOXY_HTML_DIR}/../snippets/pygments_test.html" "${PYG_HTMLOUT}")
FILE(APPEND "${DOXY_HTML_DIR}/../snippets/pygments_test.html" "</div>")

# Write Pygments LaTeX style file
EXECUTE_PROCESS(
  COMMAND "${PYGMENTS_EXE}" -f latex -S ${PYGMENTS_STYLE} -O linenos
  OUTPUT_VARIABLE PYGMENTS_LATEX
  )

FILE(WRITE "${DOXY_LATEX_DIR}/pygments.tex" "${PYGMENTS_LATEX}")


STRING(REPLACE "commandchars"
  "frame=lines,framesep=2mm,fontsize=\\small,commandchars"
  PYG_LATEXOUT
  "${PYG_LATEXOUT}"
  )


