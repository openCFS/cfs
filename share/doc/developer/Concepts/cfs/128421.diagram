note 128677 "for r in all Regions {
  BaseForm * b = new BaseForm(r);
  IntegratorDescriptor * d = new
       IntegratorDescriptor(b);
  d->SetMatrixType(STIFFNESS)
  assemble->AddIntegrator(d)
}"
