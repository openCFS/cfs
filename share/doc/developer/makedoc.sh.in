#!/bin/bash

MODE=$1

function clean {
    echo "========================================"
    echo " Cleaning up developer doc directory... "
    echo "========================================"

    echo "============================================="
    echo " Deleting Doxygen Documentation for CFS++ in "
    echo " @CMAKE_CURRENT_SOURCE_DIR@/html"
    echo "============================================="

    rm -rfv @CMAKE_CURRENT_SOURCE_DIR@/html
    RETCODE=$?

    if [ "$RETCODE" != "0" ]; then
	echo " Error while deleting Doxygen Doc.!"
	exit 1;
    fi

    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.bbl
    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.aux
    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.toc
    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.pdf
    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.log
    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.blg
    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.out
    rm -fv @CMAKE_CURRENT_SOURCE_DIR@/develManual/*.tpt

    echo "==================================="
    echo " Done cleaning up!"
    echo "==================================="

}

function build {
    echo "====================================="
    echo " Generating CFS++ developer's manual "
    echo "====================================="

    # Auto generate bootstrap_devel_machine.txt from distro.sh and bootstrap_devel_machine.sh
    cat @CMAKE_CURRENT_SOURCE_DIR@/../../scripts/distro.sh | sed '/^Help\(\)/, /^fi/d' | sed '/^      while \:$/, /^      done$/d' > @CMAKE_CURRENT_SOURCE_DIR@/develManual/attachments/bootstrap_devel_machine.txt
    echo "echo \$OSSTR" >> @CMAKE_CURRENT_SOURCE_DIR@/develManual/attachments/bootstrap_devel_machine.txt
    cat @CMAKE_CURRENT_SOURCE_DIR@/../../scripts/bootstrap_devel_machine.sh | sed '/^\#\!\/bin\/sh/, /^\. /d' >> @CMAKE_CURRENT_SOURCE_DIR@/develManual/attachments/bootstrap_devel_machine.txt

    cd @CMAKE_CURRENT_SOURCE_DIR@/develManual
    DOCUMENT=develManual

    # Apply syntax coloring to files in sources directory
    sources/pygmentize.sh $PWD/sources $PWD

    @PDFLATEX_COMPILER@ $DOCUMENT && \
    @BIBTEX_COMPILER@ $DOCUMENT && \
    @PDFLATEX_COMPILER@ $DOCUMENT && \
    @PDFLATEX_COMPILER@ $DOCUMENT && \
    @PDFLATEX_COMPILER@ $DOCUMENT && \
    thumbpdf $DOCUMENT && \
    @PDFLATEX_COMPILER@ $DOCUMENT
    RETCODE_DEVMAN=$?

    #
    # Generate CFS++ documentation using doxygen
    #
    echo " ==========================================="
    echo " Generating Doxygen Documentation for CFS++ "
    echo " ==========================================="
    
    @CMAKE_CURRENT_SOURCE_DIR@/DoxygenConfig/changeDate.sh \
	@CMAKE_CURRENT_SOURCE_DIR@/DoxygenConfig/footerTemplate.html \
	@CMAKE_CURRENT_SOURCE_DIR@/DoxygenConfig/footer.html
    @DOXYGEN_EXECUTABLE@ @DOXY_CONFIG@
    RETCODE_DOXY=$?

    if [ "$RETCODE_DOXY" != "0" ]; then
	echo " Could not make Doxygen help!"
	exit 1;
    else
	echo " "
	echo " See @CMAKE_CURRENT_SOURCE_DIR@/html/index.html for doc."
	echo " "
    fi

    if [ "$RETCODE_DEVMAN" != "0" ]; then
	echo " Could not make developer's manual!"
	exit 1;
    else
	echo " See @CMAKE_CURRENT_SOURCE_DIR@/devManual/devManual.pdf developer's manual."
	echo " "
    fi

}

case "$MODE" in
    build)
	build
        ;;
    rebuild)
	clean
	build
        ;;
    clean)
	clean
        ;;
    *)
        echo "No proper mode specified"
	exit 1
        ;;
esac
