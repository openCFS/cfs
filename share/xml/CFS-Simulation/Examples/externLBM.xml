<cfsSimulation xmlns="http://www.cfs++.org">
  
  <fileFormats>
    <output>
      <gid directory="." />
      <hdf5 directory="."/>
      <info/>
     </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
  
  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="99mod"/>
    </regionList>
    <elemList>
      <elems name="inlet">
        <list>
          <freeCoord comp="y" start="1.0" stop="2.0" inc="0.05" />
          <fixedCoord comp="x" value="0"/>
        </list>
      </elems>
      <elems name="outlet">
        <list>
          <freeCoord comp="y" start="1.0" stop="2.0" inc="0.05" />
          <fixedCoord comp="x" value="3.0"/>
        </list>
      </elems>
    </elemList>
  </domain>
  
  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      <externLBM>
        <regionList>
          <region name="mech"/>
        </regionList>
          <bcsAndLoads>
          <inlet name="inlet" dof="x" value="1.0"/>
          <inlet name="inlet" dof="y" value="1.0"/>
          <inlet name="inlet" dof="z" value="1.0"/>
          <outlet name="outlet"/>
        </bcsAndLoads>    
        <LBM omega="1.0"/>
        <storeResults>
          <elemResult type="externLBMVelocity" >  
            <allRegions />
          </elemResult>
        </storeResults> 
      </externLBM>
    </pdeList>
    
     <linearSystems>
     <system name="externLBM">
        <solver type="cholmod" />
     </system>
    </linearSystems>
    
  </sequenceStep>
</cfsSimulation>


