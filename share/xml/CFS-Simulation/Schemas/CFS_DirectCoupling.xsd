					  <!-- (volume) region list -->
					  <xsd:element name="regionList" minOccurs="1" maxOccurs="1">
						  <xsd:complexType>
							  <xsd:sequence>
								  <xsd:element name="region" minOccurs="1" maxOccurs="unbounded">
									  <xsd:complexType>
										  <xsd:attribute name="nonLinIds" type="xsd:token" 
														 use="optional" default=""/>
										  <xsd:attribute name="name" type="xsd:token" use="required"/>
									  </xsd:complexType>
								  </xsd:element>            
							  </xsd:sequence>
						  </xsd:complexType>
					  </xsd:element>
					  
					  <!-- List defining nonlinear types -->
					  <!--<xsd:element name="nonLinList" minOccurs="0" maxOccurs="0">
						  <xsd:complexType>
							  <xsd:choice maxOccurs="unbounded">
								  <xsd:element name="geometric" type="DT_PiezoDirectNonLinGeo"/>
								  <xsd:element name="hysteresis" type="DT_PiezoDirectNonLinHyst"/>
								  <xsd:element name="material" type="DT_PiezoDirectNonLinMat"/>
							  </xsd:choice>
						  </xsd:complexType>
					  </xsd:element>-->
					  
					  <!-- Desired solution values (optional) -->
					  <!--<xsd:element name="storeResults" type="DT_PiezoDirectStoreResults"
								   minOccurs="0" maxOccurs="1"/>
					  <!- Type of materialDataType (real / complex) (optional) ->
					  <xsd:element name="materialDataType" type="DT_MatData"
								   minOccurs="0" maxOccurs="1"/>          
					  <xsd:element name="nonLinear" type="DT_NonLinParams" minOccurs="0"/>-->
				  </xsd:sequence>
			  </xsd:extension>
		  </xsd:complexContent>
	  </xsd:complexType>
  </xsd:element> 
  
  <!-- Thermo-Electric coupling -->
  <xsd:element name="thermoElectricDirect" substitutionGroup="PDEBasicDirectCoupling">
	  <xsd:complexType>
		  <xsd:complexContent>
			  <xsd:extension base="DT_BasicDirectCoupling">
				  <xsd:sequence>
					  
					  <!-- (volume) region list -->
					  <xsd:element name="regionList" minOccurs="1" maxOccurs="1">
						  <xsd:complexType>
							  <xsd:sequence>
								  <xsd:element name="region" minOccurs="1" maxOccurs="unbounded">
									  <xsd:complexType>
										  <xsd:attribute name="nonLinIds" type="xsd:token" 
														 use="optional" default=""/>
										  <xsd:attribute name="name" type="xsd:token" use="required"/>
									  </xsd:complexType>
								  </xsd:element>            
							  </xsd:sequence>
						  </xsd:complexType>
					  </xsd:element>
					  
					  <!-- List defining nonlinear types -->
					  <!--<xsd:element name="nonLinList" minOccurs="0" maxOccurs="0">
						  <xsd:complexType>
							  <xsd:choice maxOccurs="unbounded">
								  <xsd:element name="geometric" type="DT_PiezoDirectNonLinGeo"/>
								  <xsd:element name="hysteresis" type="DT_PiezoDirectNonLinHyst"/>
								  <xsd:element name="material" type="DT_PiezoDirectNonLinMat"/>
							  </xsd:choice>
						  </xsd:complexType>
					  </xsd:element>-->
					  
					  <!-- Desired solution values (optional) -->
					  <!--<xsd:element name="storeResults" type="DT_PiezoDirectStoreResults"
									   minOccurs="0" maxOccurs="1"/>
					  <!- Type of materialDataType (real / complex) (optional) ->
					  <xsd:element name="materialDataType" type="DT_MatData"
								   minOccurs="0" maxOccurs="1"/>          
					  <xsd:element name="nonLinear" type="DT_NonLinParams" minOccurs="0"/>-->
				  </xsd:sequence>
			  </xsd:extension>
		  </xsd:complexContent>
	  </xsd:complexType>
  </xsd:element>
  
  <!-- ...................................................................................................-->
  
  <!-- Piezo (Elec-Mech) coupling -->
  <xsd:element name="piezoDirect" substitutionGroup="PDEBasicDirectCoupling">
    <xsd:complexType>
      <xsd:complexContent>
        <xsd:extension base="DT_BasicDirectCoupling">
          <xsd:sequence>

            <!-- (volume) region list -->
            <xsd:element name="regionList" minOccurs="1" maxOccurs="1">
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="region" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:attribute name="nonLinIds" type="xsd:token" 
                        use="optional" default=""/>
                      <xsd:attribute name="name" type="xsd:token" use="required"/>
                      <xsd:attribute name="complexMaterial" type="DT_CFSBool" use="optional" default="no"/>
                    </xsd:complexType>
                  </xsd:element>            
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>

            <!-- List defining nonlinear types -->
            <xsd:element name="nonLinList" minOccurs="0" maxOccurs="0">
              <xsd:complexType>
                <xsd:choice maxOccurs="unbounded">
                  <xsd:element name="geometric" type="DT_PiezoDirectNonLinGeo"/>
                  <xsd:element name="hysteresis" type="DT_PiezoDirectNonLinHyst"/>
                  <xsd:element name="material" type="DT_PiezoDirectNonLinMat"/>
                  <xsd:element name="piezoMicroHF" type="DT_PiezoDirectNonLinHyst"/> 
                </xsd:choice>
              </xsd:complexType>
            </xsd:element>
            
            <!-- Desired solution values (optional) -->
            <xsd:element name="storeResults" type="DT_PiezoDirectStoreResults"
              minOccurs="0" maxOccurs="1"/>          
            <xsd:element name="nonLinear" type="DT_NonLinParams" minOccurs="0"/>
            
            
            <!-- Material data for computation of polarization matrix, see class TopGrad (optional) -->
            <xsd:element name="polarizationMatrix" minOccurs="0" maxOccurs="1">
              <xsd:complexType>
               <xsd:sequence>
                  <xsd:element name="mechTensor" type="DT_MechElastTensor" minOccurs="1" maxOccurs="1"/>
                  <xsd:element name="elecTensor" type="DT_ElecPermTensor" minOccurs="1" maxOccurs="1"/>
                  <xsd:element name="couplingTensor" type="DT_PiezoCouplTensor" minOccurs="1" maxOccurs="1"/>         
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
          </xsd:sequence>
        </xsd:extension>
      </xsd:complexContent>
    </xsd:complexType>
  </xsd:element> 
  
  <!-- ======================================= -->
  <!--  Magnetostrictive (Mag-Meech) coupling  -->
  <!-- ======================================= -->
  <xsd:element name="magnetoStrictionDirect" substitutionGroup="PDEBasicDirectCoupling">
    <xsd:complexType>
      <xsd:complexContent>
        <xsd:extension base="DT_BasicDirectCoupling">
          <xsd:sequence>
            
            <!-- (volume) region list -->
            <xsd:element name="regionList" minOccurs="1" maxOccurs="1">
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="region" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:attribute name="nonLinIds" type="xsd:token" 
                        use="optional" default=""/>
                      <xsd:attribute name="name" type="xsd:token" use="required"/>
                    </xsd:complexType>
                  </xsd:element>            
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
            
            <!-- List defining nonlinear types -->
            <!--<xsd:element name="nonLinList" minOccurs="0" maxOccurs="0">
              <xsd:complexType>
              <xsd:choice maxOccurs="unbounded">
              <xsd:element name="geometric" type="DT_PiezoDirectNonLinGeo"/>
              <xsd:element name="hysteresis" type="DT_PiezoDirectNonLinHyst"/>
              <xsd:element name="material" type="DT_PiezoDirectNonLinMat"/>
              </xsd:choice>
              </xsd:complexType>
              </xsd:element>-->
            
            <!-- Desired solution values (optional) -->
            <!-- have to create the MagmechDriectStoreResults later on -->
            <xsd:element name="storeResults" type="DT_MagStrictStoreResults"
              minOccurs="0" maxOccurs="1"/>
            <!-- Type of materialDataType (real / complex) (optional) -->
            <xsd:element name="materialDataType" type="DT_MatData"
              minOccurs="0" maxOccurs="1"/>          
            <xsd:element name="nonLinear" type="DT_NonLinParams" minOccurs="0"/>
          </xsd:sequence>
        </xsd:extension>
      </xsd:complexContent>
    </xsd:complexType>
  </xsd:element> 

  <!-- ******************************************************************* -->
  <!--   Definition of geometric nonlienarity -->
  <!-- ******************************************************************* -->

  <!-- Definition of geometric nonlinearity type -->
  <xsd:complexType name="DT_PiezoDirectNonLinGeo">
    <xsd:complexContent>
      <xsd:extension base="DT_NonLinBasic">
      </xsd:extension>
    </xsd:complexContent>
  </xsd:complexType>

  <!-- ******************************************************************* -->
  <!--   Definition of hysteresis nonlienarity -->
  <!-- ******************************************************************* -->

  <!-- Definition of hysteresis nonlinearity type -->
  <xsd:complexType name="DT_PiezoDirectNonLinHyst">
    <xsd:complexContent>
      <xsd:extension base="DT_NonLinBasic">
      </xsd:extension>
    </xsd:complexContent>
  </xsd:complexType>

  <!-- ******************************************************************* -->
  <!--   Definition of material nonlienarity -->
  <!-- ******************************************************************* -->

  <!-- Definition of material nonlinearity type -->
  <xsd:complexType name="DT_PiezoDirectNonLinMat">
    <xsd:complexContent>
      <xsd:extension base="DT_NonLinBasic">
      </xsd:extension>
    </xsd:complexContent>
  </xsd:complexType>
  
  <!-- ******************************************************************* -->
  <!--   ACOUSTIC-MECHANIC COUPLING -->
  <!-- ******************************************************************* -->
  <xsd:element name="acouMechDirect"
    substitutionGroup="PDEBasicDirectCoupling">
    <xsd:complexType>
      <xsd:complexContent>
        <xsd:extension base="DT_BasicDirectCoupling">
          <xsd:sequence>
            
            <!-- (surface) region list -->
            <xsd:element name="surfRegionList" minOccurs="0" maxOccurs="1">
              <xsd:complexType>
                <xsd:sequence>
                  <xsd:element name="surfRegion" minOccurs="1" maxOccurs="unbounded">
                    <xsd:complexType>
                      <xsd:attribute name="name" type="xsd:token" use="required"/>
                    </xsd:complexType>
                  </xsd:element>
                </xsd:sequence>
              </xsd:complexType>
            </xsd:element>
	    
	    <!-- NC interface list -->
	    <xsd:element name="ncInterfaceList" minOccurs="0" maxOccurs="1">
	      <xsd:complexType>
		<xsd:sequence>
		  <xsd:element name="ncInterface" minOccurs="1" maxOccurs="unbounded">
		    <xsd:complexType>
		      <xsd:attribute name="name" type="xsd:token" use="required" />
		    </xsd:complexType>
		  </xsd:element>
		</xsd:sequence>
	      </xsd:complexType>
	    </xsd:element>
	    
          </xsd:sequence>
        </xsd:extension>
      </xsd:complexContent>
    </xsd:complexType>
  </xsd:element> 

  <!-- ******************************************************************* -->
  <!--   Definition of Post Processing Results -->
  <!-- ******************************************************************* -->

  <!-- Definition of nodal result types of piezoelectric coupling -->
  <xsd:simpleType name="DT_PiezoElemResult">
    <xsd:restriction base="xsd:token">
      <xsd:enumeration value="mechStrain"/>
      <xsd:enumeration value="mechStrainIrr"/>
      <xsd:enumeration value="mechStress"/>
      <xsd:enumeration value="vonMisesStress"/>
      <xsd:enumeration value="elecPolarization"/> 
      <xsd:enumeration value="elecFluxDensity"/> 
    </xsd:restriction>
  </xsd:simpleType>

  <!-- Definition of surface element result types of piezoelectric coupling -->
  <xsd:simpleType name="DT_PiezoSurfElemResult">
    <xsd:restriction base="xsd:token">
      <xsd:enumeration value="elecCharge"/>
    </xsd:restriction>
  </xsd:simpleType>


  <!-- Piezo - Case -->
  <!-- Global type for specifying the desired  output quantities -->
  <xsd:complexType name="DT_PiezoDirectStoreResults">
    <xsd:sequence>
      <xsd:choice maxOccurs="unbounded">

        <!-- Element result definition -->
        <xsd:element name="elemResult" minOccurs="0"
          maxOccurs="unbounded">
          <xsd:complexType>
            <xsd:complexContent>
              <xsd:extension base="DT_ElemResult">
                <xsd:attribute name="type" type="DT_PiezoElemResult"/>
              </xsd:extension>
            </xsd:complexContent>
          </xsd:complexType>
        </xsd:element>

        <!-- Surface element result definition -->
        <xsd:element name="surfElemResult" minOccurs="0"
          maxOccurs="unbounded">
          <xsd:complexType>
            <xsd:complexContent>
              <xsd:extension base="DT_SurfElemResult">
                <xsd:attribute name="type" type="DT_PiezoSurfElemResult"/>
              </xsd:extension>
            </xsd:complexContent>
          </xsd:complexType>
        </xsd:element>
        
      </xsd:choice>
    </xsd:sequence>
  </xsd:complexType>

  
  <!-- Magnetostritive - Case -->
  <!-- Definition of nodal result types of mag-mech coupling -->
  <xsd:simpleType name="DT_MagStrictElemResult">
    <xsd:restriction base="xsd:token">
      <xsd:enumeration value="mechStress"/>
      <xsd:enumeration value="magFluxDensity"/>
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Global type for specifying the desired  output quantities -->
  <xsd:complexType name="DT_MagStrictStoreResults">
    <xsd:sequence>
      <!-- Element result definition -->
      <xsd:element name="elemResult" minOccurs="0"
        maxOccurs="unbounded">
        <xsd:complexType>
          <xsd:complexContent>
            <xsd:extension base="DT_ElemResult">
              <xsd:attribute name="type" type="DT_MagStrictElemResult"/>
            </xsd:extension>
          </xsd:complexContent>
        </xsd:complexType>
      </xsd:element>
    </xsd:sequence>
  </xsd:complexType>
  

