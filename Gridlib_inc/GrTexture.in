INLINE void 
GrTexture::setImage (GrImage* pkImage)
{
  image_ = pkImage;
}

INLINE GrImage* 
GrTexture::getImage ()
{
  return image_;
}

INLINE GrTexture::CorrectionMode& 
GrTexture::correction ()
{
  return correction_;
}

INLINE GrTexture::ApplyMode& 
GrTexture::apply ()
{
  return apply_;
}

INLINE GrColor<float> 
GrTexture::blendColor ()
{
  return GrColor<float>(blendColor_);
}

INLINE GrTexture::WrapMode& 
GrTexture::wrap ()
{
  return wrap_;
}

INLINE GrTexture::FilterMode& 
GrTexture::filter ()
{
  return filter_;
}

INLINE GrTexture::MipmapMode& 
GrTexture::mipmap ()
{
  return mipmap_;
}

INLINE float 
GrTexture::priority ()
{
  return priority_;
}

INLINE unsigned int
GrTexture::userData ()
{
  return userData_;
}

INLINE void
GrTexture::setUserData(unsigned int i)
{
  userData_ = i;
}

