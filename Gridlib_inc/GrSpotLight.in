template <class T>
INLINE typename GrLight<T>::Type 
GrSpotLight<T>::getType () const
{
  return LT_SPOT;
}

template <class T>
INLINE GbVec3<T>
GrSpotLight<T>::direction ()
{
  return GbVec3<T>(direction_);
}

template <class T>
INLINE T
GrSpotLight<T>::getAngle () const
{
  return angle_;
}

template <class T>
INLINE T
GrSpotLight<T>::exponent ()
{
  return exponent_;
}

