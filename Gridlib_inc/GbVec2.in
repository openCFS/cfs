template <class T>
INLINE const T * 
GbVec2<T>::getVec2() const
{ 
  return xy; 
}

template <class T>
INLINE void
GbVec2<T>::getVec2(T &x, T &y) const
{
  x=xy[0]; y=xy[1];
}
  
template <class T>
INLINE void
GbVec2<T>::setX(T x)
{ 
  xy[0] = x; 
}

template <class T>
INLINE void
GbVec2<T>::setY(T y)
{ 
  xy[1] = y; 
}

template <class T>
INLINE void
GbVec2<T>::setVec2(const T f[]) 
{ 
  xy[0]=f[0]; xy[1]=f[1];
}

template <class T>
INLINE void
GbVec2<T>::setVec2(T x,T y) 
{ 
  xy[0]=x; xy[1]=y;
}

