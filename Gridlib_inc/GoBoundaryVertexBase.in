template<class T>
INLINE void 
GoBoundaryVertexBase<T>::setVertex(GoVertex<T> *v) 
{ 
  data_.vertex = v; 
}

template<class T>
INLINE GoVertex<T> *
GoBoundaryVertexBase<T>::getVertex() const 
{ 
  return data_.vertex; 
}

