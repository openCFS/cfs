#ifdef LINUX
#include <cassert>
#endif

template <class T>
INLINE 
GbTStorage<T>::GbTStorage ()
{
  storage_ = NULL;
}

template <class T>
INLINE 
GbTStorage<T>::GbTStorage (int uiQuantity)
{
  if ( uiQuantity > 0 )
    storage_ = new T[uiQuantity];
  else
    storage_ = NULL;
}

template <class T>
INLINE
GbTStorage<T>::GbTStorage (T* atStorage)
{
  storage_ = atStorage;
}

template <class T>
INLINE
GbTStorage<T>::~GbTStorage ()
{
  delete[] storage_;
}

template <class T>
INLINE T* 
GbTStorage<T>::getStorage () const
{
  return storage_;
}

template <class T>
INLINE T& 
GbTStorage<T>::operator[] (int uiIndex) const
{
  assert( storage_ );
  return storage_[uiIndex];
}


