INLINE int 
GbLattice::getDimensions () const
{
  return dimensions_;
}

INLINE const int* 
GbLattice::getBounds () const
{
  return iBound_;
}

INLINE int 
GbLattice::getBound (int uiI) const
{
  //assert( uiI < dimensions_ );
  return iBound_[uiI];
}

INLINE int 
GbLattice::getQuantity () const
{
  return iSize_;
}

INLINE const int* 
GbLattice::getOffsets () const
{
  return offset_;
}

INLINE int 
GbLattice::getOffset (int uiI) const
{
  //assert( uiI < dimensions_ );
  return offset_[uiI];
}


