template<class CREATOR>
INLINE GbBool
GoClassRegistry<CREATOR>::containsCreator(const GbString& className)
{
//  ACE_Guard<ACE_Thread_Mutex> guard(mtx_);

  ClassMap::const_iterator iter = creators_.find(className);
  
  if (iter != creators_.end()) {
    return true;
  }

  return false;
}


template<class CREATOR>
INLINE CREATOR
GoClassRegistry<CREATOR>::queryCreator(const GbString& className) 
{
//  ACE_Guard<ACE_Thread_Mutex> guard(mtx_);

  return creators_[className];
}

