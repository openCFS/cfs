template <class T>
INLINE typename GrLight<T>::Type 
GrDirectionalLight<T>::getType () const
{
  return LT_DIRECTIONAL;
}

template <class T>
INLINE GbVec3<T> 
GrDirectionalLight<T>::direction ()
{
  return GbVec3<T>(direction_);
}

