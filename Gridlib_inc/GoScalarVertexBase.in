template <class T>
INLINE void 
GoScalarVertexBase<T>::setValue(T v) 
{ 
  data_.value = v; 
}

template <class T>
INLINE T
GoScalarVertexBase<T>::getValue() const 
{ 
  return data_.value; 
}

