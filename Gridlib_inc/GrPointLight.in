template <class T>
INLINE typename GrLight<T>::Type 
GrPointLight<T>::getType () const
{
  return LT_POINT;
}

template <class T>
INLINE GbVec3<T>
GrPointLight<T>::location ()
{
  return GbVec3<T>(location_);
}

