INLINE GbBool 
GrZBufferState::enabled ()
{
  return enabled_;
}

INLINE void 
GrZBufferState::enable(GbBool e)
{
  enabled_ = e;
}

INLINE GbBool 
GrZBufferState::writeable ()
{
  return writeable_;
}

INLINE void 
GrZBufferState::write(GbBool e)
{
  writeable_ = e;
}

INLINE GrZBufferState::CompareFunction & 
GrZBufferState::compare ()
{
  return compare_;
}

INLINE void
GrZBufferState::setCompare(CompareFunction c)
{
  compare_ = c;
}

