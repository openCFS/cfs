INLINE GbBool 
GrGeoPrimitiveRendererMesh::getVertexVisible (int uiV) const
{
  return vertexVisible_[uiV];
}

INLINE GbBool 
GrGeoPrimitiveRendererMesh::getEdgeVisible (int uiE) const
{
  return edgeVisible_[uiE];
}

INLINE GbBool 
GrGeoPrimitiveRendererMesh::getTriangleVisible (int uiT) const
{
  return triangleVisible_[uiT];
}

INLINE float& 
GrGeoPrimitiveRendererMesh::depth (int uiV)
{
  return depth_[uiV];
}

INLINE GbVec3<float>& 
GrGeoPrimitiveRendererMesh::modelVertex (int uiV)
{
  return modelVertex_[uiV];
}

INLINE std::vector<GbVec3<float> >&
GrGeoPrimitiveRendererMesh::getModelVertices ()
{
  return modelVertex_;
}

INLINE GbBool 
GrGeoPrimitiveRendererMesh::hasModelVertices () const
{
  return hasModelVertices_;
}

INLINE GbBool 
GrGeoPrimitiveRendererMesh::hasLights () const
{
  return hasLights_;
}

