INLINE 
int 
GrConvexRegion::getPortalQuantity () const
{
  return nbrPortals_;
}

INLINE
GrPortal* 
GrConvexRegion::getPortal (int i) const
{
  assert( i < nbrPortals_ );
  return portal_[i];
}

