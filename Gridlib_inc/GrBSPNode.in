INLINE
GbPlane<float>& 
GrBSPNode::modelPlane ()
{
  return modelPlane_;
}

INLINE
const GbPlane<float>& 
GrBSPNode::modelPlane () const
{
  return modelPlane_;
}

INLINE
const GbPlane<float>& 
GrBSPNode::getWorldPlane () const
{
  return worldPlane_;
}

INLINE
void*& 
GrBSPNode::data ()
{
  return data_;
}

INLINE
GrBSPNode::CallbackFunction& 
GrBSPNode::callback ()
{
  return callback_;
}


