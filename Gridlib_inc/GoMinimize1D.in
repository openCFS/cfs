template <class T>
INLINE 
GoMinimize1D<T>::~GoMinimize1D ()
{
}

template <class T>
INLINE int& 
GoMinimize1D<T>::maxLevel ()
{
  return maxLevel_;
}

template <class T>
INLINE int& 
GoMinimize1D<T>::maxBracket ()
{
  return maxBracket_;
}

template <class T>
INLINE void*& 
GoMinimize1D<T>::userData ()
{
  return userData_;
}

