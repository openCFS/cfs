template <class T>
INLINE int& 
GoMinimizeND<T>::maxLevel ()
{
  return oneDMinimizer_.maxLevel();
}

template <class T>
INLINE int& 
GoMinimizeND<T>::maxBracket ()
{
  return oneDMinimizer_.maxBracket();
}

template <class T>
INLINE void*& 
GoMinimizeND<T>::userData ()
{
  return userData_;
}

