reset
undo on


set logging errors on file 'mesh_log.txt'

#{b = 10e-3}; # width of the channel
#{l_1 = 200e-3}; # length of the LF region
#{l_2 = 1}; # length of the Acou region
#{h_el = 20e-3}; # element size

#{tol = 1e-6}
merge tolerance {tol}


# geometry

create surface rectangle width {l_1} height {b} zplane
move surface 1 x {l_1/2} y 0 z 0 

create surface rectangle width {l_2} height {b} zplane
move surface 2 x {l_1+l_2/2} y 0 z 0 


# mesh
surface 1 size {h_el} scheme submap
mesh surface 1

surface 2 size {h_el} scheme submap
mesh surface 2


# blocks and nodesets

block 1 add surface 1
block 1 name "Channel_LF"

block 2 add surface 2
block 2 name "Channel_Acou"


nodeset 1 add curve 2
nodeset 1 name "Excite"

nodeset 2 add curve 3
nodeset 2 name "LF_Bot"

nodeset 3 add curve 1
nodeset 3 name "LF_Top"

nodeset 4 add curve 4
nodeset 4 name "LF_IF

nodeset 5 add curve 6
nodeset 5 name "Acou_IF"

nodeset 6 add curve 8
nodeset 6 name "ABC"




# use this command to enable the output of wedges inside your hex-blocks (otherwise you get holes)
Set Block Mixed Element Output Degenerate

export ansys cdb "Channel_mesh.cdb" overwrite





