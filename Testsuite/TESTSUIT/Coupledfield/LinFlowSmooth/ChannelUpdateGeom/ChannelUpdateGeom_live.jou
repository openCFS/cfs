reset
undo on


#{h_air = 500e-6}; # height of the air-gap
#{h_d = 0e-6}; # heigth of the dent
#{l = 1e-3}; # length of the domain
#{l_i = 100e-6}; # length of the inlet
#{l_o = 10e-3}; # length of the outlet
#{h_el = 125e-6}; # element size
#{tol = 1e-6}

merge tolerance {tol}


# geometry


#{num = 0} {rad = 10} {nintv = 10} {nloop = nintv + 1}

#{loop(nloop)}
#{num++}
Create Vertex {(num-1)/nintv*l} {-sind((num-1)/nintv*180)*h_d}
#{endloop}

create curve spline location vertex all delete

create curve location position 0 0 0  location 0 {-h_air} 0
create curve location position {l} 0 0  location {l} {-h_air} 0
create curve location position 0 {-h_air} 0  location {l} {-h_air} 0

create surface curve all 

create surface rectangle width {l_i} height {h_air} zplane
move surface 2 x {-l_i/2} y {-h_air/2} z 0

create surface rectangle width {l_o} height {h_air} zplane
move surface 3 x {l+l_o/2} y {-h_air/2} z 0


# merge

imprint tolerant volume all
merge volume all


# mesh

surface all size {h_el}
mesh surface all 



block 1 add surface 2
block 1 name "Air_1"

block 2 add surface 1
block 2 name "Air_2"

block 3 add surface 3
block 3 name "Air_3"


nodeset 1 add curve 6
nodeset 1 name "ExcVel"

nodeset 2 add curve 1
nodeset 2 name "ExcDisp"

nodeset 3 add curve 2
nodeset 3 name "Fix_l"

nodeset 4 add curve 3
nodeset 4 name "Fix_r"

nodeset 5 add curve 4
nodeset 5 name "Fix_b"

nodeset 6 add curve 5 1 9
nodeset 6 name "Fix_Air_t"

nodeset 7 add curve 7 4 11
nodeset 7 name "Fix_Air_b"

nodeset 8 add curve 12
nodeset 8 name "Fix_Air_r



export ansys cdb "ChannelUpdateGeom_live.cdb" overwrite








