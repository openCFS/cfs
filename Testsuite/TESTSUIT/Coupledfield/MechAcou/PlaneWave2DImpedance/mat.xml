            <compressionModulus>
              <real>1.0</real>
            </compressionModulus>
          </isotropic>
        </linear>
      </elasticity>
    </mechanical>
    <acoustic>
      <density>
        <linear>
          <real>2.0</real>
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real>1.0</real>
        </linear>
      </compressionModulus>
    </acoustic>
