<?xml version="1.0" encoding="UTF-8"?>
<cfsMaterialDataBase xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/material ../../../../../share/xml/CFS-Material/CFS_Material.xsd"
  xmlns="http://www.cfs++.org/material">
  <material name="mat_left">
    <acoustic>
      <density>
        <linear>
          <real>1.0</real>
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real>1.0</real>
        </linear>
      </compressionModulus>
    </acoustic>
  </material>
