<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation">

  <fileFormats>
    <input>
      <mesh fileName="piston2d_nc.mesh"/>
    </input>
    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="solid" material="steel"/>
      <region name="waterEl" material="water"/>
    </regionList>
    <surfRegionList>
      <surfRegion name="master_interface"/>
      <surfRegion name="slave_interface"/>
    </surfRegionList>

    <ncInterfaceList>
      <ncInterface name="my_interface"
        primarySide="master_interface"
        secondarySide="slave_interface"/>
    </ncInterfaceList>

    <nodeList>
      <nodes name="acouMech"/>
      <nodes name="bottom"/>
    </nodeList>
  </domain>

  <sequenceStep>
    <analysis>
      <transient>
        <numSteps>    50    </numSteps> 
        <deltaT>     5e-05 </deltaT>
      </transient>
    </analysis>

    <pdeList>
      <acoustic formulation="acouPotential">
        <regionList>
          <region name="waterEl"/>
        </regionList>
        <storeResults>
          <nodeResult type="acouPotential">
            <allRegions/>
          </nodeResult>
          <nodeResult type="acouPotentialD1">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>

      <mechanic subType="planeStrain">
        <regionList>
          <region name="solid"/>
        </regionList>

        <bcsAndLoads>
          <fix name="bottom">
            <comp dof="x"/>
          </fix>
          <fix name="bottom">
            <comp dof="y"/>
          </fix>          
          <pressure name="master_interface" value="-1e9 * sample1D('sin1k.dat',t,1)"/>
        </bcsAndLoads>
        <storeResults>

          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
        </storeResults>

      </mechanic>
    </pdeList>

    <couplingList>
      <direct>
        <acouMechDirect>
          <ncInterfaceList>
            <ncInterface name="my_interface" />
          </ncInterfaceList>
        </acouMechDirect>
      </direct>

    </couplingList>

  </sequenceStep>

</cfsSimulation>
