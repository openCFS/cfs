reset

create surface rectangle width 0.1 height 0.1 zplane 
create surface rectangle width 0.1 height 1 zplane 
move Surface 2 y 0.55 include_merged 

# mesh
surface all size 0.02
curve 1 3  interval 5
curve 1 3  scheme equal
curve 5 7  interval 4
curve 5 7  scheme equal
mesh surface all

# regions
block 1 add surface 2 
block 1 name "S_fluid"

block 2 add surface 1 
block 2 name "S_mech"

nodeset 1 add curve 1 
nodeset 1 name "L_mech"
nodeset 2  add curve 7 
nodeset 2  name "L_fluid"
nodeset 3 add curve 3 
nodeset 3  name "L_fixdis"
nodeset 4 add curve 5 
nodeset 4  name "L_fixpot"

export ansys cdb "mesh.cdb"  overwrite 