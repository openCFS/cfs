reset

### Mesh size
#{ r = 0.005  }

create surface rectangle width 1.1 height 0.1 zplane 
webcut body 1  with plane xplane offset -0.45 
merge curve all

curve 9  size {r}
curve 9  scheme equal
mesh curve 9 

curve 7  size {r}
curve 7  scheme equal
mesh curve 7 

surface 2 3  size auto factor 8
mesh surface 2 3 

set duplicate block elements off

block 1 add surface 2 
block 1 name "waterEl"

set duplicate block elements off

block 2 add surface 3 
block 2 name "solidEl"

set duplicate block elements off

block 3 add curve 5 
block 3 name "coupleEl"

nodeset 1 add curve 2  
nodeset 1 name "bottomEl"

nodeset 2 add curve 4  
nodeset 2 name "S_right_boundary"

export ansys cdb "PistonComplex1D.cdb"  geometry overwrite 
