reset
undo on

Journal off
Echo off
Warning off

#{h_air = 100e-6}; # height of the air
#{l_air_1 = 100e-6}; # length of the first air region
#{l_air_2 = 200e-6}; # length of the second air region
#{h_el = 100e-6}; # element size
#{tol = 1e-6}

merge tolerance {tol}


# geometry

create surface rectangle width {l_air_1} height {h_air} zplane
move surface 1 x {-l_air_1/2} y 0 z 0

create surface rectangle width {l_air_2} height {h_air} zplane
move surface 2 x {l_air_2/2} y 0 z 0


# merge

imprint tolerant volume all
merge volume all


# mesh

surface all size {h_el}
mesh surface all 



block 1 add surface 1
block 1 name "Air_1"

block 2 add surface 2
block 2 name "Air_2"




nodeset 1 add curve 2
nodeset 1 name "Exc_1"

nodeset 2 add curve 1
nodeset 2 name "Fix_1_t"

nodeset 3 add curve 3
nodeset 3 name "Fix_1_b"

nodeset 4 add curve 4
nodeset 4 name "IF"

nodeset 5 add curve 5
nodeset 5 name "Fix_2_t"

nodeset 6 add curve 7
nodeset 6 name "Fix_2_b"

nodeset 7 add curve 8
nodeset 7 name "Exc_2"




Journal on
Echo on
Warning on

export ansys cdb "SmoothMech_MWE.cdb" overwrite









