undo on
reset
#{ N = 2 }
brick x 1 y 1 z 1
volume all interval { N }
mesh volume all
block 1 add volume 1
block 1 name "Vol"
#block 1 element type hex20
nodeset 1 add surface 6
nodeset 1 name "S_E"
nodeset 2 add surface 5
nodeset 2 name "S_N"
nodeset 3 add surface 1
nodeset 3 name "S_T"
nodeset 4 add surface 4
nodeset 4 name "S_W"
nodeset 5 add surface 3
nodeset 5 name "S_S"
nodeset 6 add surface 2
nodeset 6 name "S_B"
nodeset 7 add curve 12
nodeset 7 name "L_NE"
nodeset 8 add curve 5
nodeset 8 name "L_EB"
nodeset 9 add curve 1
nodeset 9 name "L_ET"
nodeset 10 add curve 2
nodeset 10 name "L_NT"
nodeset 11 add curve 8
nodeset 11 name "L_NB"
nodeset 12 add curve 11
nodeset 12 name "L_NW"
nodeset 13 add curve 3
nodeset 13 name "L_WT"
nodeset 14 add curve 4
nodeset 14 name "L_ST"
nodeset 15 add curve 6
nodeset 15 name "L_SB"
nodeset 16 add curve 7
nodeset 16 name "L_WB"
nodeset 17 add curve 9
nodeset 17 name "L_SW"
nodeset 18 add curve 10
nodeset 18 name "L_SE"
nodeset 19 add vertex 1
nodeset 19 name "P_SET"
nodeset 20 add vertex 2
nodeset 20 name "P_NET"
nodeset 21 add vertex 3
nodeset 21 name "P_NWT"
nodeset 22 add vertex 4
nodeset 22 name "P_SWT"
nodeset 23 add vertex 6
nodeset 23 name "P_SEB"
nodeset 24 add vertex 5
nodeset 24 name "P_NEB"
nodeset 25 add vertex 8
nodeset 25 name "P_NWB"
nodeset 26 add vertex 7
nodeset 26 name "P_SWB"
export ansys cdb "./UnitCube.cdb" overwrite
