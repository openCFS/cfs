reset
#{ l = 1 }
#{ h_gap=0.2}
#{ h_electrodes=0.1}
#{ x_air=1e-1}
#{ x_electrodes=1e-1}
#
create surface rectangle width {l} height {h_gap} zplane
create surface rectangle width {l} height {h_electrodes} zplane
move surface 2 y {0.5*(h_gap+h_electrodes)}
create surface rectangle width {l} height {h_electrodes} zplane
move surface 3 y {-0.5*(h_gap+h_electrodes)}
create surface rectangle width {l} height {l**2} zplane
move surface 4 y {0.5*(h_gap+2*h_electrodes+l**2)}
imprint volume all
merge volume all
nodeset 1 add curve 1
nodeset 1 name "L_upper_electrode"
nodeset 2 add curve 3
nodeset 2 name "L_lower_electrode"
nodeset 3 add curve 13
nodeset 3 name "L_fix"
nodeset 4 add curve 8 6
nodeset 4 name "L_guide"
nodeset 5 add vertex 1
nodeset 5 name "sensor"
block 1 add surface 1
block 1 name "S_air"
block 2 add surface 2
block 2 name "S_upper_electrode"
block 3 add surface 3
block 3 name "S_lower_electrode"
block 4 add surface 4
block 4 name "S_spring"
surface 1 size {x_air}
surface 2 3 4 size {x_electrodes}
mesh surface all
#
export ansys cdb "./ElecForcesCapacitorStatic2D.cdb" overwrite


