undo on 
reset

# Creat surface 
#{ L = 0.5}
#{ h = 0.0001 }
create surface rectangle width {L} height {h} zplane 
move Surface 1 x {L/2} y {h/2}  

# create boundary
block 1 add surface 1 
block 1 name "S_flow"

nodeset 2 add curve 2  
nodeset 2 name "L_left"

nodeset 3 add curve 4  
nodeset 3 name "L_right"

nodeset 4 add curve 1  
nodeset 4 name "L_top"

nodeset 5 add curve 3  
nodeset 5 name "L_bottom"

curve 1 3  interval 500
curve 1 3  scheme equal
curve 2 4  interval 50
curve 2 4  scheme equal
mesh curve 1 3 
#surface 1  size 5e-6
mesh surface 1 



export ansys cdb "channel2d.cdb"  overwrite 

export nastran "mesh-thermo.bdf" overwrite everything


