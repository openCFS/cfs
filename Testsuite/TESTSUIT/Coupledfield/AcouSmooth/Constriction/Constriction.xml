<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.cfs++.org/simulation 
    file:/Users/manfred/Forsch/openCFS/SRC/mkalten_AcouSmooth/share/xml/CFS-Simulation/CFS.xsd">

  <documentation>
    <title>channel flow on updated geometry (LinFlow-smooth)</title>
    <authors>
      <author>mkaltenbacher</author>
    </authors>
    <date>2026-04-18</date>
    <keywords>
      <keyword>acoustic</keyword>
      <keyword>smooth</keyword>
    </keywords>
    <references> 
          Non Just functionality test
    </references>
    <isVerified>yes</isVerified>
    <description>
   	  This test the computation of waves on changing geometry (simple larynx). It solves PCWE on changing geometry
	  without background flow.
    </description>
  </documentation>

	<fileFormats>
		<input>
			<hdf5 fileName="merged_interpNew.cfs" />
		</input>

		<output>
			<hdf5 />
			<text id="txt" />
		</output>

		<materialData file="mat.xml" format="xml" />
	</fileFormats>

	<domain geometryType="plane">
		<variableList>
			<!-- Existing -->
			<var name="rho" value="1.204" />
			<var name="c" value="343.5" />
			<var name="sigma" value="0.6" />
			<var name="tau" value="20e-3" />

			<!-- Motion parameters -->
			<var name="A" value="0.4" />   
			<var name="fq" value="5.01" />   
		</variableList>

		<regionList>
			<region name="larynx" material="smoothMat" />
			<region name="pml" material="smoothMat" />
		</regionList>

		<surfRegionList>
			<surfRegion name="VFupper" />
			<surfRegion name="VFlower" />
			<surfRegion name="walls" />
		</surfRegionList>

		<nodeList>
			<nodes name="excite">
				<coord x="1" y="5"/>
			</nodes>
			<nodes name="mic1">
				<coord x="20" y="5"/>
			</nodes>
		</nodeList>
	</domain>

	<sequenceStep>
		<analysis>
			<transient>
				<numSteps>2</numSteps>
				<deltaT>0.5e-2</deltaT>
			</transient>
		</analysis>

		<pdeList>
			<smooth>
				<regionList>
					<region name="larynx" />
					<region name="pml" />
				</regionList>
				
				<bcsAndLoads>

					<!-- Fix outer boundaries -->
					<fix name="walls">
						<comp dof="x" />
						<comp dof="y" />
					</fix>

					<!-- Upper vocal fold -->
					<displacement name="VFupper">
						<comp dof="x" value="0" />
						<comp dof="y" value="A*sin(2*pi*fq*t)" />
					</displacement>

					<!-- Lower vocal fold -->
					<displacement name="VFlower">
						<comp dof="x" value="0" />
						<comp dof="y" value="-A*sin(2*pi*fq*t)" />
					</displacement>
				</bcsAndLoads>

				<storeResults>

					<nodeResult type="smoothDisplacement">
						<allRegions />
					</nodeResult>

					<nodeResult type="smoothVelocity">
						<allRegions />
					</nodeResult>

				</storeResults>
			</smooth> 

			<acoustic formulation="acouPotential">
				<!-- Computation Domain -->
				<regionList>
					<region name="larynx" movingMeshId="moveGridID"/>
					<region name="pml" dampingId="mypml"/>
				</regionList>

				<!-- Damping Model -->
				<dampingList>
					<pml id="mypml">
						<type>inverseDist</type>
						<dampFactor>1</dampFactor>
					</pml>
				</dampingList>

				<movingMeshList>
          		  <movingMesh name="moveGridID">
            		<coupling pdeName="smooth">
                      <quantity name="smoothVelocity"/>
                    </coupling>
                  </movingMesh>
                </movingMeshList>

				<!-- Boundary Conditions and Volume Loads -->
				<bcsAndLoads>
					 <potential name="excite" value="1.0 * sin(2*pi*10*t)"/>

					<velocity name="VFupper">
						<coupling pdeName="smooth">
							<quantity name="smoothVelocity" />
						</coupling>
					</velocity>

					<velocity name="VFlower">
						<coupling pdeName="smooth">
							<quantity name="smoothVelocity" />
						</coupling>
					</velocity>

					<velocity name="walls">
						<coupling pdeName="smooth">
							<quantity name="smoothVelocity" />
						</coupling>
					</velocity>
				</bcsAndLoads>

				<!-- Results Definition -->
				<storeResults>
					<!-- Export node result -->
					<nodeResult type="acouPotential">
						<allRegions />
						<nodeList>
                          <nodes name="mic1" outputIds="txt" />
						</nodeList>
					</nodeResult>
					
					<nodeResult type="acouRhsLoad">
						<allRegions />
					</nodeResult>

					<!-- eg.: <nodeResult type="acouPotentialD1"> <allRegions/> </nodeResult> -->
				</storeResults>
			</acoustic>

		</pdeList>

		<couplingList>
			<iterative PDEorder="smooth;acoustic">
				<convergence logging="yes" maxNumIters="1" stopOnDivergence="no">
    			 	<quantity name="smoothDisplacement" value="1e+3" normType="rel"/>
     				<!--quantity name="smoothVelocity" value="1e-3" normType="rel"/>
      				<quantity name="acouPotential" value="1e-3" normType="rel"/-->
    			</convergence>
    			<geometryUpdate>
     			 	<region name="larynx"/>
					<region name="pml" />
    			</geometryUpdate>
			</iterative>
		</couplingList> 

    <linearSystems>
          <system>
            <solverList>
              <directLU></directLU>
            </solverList>
         </system>
    </linearSystems>
	
	</sequenceStep>

</cfsSimulation>
