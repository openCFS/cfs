reset
undo on


#{b = 10e-3}; # width of the channel
#{l_1 = 200e-3}; # length of the LF region
#{l_2 = 300e-3}; # length of the LF non-updated region
#{l_3 = 700e-3}; # length of the LF non-updated region
#{h_el = 10e-3}; # element size

#{l_PML = 10*h_el}; # length of the PML region

#{tol = 1e-6}
merge tolerance {tol}


# geometry

create surface rectangle width {l_1} height {b} zplane
move surface 1 x {l_1/2} y {b/2} z 0 

create surface rectangle width {l_2} height {b} zplane
move surface 2 x {l_1+l_2/2} y {b/2} z 0 

create surface rectangle width {l_3} height {b} zplane
move surface 3 x {l_1+l_2+l_3/2} y {b/2} z 0 

create surface rectangle width {l_PML} height {b} zplane
move surface 4 x {l_1+l_2+l_3+l_PML/2} y {b/2} z 0 

imprint tolerant volume 1 2
merge volume 1 2

imprint tolerant volume 3 4
merge volume 3 4

# mesh
surface 1 2 3 4size {h_el} scheme submap
mesh surface 1 2 3 4


# blocks and nodesets

block 1 add surface 1
block 1 name "Channel_LF_updated"

block 2 add surface 2
block 2 name "Channel_LF"

block 3 add surface 3
block 3 name "Channel_Acou"

block 4 add surface 4
block 4 name "PML"



nodeset 1 add curve 2
nodeset 1 name "Excite"

nodeset 2 add curve 3
nodeset 2 name "LF_Bot_updated"

nodeset 3 add curve 1
nodeset 3 name "LF_Top_updated"

nodeset 4 add curve 4
nodeset 4 name "LF_Fix"

nodeset 5 add curve 7
nodeset 5 name "LF_Bot"

nodeset 6 add curve 5
nodeset 6 name "LF_Top"

nodeset 7 add curve 8
nodeset 7 name "IF_M"

nodeset 8 add curve 10
nodeset 8 name "IF_S



# use this command to enable the output of wedges inside your hex-blocks (otherwise you get holes)
Set Block Mixed Element Output Degenerate

export ansys cdb "Channel_mesh.cdb" overwrite








