  <material name="PIC_255">
    <!-- daten aus Diss. Jürgen Ilg -->
    <mechanical>
      <density>
        <linear>
          <real> 7800 </real>
        </linear>
      </density>
      <!-- aus PI datenblatt -->
      <elasticity>
        <linear>
          <tensor dim1="6" dim2="6">
            <real>
            124.5e9   78.5e9   80.5e9   0    0     0   
             78.5e9  124.5e9   80.5e9   0    0     0   
             80.5e9   80.5e9  120.6e9   0    0     0   
              0      0      0    20.3e9  0     0   
              0      0      0     0   20.3e9   0  
              0      0      0     0    0    20.3e9
          </real>
          </tensor>
        </linear>
      </elasticity>
      <damping>
        <rayleigh>
          <computeFromTanDeltaAtFrequency>
            <centerFreq>5e3</centerFreq>
            <ratioDeltaF>1e-2</ratioDeltaF>
            <lossTangensDelta>0.01</lossTangensDelta>
          </computeFromTanDeltaAtFrequency>
        </rayleigh>
      </damping>
    </mechanical>
    <electric>
      <permittivity>
        <linear>
