          -0.6195e+07   -0.6195e+07    1.2390e+07             0             0         0
        </real>
      </magnetoStrictionTensor_h_mag>
    </magnetic>
    <magnetoStrictive>
      <magnetoStrictionTensor_h dim1="3" dim2="6">
        <real>
                    0             0             0             0    0.9292e+07         0
                    0             0             0    0.9292e+07             0         0
          -0.6195e+07   -0.6195e+07    1.2390e+07             0             0         0
