  <TEF resultName=""/>
  <meanVelocity resultName=""/>
  <localDensity resultName=""/>
  <localTemp resultName=""/>
  <output resultName=""/>
  <incrementModes></incrementModes>
  <waveNumBounds minWN="1" maxWN="2"/>
  <frequencyBounds/>
</syntheticTurbulence_SNGR>-->
    
    
    <meshOutput id="staticInput" inputFilterIds="cfdEnsight">
      <outputFile>
        <hdf5 compressionLevel="1" externalFiles="no"/>
      </outputFile>
      <saveResults>
        <result resultName="fluidMechTEF">
          <allRegions/>
        </result>
      </saveResults>
    </meshOutput>

  </pipeline>
</cfsdat>

