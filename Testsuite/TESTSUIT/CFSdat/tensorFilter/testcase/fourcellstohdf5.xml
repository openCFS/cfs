<?xml version="1.0" encoding="UTF-8"?>
<cfsdat xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.cfs++.org/simulation">
  <pipeline>
    <stepValueDefinition>
      <startStop>
        <startStep value="0"/>
        <numSteps value="1"/>
        <!--numSteps value="4400"/-->
        <startTime value="0"/>
        <delta value="1"/>
        <deleteOffset value="no"/>
      </startStop>
      <!--dynamic></dynamic-->
    </stepValueDefinition>

    <meshInput id="input" gridType="fullGrid">
      <inputFile>
        <ensight fileName="fourcells.case" readFVMesh="no" fixFVPyramids="no">
          <variableList>
            <variable CFSVarName="optResult_1" EnsightVarName="One"/>
            <variable CFSVarName="optResult_2" EnsightVarName="Two"/>
            <variable CFSVarName="optResult_3" EnsightVarName="Three"/>
            <variable CFSVarName="optResult_4" EnsightVarName="Four"/>
            <variable CFSVarName="optResult_5" EnsightVarName="Five"/>
            <variable CFSVarName="optResult_6" EnsightVarName="Six"/>
            <variable CFSVarName="optResult_7" EnsightVarName="Seven"/>
            <variable CFSVarName="optResult_8" EnsightVarName="Eight"/>
            <variable CFSVarName="optResult_9" EnsightVarName="Nine"/>
          </variableList>
        </ensight>
      </inputFile>
    </meshInput>


    <meshOutput id="fourcells" inputFilterIds="input">
      <outputFile>
        <hdf5 extension="h5" compressionLevel="0" externalFiles="no"/>
      </outputFile>
      <saveResults>
        <result resultName="optResult_1">
          <allRegions/>
        </result>
        <result resultName="optResult_2">
          <allRegions/>
        </result>
        <result resultName="optResult_3">
          <allRegions/>
        </result>
        <result resultName="optResult_4">
          <allRegions/>
        </result>
        <result resultName="optResult_5">
          <allRegions/>
        </result>
        <result resultName="optResult_6">
          <allRegions/>
        </result>
        <result resultName="optResult_7">
          <allRegions/>
        </result>
        <result resultName="optResult_8">
          <allRegions/>
        </result>
        <result resultName="optResult_9">
          <allRegions/>
        </result>
      </saveResults>
    </meshOutput>


  </pipeline>
</cfsdat>
