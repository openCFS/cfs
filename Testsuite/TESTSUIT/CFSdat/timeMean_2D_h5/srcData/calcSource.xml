<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.cfs++.org/simulation">

   <fileFormats>
     
      <input>
        <hdf5 fileName="sourceMesh.h5" id="default" gridId="default"/>
      </input>

      <output>
        <hdf5 extension="h5" id="hdf5"/>
        <text id="txt"/>
      </output>

     <materialData file="air.xml"/>
   </fileFormats>

  <domain geometryType="plane">
      <regionList>
        <region name="fluid"      material="iso"/>
      </regionList>
  </domain>

    <sequenceStep>
      <analysis>
        <transient>
          <numSteps>100</numSteps>
          <deltaT>0.1</deltaT>
        </transient>           
      </analysis>

      <pdeList>
        <!-- VECTOR INPUT FOR GRAD AND ROT OPERATOR        -->
        <mechanic subType="planeStress">
          <regionList>
            <region name="fluid"/>
          </regionList>
          <bcsAndLoads>
            <rhsValues name="fluid">
              <comp dof="x" value="1"/>
              <comp dof="y" value="2"/>
            </rhsValues>
          </bcsAndLoads>
          <storeResults>
            <nodeResult type="mechRhsLoad">
              <allRegions outputIds="hdf5"/>
            </nodeResult>
          </storeResults>
        </mechanic>

        <!-- SCALAR INPUT FOR GRAD OPERATOR        -->
<!--        <acoustic>
          <regionList>
            <region name="fluid"/>
          </regionList>
          <bcsAndLoads>
            <rhsValues name="fluid" value="t*(cos(x/2+y/2))">  </rhsValues>
          </bcsAndLoads>
          <storeResults>
            <nodeResult type="acouRhsLoad">
              <allRegions outputIds="hdf5"/>
            </nodeResult>         
          </storeResults>
        </acoustic>-->



      </pdeList>


      <linearSystems>
        <system>

          <solutionStrategy>
            <standard>
              <matrix reordering="noReordering" storage="sparseSym"/>
              <solver id="pardiso"/> <!--used solver-->
            </standard>
          </solutionStrategy>

          <solverList>
            <cg id="cg">
              <maxIter>1</maxIter>
              <logging>yes</logging>
            </cg>

            <pardiso id="pardiso">
              <outOfCore>2</outOfCore>
              <IterRefineSteps>60</IterRefineSteps>                      
              <logging>no</logging>
              <stats>no</stats>   
            </pardiso>

            <lis id="lis">
              <precond>
                <iluk fill="1"/>
              </precond>

              <solver>
                <CGS/>
              </solver> 

              <maxIter>1000</maxIter>
              <tolerance>1.0E-7</tolerance>
              <logging>true</logging>             
            </lis>
          </solverList>

        </system>
      </linearSystems>
    </sequenceStep>
</cfsSimulation>
