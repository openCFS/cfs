<cfsSimulation xmlns="http://www.cfs++.org/simulation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
  <documentation>
    <title>External Solver static test</title>
    <authors>
      <author>lklimon</author>
    </authors>
    <date>2022-09-15</date>
    <keywords>
      <keyword>mechanic</keyword>
      <keyword>static</keyword>
    </keywords>
    <references/>
    <isVerified>no</isVerified>
    <description>
      This is a test for the externalSolver Solver. The reference solution is computated with the directLU solver in CFS.
      This tests checks a static analysis, where the entry type of the format will be real and the solution vector will be profided
      from the external Solver in the Matrix Market Coordinate Format.
    </description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="staticRealCoord.h5ref"/>
    </input>
    <output>
      <hdf5/>
        <info/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <regionList>
      <region name="V_mech" material="steel"/>
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="3d">
        <regionList>
          <region name="V_mech" />
        </regionList>

        <bcsAndLoads>
          <fix name="S_fix">
            <comp dof="x" />
            <comp dof="y" />
            <comp dof="z" />
          </fix>
          <force name="N_force">
            <comp dof="x" value="1000" />
            <comp dof="y" value="-1000" />
          </force>
        </bcsAndLoads>

        <storeResults>
          <elemResult type="mechStress">
            <allRegions />
          </elemResult>
          <nodeResult type="mechDisplacement">
            <allRegions />
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>

    <linearSystems>
      <system>
        <solverList>
          <externalSolver>
            <logging>yes</logging>
            <cmd>python3 solve.py</cmd>
            <arguments>
              <matrixFileName></matrixFileName>
              <rhsFileName></rhsFileName>
              <solutionFileName></solutionFileName>
            </arguments>
            <deleteFiles>yes</deleteFiles>
          </externalSolver>
        </solverList>
      </system>
    </linearSystems>
  </sequenceStep>
</cfsSimulation>
