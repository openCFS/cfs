<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xsi:schemaLocation="http://www.cfs++.org/simulation 
  https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
  <documentation>
    <title>Ginkgo iterative solver with default setting</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2025-02-28</date>
    <keywords>
      <keyword>iterative_solver</keyword>
    </keywords>
    <references>https://github.com/ginkgo-project/ginkgo</references>
    <isVerified>yes</isVerified>
    <description>Ginkgo is a quite fast parallel iterative solver package.
      We support only a subset of options via xml, but via json (see test case) any configuration can be applied.
    
      amg as preconditioner is efficient, if it works (e.g. 2d) but fails for 3d elasticity?!
    
      jacobi/cg is perfomant and robust, even for topology optimization.
    
      the matrix nees to be sparseNonSym, which is set as default.
      the input can be generated by create_mesh.py --type bulk3d --res 5

      Verified in the sense, that the result matches a direct solver's result.
    </description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="jacobi_cg.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="3d">
    <regionList>
      <region material="99lines" name="mech" />
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="3d">
        <regionList>
          <region name="mech" />
        </regionList>

        <bcsAndLoads>
           <fix name="bottom_left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
              <comp dof="z"/>
           </fix>
           <fix name="bottom_right"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
              <comp dof="z"/>
           </fix>
           <force name="top">
             <comp dof="y" value="-1"/>
           </force>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <regionResult type="mechDeformEnergy">
             <allRegions/>
          </regionResult>
        </storeResults>
      </mechanic>
    </pdeList>

   <linearSystems>
     <system>
       <solverList>
         <!-- This are is the default configuration at time of test case creation, hence the same as a plain gingko element.
              We need a sparseNonSym matrix storage, see lis test case -->
          <ginkgo precond="ilu" solver="cg" maxIter="10000" tolerance="1e-12" minimalTolerance="1e-11" >
            <jacobi max_block_size="3"/>
          </ginkgo>
        </solverList>
      </system>
    </linearSystems> 
  </sequenceStep> 
</cfsSimulation>


