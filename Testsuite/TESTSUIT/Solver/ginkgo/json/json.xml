<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xsi:schemaLocation="http://www.cfs++.org/simulation 
  https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
  <documentation>
    <title>Ginkgo iterative solver with json configuration</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2025-02-28</date>
    <keywords>
      <keyword>iterative_solver</keyword>
    </keywords>
    <references>https://github.com/ginkgo-project/ginkgo</references>
    <isVerified>yes</isVerified>
    <description>See the Ginkgo/jacobi_cg test for the general description.
    
      Here we use the possibility to configure Ginkgo arbitrarily via an external json file.
      This is important, as we have only a subset of possible options accessible via xml.
      The exmple json files are based on https://github.com/ginkgo-project/ginkgo/tree/develop/examples/file-config-solver/config
      but the iterations are sometimes increased.
      
      the input can be generated by create_mesh.py --type bulk3d --res 5
    </description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="json.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="3d">
    <regionList>
      <region material="99lines" name="mech" />
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="3d">
        <regionList>
          <region name="mech" />
        </regionList>

        <bcsAndLoads>
           <fix name="bottom_left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
              <comp dof="z"/>
           </fix>
           <fix name="bottom_right"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
              <comp dof="z"/>
           </fix>
           <force name="top">
             <comp dof="y" value="-1"/>
           </force>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <regionResult type="mechDeformEnergy">
             <allRegions/>
          </regionResult>
        </storeResults>
      </mechanic>
    </pdeList>

   <linearSystems>
     <system>
       <solverList>
         <!-- maximal iterations and tolerance are purely from the json file, all settings in the ginkgo element are ignored -->
          <ginkgo json="cg.json" />
        </solverList>
      </system>
    </linearSystems> 
  </sequenceStep> 
</cfsSimulation>


