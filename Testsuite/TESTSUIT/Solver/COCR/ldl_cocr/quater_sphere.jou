reset
#{freq = 100}
#{c0 = 343}
#{lambda = c0 / freq}
#{mesh_size = lambda / 12}
#{R = 5*lambda}
### create a quater circle with radius R
create vertex 0 0 0
create vertex {R} 0 0
#create vertex 5 0 0
create vertex 0 {R} 0
#create vertex 0 5 0
create curve arc center vertex 1 3 2
create curve vertex 1 2
create curve vertex 1 3
create surface curve all
### meshing the quarter circle
surface 1 scheme pave size {mesh_size}
mesh surface 1
### refine elements near center node
#refine vertex 1 numsplit 2 bias 1 depth 1 smooth
#refine curve 1 numsplit 2 bias 1 depth 1 smooth
### assign regions and BCs
block 1 add surface 1 name "S_channel"
### use second order element
block 1 element type QUAD8
nodeset 1 add node 1 name "center_node"
nodeset 2 add curve 1 name "L_ABC"
nodeset 3 add curve 2 name "L_bottom"
nodeset 4 add curve 3 name "L_left"
export ansys cdb "./quater_sphere.cdb" overwrite


