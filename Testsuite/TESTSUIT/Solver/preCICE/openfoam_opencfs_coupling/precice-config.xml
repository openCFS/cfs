<precice-configuration>

<log>
    <sink
    filter="%Severity% >= info and %Rank% = 0"
    format="---[precice] %ColorizedSeverity% %Message%"
    enabled="true" />
</log>

<data:scalar name="Pressure"/>
<!-- <data:scalar name="acouRhsLoad"/> -->

<mesh name="openCFSMesh" dimensions="2">
    <use-data name="Pressure"/>
    <!-- <use-data name="acouRhsLoad"/> -->
</mesh>
<mesh name="openFOAMMesh" dimensions="2">
    <use-data name="Pressure"/>
    <!-- <use-data name="acouRhsLoad"/> -->
</mesh>

<participant name="openFOAM">
    <provide-mesh name="openFOAMMesh"/>
    <receive-mesh name="openCFSMesh" from="openCFS"/>
    <write-data name="Pressure" mesh="openFOAMMesh"/>
</participant>

<participant name="openCFS">
    <provide-mesh name="openCFSMesh"/>
    <receive-mesh name="openFOAMMesh" from="openFOAM"/>
    <read-data name="Pressure" mesh="openCFSMesh"/>
    <!-- <read-data name="acouRhsLoad" mesh="openCFSMesh"/> -->
    <mapping:nearest-neighbor direction="read" from="openFOAMMesh" to="openCFSMesh" constraint="conservative"/>
</participant>

<!-- <mappings>
    <mapping name="Pmap" direction="read" from="openFOAMMesh" to="openCFSMesh" type="nearest-neighbor" />
</mappings> -->

<m2n:sockets acceptor="openFOAM" connector="openCFS" exchange-directory=".."/>
<!-- <m2n:sockets acceptor="openFOAM" connector="openCFS"/> -->

<coupling-scheme:serial-explicit>
    <participants first="openFOAM" second="openCFS"/>
    <max-time-windows value="20"/> 
    <time-window-size value="5e-5"/>
    <exchange data="Pressure" mesh="openFOAMMesh" from="openFOAM" to="openCFS"/>
    <!-- <exchange data="acouRhsLoad" mesh="openFOAMMesh" from="openFOAM" to="openCFS"/> -->
</coupling-scheme:serial-explicit>

</precice-configuration>