<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <documentation>
    <title>SmoothPDE prescribed-displacement mode: analytic whole-domain injection (no solve)</title>
    <authors>
      <author>Dominik Mayrhofer</author>
    </authors>
    <date>2026-07-15</date>
    <keywords>
      <keyword>transient</keyword>
      <keyword>smooth</keyword>
    </keywords>
    <references>No references</references>
    <isVerified>no</isVerified>
    <description>
      Standalone test of the SmoothPDE "prescribed displacement" mode (no preCICE).
      The whole-domain displacement is given analytically and must be injected directly into the
      SMOOTH_DISPLACEMENT solution every step WITHOUT solving. Since there is no Dirichlet BC and
      no load, a real smoothing solve would give u = 0 everywhere; therefore a non-zero result
      that matches the prescribed field proves the field is injected (not solved).
      The duct mesh is generated by make_mesh.py (see there for the geometry parameters).
    </description>
  </documentation>

  <fileFormats>
    <input>
      <gmsh fileName="channel.msh"/>
    </input>
    <output>
      <hdf5 id="hdf5"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <regionList>
      <region name="V" material="smoothMat"/>
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <transient>
        <numSteps>20</numSteps>
        <deltaT>1e-4</deltaT>
      </transient>
    </analysis>

    <pdeList>
      <smooth subType="3d">
        <regionList>
          <region name="V"/>
        </regionList>

        <!-- Externally prescribed whole-domain displacement: u = (A sin(wt), B cos(wt), 0),
             uniform in space, time-varying (verifies per-step re-evaluation and no-solve). -->
        <prescribedDisplacement>
          <vector name="V">
            <comp dof="x" value="0.001*sin(2*pi*1000*t)"/>
            <comp dof="y" value="0.0005*cos(2*pi*1000*t)"/>
            <comp dof="z" value="0.0"/>
          </vector>
        </prescribedDisplacement>

        <storeResults>
          <nodeResult type="smoothDisplacement"><allRegions/></nodeResult>
        </storeResults>
      </smooth>
    </pdeList>

    <linearSystems>
      <system>
        <solutionStrategy>
          <standard><matrix storage="sparseNonSym"/></standard>
        </solutionStrategy>
        <solverList>
          <pardiso/>
        </solverList>
      </system>
    </linearSystems>
  </sequenceStep>
</cfsSimulation>
