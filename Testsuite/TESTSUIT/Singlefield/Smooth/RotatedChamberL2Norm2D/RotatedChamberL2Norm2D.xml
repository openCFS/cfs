          <dof name="y" realFunc="((t lt 1/f_exc)? amp*(y*cos(rot_angle*pi/180)-x*sin(rot_angle*pi/180))/d*1/2*(1-cos(pi*f_exc*t))*cos(rot_angle*pi/180) : (amp))*(y*cos(rot_angle*pi/180)-x*sin(rot_angle*pi/180))/d*cos(rot_angle*pi/180)"/>
        </L2Norm>
