            <comp dof="y" value="((t lt 1/f_exc)? amp*1/2*(1-cos(pi*f_exc*t))*cos(rot_angle*pi/180) : (amp)*cos(rot_angle*pi/180))"/>
          </displacement>
          <fix name="C_Fix">
