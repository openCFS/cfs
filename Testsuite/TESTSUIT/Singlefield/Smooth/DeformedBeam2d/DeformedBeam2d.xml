<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
               xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../../share/xml/CFS-Simulation/CFS.xsd"
               xmlns="http://www.cfs++.org/simulation">
    <documentation>
        <title>Deformed Beam 2d</title>
        <authors>
            <author>Nnamdi Opara</author>
            <author>Michael Mörth</author>
        </authors>
        <date>2026-02-09</date>
        <keywords>
        </keywords>
        <references></references>
        <isVerified>no</isVerified>
        <description>
            This is a 2D model of a Euler beam, clamped on one side, free on the other.
            We apply a reference displacement on the free side

            dimension l/b = 50/3

            The geometry as well as the cfs input and material files have been adapted from the
            Testsuit "BucklingBeam2d" from the mechanicPDE.

            The reference file was compared to a solution given by a mechanicPDE simulation (included in reference folder).
        </description>
    </documentation>
    <fileFormats>
        <input>
            <hdf5 fileName="DeformedBeam2d.h5ref"/>
            <!--<cdb fileName="mesh_beam.cdb"/>--> 
        </input>
        <output>
            <hdf5 />
        </output>
        <materialData file="./mat_smooth.xml" format="xml" />
    </fileFormats>

    <domain geometryType="plane">
        <variableList>
            <var name="E" value="100e03" />
            <var name="nu" value="0.3" />
        </variableList>
        <regionList>
            <region name="beam" material="elastic" />
        </regionList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <static/>
        </analysis>
        <pdeList>
            <smooth subType="planeStress">
                <regionList>
                    <region name="beam"/>
                </regionList>
                <bcsAndLoads>
                    <fix name="BC_fix">
                        <comp dof="x" />
                        <comp dof="y" />
                    </fix>
                    <displacement name="BC_displace">
                        <comp dof="x" value="1" />
                    </displacement>
                </bcsAndLoads>
                <storeResults>
                    <elemResult type="smoothStress">
                        <allRegions />
                    </elemResult>
                    <nodeResult type="smoothDisplacement">
                        <allRegions />
                    </nodeResult>
                </storeResults>
            </smooth>
        </pdeList>
    </sequenceStep>


</cfsSimulation>