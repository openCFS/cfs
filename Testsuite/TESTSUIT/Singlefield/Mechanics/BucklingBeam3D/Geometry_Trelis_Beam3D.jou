Journal Off
reset
undo off


# Define mesh intervall
#{ELA = 3}
#{ELB = 3}
#{ELC = 17}

# Define beam size
#{a = 3}
#{b = 4}
#{l = 100}


# create volume
brick x {l} y {a} z {b}

# mesh volume
curve 1  interval {ELA}
curve 12  interval {ELB}
curve 2  interval {ELC}
curve 1 12 2  scheme equal
volume 1 scheme map
mesh curve 1 12 2
mesh volume 1

# define regions
block 1 add volume all
block 1 name "beam"

sideset 1 add surface all with x_coord={l/2}
sideset 1 name "reference_Load_surface"

nodeset 1 add node all with x_coord={- l/2}
nodeset 1 name "BC_fix"

nodeset 7 add node all with z_coord={- b/2}
nodeset 7 name "BC_sym"

nodeset 2 add node all with x_coord={l/2}
nodeset 2 name "reference_Load"

nodeset 2 remove node all with y_coord={a/2}
nodeset 2 remove node all with z_coord={b/2}
nodeset 2 remove node all with y_coord={-a/2}
nodeset 2 remove node all with z_coord={-b/2}
nodeset 2 name "reference_Load_face"


nodeset 3 add node all with x_coord={l/2} and with y_coord={a/2}
nodeset 3 add node all with x_coord={l/2} and with y_coord={-a/2}
nodeset 3 add node all with x_coord={l/2} and with z_coord={b/2}
nodeset 3 add node all with x_coord={l/2} and with z_coord={-b/2}

nodeset 3 remove node all with y_coord = {a/2} and with z_coord = {b/2}
nodeset 3 remove node all with y_coord = {-a/2} and with z_coord = {b/2}
nodeset 3 remove node all with y_coord = {a/2} and with z_coord = {-b/2}
nodeset 3 remove node all with y_coord = {-a/2} and with z_coord = {-b/2}
nodeset 3 name "reference_Load_edge"

nodeset 4 add node all with y_coord = {a/2} and with z_coord = {b/2} and with x_coord={l/2} 
nodeset 4 add node all with y_coord = {-a/2} and with z_coord = {b/2} and with x_coord={l/2} 
nodeset 4 add node all with y_coord = {a/2} and with z_coord = {-b/2} and with x_coord={l/2} 
nodeset 4 add node all with y_coord = {-a/2} and with z_coord = {-b/2} and with x_coord={l/2} 
nodeset 4 name "reference_Load_corner"



block 1 element type hex20
nodeset 1 add node all with x_coord={- l/2}
nodeset 7 add node all with z_coord={- b/2}

nodeset 5 add node all with x_coord={l/2} 
nodeset 5 remove node in nodeset 2
nodeset 5 remove node in nodeset 3
nodeset 5 remove node in nodeset 4
nodeset 5 remove node all with x_coord={l/2} and with y_coord={a/2}
nodeset 5 remove node all with x_coord={l/2} and with y_coord={-a/2}
nodeset 5 remove node all with x_coord={l/2} and with z_coord={b/2}
nodeset 5 remove node all with x_coord={l/2} and with z_coord={-b/2}
nodeset 5 name "reference_Load_face_mid"


nodeset 6 add node all with x_coord={l/2} 
nodeset 6 remove node in nodeset 2
nodeset 6 remove node in nodeset 3
nodeset 6 remove node in nodeset 4
nodeset 6 remove node in nodeset 5
nodeset 6 name "reference_Load_edge_mid"


delete nodeset 3 4 5 6

nodeset 2 add node all with x_coord={l/2}
nodeset 2 name "reference_Load"

export ansys cdb "./mesh_quad.cdb"  overwrite 
export abaqus "./mesh_quad.inp"  partial overwrite  everything 
