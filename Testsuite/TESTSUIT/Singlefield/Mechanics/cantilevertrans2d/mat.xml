    <mechanical>
      <density>
        <linear>
          <real> 2.33E+03 </real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <isotropic>
            <elasticityModulus>
              <real> 162e9 </real>
            </elasticityModulus>
