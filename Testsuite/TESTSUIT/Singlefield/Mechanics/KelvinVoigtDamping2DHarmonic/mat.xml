<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material">
  <material name="massKelvinVoigt">
    <mechanical>
      <density>
        <linear>
          <real> 100 </real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <tensor dim1="3" dim2="3">
            <real>
              1e5 0    0   
              0    1e5 0   
              0    0    5e4
            </real>
          </tensor>
        </linear>
      </elasticity>
      <damping>
        <kelvinVoigt>
          <linear>
            <tensor dim1="3" dim2="3">
              <real>
                1    0    0  
                0    1    0  
                0    0    0.5
              </real>
            </tensor>
          </linear>
        </kelvinVoigt>
      </damping>
    </mechanical>
  </material>
  <material name="springKelvinVoigt">
    <mechanical>
      <density>
        <linear>
          <real> 1e-12 </real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <tensor dim1="3" dim2="3">
            <real>
              1    0    0  
              0    1    0  
              0    0    0.5
            </real>
          </tensor>
        </linear>
      </elasticity>
      <damping>
        <kelvinVoigt>
          <linear>
            <tensor dim1="3" dim2="3">
              <real>
                1    0    0  
                0    1    0  
                0    0    0.5
              </real>
            </tensor>
          </linear>
        </kelvinVoigt>
      </damping>
    </mechanical>
  </material>
</cfsMaterialDataBase>