<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation http://cfs-doc.mdmt.tuwien.ac.at/xml/CFS-Simulation/CFS.xsd">

  <documentation>
    <title>harmonic analysis of prestressed 2D cantilever with incompatible modes</title>
    <authors>
      <author>pheidegger, kaltenbacher, ahauck</author>
    </authors>
    <date>2025-05-07</date>
    <keywords>
      <keyword>mechanic</keyword>
      <keyword>prestress</keyword>
      <keyword>incompatible modes</keyword>
    </keywords>
    <references>NACS example</references>
    <isVerified>no</isVerified>
    <description> This is a 2D model of a cantilever, clamped on one side. In a first sequence step, a constant pressure is a applied to one surface of the cantilever. In a second step we use the displacements of the first step to calculate a prestressing of the structure, within a harmonic analysis. This test is computed with ICModes activated, to check the combination of preStress with ICModes.</description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="PreStress2dMS_Harm_ICModes.h5ref"/>
    </input>
    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="cantilev" material="steel"/>
    </regionList>
    <surfRegionList>
      <surfRegion name="surf"/>
    </surfRegionList>
    <nodeList>
      <nodes name="ux-dof"/>
      <nodes name="uy-dof"/>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>
    <pdeList>
      <mechanic subType="planeStrain">
        <regionList>
          <region name="cantilev" softeningId="icm"/>
        </regionList>
        <softeningList>
          <icModesTW id="icm"/>
        </softeningList>
        <bcsAndLoads>
          <fix name="ux-dof">
            <comp dof="x"/>
          </fix>
          <fix name="uy-dof">
            <comp dof="y"/>
          </fix>
          <pressure name="surf" value="-1e4"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <elemResult type="mechStress">
            <allRegions/>
          </elemResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>

  <sequenceStep index="2">
    <analysis>
      <harmonic>
        <numFreq> 1 </numFreq>
        <startFreq> 10 </startFreq>
        <stopFreq> 10 </stopFreq>
      </harmonic>
    </analysis>
    <pdeList>
      <mechanic subType="planeStrain">
        <regionList>
          <region name="cantilev" softeningId="icm"/>
        </regionList>
        <softeningList>
          <icModesTW id="icm"/>
        </softeningList>
        <bcsAndLoads>
          <fix name="ux-dof">
            <comp dof="x"/>
          </fix>
          <fix name="uy-dof">
            <comp dof="y"/>
          </fix>
          <pressure name="surf" value="-1e4"/>
          <preStress region="cantilev">
            <computeLHS sequenceStep="1"/>
          </preStress>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>
</cfsSimulation>