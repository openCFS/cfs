<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.cfs++.org/material 
https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd" >
    <material name="Steel"> 
        <!-- E=210 GPa . \nu=0.3 -->
        <mechanical>
            <density>
                <linear>
                    <real>7850</real>
                </linear>
            </density>
            <elasticity>
                <linear>
                    <isotropic>
                        <lameParameterMu>
                            <real>8.0769e+10</real>
                        </lameParameterMu>
                        <lameParameterLambda>
                            <real>1.2115e+11</real>
                        </lameParameterLambda>
                    </isotropic>
                </linear>
            </elasticity>
        </mechanical>
    </material>
    <material name="Copper"> 
        <!-- E = 115 GPa . \nu = 0.31-->
        <mechanical>
            <density>
                <linear>
                    <real>8890</real>
                </linear>
            </density>
            <elasticity>
                <linear>
                    <isotropic>
                        <lameParameterMu>
                            <real>4.3893e+10</real>
                        </lameParameterMu>
                        <lameParameterLambda>
                            <real>7.1615e+10</real>
                        </lameParameterLambda>
                    </isotropic>
                </linear>
            </elasticity>
        </mechanical>
    </material>
    <material name="layerMaterial"> 
        <mechanical>
            <density>
                <linear>
                    <real>8000</real>
                </linear>
            </density>
            <elasticity>
                <linear>
                    <isotropic>
                        <lameParameterMu>
                            <real>82e9</real>
                        </lameParameterMu>
                        <lameParameterLambda>
                            <real>115e9</real>
                        </lameParameterLambda>
                    </isotropic>
                </linear>
            </elasticity>
        </mechanical>
    </material>
    <material name="layerMaterialSoft"> 
        <!-- Rubber. E = 0.05 GPa . \nu = 0.49 -->
        <mechanical>
            <density>
                <linear>
                    <real>1100</real>
                </linear>
            </density>
            <elasticity>
                <linear>
                    <isotropic>
                        <lameParameterMu>
                            <real>1.6779e+07</real>
                        </lameParameterMu>
                        <lameParameterLambda>
                            <real>8.2215e+08</real>
                        </lameParameterLambda>
                    </isotropic>
                </linear>
            </elasticity>
        </mechanical>
    </material>
</cfsMaterialDataBase>