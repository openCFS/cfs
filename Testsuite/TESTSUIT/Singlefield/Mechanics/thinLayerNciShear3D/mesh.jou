reset

# VARIABLES
{L = 1}
{size_l = 0.1}
{size_r = 0.15}
{t = 2*L/100}

# GEOMETRY
# --- planes
create Vertex 0 0 0		# for reference
create brick x {L/2} y {L} z {L}
create brick x {L/2} y {L} z {L}

# --- have 0|0|0 at left|bottom|front corner
move volume 1 x {L/4}  y {L/2} z {-L/2} include_merged 
move volume 2 x {L*3/4} y {L/2} z {-L/2}include_merged

# MESH
volume 1 size {size_l}
volume 2 size {size_r}
mesh volume 1 2

# DOMAIN AND BOUNDARIES
block 1 add volume 1
block 1 name "V_left"

block 2 add volume 2
block 2 name "V_right"

nodeset 1 add surface 4
nodeset 1 name "S_left"

nodeset 2 add surface 12
nodeset 2 name "S_right"

nodeset 3 add surface 6
nodeset 3 name "NCI_leftSlave"

nodeset 4 add surface 10
nodeset 4 name "NCI_rightMaster"

nodeset 5 add surface 5 11
nodeset 5 name "S_top"

nodeset 7 add surface 3 9
nodeset 7 name "S_bottom"

nodeset 9 add surface 1 7
nodeset 9 name "S_front"

nodeset 11 add surface 2 8
nodeset 11 name "S_back"

# SAVING
export ansys cdb "mesh.cdb"  overwrite 