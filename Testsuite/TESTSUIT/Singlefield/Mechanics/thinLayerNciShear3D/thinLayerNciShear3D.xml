<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title> Non-Conforming 2D Mechanics with thinLayer formulation </title>
        <authors>
            <author>vfilkin</author>
        </authors>
        <date>2024-03-23</date>
        <keywords>
            <keyword>mechanic</keyword>
            <keyword>nonmatching grids</keyword>
        </keywords>
        <references></references>
        <isVerified>no</isVerified>
        <description> 
            Mechanics/Shear 3D - thinLayer - Nci
            Non-conforming mesh with thinLayer formulation for vector fields
            Dimensions: cube with sidelength 1. thin layer thickness 0.02.
            Boundary Conditions: left side is fixed. other  sides have a prescribed traction of: +-1e9
            Materials: The cube has material steel. The thin layer section has material copper.
            Validation: 1. comparison between thin layer and fully modelled verison in paraview
        </description>
    </documentation>

    <fileFormats>
        <input>
            <!-- <cdb fileName="mesh.cdb"/> -->
            <hdf5 fileName="mesh.cfs"/>
        </input>
        <output>
            <hdf5/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>

    <domain geometryType="3d">
        <regionList>
            <region name="V_left" material="Steel"/>
            <region name="V_right" material="Steel"/>
        </regionList>
        <surfRegionList>
            <surfRegion name="NCI_rightMaster" />
            <surfRegion name="NCI_leftSlave" />
        </surfRegionList>
        <ncInterfaceList>
            <ncInterface name="nciThinLayer" primarySide="NCI_rightMaster" secondarySide="NCI_leftSlave"/>
        </ncInterfaceList>       
    </domain>

    <sequenceStep index="1">
        <analysis>
            <static/>
        </analysis>

        <pdeList>
            <mechanic subType="3d">
                <regionList>
                    <region name="V_left"/>
                    <region name="V_right"/>
                </regionList>

                <ncInterfaceList>
                    <ncInterface name="nciThinLayer" formulation="Nitsche">
                        <thinLayer layerThickness="0.02" layerMaterial="Copper"/>
                    </ncInterface>
                </ncInterfaceList>

                <bcsAndLoads>
                    <fix name="S_left">
                        <comp dof="x" />
                        <comp dof="y" />
                        <comp dof="z" />
                    </fix>
                    <traction name="S_right" >
                        <comp dof="z" value="1e9" />
                    </traction>
                    <traction name="S_left" >
                        <comp dof="z" value="-1e9" />
                    </traction>
                    <traction name="S_front" >
                        <comp dof="x" value="1e9" />
                    </traction>
                    <traction name="S_back" >
                        <comp dof="x" value="-1e9" />
                    </traction>
                </bcsAndLoads>

                <storeResults>
                    <nodeResult type="mechDisplacement">
                        <allRegions/>
                    </nodeResult>
                    <elemResult type="mechStress">
                        <allRegions/>
                    </elemResult>

                    <!-- used for calculations.ipynb -->
                    <!-- <sensorArray fileName="sensorArray/Disp_nci_trac1e9_t002.csv" type="mechDisplacement" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="0" stop="L" inc="0.001"/>
                          <list comp="y" start="L/2" stop="L/2" inc="0"/>
                          <list comp="z" start="-L/2" stop="-L/2" inc="0" />
                        </parametric>
                    </sensorArray>
                    <sensorArray fileName="sensorArray/Strain_nci_trac1e9_t002.csv" type="mechStrain" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="0" stop="L" inc="0.001"/>
                          <list comp="y" start="L/2" stop="L/2" inc="0"/>
                          <list comp="z" start="-L/2" stop="-L/2" inc="0" />
                        </parametric>
                    </sensorArray> -->
                </storeResults>

            </mechanic>
        </pdeList>

    </sequenceStep>

</cfsSimulation>