<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title> Non-Conforming 2D Mechanics with thinLayer formulation </title>
        <authors>
            <author>vfilkin</author>
        </authors>
        <date>2024-03-23</date>
        <keywords>
            <keyword>mechanic</keyword>
            <keyword>nonmatching grids</keyword>
        </keywords>
        <references></references>
        <isVerified>no</isVerified>
        <description> 
            Mechanics/Shear 3D - thinLayer - Nci - full model
            Non-conforming mesh with thinLayer formulation for vector fields
            fully modelled version to thinLayerNciShear3D.xml
        </description>
    </documentation>

    <fileFormats>
        <input>
            <!-- <cdb fileName="meshFull.cdb"/> -->
            <hdf5 fileName="meshFull.cfs"/>
        </input>
        <output>
            <hdf5/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>

    <domain geometryType="3d">
        <variableList>
            <var name="L" value="1" />
            <var name="layerthickness" value="2*L/100" />
        </variableList>
        <regionList>
            <region name="V_left" material="Steel"/>
            <region name="V_right" material="Steel"/>
            <region name="V_tlr" material="Copper"/>
        </regionList>  
    </domain>

    <sequenceStep index="1">
        <analysis>
            <static/>
        </analysis>

        <pdeList>
            <mechanic subType="3d">
                <regionList>
                    <region name="V_left"/>
                    <region name="V_right"/>
                    <region name="V_tlr" />
                </regionList>

                <bcsAndLoads>
                    <fix name="S_left">
                        <comp dof="x" />
                        <comp dof="y" />
                        <comp dof="z" />
                    </fix>
                    <traction name="S_right" >
                        <comp dof="z" value="1e9" />
                    </traction>
                    <traction name="S_left" >
                        <comp dof="z" value="-1e9" />
                    </traction>
                    <traction name="S_front" >
                        <comp dof="x" value="1e9" />
                    </traction>
                    <traction name="S_back" >
                        <comp dof="x" value="-1e9" />
                    </traction>
                </bcsAndLoads>

                <storeResults>
                    <nodeResult type="mechDisplacement">
                        <allRegions/>
                    </nodeResult>
                    <elemResult type="mechStress">
                        <allRegions/>
                    </elemResult>

                    <sensorArray fileName="sensorArray/Disp_full_trac1e9_t002.csv" type="mechDisplacement" csv="yes" delimiter=",">
                        <parametric> 
                          <list comp="x" start="0" stop="L+layerthickness" inc="0.001"/>
                          <list comp="y" start="L/2" stop="L/2" inc="0"/>
                          <list comp="z" start="-L/2" stop="-L/2" inc="0" />
                        </parametric>
                    </sensorArray>
                    <sensorArray fileName="sensorArray/Strain_full_trac1e9_t002.csv" type="mechStrain" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="0" stop="L+layerthickness" inc="0.001"/>
                          <list comp="y" start="L/2" stop="L/2" inc="0"/>
                          <list comp="z" start="-L/2" stop="-L/2" inc="0" />
                        </parametric>
                    </sensorArray>
                </storeResults>
            </mechanic>
        </pdeList>

    </sequenceStep>

</cfsSimulation>