<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title> Non-Conforming 2D Mechanics with thinLayer formulation </title>
        <authors>
            <author>vfilkin</author>
        </authors>
        <date>2024-03-23</date>
        <keywords>
            <keyword>mechanic</keyword>
            <keyword>nonmatching grids</keyword>
        </keywords>
        <references></references>
        <isVerified>no</isVerified>
        <description> 
            Mechanics 2D. extension beam.
            Non-conforming mesh with thinLayer formulation for vector fields
            Dimensions: beam with length 1. width 0.1. thin layer thickness 0.02.
            Boundary Conditions: left si-de is fixed. right side has a prescribed traction of: 10e6
            Materials: The beam has material steel. The thin layer section has material copper.
            Validation: 1. Compare Displacement along xDirection (ThinLayer version vs. fully modelled version)
                        2. Compare Stiffness across thin layer region (tlr) by comparing K u = t and the analytical stiffness.
                            with K being the stiffness across tlr.
                                 u being the difference in displacement across the tlr.
                                 t  being the applied traction. 
                        see calculations.ipynb for details.
        </description>
    </documentation>

    <fileFormats>
        <input>
            <!-- <cdb fileName="mesh.cdb"/> -->
            <hdf5 fileName="mesh.cfs"/>
        </input>
        <output>
            <hdf5/>
            <text id="txt"/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>

    <domain geometryType="plane">
        <regionList>
            <region name="V_left" material="Steel"/>
            <region name="V_right" material="Steel"/>
        </regionList>
        <surfRegionList>
            <surfRegion name="NCI_rightMaster" />
            <surfRegion name="NCI_leftSlave" />
        </surfRegionList>
        <ncInterfaceList>
            <ncInterface name="nciThinLayer" primarySide="NCI_rightMaster" secondarySide="NCI_leftSlave"/>
        </ncInterfaceList>
        <nodeList>
            <nodes name="fixNode">
                <coord x="-0.25" y="0.0001"/>
            </nodes>
        </nodeList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <static/>
        </analysis>

        <pdeList>
            <mechanic> <!-- subType="planeStrain"-->
                <regionList>
                    <!-- define regions to be included in the analysis -->
                    <region name="V_left"/>
                    <region name="V_right"/>
                </regionList>

                <ncInterfaceList>
                    <ncInterface name="nciThinLayer" formulation="Nitsche"> <!-- only nitsche type coupling implemented-->
                        <thinLayer layerThickness="0.02" layerMaterial="Copper"/>
                    </ncInterface>
                </ncInterfaceList>

                <bcsAndLoads>
                    <traction name="S_right" >
                        <comp dof="x" value="10e6" />
                    </traction>
                    <fix name="S_left">
                        <comp dof="x" />
                    </fix>
                    <fix name="fixNode">
                        <comp dof="y" />
                    </fix>
                </bcsAndLoads>

                <storeResults>

                    <nodeResult type="mechDisplacement">
                        <allRegions/>
                    </nodeResult>
                    <elemResult type="mechStress">
                        <allRegions/>
                    </elemResult>

                    <!-- used for calculations.ipynb -->
                    <!-- <sensorArray fileName="sensorArray/Disp_nci_trac10e6_t002.csv" type="mechDisplacement" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="-0.25" stop="0.75" inc="0.001"/>
                          <list comp="y" start="-0.05" stop="-0.05" inc="0"/>
                        </parametric>
                    </sensorArray>
                    <sensorArray fileName="sensorArray/Strain_nci_trac10e6_t002.csv" type="mechStrain" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="-0.25" stop="0.75" inc="0.001"/>
                          <list comp="y" start="-0.05" stop="-0.05" inc="0"/>
                        </parametric>
                    </sensorArray> -->

                </storeResults>
            </mechanic>
        </pdeList>
        
    </sequenceStep>

</cfsSimulation>