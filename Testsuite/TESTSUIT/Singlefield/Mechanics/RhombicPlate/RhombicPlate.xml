<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation http://cfs-doc.mdmt.tuwien.ac.at/xml/CFS-Simulation/CFS.xsd">

  <fileFormats>
    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
    
  <domain geometryType="3d">
    <regionList>
      <region name="plate1" material="material2"/>
    </regionList>
    <surfRegionList>
      <surfRegion name="pload"/>
    </surfRegionList>
    <nodeList>
      <nodes name="fix-all"/>
    </nodeList>
  </domain>

  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      <mechanic subType="3d">
        <regionList>
          <region name="plate1" softeningId="1"/>
        </regionList>
        
        <softeningList>
          <icModesTW id="1"/>
        </softeningList>
        
        <bcsAndLoads>
          <fix name="fix-all">
            <comp dof="x"/>
            <comp dof="y"/>
            <comp dof="z"/>
          </fix>
          <pressure name="pload" value="1"/>
        </bcsAndLoads>
        
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
            <nodeList>
              <nodes name="save1"/>
            </nodeList>
          </nodeResult>
      </storeResults>

      </mechanic>
    </pdeList>

    <linearSystems>
      <system>
        <solverList>
          <directLU/>
        </solverList>
      </system>
    </linearSystems>
 

  </sequenceStep>
</cfsSimulation>
