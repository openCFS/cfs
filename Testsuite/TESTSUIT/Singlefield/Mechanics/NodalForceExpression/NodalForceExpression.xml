<?xml version="1.0" encoding="UTF-8"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation">
  <documentation>
    <title>demonstrates usage of nodal forces as mathparser expression</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2022-02-04</date>
    <keywords>
      <keyword>file format</keyword>
    </keywords>
    <references>Standard</references>
    <isVerified>yes</isVerified>
    <description>Re-enables expression force values. Note that the force is divided by number of chosen nodes.
      Note that there might be named nodes, not part of a simulated region, then sum of the active nodes is below
      the specified value! See also the test case Technical/NodalDataFile). The mesh is created by the provided make_mesh.py.
    </description>
  </documentation>
  <fileFormats>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech" />
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech" />
        </regionList>

        <bcsAndLoads>
           <fix name="outer_nodes"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
           </fix>
           <!-- Ihe inclusion nodes are circular around the center (0.5, 0.5).
                Therefore the nodal force is outwards. The force is devided by
                the number of nodes in inclusion_nodes.
                See info.xml in assemble, possibly you need to run cfs with -d (for detailed) -->
           <force name="inclusion_nodes">
             <comp dof="x" value="x-0.5"/>
             <comp dof="y" value="y-0.5"/>           
           </force>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <nodeResult type="mechRhsLoad">
            <allRegions/>
          </nodeResult>
          <regionResult type="mechDeformEnergy">
            <allRegions/>
          </regionResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>

</cfsSimulation>
