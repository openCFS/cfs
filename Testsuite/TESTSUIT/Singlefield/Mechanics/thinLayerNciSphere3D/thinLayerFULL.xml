<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title> Non-Conforming 3D Mechanics with thinLayer Formulation </title>
        <authors>
            <author>vfilkin</author>
        </authors>
        <date>2025-10-20</date>
        <keywords>
            <keyword>mechanic</keyword>
            <keyword>nonmatching grids</keyword>
        </keywords>
        <references></references>
        <isVerified>no</isVerified>
        <description> 
            Mechanics 3D - thinLayer - Nci
            Non-conforming mesh with thinLayer formulation for vector fields
            fully modelled version to thinLayerNciSphere3D.xml
        </description>
    </documentation>

    <fileFormats>
        <input>
            <!-- <cdb fileName="meshFull.cdb"/> -->
            <hdf5 fileName="meshFull.cfs"/>
        </input>
        <output>
            <hdf5/>
            <text id="txt"/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>

    <domain geometryType="3d">
        <variableList>
            <var name="layerthickness" value="0.01"/>
        </variableList>
        <regionList>
            <region name="V_in" material="Steel"/>
            <region name="V_out" material="Steel"/>
            <region name="V_mid" material="Copper"/>
        </regionList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <static/>
        </analysis>

        <pdeList>
            <mechanic subType="3d">
                <regionList>
                    <region name="V_in"/>
                    <region name="V_out"/>
                    <region name="V_mid"/>
                </regionList>

                <bcsAndLoads>
                    <pressure name="S_out" value="10e6"/>
                    <fix name="S_yz">
                        <comp dof="x"/>
                    </fix>
                    <fix name="S_xy">
                        <comp dof="z"/>
                    </fix>
                    <fix name="S_xz">
                        <comp dof="y"/>
                    </fix>
                </bcsAndLoads>

                <storeResults>
                    <nodeResult type="mechDisplacement">
                        <allRegions/>
                    </nodeResult>
                    <elemResult type="mechStress">
                        <allRegions/>
                    </elemResult>
                    <elemResult type="mechStrain">
                        <allRegions />
                    </elemResult>
                </storeResults>
                
            </mechanic>
        </pdeList>
    </sequenceStep>

</cfsSimulation>