<?xml version='1.0' encoding='UTF-8'?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation http://cfs-doc.mdmt.tuwien.ac.at/xml/CFS-Simulation/CFS.xsd">

<documentation>
  <title>prestressed 3D cantilever</title>
  <authors>
    <author>kaltenbacher, ahauck</author>
  </authors>
  <date>2011-03-16</date>
  <keywords>
    <keyword>prestress</keyword>
  </keywords>
  <references>NACS example</references>
  <isVerified>no</isVerified>
  <description>
    This is a 3D model of a cantilever, clamped on both sides. We apply
    a constant prestressing of 10 kN/m^2 to the whole structure in length 
    direction to shift the resonance frequency.
  </description>
</documentation>
  
  <fileFormats>
    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <regionList>
      <region name="feco" material="steel"/>
      <region name="sio2" material="steel"/>
    </regionList>
    <nodeList>
      <nodes name="fix-all"/>
      <nodes name="load"/>
      <nodes name="fix-top"/>
      <nodes name="hist"/>
    </nodeList>
  </domain>

  <sequenceStep>
    <analysis>

      <eigenFrequency>
        <isQuadratic>no</isQuadratic>
        <numModes> 10 </numModes>
        <freqShift> 1 </freqShift>
        <writeModes> yes </writeModes>
      </eigenFrequency>
    </analysis>

    <pdeList>
      <mechanic subType="3d">

        <regionList>
          <region name="sio2"/>
        </regionList>

        <bcsAndLoads>
          <fix name="fix-all">
            <comp dof="x"/>
            <comp dof="y"/>
            <comp dof="z"/>
          </fix>
          <fix name="fix-top">
            <comp dof="x"/>
            <comp dof="y"/>
            <comp dof="z"/>
          </fix>
          <preStress region="sio2">
            <prescribedLHS value="0 1e4 0 0 0 0"/>
          </preStress>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <elemResult type="mechStress">
            <allRegions/>
          </elemResult>
        </storeResults>
      </mechanic>
    </pdeList>

    <linearSystems>
      <system>
        <solverList>
          <directLU/>
        </solverList>
      </system>
    </linearSystems>

  </sequenceStep>
</cfsSimulation>
