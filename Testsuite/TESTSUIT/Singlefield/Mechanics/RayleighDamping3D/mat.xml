<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material">
  <material name="mechRaylCoeffs">
    <mechanical>
      <density>
        <linear>
          <real> 1 </real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <isotropic>
            <elasticityModulus>
              <real> 1 </real>
            </elasticityModulus>
            <poissonNumber>
              <real>0.1 </real>
            </poissonNumber>
          </isotropic>
        </linear>
      </elasticity>
      <damping>
        <rayleigh>
          <!-- tanDelta = 1.8 at 100Hz +-10Hz -->
          <coefficients>
            <alpha> 5.598318108697010e+02 </alpha>
            <beta> 0.001432394487827 </beta>
          </coefficients>
        </rayleigh>
      </damping>
    </mechanical>
  </material>
  <material name="mechRayl2Freq">
    <mechanical>
      <density>
        <linear>
          <real> 1 </real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <isotropic>
            <elasticityModulus>
              <real> 1 </real>
            </elasticityModulus>
            <poissonNumber>
              <real>0.1 </real>
            </poissonNumber>
          </isotropic>
        </linear>
      </elasticity>
      <damping>
        <rayleigh>
          <!-- alpha = 5.598318108697010e+02, beta = 0.001432394487827 -->
          <computeFromTwoPoints>
            <point1 frequency="90" lossTangensDelta="1.8"/>
            <point2 frequency="110" lossTangensDelta="1.8"/>
          </computeFromTwoPoints>
        </rayleigh>
      </damping>
    </mechanical>
  </material>
  <material name="mechRaylRatioDeltaF">
    <mechanical>
      <density>
        <linear>
          <real> 1 </real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <isotropic>
            <elasticityModulus>
              <real> 1 </real>
            </elasticityModulus>
            <poissonNumber>
              <real>0.1 </real>
            </poissonNumber>
          </isotropic>
        </linear>
      </elasticity>
      <damping>
        <rayleigh>
          <!-- alpha = 5.598318108697010e+02, beta = 0.001432394487827 -->
          <computeFromTanDeltaAtFrequency> 
            <centerFreq> 100 </centerFreq>
            <ratioDeltaF> 1e-1 </ratioDeltaF>
            <lossTangensDelta> 1.8 </lossTangensDelta>
          </computeFromTanDeltaAtFrequency>
        </rayleigh>
      </damping>
    </mechanical>
  </material>
</cfsMaterialDataBase>