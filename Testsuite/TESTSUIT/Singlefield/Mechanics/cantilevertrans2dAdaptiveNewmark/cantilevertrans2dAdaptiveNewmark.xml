<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation http://cfs-doc.mdmt.tuwien.ac.at/xml/CFS-Simulation/CFS.xsd">
  <documentation>
    <title>transient 2D cantilever with adaptive Newmark timestepping</title>
    <authors>
      <author>rdorninger</author>
    </authors>
    <date>2026-06-12</date>
    <keywords>
      <keyword>mechanic</keyword>
      <keyword>transient</keyword>
    </keywords>
    <references>
      based on cantilevertrans2d; Zienkiewicz/Xie 1991 LTE estimator
    </references>
    <isVerified>yes</isVerified>
    <description>
      Regression test for adaptive timestepping with the (default) Newmark scheme
      on MechPDE: force pulse on the cantilever tip, then free damped oscillation.
      PI controller, normalizedError norm, relativeTol/absoluteTol scaling with
      absoluteTol = relativeTol * tip amplitude (amplitude rule).
    </description>
  </documentation>

  <fileFormats>
    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="cantilev" material="silizium"/>
    </regionList>
    <nodeList>
      <nodes name="ux-dof"/>
      <nodes name="uy-dof"/>
      <nodes name="uy-load"/>
    </nodeList>
  </domain>

  <sequenceStep>
    <analysis>
      <transient>
        <numSteps>  100  </numSteps>
        <deltaT>   3e-06 </deltaT>
        <adaptiveTimeStepping>
          <deltaT min="3e-07" max="3e-05"/>
          <method>
            <normalizedError controller="PI" relTol="1e-3" absTol="4.4e-11"/>
          </method>
        </adaptiveTimeStepping>
      </transient>
    </analysis>

    <pdeList>
      <mechanic subType="planeStrain">
        <regionList>
          <region name="cantilev"/>
        </regionList>

        <dampingList>
          <rayleigh id="1"/>
        </dampingList>

        <bcsAndLoads>
          <fix name="ux-dof">
            <comp dof="x"/>
          </fix>
          <fix name="uy-dof">
            <comp dof="y"/>
          </fix>

          <!-- Force pulse excitation -->
          <force name="uy-load">
            <comp dof="y" value="(t  lt 7e-6)?4:0"/>
          </force>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
            <nodeList>
              <nodes name="uy-load"/>
            </nodeList>
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>

    <linearSystems>
      <system>
        <solverList>
          <directLU/>
        </solverList>
      </system>
    </linearSystems>

  </sequenceStep>
</cfsSimulation>
