<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../../share/xml/CFS-Simulation/CFS.xsd"
  xmlns="http://www.cfs++.org/simulation">
  <documentation>
    <title>VolumeAccelerationRhs3D</title>
    <authors>
      <author>pheidegger</author>
    </authors>
    <date>2025-05-02</date>
    <keywords>
      <keyword>mechanic</keyword>
      <keyword>nonmatching grids</keyword>
      <keyword>volumeSrc</keyword>
      <keyword>static</keyword>
    </keywords>
    <references></references>
    <isVerified>yes</isVerified>
    <description> Here we test the volume acceleration RHS in a 3D 2 brick elements connected by a Nitsche interface and connected to the ground. The acceleration is applied as a gravity in the positive x direction, which is the ground-normal direction. In this case, the normal stress on the ground surface should be $\sigma_n \approx - \rho g h$. In this example, $g=1$, $h=1$, and $\rho=1e10$. A dense and stiff material with a low Poisson ratio is chosen to reduce the effect of shear stresses, so that the solution follows the analytical approximation. </description>
  </documentation>
  <fileFormats>
    <input>
      <!-- <cdb fileName="brick.cdb"/> -->
      <hdf5 fileName="VolumeAccelerationRhs3D_NitscheNCI.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <text id="txt"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
  <domain geometryType="3d">
    <regionList>
      <region name="brick_1" material="myMaterial"/>
      <region name="brick_2" material="myMaterial"/>
    </regionList>
    <surfRegionList>
      <surfRegion name="ground"/>
      <surfRegion name="y_normal_1"/>
      <surfRegion name="z_normal_1"/>
      <surfRegion name="y_normal_2"/>
      <surfRegion name="z_normal_2"/>
      <surfRegion name="if_1"/>
      <surfRegion name="if_2"/>
    </surfRegionList>
    <ncInterfaceList>
      <ncInterface primarySide="if_1" secondarySide="if_2" name="nci_1"/>
    </ncInterfaceList>
  </domain>

  <fePolynomialList>
    <Legendre id="mechanicPolyId">
      <isoOrder>2</isoOrder>
    </Legendre>
  </fePolynomialList>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>
    <pdeList>
      <mechanic subType="3d">
        <regionList>
          <region name="brick_1" polyId="mechanicPolyId"/>
          <region name="brick_2" polyId="mechanicPolyId"/>
        </regionList>
        <ncInterfaceList>
          <ncInterface formulation="Nitsche" name="nci_1" nitscheFactor="1000"/>
        </ncInterfaceList>
        <bcsAndLoads>
          <fix name="ground">
            <comp dof="x"/>
          </fix>
          <fix name="y_normal_1">
            <comp dof="y"/>
            <comp dof="z"/>
          </fix>
          <fix name="y_normal_2">
            <comp dof="y"/>
            <comp dof="z"/>
          </fix>
          <fix name="z_normal_1">
            <comp dof="y"/>
            <comp dof="z"/>
          </fix>
          <fix name="z_normal_2">
            <comp dof="y"/>
            <comp dof="z"/>
          </fix>
          <volumeAcceleration name="brick_1">
            <comp dof="x" value="1"/>
            <comp dof="y" value="0"/>
            <comp dof="z" value="0"/>
          </volumeAcceleration>
          <volumeAcceleration name="brick_2">
            <comp dof="x" value="1"/>
            <comp dof="y" value="0"/>
            <comp dof="z" value="0"/>
          </volumeAcceleration>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <elemResult type="mechStress">
            <allRegions/>
          </elemResult>
          <surfElemResult type="mechNormalStress">
            <surfRegionList>
              <surfRegion name="ground"/>
            </surfRegionList>
          </surfElemResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>
</cfsSimulation>