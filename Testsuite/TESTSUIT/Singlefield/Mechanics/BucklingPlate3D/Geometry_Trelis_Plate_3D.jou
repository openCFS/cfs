Journal Off
reset
undo off


# Define mesh intervall
#{ELA = 2}
#{ELB = 8}
#{ELC = 9}

# Define platesize
#{a = 2}
#{b = 60}
#{l = 100}


# create volume
brick x {l} y {a} z {b}

# mesh volume
curve 1  interval {ELA}
curve 12  interval {ELB}
curve 2  interval {ELC}
curve 1 12 2  scheme equal
volume 1 scheme map
mesh curve 1 12 2
mesh volume 1

# define regions
block 1 add volume all
block 1 name "plate"
block 1 element type hex20

nodeset 1 add node all with x_coord={ l/2}
nodeset 1 add node all with x_coord={- l/2}
nodeset 1 name "BC_fix_xy"

nodeset 2 add node all with z_coord={ b/2}
nodeset 2 add node all with z_coord={-b/2}
nodeset 2 name "BC_fix_yz"

nodeset 3 add node all with x_coord={- l/2}
nodeset 3 name "BC_fix_xy_left"


nodeset 4 add node all with x_coord={l/2}
nodeset 4 name "reference_Load_x"


export ansys cdb "./mesh_quad.cdb"  overwrite 
export abaqus "./mesh_quad.inp"  partial overwrite  everything 



