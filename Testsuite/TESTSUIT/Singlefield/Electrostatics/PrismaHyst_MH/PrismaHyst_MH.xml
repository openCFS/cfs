                            <abortOnMaxNumIters>no</abortOnMaxNumIters>
                        </nonLinear>
                    </standard>
                </solutionStrategy>
                <solverList>
                    <pardiso id="pardiso"/>
                    <gmres>
                        <stoppingRule type="absNorm"/>
                        <tol>1e-16</tol>
                        <maxIter>20</maxIter>
                        <maxKrylovDim>5</maxKrylovDim>
                        <logging>yes</logging>
                        <consoleConvergence>no</consoleConvergence>
                    </gmres>
                </solverList>
                <precondList>
                    <SBMDiag>
