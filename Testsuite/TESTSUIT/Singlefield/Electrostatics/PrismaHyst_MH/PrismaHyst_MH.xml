    <linearSystems>
            <system>
                <solutionStrategy>
                    <standard>
                        <setup idbcHandling="elimination"/>
                        <matrix reordering="noReordering" storage="sparseNonSym" />
                        <nonLinear method="fixPoint">
                        <lineSearch type="none"/>
                            <incStopCrit>1e-3</incStopCrit>
                            <resStopCrit>1e-3</resStopCrit>
