<?xml version="1.0"?>


<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.cfs++.org/simulation 
/home/alex/Devel/CFS_SRC/CFS/share/xml/CFS-Simulation/CFS.xsd" >

<documentation>
  <title>Nonlinear Electrostatic</title>
  <authors>
      <author>apapst</author>
  </authors>
  <date>2021-02-10</date>
  <keywords>
    <keyword>electrostatic</keyword>
    <keyword>nonlinear</keyword>
  </keywords>
  <references></references>
  <isVerified>yes</isVerified>
  <description>
  On a prisma, a potential is applied on S_small and ground on S_large.
  The material shows hysteretic behaviour (JA-model).
  </description>
</documentation>

  <fileFormats>
    <input>
     <!-- <cdb fileName="mesh.cdb"/> -->
     <hdf5 fileName="PrismaHyst_MH.h5ref"/>
    </input>

    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <variableList>
      <var name="P" value="2*3.1415" />
      <var name="Step" value="200" />
    </variableList>
    <regionList>
      <region name="Vol" material="PZT-4"/>
    </regionList>
    <nodeList>
      <nodes name="S_large"/>
      <nodes name="S_small" />
    </nodeList>
  </domain>

 
<sequenceStep index="1">
    <analysis>
        <multiharmonic>
            <baseFreq>1</baseFreq>
            <numHarmonics_N>9</numHarmonics_N>
            <numFFTPoints>512</numFFTPoints>
            <fullSystem>true</fullSystem>
        </multiharmonic>
    </analysis>
    <pdeList>
      <electrostatic>        
        <regionList>
          <region name="Vol" nonLinIds="perm"/>
        </regionList>
        
        <nonLinList>
            <elecPermittivity id="perm" model="JilesAthertonModel"/>
        </nonLinList>   

        <bcsAndLoads>
          <ground name="S_large" />
          <potential name="S_small" value="1000000" harmonic="0"/>
          <potential name="S_small" value="800000" harmonic="1"/>
        </bcsAndLoads>
        
        <storeResults>
          <nodeResult type="elecPotential">
            <allRegions/>
          </nodeResult>
          
          <elemResult type="elecFieldIntensity">
            <allRegions/>
          </elemResult>
          
          <elemResult type="elecElemPermittivity">
            <allRegions/>
          </elemResult>
          
        </storeResults>
      </electrostatic>
    </pdeList>

    <linearSystems>
            <system>
                <solutionStrategy>
                    <standard>
                        <setup idbcHandling="elimination"/>
                        <matrix reordering="noReordering" storage="sparseNonSym" />
                        <nonLinear method="fixPoint">
                        <lineSearch type="multiharmonicIncreasing"/>
                            <incStopCrit>1e-3</incStopCrit>
                            <resStopCrit>1e-3</resStopCrit>
                            <maxNumIters>10</maxNumIters>
                            <abortOnMaxNumIters>no</abortOnMaxNumIters>
                        </nonLinear>
                    </standard>
                </solutionStrategy>
                <solverList>
                    <pardiso id="pardiso"/>
                    <gmres>
                        <stoppingRule type="absNorm"/>
                        <tol>1e-16</tol>
                        <maxIter>20</maxIter>
                        <maxKrylovDim>5</maxKrylovDim>
                        <logging>yes</logging>
                        <consoleConvergence>no</consoleConvergence>
                    </gmres>
                </solverList>
                <precondList>
                    <SBMDiag>
                        <precond block="1" id="def"/>
                        <precond block="2" id="def"/>
                        <precond block="3" id="def"/>
                        <precond block="4" id="def"/>
                        <precond block="5" id="def"/>
                        <precond block="6" id="def"/>
                        <precond block="7" id="def"/>
                        <precond block="8" id="def"/>
                        <precond block="9" id="def"/>
                        <precond block="10" id="def"/>
                        <precond block="11" id="def"/>
                        <precond block="12" id="def"/>
