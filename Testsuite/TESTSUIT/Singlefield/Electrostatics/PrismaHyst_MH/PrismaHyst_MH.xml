                        <precond block="37" id="def"/>
                        <precond block="38" id="def"/>
                        <precond block="39" id="def"/>
                    </SBMDiag>
                    <pardiso id="def"/>
                </precondList>
            </system>
        </linearSystems>
  </sequenceStep>

<sequenceStep index="2">
    <analysis>
        <multiharmonic>
            <baseFreq>1</baseFreq>
            <numHarmonics_N>9</numHarmonics_N>
