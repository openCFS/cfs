reset
#{ R = 0.1 }
#{ H = 1.0 }

# create geometry
brick x {H}
create sphere radius {R}

webcut volume 1 2 with plane xplane
delete volume 3 4
chop volume 1 with volume 2

imprint volume 5 6
merge volume 5 6

Trimesher surface gradation 2.4
Trimesher volume gradation 1.9

curve 31 scheme equal
curve 31 interval 50

surface 19 scheme trimesh geometry approximation angle 5
trimesher surface gradation 1
trimesher geometry sizing on
mesh surface 19
surface 22 scheme trimesh geometry approximation angle 5
trimesher surface gradation 1
trimesher geometry sizing on
mesh surface 22

volume 5 scheme tetmesh proximity layers off geometry approximation angle 3
volume 5 tetmesh growth_factor 2
mesh volume 5


curve 12 16 10 14 15 1 13 5   interval 10
curve 12 16 10 14 15 1 13 5   scheme equal
curve 18 17 20 19 interval 5
curve 18 17 20 19 interval 5
Trimesher surface gradation 1.4
Trimesher volume gradation 1.9
volume 6 scheme tetmesh proximity layers off geometry approximation angle 5
volume 6 tetmesh growth_factor 1.3
mesh volume 6

#define boundaries
block 1 add volume 6
block 1 name "extern"

block 2 add volume 5
block 2 name "intern"

block 1 element type tetra10
block 2 element type tetra10

nodeset 4 add surface 9 10 11 6 12 
nodeset 4 name "boundary_surrounding"

#export ansys cdb "sphere.cdb" overwrite








