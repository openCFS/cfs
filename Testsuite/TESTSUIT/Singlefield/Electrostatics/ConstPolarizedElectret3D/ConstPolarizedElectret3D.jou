reset
#{ L = 0.02 }
#{ H = 0.001 }
#{Hpol = 0.0003}

create brick x {L} y {H} z {L}
webcut volume 1 with plane yplane offset {-H/2+Hpol}

imprint volume 1 2
merge volume 1 2

curve 17 18 19 20  interval 2
curve 17 18 19 20  scheme equal
mesh curve 17 18 19 20

curve 25 26 27 28  interval 4
curve 25 26 27 28 scheme equal
mesh curve 25 26 27 28

curve 4 15 2 9 14 11 6 13 8 10 16 12 interval 20
curve 4 15 2 9 14 11 6 13 8 10 16 12 scheme equal
mesh curve 4 15 2 9 14 11 6 13 8 10 16 12

volume 2 1 scheme auto
mesh volume 2 1

block 1 add volume 2
block 1 name "Air"
block 1 element type hex4
 
block 2 add volume 1 
block 2 name "Mat_Polarized"
block 2 element type hex4

nodeset 3 add surface 3
nodeset 3 name "Electrode"

nodeset 4 add surface 7
nodeset 4 name "Edge_pol_mat"

nodeset 5 add surface 5
nodeset 5 name "Ground_surf"
