reset
#{ L = 0.03 }
#{ H = 0.001 }

create surface rectangle width {L} height {H} zplane

curve 1 3  interval 40
curve 2 4 interval 5
curve 1 2 3 4  scheme equal
mesh curve 1 2 3 4

mesh surface 1

block 1 add surface 1
block 1 name "polarized_mat"
block 1  element type quad8

nodeset 1 add curve 1 3
nodeset 1 name "ground_boundary"

nodeset 2 add curve 2 4
nodeset 2 name "side_boundary"



