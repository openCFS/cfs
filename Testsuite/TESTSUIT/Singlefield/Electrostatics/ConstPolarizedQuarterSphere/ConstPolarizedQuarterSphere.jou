reset
#{ R = 0.1 }
#{ H = 1.0 }

# create geometry
brick x {H}
create sphere radius {R}
chop volume 1 with volume 2

webcut volume 3 with plane xplane offset 0
webcut volume 4 with plane xplane offset 0
delete volume 5 6
webcut volume 3 with plane zplane offset 0
webcut volume 4 with plane zplane offset 0
delete volume 7 8
imprint volume 3 4
merge volume 3 4

curve 33 34 35 scheme equal
curve 33 34 35 interval 25
mesh curve 33 34 35 
surface 25 scheme trimesh geometry approximation angle 5
trimesher surface gradation 1
trimesher geometry sizing on
mesh surface 25
surface 26 scheme trimesh geometry approximation angle 5
trimesher surface gradation 1
trimesher geometry sizing on
mesh surface 26
surface 27 scheme trimesh geometry approximation angle 5
trimesher surface gradation 1
trimesher geometry sizing on
mesh surface 27
volume 3 scheme tetmesh proximity layers off geometry approximation angle 3
volume 3 tetmesh growth_factor 2
mesh volume 3

curve 20 49 50 45 47 21 43 46  scheme equal
curve 20 49 50 45 47 21 43 46  interval 5
curve 18 1 44   scheme equal
curve 18 1 44   interval 10
mesh curve 20 49 50 45 47 21 43 46 18 1 44

Trimesher surface gradation 1.4
Trimesher volume gradation 1.9
volume 4 scheme tetmesh proximity layers off geometry approximation angle 3
volume 4 tetmesh growth_factor 2
mesh volume 4



#define boundaries
block 1 add volume 4
block 1 name "extern"

block 2 add volume 3
block 2 name "intern"

nodeset 1 add surface 35 15 36 32 31 25 
nodeset 1 name "boundary_surrounding"

block 1 element type tetra10
block 2 element type tetra10


#export ansys cdb "sphere_quarter.cdb" overwrite