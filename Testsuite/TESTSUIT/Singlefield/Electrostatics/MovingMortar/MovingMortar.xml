<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../../share/xml/CFS-Simulation/CFS.xsd"
  xmlns="http://www.cfs++.org/simulation">
  <documentation>
    <title>MovingMortar</title>
    <authors>
      <author>?</author>
      <author>pheidegger</author>
    </authors>
    <date>2024-06-05</date>
    <keywords>
      <keyword>electrostatic</keyword>
      <keyword>mortar fem</keyword>
      <keyword>nonmatching grids</keyword>
      <keyword>dual LM</keyword>
    </keywords>
    <references></references>
    <isVerified>no</isVerified>
    <description>
      A simple electrostatic problem with a moving mortar interface. The top region is grounded, the bottom region has a potential of 1.
      The bottom interface is moving with a velocity of -t in x-direction.
      The example also tests forcing the coordinates of the y axis to be 1 by the tag forceYValue="1".
    </description>
  </documentation>
  <fileFormats>
    <input>
      <hdf5 fileName="MovingMortar.h5"/>
    </input>
    <output>
      <hdf5 compressionLevel="9"></hdf5>
    </output>
    <materialData file="mat.xml" format="xml"></materialData>
  </fileFormats>
  
  <domain geometryType="plane">
    <regionList>
      <region name="top" material="air"></region>
      <region name="bottom" material="air"></region>
    </regionList>
    
    <surfRegionList>
      <surfRegion name="elec_top"></surfRegion>
      <surfRegion name="elec_bottom"></surfRegion>
      <surfRegion name="iface_top"></surfRegion>
      <surfRegion name="iface_bottom"></surfRegion>
    </surfRegionList>
    
    <ncInterfaceList>
      <ncInterface name="iface" primarySide="iface_top" secondarySide="iface_bottom" storeIntegrationGrid="yes" forceYValue="1">
        <generalMotion displace1="-t" displace2="0" movingSide="secondary"></generalMotion>
      </ncInterface>
    </ncInterfaceList> 
  </domain>
  
  <sequenceStep>
    <analysis>
      <transient>
        <numSteps>42</numSteps>
        <deltaT>1.0/42</deltaT>
      </transient>
    </analysis>
    
    <pdeList>
      <electrostatic>
        <regionList>
          <region name="top"></region>
          <region name="bottom"></region>
        </regionList>
        
        <ncInterfaceList>
          <ncInterface name="iface"></ncInterface>
        </ncInterfaceList>
        
        <bcsAndLoads>
          <ground name="elec_bottom"></ground>
          <potential name="elec_top" value="1"></potential>
        </bcsAndLoads>
        
        <storeResults>
          <nodeResult type="elecPotential">
            <allRegions postProcId="bla"></allRegions>
          </nodeResult>
          <elemResult type="elecFieldIntensity">
            <allRegions></allRegions>
          </elemResult>
        </storeResults>
      </electrostatic>
    </pdeList>
    
    <postProcList>
      <postProc id="bla">
        <function resultName="meshDisplacement" outputIds="hdf5" writeResult="yes">
          <inputResult variableName="u"/>
          <vector>
            <comp dof="x" realFunc="-t"/>
            <comp dof="y" realFunc="0"/>
          </vector>
        </function>
      </postProc>
    </postProcList>
    
    <linearSystems>
      <system>
        <solutionStrategy>
          <standard>
            <matrix reordering="noReordering" storage="sparseNonSym"></matrix>
          </standard>
        </solutionStrategy>
        <solverList>
          <pardiso>
            <posDef>no</posDef>
            <symStruct>no</symStruct>
            <IterRefineSteps>10</IterRefineSteps>
          </pardiso>
        </solverList>
      </system>
    </linearSystems>
  </sequenceStep>
</cfsSimulation>
