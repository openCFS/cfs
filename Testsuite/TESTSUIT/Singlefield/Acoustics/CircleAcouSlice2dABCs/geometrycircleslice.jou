undo on 
reset

# Mesh description 2 circels, 1 ring surfaces, slices 
# define several sections for acoustic propagation in radial direction

## Sizing the mesh
# speed of sound in air ca. 330m/s
# speed of soud in water ca. 1481m/2

# f = 10 kHz, lambda = c/ f
# lambda in air   : 0.033 m 
# lambda in water : 0.14
# 

### Inner solid ring
#{ r1 = 0.20  }
#{ r2 = 0.25  }

# outer boundary fluid ring
# { r3 = 1.0 }


# Note Gridsize dgx, dgy ... should be lambda / 10 ... lambda / 20
#{ radsec1   = 10 }
#{ radsec2   = 60 }
#{ dgphi1 = 0.125 /8 }
#{ dgphi2 = 0.15625 / 8}
#{ dgphi3 = 0.625 / 32 }

#{ nphi1 = 16 }
#{ nphi2 = 16 }
#{ nphi3 = nphi2 * 1 }

# Slice beta1, beta2, Angles for slice cut around xpos direction

#{ beta1 =  10 }
#{ beta2 = 350 }


## Vertices on ring inner side 
create curve arc vertex   radius { r1 } normal 0 0 1  

## Vertices on ring outer side
create curve arc vertex   radius { r2 } normal 0 0 1  

## Vertices on fluid outer side
create curve arc vertex   radius { r3 } normal 0 0 1  

## vertices on inner side ring
create vertex { r1 }    0      0 on curve 1
create vertex 0       { r1 }   0 on curve 1
create vertex { -r1 }   0      0 on curve 1
create vertex  0     { -r1 }   0 on curve 1

create vertex { r2 }    0       0 on curve 2 
create vertex 0       { r2 }    0 on curve 2
create vertex { -r2 }   0       0 on curve 2
create vertex 0      { -r2 }    0 on curve 2

create vertex { r3 }    0       0 on curve 3
create vertex 0       { r3 }    0 on curve 3 
create vertex { -r3 }   0       0 on curve 3
create vertex 0      { -r3 }    0 on curve 3


#


#########################
# mesh curves

# mesh curve 1
# mesh curve 2
# mesh curve 3



##########################
# create ring surfaces from circles

### inner solid ring
create surface 1 2 


### outer fluid ring
create surface 2 3

#############################
# Decompose for slice

# separate 1 2

# webcut body 1 2 with general plane yz

# webcut body 1 2 with plane xplane rotate 15 about z

webcut body 1 2 with plane yplane rotate {beta1 } about z
webcut body 1 2 with plane yplane rotate {beta2 } about z


delete body 1
delete body 2
delete body 3
delete body 4

delete vertex 5 6 7 9 10 11 13 14 15


#############################
# outer ring meshing scheme radial

# surface  8 scheme hole rad_intervals { radsec1 }
# surface 10 scheme hole rad_intervals { radsec2 }


## meshing scheme radial 

# inner ring radial
curve 5 24 interval { radsec1 }

# outer ring radial
curve 13 30 interval { radsec2 }


## meshing scheme arc with gridpoint number control 
curve 26 interval { nphi1 }
# curve 1 scheme interval

curve 25 interval { nphi2 }
# curve 32 scheme interval

curve 31 interval { nphi3 }
# curve 3 scheme interval

#############################
# remove inner ring with sold

delete volume 5



#############################
#imprint and merge
# imprint all
merge all




########################
# mesh surface 8
mesh surface 10



#########################
# Assign names for simulation


block 2 add surface 10 
block 2 name "S_fluid"


nodeset 2 add curve 32  
nodeset 2 name "L_excite"

nodeset 3 add curve 31  
nodeset 3 name "L_ABC"


nodeset 4 add vertex 4
nodeset 4 name "P1_xpos"

nodeset 5 add vertex 8
nodeset 5 name "P2_xpos"

nodeset 6 add vertex 12
nodeset 6 name "P3_xpos"


nodeset 7 add curve 13
nodeset 7 name "L_rad2_p"


nodeset 8 add curve 30
nodeset 8 name "L_rad2_m"



##########################
# Define elements

block 2  element type quad8


# write mesh
export ansys cdb "./geometry.cdb"  overwrite
save cub5 "./geometry.cub5" overwrite journal




