<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title>bloch periodic boundary condition for acoustic pressure</title>
        <authors>
            <author>Felix Huber</author>
        </authors>
        <date>2026-04-22</date>
        <description>Tests the Mortar type implementation of blochPeriodic boundary condition for acoustic pressure.
            Waveguide with angled planar wave, invisible excitation with PMLs on both ends.</description>
    </documentation>

    <fileFormats>
        <!-- create_mesh_acou.py -lin 0.04 -labh 0.06 -win 0.05 -wabh 0.05 -wout 0.05 -tpml 0.002 -o bloch_periodic.mesh 10 -->
        <output>
            <hdf5 />
            <info id="info"/>
        </output>
        <materialData file="mat.xml"/>
    </fileFormats>

    <domain geometryType="plane">
        <variableList>
            <var name="ang" value="10" />
            <!-- width of the periodic waveguide -->
            <var name="win" value="0.05" />
            <!-- taken from .info.xml -->
            <var name="c0" value="343.42422648314749" />
            <!-- k / f, because we cant use f in a variable -->
            <var name="kperf" value="2 * pi / c0" />
        </variableList>
        <regionList>
            <region name="S_acou" material="air"/>
            <region name="S_opt" material="air"/>
            <region material="air" name="S_pml_in" />
            <region material="air" name="S_pml_out" />
        </regionList>
        <ncInterfaceList>
            <ncInterface name="NC_pbc_in"  primarySide="L_top_in_surf" secondarySide="L_axi_in_surf" mutualProjection="yes"/>
            <ncInterface name="NC_pbc_abh"  primarySide="L_top_abh_surf" secondarySide="L_axi_abh_surf" mutualProjection="yes"/>
        </ncInterfaceList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <harmonic>
                <numFreq>1</numFreq>
                <startFreq>5000</startFreq>
                <stopFreq>5000</stopFreq>
                <sampling>linear</sampling>
            </harmonic>
        </analysis>
        <pdeList>
            <acoustic formulation="acouPressure">
                <regionList>
                    <region name="S_acou" complexFluid="yes"/>
                    <region name="S_opt" complexFluid="yes"/>
                    <region name="S_pml_in" dampingId="pml"/>
                    <region name="S_pml_out" dampingId="pml"/>
                </regionList>
                <dampingList>
                    <pml  id="pml">
                        <type> inverseDist </type>
                        <dampFactor> 1 </dampFactor>
                    </pml>
                </dampingList>
                <bcsAndLoads>
                    <normalVelocity name="L_in_surf" value="1" phase="360*f/c0*x*sin(pi/180*ang)" />
                    <!-- periodic only works for angles where the pressures on both boundaries are in phase-->
                    <!-- ang = asin(n * c0 / f / win) / pi * 180 =    in deg (does not work for large wavelengths-->
                    <!--<periodic primary="L_axi" secondary="L_top" quantity="acouPressure" />-->
                    <blochPeriodic factor_value="1.0" factor_phase="kperf * f * win * sin(pi/180*ang)" formulation="Mortar" >
                        <region name="NC_pbc_in" />
                        <region name="NC_pbc_abh" />
                    </blochPeriodic>
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="acouPressure">
                        <allRegions/>
                    </nodeResult>
                </storeResults>
            </acoustic>
        </pdeList>
    </sequenceStep>
</cfsSimulation>
