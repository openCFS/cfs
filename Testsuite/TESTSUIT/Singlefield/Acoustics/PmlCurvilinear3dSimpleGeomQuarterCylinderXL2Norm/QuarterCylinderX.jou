# cubit file that creates a quarter of a cylinder with a hole (cylinder's z axis in x)
reset

#{meshSize = 0.1};    # meh size
#{r = 1};             # radius of the cylinder
#{ri = 0.5};          # radius of the source
#{h = 0.1};           # height of the cylinder

# create body
create Cylinder height {h} radius {r}
create Cylinder height {h} radius {ri}

# subtract to obtain outer layer
subtract body 2 from body 1

# do webcut
create surface rectangle width {2*r} xplane
create surface rectangle width {2*r} yplane
webcut volume 1  with sheet body 3
webcut volume 1  with sheet body 4

# delete unnecessary bodys
delete volume 3 4 5 6

# mesh
volume 1 size {meshSize}
mesh volume 1

# move to offset
move volume all x 0.456395 y 1.394827 z -0.384756

# set blocks
block 1 add volume 1
block 1 name "prop"

# set nodesets
nodeset 1 add surface 28
nodeset 1 name "src"
nodeset 2 add surface 26
nodeset 2 name "ifPML"

# rotate
rotate Volume 1 angle 90 about Y
rotate Volume 1 angle 90 about X

# save mesh
export ansys cdb "./PmlCurvilinear3dSimpleGeomQuarterCylinderXL2Norm.cdb" overwrite
