undo on
reset

#============================================================
# =============== Parameter definition ===============================
#============================================================

#{ wlength= 0.145902450773947 }

#{ h_init= 0.05 }
#{ num_h= 2+1 }	# number of element sizes including the initial one

#{ l_init= 4*wlength}
#{ num_l= 3+1 }	# number of duct lengths including the initial one

#============================================================

#{ i_l= 4 }
#{ i_h= 3 }

#{ elSize= h_init /(2^i_h)}
#{L=l_init /(2^i_l)}
#{W=elSize }

brick x {W} y {W} z {L}
move volume all x {L/2}  include_merged

volume all size {elSize}
mesh volume all

#===================================
# Nodeset definition

nodeset 1 add surface 2
nodeset 1 name "bc_left"

nodeset 2 add surface 1
nodeset 2 name "bc_right"

#===================================
# Block definition

block 1 add volume 1
block 1 name "eqFluid"

export ansys cdb "TDEFwNRBC3D.cdb" overwrite












