<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../../share/xml/CFS-Simulation/CFS.xsd" xmlns="http://www.cfs++.org/simulation">

	<documentation>
		<title>Acoustic</title>
		<authors>
			<author>awurzinger</author>
		</authors>
		<date>2023-11-23</date>
		<keywords>
			<keyword>acoustic</keyword>
		</keywords>
		<references></references>
		<isVerified>yes</isVerified>
		<description>
			Plane wave propagation in 1D harmonic setup with convection velocity read from grid
		</description>
	</documentation>
	<fileFormats>
		<input>
			<hdf5 fileName="PlaneWave2DConvectionReadGrid.h5ref" />
		</input>
		<output>
			<hdf5 />
		</output>
		<materialData file="mat.xml" format="xml" />
	</fileFormats>

	<domain geometryType="plane">
		<regionList>
			<region name="S_flow" material="FluidMat" />
		</regionList>
	</domain>

	<sequenceStep index="1">
		<analysis>
			<harmonic>
				<frequencyList>
					<freq value="1" />
				</frequencyList>
			</harmonic>
		</analysis>
		<pdeList>
			<acoustic formulation="acouPressure" flowFormulation="withDivergence">
				<regionList>
					<region name="S_flow" flowId="myFlow" /><!---->
				</regionList>

				<flowList>
					<flow name="myFlow">
						<grid>
							<defaultGrid dependtype="SPACE" quantity="meanFluidMechVelocity" definedOn="node" sequenceStep="1" />
						</grid>
					</flow>
				</flowList>
				<bcsAndLoads>
					<pressure name="L_left" value="1.0" />
				</bcsAndLoads>
				<storeResults>
					<nodeResult type="acouPressure">
						<allRegions />
					</nodeResult>
					<nodeResult type="meanFluidMechVelocity">
						<allRegions />
					</nodeResult>
				</storeResults>
			</acoustic>
		</pdeList>
	</sequenceStep>

</cfsSimulation>
