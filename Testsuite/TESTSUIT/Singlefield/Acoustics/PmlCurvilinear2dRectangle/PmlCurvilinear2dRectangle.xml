<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../../share/xml/CFS-Simulation/CFS.xsd"
  xmlns="http://www.cfs++.org/simulation">

  <documentation>
    <title>PmlCurvilinear2dRectangle</title>
    <authors>
      <author>ChrisObenaus13</author>
    </authors>
    <date>2025-03-04</date>
    <keywords>
      <keyword>acoustic</keyword>
      <keyword>pml</keyword>
      <keyword>harmonic</keyword>
      <keyword>output</keyword>
    </keywords>
    <references></references>
    <isVerified>yes</isVerified>
    <description> 2D PML test with curvilinear coordinates and a rectangle as geometry. Geometry approximation with "plane" type. </description>
  </documentation>

  <!--***************************    INPUTs and OUTPUTs    ***********************-->
  <fileFormats>
    <input>
      <cdb fileName="PmlCurvilinear2dRectangle.cdb"/>
    </input>
    <output>
      <hdf5 id="h5"/>
      <text id="txt"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <!--***************************  REGIONSs, SURFACEs and NODEs  ***********************-->
  <domain geometryType="plane">
    <variableList>
      <var name="c" value="1"/>
      <var name="x0" value="0.0"/>
      <var name="y0" value="0.0"/>
      <var name="z0" value="0.0"/>
    </variableList>
    <regionList>
      <region name="rectangle" material="fakefluid"/>
      <region name="PML_top" material="fakefluid"/>
      <region name="PML_left" material="fakefluid"/>
      <region name="PML_bottom" material="fakefluid"/>
      <region name="PML_right" material="fakefluid"/>
    </regionList>
    <surfRegionList>
      <surfRegion name="top"/>
      <surfRegion name="left"/>
      <surfRegion name="bottom"/>
      <surfRegion name="right"/>
    </surfRegionList>
    <layerGenerationList>
      <newRegion name="PML_top">
        <sourceSurfRegion name="top"/>
        <extrusionParameters elemHeight="0.03" numLayers="4"/>
        <surfGeometry>
          <analyticApproximation>
            <plane normalDirection="y"/>
          </analyticApproximation>
        </surfGeometry>
      </newRegion>
      <newRegion name="PML_left">
        <sourceSurfRegion name="left"/>
        <extrusionParameters elemHeight="0.03" numLayers="4"/>
        <surfGeometry>
          <analyticApproximation>
            <plane normalDirection="x"/>
          </analyticApproximation>
        </surfGeometry>
      </newRegion>
      <newRegion name="PML_bottom">
        <sourceSurfRegion name="bottom"/>
        <extrusionParameters elemHeight="0.03" numLayers="4"/>
        <surfGeometry>
          <analyticApproximation>
            <plane normalDirection="y"/>
          </analyticApproximation>
        </surfGeometry>
      </newRegion>
      <newRegion name="PML_right">
        <sourceSurfRegion name="right"/>
        <extrusionParameters elemHeight="0.03" numLayers="4"/>
        <surfGeometry>
          <analyticApproximation>
            <plane normalDirection="x"/>
          </analyticApproximation>
        </surfGeometry>
      </newRegion>
    </layerGenerationList>
  </domain>

  <!--***************************  ANALYSIS  ***********************-->
  <sequenceStep index="1">
    <analysis>
      <harmonic>
        <frequencyList>
          <freq value="0.1"/>
        </frequencyList>
      </harmonic>
    </analysis>
    <!--***************************  PDE LISTs  ***********************-->
    <pdeList>
      <acoustic formulation="acouPressure">
        <regionList>
          <region name="rectangle"/>
          <region name="PML_top" dampingId="PMLdamp"/>
          <region name="PML_left" dampingId="PMLdamp"/>
          <region name="PML_bottom" dampingId="PMLdamp"/>
          <region name="PML_right" dampingId="PMLdamp"/>
        </regionList>
        <dampingList>
          <pml id="PMLdamp" formulation="curvilinear">
            <type> inverseDist </type>
            <dampFactor> 1.0 </dampFactor>
          </pml>
        </dampingList>
        <!-- ************************************************************ BCS / SOURCES ****************************************************** -->
        <bcsAndLoads>
          <pressure name="top" value="1.0"/>
          <pressure name="left" value="1.0"/>
          <pressure name="bottom" value="1.0"/>
          <pressure name="right" value="1.0"/>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions outputIds="h5"/>
          </nodeResult>
          <elemResult type="pmlDampFactor">
            <regionList>
              <region name="PML_top" outputIds="h5"/>
            </regionList>
          </elemResult>
          <elemResult type="pmlTensor">
            <regionList>
              <region name="PML_top" outputIds="h5"/>
            </regionList>
          </elemResult>
          <elemResult type="pmlDeterminant">
            <regionList>
              <region name="PML_top" outputIds="h5"/>
            </regionList>
          </elemResult>
          <elemResult type="pmlDistance">
            <regionList>
              <region name="PML_top" outputIds="h5"/>
            </regionList>
          </elemResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
</cfsSimulation>