# cubit file that creates a rectangle
reset

# set variables
#{meshSize = 0.05};  # mesh size
#{width = 1.0};
#{height = 0.2};

# create body
create surface rectangle width {width} height {height} zplane

# mesh
surface 1 size {meshSize}
mesh surface 1

# set blocks
block 1 add surface 1
block 1 name "rectangle"

# set nodesets
nodeset 1 add curve 1
nodeset 1 name "top"
nodeset 2 add curve 2
nodeset 2 name "left"
nodeset 3 add curve 3
nodeset 3 name "bottom"
nodeset 4 add curve 4
nodeset 4 name "right"

# save mesh
export ansys cdb "./PmlCurvilinear2dRectangle.cdb" overwrite





