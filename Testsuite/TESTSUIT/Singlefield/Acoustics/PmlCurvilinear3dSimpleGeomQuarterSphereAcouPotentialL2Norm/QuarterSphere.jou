# cubit file that creates a quarter of a sphere with a hole
reset

#{meshSize = 0.4};    # mesh size
#{r = 1};             # sphere radius
#{ri = 0.5};          # source radius

# create body
create sphere radius {r}
create sphere radius {ri}
subtract body 2 from body 1 

# do webcut
create surface rectangle width {2*r} xplane
create surface rectangle width {2*r} yplane
create surface rectangle width {2*r} zplane
webcut volume 3  with sheet body 3
webcut volume 3  with sheet body 4
webcut volume 3  with sheet body 5

# delete unnecessary bodys
delete volume 7 8 9
delete body 3 4 5

# move sphere
move volume 3 x 0.456395 y 1.394827 z -0.384756 include_merged

# mesh
volume 3 size {meshSize}
volume 3 scheme tetmesh
mesh volume 3

# set blocks
block 1 add volume 3
block 1 name "prop"

# set nodesets
nodeset 1 add surface 23
nodeset 1 name "src"
nodeset 2 add surface 25
nodeset 2 name "ifPML"

# save mesh
export ansys cdb "./PmlCurvilinear3dSimpleGeomQuarterSphereAcouPotentialL2Norm.cdb" overwrite



