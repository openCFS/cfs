# cubit file that creates a cross of rectangles in x, y, and z.
reset

#{meshSize = 0.05};     # mesh size
#{l = 0.5};             # length of the tubes
#{b = 2*meshSize};      # width of the tubes
#{h = 2*meshSize};      # height of the tubes

# create body
create brick x {l} y {b} z {h}
create brick x {b} y {l} z {h}
create brick x {b} y {h} z {l}
unite volume all

# mesh
volume all size {meshSize}
mesh volume 1

# set blocks
block 1 add volume 1
block 1 name "prop"

# set nodesets
nodeset 1 add surface 4
nodeset 1 name "ifPML-x"
nodeset 2 add surface 6
nodeset 2 name "ifPML+x"
nodeset 3 add surface 9
nodeset 3 name "ifPML-y"
nodeset 4 add surface 11
nodeset 4 name "ifPML+y"
nodeset 5 add surface 13
nodeset 5 name "ifPML+z"
nodeset 6 add surface 14
nodeset 6 name "ifPML-z"

# save mesh
export ansys cdb "PmlCurvilinear3dSimpleGeomPlaneXYZ.cdb" overwrite
