<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../share/xml/CFS-Simulation/CFS.xsd"
  xmlns="http://www.cfs++.org/simulation">

  <documentation>
    <title> Rayleigh Damping 3D </title>
    <authors>
      <author>Patrick Heidegger</author>
    </authors>
    <date>2024-12-03</date>
    <keywords>
      <keyword>rayleigh damping</keyword>
      <keyword>acoustic</keyword>
    </keywords>
    <references>
      no references, only functionality test
    </references>
    <isVerified>yes</isVerified>
    <description>
      This is a simple functionality test for the frequency-adapted loss tan delta damping.
    </description>
  </documentation>

  <fileFormats>
    <input>
      <!-- <cdb fileName="AdaptedLossTanDelta3D.cdb"/> -->
      <hdf5 fileName="AdaptedLossTanDelta3D.h5ref"/>
    </input>
    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <variableList>
      <var name="freq" value="100"/>
      <var name="freqLow" value="50"/>
    </variableList>
    <regionList>
      <region name="domain1" material="acouTanDeltaConst"/>
      <region name="domain2" material="acouTanDeltaFile"/>
    </regionList>

    <surfRegionList>
      <surfRegion name="src1"/>
      <surfRegion name="src2"/>
    </surfRegionList>
  </domain>
  <!-- constant damping -->
  <sequenceStep index="1">
    <analysis>
      <harmonic>
        <numFreq> 2 </numFreq>
        <startFreq> freqLow </startFreq>
        <stopFreq> freq </stopFreq>
        <sampling> linear </sampling>
      </harmonic>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain1" dampingId="adaptedLoss"/>
        </regionList>
        <dampingList>
          <adaptedLossTangensDelta id="adaptedLoss"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src1" value="1.0"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
  <!-- frequency dependent damping -->
  <sequenceStep index="2">
    <analysis>
      <harmonic>
        <numFreq> 2 </numFreq>
        <startFreq> freqLow </startFreq>
        <stopFreq> freq </stopFreq>
        <sampling> linear </sampling>
      </harmonic>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain2" dampingId="adaptedLoss"/>
        </regionList>
        <dampingList>
          <adaptedLossTangensDelta id="adaptedLoss"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src2" value="1.0"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
</cfsSimulation>