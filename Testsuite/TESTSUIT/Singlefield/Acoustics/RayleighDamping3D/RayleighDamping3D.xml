<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
               xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../share/xml/CFS-Simulation/CFS.xsd"
               xmlns="http://www.cfs++.org/simulation">

  <documentation>
    <title> Rayleigh Damping 3D </title>
    <authors>
      <author>Patrick Heidegger</author>
    </authors>
    <date>2024-12-03</date>
    <keywords>
      <keyword>rayleigh damping</keyword>
      <keyword>acoustic</keyword>
    </keywords>
    <references>
      no references, only functionality test
    </references>
    <isVerified>yes</isVerified>
    <description>
      This is a simple functionality test for the Rayleigh damping in 3D.
    </description>
  </documentation>

  <fileFormats>
    <input>
      <!-- <cdb fileName="RayleighDamping3D.cdb"/> -->
      <hdf5 fileName="RayleighDamping3D.h5ref"/>
    </input>
    <output>
      <hdf5/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <variableList>
      <var name="freq" value="100"/>
      <var name="freqLow" value="50"/>
      <var name="nT" value="20"/>
      <var name="dT" value="5e-4"/>
    </variableList>
    <regionList>
      <region name="domain1" material="acouRaylCoeffs"/>
      <region name="domain2" material="acouRayl2Freq"/>
      <region name="domain3" material="acouRaylRatioDeltaF"/>
    </regionList>

    <surfRegionList>
      <surfRegion name="src1"/>
      <surfRegion name="src2"/>
      <surfRegion name="src3"/>
    </surfRegionList>
  </domain>
  <!-- time domain, coefficients-->
  <sequenceStep index="1">
    <analysis>
      <transient>
        <numSteps>nT</numSteps>
        <deltaT>dT</deltaT>
      </transient>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain1" dampingId="rayl"/>
        </regionList>
        <dampingList>
          <rayleigh id="rayl"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src1" value="1.0*sin(2.0*pi*freq*t)"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
  <!-- time domain, 2 point-->
  <sequenceStep index="2">
    <analysis>
      <transient>
        <numSteps>nT</numSteps>
        <deltaT>dT</deltaT>
      </transient>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain2" dampingId="rayl"/>
        </regionList>
        <dampingList>
          <rayleigh id="rayl"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src2" value="1.0*sin(2.0*pi*freq*t)"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
  <!-- time domain, single point-->
  <sequenceStep index="3">
    <analysis>
      <transient>
        <numSteps>nT</numSteps>
        <deltaT>dT</deltaT>
      </transient>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain3" dampingId="rayl"/>
        </regionList>
        <dampingList>
          <rayleigh id="rayl"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src3" value="1.0*sin(2.0*pi*freq*t)"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
  <!-- freq domain, coefficients-->
  <sequenceStep index="4">
    <analysis>
      <harmonic>
        <numFreq> 2 </numFreq>
        <startFreq> freqLow </startFreq>
        <stopFreq> freq </stopFreq>
        <sampling> linear </sampling>
      </harmonic>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain1" dampingId="rayl"/>
        </regionList>
        <dampingList>
          <rayleigh id="rayl"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src1" value="1.0"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
  <!-- freq domain, 2 points-->
  <sequenceStep index="5">
    <analysis>
      <harmonic>
        <numFreq> 2 </numFreq>
        <startFreq> freqLow </startFreq>
        <stopFreq> freq </stopFreq>
        <sampling> linear </sampling>
      </harmonic>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain2" dampingId="rayl"/>
        </regionList>
        <dampingList>
          <rayleigh id="rayl"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src2" value="1.0"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
  <!-- freq domain, single point-->
  <sequenceStep index="6">
    <analysis>
      <harmonic>
        <numFreq> 2 </numFreq>
        <startFreq> freqLow </startFreq>
        <stopFreq> freq </stopFreq>
        <sampling> linear </sampling>
      </harmonic>
    </analysis>
    <pdeList>
      <acoustic>
        <regionList>
          <region name="domain3" dampingId="rayl"/>
        </regionList>
        <dampingList>
          <rayleigh id="rayl"/>
        </dampingList>
        <bcsAndLoads>
          <pressure name="src3" value="1.0"/>
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
</cfsSimulation>