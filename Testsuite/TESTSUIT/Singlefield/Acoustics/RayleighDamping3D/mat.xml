<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material">
  <material name="acouRaylCoeffs">
    <acoustic>
      <density>
        <linear>
          <real> 1 </real>
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real> 1 </real>
        </linear>
      </compressionModulus>
      <damping>
        <rayleigh>
          <!-- <computeFromTwoPoints>
            <point1 frequency="90" lossTangensDelta="1.8"/>
            <point2 frequency="110" lossTangensDelta="1.8"/>
          </computeFromTwoPoints> -->
          <!-- tanDelta = 1.8 at 100Hz +-10Hz -->
          <coefficients>
            <alpha> 5.598318108697010e+02 </alpha>
            <beta> 0.001432394487827 </beta>
          </coefficients>
        </rayleigh>
      </damping>
    </acoustic>
  </material>
  <material name="acouRayl2Freq">
    <acoustic>
      <density>
        <linear>
          <real> 1 </real>
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real> 1 </real>
        </linear>
      </compressionModulus>
      <damping>
        <rayleigh>
          <!-- <coefficients>
            <alpha> 5.598318108697010e+02 </alpha>
            <beta> 0.001432394487827 </beta>
          </coefficients> -->
          <!-- alpha = 5.598318108697010e+02, beta = 0.001432394487827 -->
          <computeFromTwoPoints>
            <point1 frequency="90" lossTangensDelta="1.8"/>
            <point2 frequency="110" lossTangensDelta="1.8"/>
          </computeFromTwoPoints>
        </rayleigh>
      </damping>
    </acoustic>
  </material>
  <material name="acouRaylRatioDeltaF">
    <acoustic>
      <density>
        <linear>
          <real> 1 </real>
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real> 1 </real>
        </linear>
      </compressionModulus>
      <damping>
        <rayleigh>
          <!-- <coefficients>
            <alpha> 5.598318108697010e+02 </alpha>
            <beta> 0.001432394487827 </beta>
          </coefficients> -->
          <!-- alpha = 5.598318108697010e+02, beta = 0.001432394487827 -->
          <computeFromTanDeltaAtFrequency> 
            <centerFreq> 100 </centerFreq>
            <ratioDeltaF> 1e-1 </ratioDeltaF>
            <lossTangensDelta> 1.8 </lossTangensDelta>
          </computeFromTanDeltaAtFrequency>
        </rayleigh>
      </damping>
    </acoustic>
  </material>
</cfsMaterialDataBase>