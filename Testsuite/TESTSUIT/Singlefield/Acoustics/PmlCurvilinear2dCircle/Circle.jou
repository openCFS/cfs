# cubit file that creates an ring
reset

# set variables
#{meshSize = 0.1};  # mesh size
#{ro = 1.0};        # larger ellipsoid radius
#{ri = ro*1/4};     # smaller ellipsoid radius

# create body
create surface circle radius {ro} zplane
create surface circle radius {ri} zplane
subtract surface 2 from surface 1
move Curve 1 location 0.4 0.3 0

# mesh
surface 3 scheme hole rad_intervals 7
surface 3 size {meshSize}
mesh surface 3

# set blocks
block 1 add surface 3
block 1 name "ring"

# set nodesets
nodeset 1 add curve 3
nodeset 1 name "src"
nodeset 2 add curve 1
nodeset 2 name "ifPML"

# save mesh
export ansys cdb "./PmlCurvilinear2dCircle.cdb" overwrite

