<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
               xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../../share/xml/CFS-Simulation/CFS.xsd"
               xmlns="http://www.cfs++.org/simulation">
  <documentation>
    <title> Plane wave in three channels connected by Nitsche interfaces, where one is shifted by some degree to produce small intersection elements</title>
    <authors>
      <author>Patrick Heidegger</author>
    </authors>
    <date>2024-06-08</date>
    <keywords>
      <keyword>acoustic</keyword>
      <keyword>intersection operations</keyword>
      <keyword>mortar fem</keyword>
      <keyword>abc</keyword>
      <keyword>transient</keyword>
      <keyword>nonmatching grids</keyword>
    </keywords>
    <references>
      None just functionality test
    </references>
    <isVerified>yes</isVerified>
    <description>
      This example covers the options minRelSideLength and coincidenceRadius to reject small intersection elements in a 3d geometry setup and non conforming interfaces.
      The setup uses exaggerated values for the intersection rejection to demonstrate the effect. The setup is a simple 3d geometry with three pipes connected by Nitsche interfaces.
    </description>
  </documentation>
  <!--***************************    INPUTs and OUTPUTs    ***********************-->
  <fileFormats> 
    <input>
      <hdf5 fileName="./NCIIntersectionSmallElemRejectionCoincidenceRadiusMinRelSideLengthAcouPressure3d.h5"/>
    </input>
    <output>
      <hdf5 id="hdf5"/>
      <text id="txt"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
  <!--***************************  REGIONSs, SURFACEs and NODEs  ***********************-->
  <domain geometryType="3d">
    <variableList>
      <var name="c0" value="343.4000408"/>
      <var name="p0" value="1"/>
      <var name="rho" value="1.204"/>
      <var name="f0" value="686.8"/>
    </variableList>
    <regionList> 
      <region name="pipe1" material="air_20deg"/>
      <region name="pipe2" material="air_20deg"/>
      <region name="pipe3" material="air_20deg"/>
    </regionList>
    <surfRegionList>
      <surfRegion name="src"/>
      <surfRegion name="abc" />
      <surfRegion name="if1"/>
      <surfRegion name="if2"/>
      <surfRegion name="if3"/>
      <surfRegion name="if4"/>
    </surfRegionList>
    <ncInterfaceList>
      <ncInterface name="ncif1"   secondarySide="if1"   primarySide="if2" minRelSideLength="1e-1"/>
      <ncInterface name="ncif2"   secondarySide="if3"   primarySide="if4" coincidenceRadius="0.01"/>
    </ncInterfaceList>
  </domain>
  <!--***************************  ANALYSIS  ***********************-->
  <sequenceStep>    
    <analysis>
      <transient>
        <numSteps>
          20
        </numSteps>
        <deltaT>
          2.25e-04
        </deltaT>
      </transient>
    </analysis>    
    <!--***************************  PDE LISTs  ***********************-->
    <pdeList>
      <acoustic formulation="acouPressure">
        <regionList>
          <region name="pipe1"/>
          <region name="pipe2"/>
          <region name="pipe3"/>
        </regionList>
        <!-- ************************************************************ BCS / SOURCES ****************************************************** -->
        <ncInterfaceList>
          <ncInterface name="ncif1" nitscheFactor="100" formulation="Nitsche"/>
          <ncInterface name="ncif2" nitscheFactor="100" formulation="Nitsche"/>
        </ncInterfaceList>
        <bcsAndLoads>
          <pressure name="src" value="p0*sin(2*pi*f0*t)"/>
          <absorbingBCs volumeRegion="pipe1" name="abc" />
        </bcsAndLoads>
        <storeResults>
          <nodeResult type="acouPressure">
            <regionList>
              <region name="pipe1" outputIds="hdf5"/>
              <region name="pipe2" outputIds="hdf5"/>
              <region name="pipe3" outputIds="hdf5"/>
            </regionList>
          </nodeResult>
        </storeResults>
      </acoustic>
    </pdeList>
  </sequenceStep>
</cfsSimulation>
