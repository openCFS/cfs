undo on 
reset
#{aorta_radius = 0.02}


# geometry
create Cylinder height 101e-2 radius  {aorta_radius}
rotate volume 1  angle 90 about y include_merged
move volume 1 x 0.25 include_merged
create Cylinder height 10e-2 radius  {0.025}
rotate volume 2 angle 90 about y include_merged
move volume 2 x 0.25 include_merged

subtract volume 1 from volume 2 imprint keep_tool


#regions
block 1 add volume 1
block 1 name "aorta"

block 2 add vol 2
block 2 name "thorax"


#BCs
nodeset 1 add surface 2
nodeset 1 name "S_inj_load"

nodeset 2 add surface 3
nodeset 2 name "S_inj_ground"

imprint all
merge all


#mesh
volume all scheme tetmesh
volume all size auto factor 7 propagate
#volume all scheme auto
mesh volume all


export ansys cdb "thorax_exp.cdb" overwrite
