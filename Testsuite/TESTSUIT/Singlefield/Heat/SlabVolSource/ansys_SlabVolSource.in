! start a new Ansys project
! SlabVolSource.in: just a simple rectangular domain with a volume heating source

fini
/clear
/filname,SlabVolSource
/uis,msgpop,1
/prep7
init

!define variable
eps = 1e-3                    !Toleranz
len = 0.1                     !length
thick = 0.01                  !thickness

gw = len/10                   !mesh size


k,1,0,0
k,2,len,0
k,3,len,thick
k,4,0,thick

a,1,2,3,4

! Define components
allsel
asel,s,,,1
cm,'slabA',area

! do mesh
setelems,'quadr'
mshkey,2
esize,gw
allsel
amesh,all


! === write mesh components ===

allsel
wnodes

cmsel,s,slabA
esla
welems,'slab'

allsel
lsel,s,loc,x,-eps,eps
nsll,s,1
wnodbc,'bcleft'

allsel
lsel,s,loc,x,len-eps,len+eps
nsll,s,1
wnodbc,'bcright'

allsel
lsel,s,loc,x,len/2-eps,len/2+eps
nsll,s,1
wnodbc,'historyNode'

mkhdf5,,'tolerant'