<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.cfs++.org/simulation https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
    
        <documentation>
    <title>Heat PDE</title>
    <authors>
      <author>mhofmarc, msocacu</author>
    </authors>
    <date>2026-01-22</date>
    <keywords>
      <keyword>heatConduction</keyword>
    </keywords>
    <references></references>
    <isVerified>no</isVerified>
    <description>
    Test case for 3D alignment of the heat conduction tensor with a vector field.
    The rotateMaterialTensorsId is assigned to a region where the heatConduction problem is applied and a rotation is needed.
    For this Id a rotation list with a reference vector field and a target vector field is created.
    The heat conduction tensor is rotated from the reference vector field to the target vector field.
    </description>
  </documentation>

    <fileFormats>
      <input>
        <hdf5 fileName="RotateMatTensorWithVectorfield3D.h5ref"/>
      </input>
        <output>
            <hdf5 />
            <text id="txt" />
        </output>
        <materialData file="mat.xml" format="xml" />
    </fileFormats>

    <domain geometryType="3d">
        <regionList>
            <region name="V_cube" material="iron" >
                <matRotation alpha="0.0" beta="0.0" gamma="0.0" />
            </region>
        </regionList>
    </domain>
    <sequenceStep index="1">
        <analysis>
            <static />
        </analysis>
        <pdeList>
            <heatConduction>
                <regionList>
                    <region name="V_cube" rotateMaterialTensorsId="rotation" />
                </regionList>
                <rotationList>
                    <rotation name="rotation">
                        <refVec>
                            <comp dof="x" value="1" />
                        </refVec>
                        <targetVec>
                            <comp dof="x" value="1" />
                            <comp dof="y" value="cos(x/5 *pi)" />
                            <comp dof="z" value="sin(x/5 *pi)" />
                        </targetVec>
                    </rotation>
                </rotationList>   

                <bcsAndLoads>
                    <heatFlux name="S_top" value="1000"/>
                    <heatTransport name="S_bottom" volumeRegion="V_cube" heatTransferCoefficient="100" bulkTemperature="20.0"/>
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="heatTemperature">
                        <allRegions />
                    </nodeResult>
                    <elemResult type="heatFluxDensity">
                        <allRegions />
                    </elemResult>
                </storeResults>
            </heatConduction>
        </pdeList>
    </sequenceStep>
</cfsSimulation>
