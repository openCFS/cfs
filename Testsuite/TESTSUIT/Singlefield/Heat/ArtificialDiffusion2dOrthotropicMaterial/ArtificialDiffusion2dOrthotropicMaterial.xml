<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.cfs++.org/simulation https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
    <documentation>
        <title>Convection Diffusion PDE with Artificial Diffusion Stabilistaion</title>
        <authors>
            <author>Vladimir Filkin</author>
        </authors>
        <date>2024-05-08</date>
        <keywords>
            <keyword>heatConduction</keyword>
        </keywords>
        <references></references>
        <isVerified>yes</isVerified>
        <description> Solution of 2D convection diffusion PDE with Artificial diffusion
            stabilistaion on x = [0,L] and y = [0,L] with Dirichlet BC's is T(0,0:L)= 0, T(0:L,0)=0,
            T(0:L,L)=1 and T(L,0:L)=0. Only 4 elements are used. The main idea is that for all the
            performed computation stabilisation should be suffitient to give the temperature in the
            middle node close to 0 for cases with high velocity. Here we validate linear material
            with orthotropic properties and 2D formulation. </description>
    </documentation>

    <fileFormats>
        <input>
            <hdf5 fileName="ArtificialDiffusion2dOrthotropicMaterial.h5ref" />
        </input>
        <output>
            <hdf5 />
            <text id="txt" />
        </output>
        <materialData file="mat.xml" format="xml" />
    </fileFormats>

    <domain geometryType="plane">
        <regionList>
            <region name="V_sheet" material="iron" />
        </regionList>
    </domain>

    <fePolynomialList>
        <Lagrange id="idPol">
            <isoOrder>1</isoOrder>
        </Lagrange>
    </fePolynomialList>

    <sequenceStep index="1">
        <analysis>
            <static />
        </analysis>
        <pdeList>
            <heatConduction>
                <regionList>
                    <region name="V_sheet" velocityId="vel" polyId="idPol" />
                </regionList>
                <velocityList>
                    <velocity name="vel" stabilisation="ArtificialDiffusion">
                        <comp dof="x" value="1" />
                        <comp dof="y" value="1" />
                    </velocity>
                </velocityList>
                <bcsAndLoads>
                    <temperature name="East" value="0.0" />
                    <temperature name="South" value="0.0" />
                    <temperature name="North" value="1.0" />
                    <temperature name="West" value="1.0" />
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="heatTemperature">
                        <allRegions />
                    </nodeResult>
                </storeResults>
            </heatConduction>
        </pdeList>
    </sequenceStep>
</cfsSimulation>