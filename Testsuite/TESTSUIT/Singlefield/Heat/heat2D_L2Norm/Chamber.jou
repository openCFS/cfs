reset
undo on

#{d = 1e-1};
#{h_el = 2e-2};

#{tol = 1e-6}

merge tolerance {tol}


# geom

create surface rectangle width {d} height {d} zplane
move surface 1 x {d/2} y {d/2} z 0


# mesh

surface all size {h_el}
mesh surface all


# blocks and nodesets

block 1 add surface 1
block 1 name "Chamber"


nodeset 1 add curve 1
nodeset 1 name "C_Exc"

nodeset 2 add curve 2 4
nodeset 2 name "C_Side"

nodeset 3 add curve 3
nodeset 3 name "C_Fix"




Echo on
Warning on

export ansys cdb "Chamber.cdb" overwrite


