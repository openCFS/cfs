reset

create surface rectangle width 1 height 0.01 zplane
move surface 1 x 0.5

surface 1 size 0.01
mesh surface 1

block 1 add surface 1
block 1 name "S_all"

nodeset 1 add curve 2
nodeset 1 name "C_0"
nodeset 2 add curve 4
nodeset 2 name "C_L"
nodeset 3 add curve 3
nodeset 3 name "C_bot"
nodeset 4 add surface 1
nodeset 4 name "C_all"

export ansys cdb "sheet.cdb" overwrite
