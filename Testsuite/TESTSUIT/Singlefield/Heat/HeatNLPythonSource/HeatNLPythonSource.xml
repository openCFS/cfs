<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <documentation>
    <title>static heat with nonlinear spacial heat source via python</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2023-04-06</date>
    <keywords>
      <keyword>static</keyword>
      <keyword>nonlinear</keyword>
    </keywords>
    <references>no</references>
    <isVerified>no</isVerified>
    <description>Test the StepStaticNonLinFixedPointSimple() nonlinear solver. 
    The nonlinearity is a spacial heat temperature dependent heat source realized by a python script.
    
    The quadratic domain has IDBC on the left and a centered radial cone as heat source realized via Python.
    You can create arbitrary meshes via create_mesh.py --type bulk2d --res 30
    
    The damping is realized by python. Python gets the current solution by itself.
    
    The nonlinar function is of type tanh with parameters set as python options.
    
    Try setting "plot" for python, if gives nice insight (see plot.ref.png)</description>
  </documentation>
  
  <!-- The cfs global kernel python script which holds the function for CoefFunctionPython. -->
  <python file="heatsource.py" path=".">
    <!-- to read the solution and organize history for damping -->
    <callback hook="assemble_rhs" function="assemble_rhs" />
  </python>
  
  <fileFormats>
    <input>
      <!-- meshes can ceated by create_mesh.py with bulk2d type -->
      <hdf5 fileName="HeatNLPythonSource.h5ref"/>
    </input>
    <output>
      <hdf5 />
      <info />
    </output>
    <materialData file="mat.xml"/>
  </fileFormats>
  
  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="air"/>
    </regionList>
    <nodeList>
      <nodes name="source">
        <allNodesInRegion regName="mech"/>
      </nodes>
      <nodes name="center">
        <coord x=".5" y=".5" />
      </nodes>
    </nodeList>
  </domain>
  
  <sequenceStep>
    <analysis>
      <static/>
    </analysis>
    <pdeList>
      <heatConduction>
        <regionList>
         <region name="mech" nonLinIds="source" />
        </regionList>
        
        <nonLinList>
          <!-- the python heat source reads the current solution by the assemböe_rhs() hook and returns a damped temperature
          dependend spacial varying heat source -->
          <heatSource id="source"/>
        </nonLinList>           
                
        <bcsAndLoads>
          <!-- IDBC to act with the heat source -->
          <temperature name="left" value="1"/>
          <heatSource name="source">
            <!-- not by_coord as we need the node number to obtain the temperature -->
            <python function="coef_eval" init="coef_init" normalize="false" by_coord="false">
              <option key="center" value="[.5, .5]"/>
              <option key="radius" value=".3"/>
              <!-- this is the heat source for sufficiently cold temperatures -->
              <option key="nominal" value=".4"/>
              <!-- where the tanh like function switches (half nominal) -->
              <option key="switch_temp" value="80"/>
              <!-- sharpness of the nonlinar function. Higher values have poorer convergence -->
              <option key="beta" value=".1"/>
              <!-- produce a nice pop-up plot which needs to be closed each nonlinear iteration -->
              <!-- <option key="plot" value="1"/> -->
              <option key="center_output" value="true"/>
            </python>          
          </heatSource>
        </bcsAndLoads>
                
        <storeResults>
          <nodeResult type="heatTemperature">
            <allRegions/>
            <nodeList>
              <nodes name="source"/>
            </nodeList>
          </nodeResult>
          <nodeResult type="heatRhsLoad">
            <allRegions/>
          </nodeResult>          
        </storeResults>
      </heatConduction>
    </pdeList>

    <linearSystems>
      <system>
        <solutionStrategy>
          <standard>
            <nonLinear logging="yes" method="fixPoint" >
              <lineSearch type="none"/>
              <incStopCrit>1e-6</incStopCrit>
              <maxNumIters>40</maxNumIters>
              <abortOnMaxNumIters>no</abortOnMaxNumIters>
            </nonLinear>
          </standard>
        </solutionStrategy>
      </system>
    </linearSystems>
  </sequenceStep>
  
</cfsSimulation>
