reset

brick x 0.4 y 0.0033333333333333335 z 0.0033333333333333335
brick x 0.2 y 0.0033333333333333335 z 0.0033333333333333335
brick x 0.4 y 0.0033333333333333335 z 0.0033333333333333335
move volume 1 x 0.2
move volume 2 x 0.5
move volume 3 x 0.8

imprint volume all
merge volume all

# here the size should be divided by 15 for the reference case
curve 2 4 6 8 14 16 18 20 26 28 30 32 size 0.05
# this should stay the same for reference case
curve 3 7 9 11 1 5 10 12 13 17 22 24  25 29 34 36 size 0.0033333333333333335
mesh volume all

block 1 add volume all
block 1 name "V_all"

nodeset 1 add volume 2
nodeset 1 name "V_mid"

nodeset 2 add surface 4
nodeset 2 name "S_0"

nodeset 3 add surface 18 
nodeset 3 name "S_L"

nodeset 4 add surface 3
nodeset 4 name "S_bot0"

nodeset 5 add surface 5
nodeset 5 name "S_top0"

nodeset 6 add surface 15
nodeset 6 name "S_botL"

nodeset 7 add surface 17
nodeset 7 name "S_topL"

export ansys cdb "body.cdb" overwrite
