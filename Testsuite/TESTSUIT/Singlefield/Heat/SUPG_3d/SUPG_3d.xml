<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.cfs++.org/simulation https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
    <documentation>
        <title>SUPG 3d</title>
        <authors>
            <author>Felix Huber</author>
        </authors>
        <date>2025-03-02</date>
        <references>https://www.comsol.com/blogs/understanding-stabilization-methods</references>
        <description>
            This simulation tests the SUPG implementaion for a 3d problem.
            Additionally, the RHS boundary conditions heatTransport, heatFLux, and heatSourceDensity
            and their SUPG terms are tested.
            The example was verified with with a finer meshed version with a Peclier number smaller 1 
            and therefore no stability issues.
        </description>
    </documentation>
    <fileFormats>
        <input>
            <hdf5 fileName="SUPG_3d.h5ref" />
        </input>
        <output>
            <hdf5 />
        </output>
        <materialData file="mat.xml" format="xml" />
    </fileFormats>

    <domain geometryType="3d">
        <regionList>
            <region name="V_all" material="iron" />
        </regionList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <transient>
            <numSteps>50</numSteps>
            <deltaT>0.02</deltaT>
            </transient>
        </analysis>
        <pdeList>
            <heatConduction>
                <regionList>
                    <region name="V_all" velocityId="vel"/>
                </regionList>
                <velocityList>
                    <velocity name="vel" stabilisation="SUPG">
                        <comp dof="x" value="1"/>
                    </velocity>
                </velocityList>
                <bcsAndLoads>
                    <heatTransport name="S_top0" volumeRegion="V_all" heatTransferCoefficient="0.1" bulkTemperature="0"/>
                    <heatFlux name="S_bot0" value="-10" volumeRegion="V_all"/>
                    <heatTransport name="S_topL" volumeRegion="V_all" heatTransferCoefficient="0.1" bulkTemperature="100"/>
                    <heatFlux name="S_botL" value="10" volumeRegion="V_all"/>
                    <heatSourceDensity name="V_mid" value="-1" volumeRegion="V_all"/>
                    <temperature name="S_0" value="0"/>
                    <temperature name="S_L" value="0"/>
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="heatTemperature" >
                        <allRegions/>
                    </nodeResult>
                </storeResults>
            </heatConduction>
        </pdeList>
    </sequenceStep>
</cfsSimulation>