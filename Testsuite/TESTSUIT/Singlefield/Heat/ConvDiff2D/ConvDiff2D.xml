<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.cfs++.org/simulation">
  
  <documentation>
    <title>Convection Diffusion PDE with Dirichlet BC</title>
    <authors>
      <author>kroppert</author>
    </authors>
    <date>2017-10-15</date>
    <keywords>
      <keyword>heatConduction</keyword>
    </keywords>
    <references></references>
    <isVerified>yes</isVerified>
    <description> Solution of 1D convection diffusion PDE on [0,1] with Dirichlet BC's
    is T(x)=(exp( (u/c) * x) - 1)/(exp( u/c ) - 1),
    where c is c=\sqrt(\lambda/(\rho c_p))
    </description>
  </documentation>
  <fileFormats>
    <input>
      <hdf5 fileName="mesh/mesh.h5"/>
    </input>
    <output>
      <hdf5/>
      <text id="txt"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
  
  <domain geometryType="plane">
    <regionList>
      <region name="S_inner" material="unit"/>
    </regionList> 
  </domain>
  
  
  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      <heatConduction>
        <regionList>
          <region name="S_inner" velocityId="velId1"/>  
        </regionList>
        
        <velocityList>
          <velocity name="velId1">
            <comp dof="x" value="7"/>
          </velocity>
        </velocityList>
         
        <bcsAndLoads>
          <heatFlux name="top" value="0"/>
          <heatFlux name="bottom" value="0"/>
          <temperature name="left" value="0"/>
          <temperature name="right" value="1"/>
        </bcsAndLoads>
        
        
        <storeResults>
          <nodeResult type="heatTemperature">
            <allRegions/>
          </nodeResult>
          <elemResult type="heatFluxDensity">
            <allRegions/>
          </elemResult>
        </storeResults>
      </heatConduction>
    </pdeList>
    
    
    <linearSystems>
      <system>
        <solutionStrategy>
          <standard>
          </standard>
        </solutionStrategy>
        <solverList>
              <pardiso/>
                </solverList>
      </system>
    </linearSystems>
  </sequenceStep>
</cfsSimulation>

