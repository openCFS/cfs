<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.cfs++.org/simulation https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
    <documentation>
        <title>Convection Diffusion PDE with Artificial Diffusion Stabilistaion</title>
        <authors>
            <author>Vladimir Filkin</author>
        </authors>
        <date>2024-05-08</date>
        <keywords>
            <keyword>heatConduction</keyword>
        </keywords>
        <references></references>
        <isVerified>yes</isVerified>
        <description> Solution of quasi-1D convection diffusion PDE with Artificial diffusion stabilistaion
            on x = [0,3] with Dirichlet BC's is T(0)= 0 and T(3)=1. Only 2 elements in the x-direction are used.
   
            The analytical solution for the cases with and without stabilistaion is in Mathematica file.
            The main idea is that for all the performed computations stabilisation should be suffitient to 
            give the T(1.5) close to 0 for cases with high velocity.
            There are 3 sequenceSteps. 
            The first one is with hight velocity and linear material (convection dominated results).
            Here we validate if the stabilisation works.
            The second is with low velocity and linear material (a diffusion-dominated problem where stabilization is not required).
            Here we validate if the stabilisation changes the model, which does not require stabilisation.
            The third is a velocity inbeteen with nonLinear material (convection dominated results).
            Here we validate if the nonLinear material workflow works.  
        </description>
    </documentation>
    
    <fileFormats>
        <input>
            <hdf5 fileName="ArtificialDiffusion3dIsotropicMaterial.h5ref" />
        </input>
        <output>
            <hdf5 />
            <text id="txt" />
        </output>
        <materialData file="mat.xml" format="xml" />
    </fileFormats>

    <domain geometryType="3d">
        <regionList>
            <region name="V_sheet" material="ironNonLinear" />
        </regionList>
    </domain>

    <fePolynomialList>
        <Lagrange id="idPol">
            <isoOrder>1</isoOrder>
        </Lagrange>
    </fePolynomialList>

    <sequenceStep index="1">
        <analysis>
            <static />
        </analysis>
        <pdeList>
            <heatConduction>
                <regionList>
                    <region name="V_sheet" velocityId="vel" polyId="idPol" />
                </regionList>
                <velocityList>
                    <velocity name="vel" stabilisation="ArtificialDiffusion">
                        <comp dof="x" value="1000" />
                    </velocity>
                </velocityList>
                <bcsAndLoads>
                    <temperature name="S_sheet_xN" value="0.0" />
                    <temperature name="S_sheet_xP" value="1.0" />
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="heatTemperature">
                        <allRegions />
                    </nodeResult>
                </storeResults>
            </heatConduction>
        </pdeList>
    </sequenceStep>

    <sequenceStep index="2">
        <analysis>
            <static />
        </analysis>
        <pdeList>
            <heatConduction>
                <regionList>
                    <region name="V_sheet" velocityId="vel" polyId="idPol" />
                </regionList>
                <velocityList>
                    <velocity name="vel" stabilisation="ArtificialDiffusion">
                        <comp dof="x" value="0.0000000000001" />
                    </velocity>
                </velocityList>
                <bcsAndLoads>
                    <temperature name="S_sheet_xN" value="0.0" />
                    <temperature name="S_sheet_xP" value="1.0" />
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="heatTemperature">
                        <allRegions />
                    </nodeResult>
                </storeResults>
            </heatConduction>
        </pdeList>
    </sequenceStep>

    <sequenceStep index="3">
        <analysis>
            <static />
        </analysis>
        <pdeList>
            <heatConduction>
                <regionList>
                    <region name="V_sheet" velocityId="vel" nonLinIds="nonLin" polyId="idPol" />
                </regionList>
                <nonLinList>
                    <heatConductivity id="nonLin" />
                </nonLinList>
                <velocityList>
                    <velocity name="vel" stabilisation="ArtificialDiffusion">
                        <comp dof="x" value="1" />
                    </velocity>
                </velocityList>
                <bcsAndLoads>
                    <temperature name="S_sheet_xN" value="0.0" />
                    <temperature name="S_sheet_xP" value="1.0" />
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="heatTemperature">
                        <allRegions />
                    </nodeResult>
                </storeResults>
            </heatConduction>
        </pdeList>

        <linearSystems>
            <system>
                <solutionStrategy>
                    <standard>
                        <nonLinear method="fixPoint">
                            <lineSearch type="minEnergy" />
                            <incStopCrit>1e-7</incStopCrit>
                            <resStopCrit>1e-7</resStopCrit>
                            <maxNumIters>25</maxNumIters>
                        </nonLinear>
                    </standard>
                </solutionStrategy>
            </system>
        </linearSystems>
    </sequenceStep>
</cfsSimulation>