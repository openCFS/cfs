<cfsSimulation xmlns="http://www.cfs++.org/simulation"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title> Non-Conforming Heat Transfer through Pipe 2D </title>
        <authors>
            <author>russwurm</author>
        </authors>
        <date>2024-03-23</date>
        <keywords>
            <keyword>heatConduction</keyword>
            <keyword>nonmatching grids</keyword>
        </keywords>
        <references></references>
        <isVerified>no</isVerified>
        <description> 
            Heat Conduciton through domain
            Non-conforming mesh
            with heat transfer coefficient and
            thinLayer formulation
        </description>
    </documentation>

    <fileFormats>
        <input>
            <!--<gmsh fileName="mesh_merged.msh"/>-->
            <hdf5 fileName="heat2D_thinLayer_nonconforming.h5ref"/>
        </input>
        <output>
            <hdf5/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>

    <domain geometryType="plane">
        <regionList>
            <region name="s_fluid" material="material_2"/> <!-- material_2 -->
            <region name="s_solid" material="material_1"/>
        </regionList>
        <surfRegionList>
            <surfRegion name="l_exterior"/>
            <surfRegion name="l_fluid-solid"/>
            <surfRegion name="l_solid-fluid"/>
            <surfRegion name="l_solid_inner"/>
        </surfRegionList>

        <ncInterfaceList>
            <ncInterface name="tlr" primarySide="l_fluid-solid" secondarySide="l_solid-fluid"/>
        </ncInterfaceList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <static>
            </static>
        </analysis>

        <pdeList>
            <heatConduction>
                <regionList>
                    <!-- define regions to be included in the analysis -->
                    <region name="s_fluid"/>
                    <region name="s_solid"/>
                </regionList>

                <ncInterfaceList>
                    <ncInterface name="tlr" formulation="Nitsche"> <!-- only nitsche type coupling implemented-->
                        <thinLayer layerThickness="0.02" layerMaterial="ersatzMat"/>
                    </ncInterface>
                </ncInterfaceList>

                <bcsAndLoads>
                    <heatFlux name="l_exterior" value="-0.1"/>
                    <!--<heatFlux name="l_solid_inner" value="1"/>-->
                    <temperature name="l_solid_inner" value="1"/>
                    <!--<heatFlux name="l_solid_inner" value="1"/>-->
                </bcsAndLoads>

                <storeResults>
                    <nodeResult type="heatTemperature">
                        <allRegions/>
                    </nodeResult>
                    <elemResult type="heatFluxDensity">
                        <allRegions/>
                    </elemResult>
                </storeResults>
            </heatConduction>
        </pdeList>


        <linearSystems>
            <system>
                <solutionStrategy>
                    <standard>
                        <!--<setup idbcHandling="elimination"/>-->
                        <!--<exportLinSys system="true" rhs="true"/>-->
                        <!--<matrix storage="sparseNonSym" reordering="noReordering"/>-->
                    </standard>
                </solutionStrategy>
                <solverList>
                    <!--<pardiso/>-->
                </solverList>
            </system>
        </linearSystems>
    </sequenceStep>

</cfsSimulation>