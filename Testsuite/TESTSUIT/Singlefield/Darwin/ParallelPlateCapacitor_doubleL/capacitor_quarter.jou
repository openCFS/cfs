reset

#{ d_f =0.9}   # diameter of the feedline
#{ r_f = d_f/2 }  # radius of the feedline

#{ d_p = 3*2}   # diameter of the electrode
#{ r_p = d_p/2 }  # radius of the electrode



#{ r_a = r_p + 5}  # radius of the air domain

#{ h_h = 5} # height of feedline
#{ h_d = 1} # height of dielectric
#{ h_p = 0.5 }  # height of electrode
#{ h_a = 2*h_h + 2*h_p + h_d } # height of air domain


#{ n_fl =4 }  # Interval of feedline height
#{ n_fc = 2}  # Interval of feedline radius


#{ n_pc = 3 }  # Interval of electrode radius

#{ n_fr = 2}  # Intervall of feedline radius
#{ n_pr = 3}  # Intervall of electrode radius
#{ n_pl = 2}  # Intervall of electrode height
#{ n_dl = 2}  # Intervall of dielectric height

#{ n_a = 2}  # Interval in air domain

# this is a comment
create Cylinder height { h_d } radius { r_p } 
create Cylinder height { h_p } radius { r_p }
move Volume 2 z { h_p/2 + h_d/2}  include_merged 
create Cylinder height { h_p } radius { r_p }
move Volume 3 z { -h_p/2 - h_d/2}  include_merged 
create Cylinder height { h_h } radius { r_f }
move volume 4 z { h_p + h_h/2 + h_d/2 } include_merged
create Cylinder height { h_h } radius { r_f }
move volume 5 z { -h_p - h_h/2 - h_d/2 } include_merged
create Cylinder height { h_a} radius { r_a }
#subtract volume 6 from volume 4 keep
#subtract volume 7 from volume 4 keep
#delete volume 7 4
#subtract volume 6 from volume 5 keep
#subtract volume 9 from volume 5 keep
#delete volume 9 5
subtract volume all except volume 6 from volume 6 keep
delete volume 6
webcut volume all with plane yplane offset 0 
delete volume all with y_coord < 0
webcut volume all with plane xplane offset 0 
delete volume all with x_coord < 0
webcut volume 13 with sheet extended from surface 98
webcut volume all with sheet extended from surface 118
webcut volume 13 with plane zplane offset {h_d/2} 
webcut volume 13 with plane zplane offset {h_d/2 + h_p} 
webcut volume 25 with plane zplane offset {-h_d/2} 
webcut volume 27 with plane zplane offset {-h_d/2 - h_p}



# imprint & merge to create unique volumes
imprint volume all 
merge volume all 




# mesh
delete mesh


# mesh type
#  #{mesh_grading = 2}
#  #{air_grading = 0.7}

# inner conductor (feedline)
curve 183 178 interval {n_fr}
curve 183 178 scheme bias factor {mesh_grading}
mesh curve 183 178 
curve 181 247 222  interval {n_fc}
mesh curve 181 247 222 
surface 119 scheme pave
mesh surface 119

# plates
curve 256 254  interval {n_pr}
curve 256 254  scheme bias factor {mesh_grading}
mesh curve 256 254  

# surrounding air
curve 243 246 interval {n_a}
curve 243 246  scheme bias factor {air_grading}
mesh curve 243 246 


surface 164 scheme map
mesh surface 164

surface 158 scheme map
mesh surface 158


curve 329 257 65 177 179 253 327 366 248 77 193 195 250 367   interval {n_fl}
curve 329 257 65 177 179 253 327 366 248 77 193 195 250 367  scheme bias factor 1
mesh curve 329 257 65 177 179 253 327 366 248 77 193 195 250 367 


curve 334 41 276 145 274 147 335 361 53 292 161 290 163 359  interval {n_pl}
curve 334 41 276 145 274 147 335 361 53 292 161 290 163 359  scheme bias factor 1
mesh curve 334 41 276 145 274 147 335 361 53 292 161 290 163 359 

curve 343 29 260 129 258 131 342  interval {n_dl}
curve 343 29 260 129 258 131 342  scheme bias factor 1
mesh curve 343 29 260 129 258 131 342 


volume 21 redistribute nodes off
volume 21 scheme sweep source surface 164 target surface 139 sweep transform least squares propagate bias
volume 21 autosmooth target off
mesh volume 21

volume 9 redistribute nodes off
volume 9 scheme sweep source surface 139 target surface 171 sweep transform least squares propagate bias
volume 9 autosmooth target off
mesh volume 9

volume 8 redistribute nodes off
volume 8 scheme sweep source surface 171 target surface 169 sweep transform least squares propagate bias
volume 8 autosmooth target off
mesh volume 8

volume 10 redistribute nodes off
volume 10 scheme sweep source surface 169 target surface 141 sweep transform least squares propagate bias
volume 10 autosmooth target off
mesh volume 10

volume 20 redistribute nodes off
volume 20 scheme sweep source surface 141 target surface 162 sweep transform least squares propagate bias
volume 20 autosmooth target off
mesh volume 20

volume 11 redistribute nodes off
volume 11 scheme sweep source surface 119 target surface 121 sweep transform least squares propagate bias
volume 11 autosmooth target off
mesh volume 11

volume 23 redistribute nodes off
volume 23 scheme sweep source surface 121 target surface 174 sweep transform least squares propagate bias
volume 23 autosmooth target off
mesh volume 23

volume 22 redistribute nodes off
volume 22 scheme sweep source surface 174 target surface 176 sweep transform least squares propagate bias
volume 22 autosmooth target off
mesh volume 22

volume 24 redistribute nodes off
volume 24 scheme sweep source surface 176 target surface 129 sweep transform least squares propagate bias
volume 24 autosmooth target off
mesh volume 24

volume 12 redistribute nodes off
volume 12 scheme sweep source surface 129 target surface 131 sweep transform least squares propagate bias
volume 12 autosmooth target off
mesh volume 12


volume 13 redistribute nodes off
volume 13 scheme sweep source surface 158 target surface 207 sweep transform least squares propagate bias
volume 13 autosmooth target off
mesh volume 13

volume 26 redistribute nodes off
volume 26 scheme sweep source surface 207 target surface 197 sweep transform least squares propagate bias
volume 26 autosmooth target off
mesh volume 26

volume 25 redistribute nodes off
volume 25 scheme sweep source surface 197 target surface 217 sweep transform least squares propagate bias
volume 25 autosmooth target off
mesh volume 25

volume 27 redistribute nodes off
volume 27 scheme sweep source surface 217 target surface 227 sweep transform least squares propagate bias
volume 27 autosmooth target off
mesh volume 27

volume 28 redistribute nodes off
volume 28 scheme sweep source surface 227 target surface 156 sweep transform least squares propagate bias
volume 28 autosmooth target off
mesh volume 28

#mesh volume 13 26 25 27 28 



# regions
block 1 add volume 8 22 
block 1 name "V_dielec"
block 2 add volume 21 13 26 25 27 28 20 
block 2 name "V_air"
block 3 add volume 23 9 
block 3 name "V_electrode_top"
block 4 add volume 11
block 4 name "V_feed_top"
block 5 add volume 10 24 
block 5 name "V_electrode_bottom"
block 6 add volume 12
block 6 name "V_feed_bottom"



nodeset 1 add surface 211 213 233 231 218 
nodeset 1 name "S_air_outer"
nodeset 2 add surface 158 164 
nodeset 2 name "S_air_top" 
nodeset 3 add surface 156 162 
nodeset 3 name "S_air_bottom" 
nodeset 4 add surface 119
nodeset 4 name "S_electrode_top"
nodeset 5 add surface 131
nodeset 5 name "S_electrode_bottom"
nodeset 6 add surface all with y_coord=0
nodeset 6 name "S_symmetry_y"
nodeset 7 add surface all with x_coord=0
nodeset 7 name "S_symmetry_x"


volume all scale 1e-3

# export
export ansys cdb "capacitor_quarter_rp_6mm.cdb"  overwrite 












































