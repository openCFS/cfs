reset

#{ r_f = 0.025 }  #radius of the feedline
#{ r = 0.15 }  # radius of the electrode
#{ R = 0.25 } # height air domain
#{ d = 0.05 } # height of dielectric
#{ l = 0.02 }  # height of electrode


# this is a comment
create Cylinder height { d } radius { r } 
create Cylinder height { l } radius { r }
move Volume 2 z { l/2 + d/2}  include_merged 
create Cylinder height { l } radius { r }
move Volume 3 z { -l/2 - d/2}  include_merged 
create Cylinder height { R } radius { r_f }
move volume 4 z { l + R/2 + d/2 } include_merged
create Cylinder height { R } radius { r_f }
move volume 5 z { -l - R/2 - d/2 } include_merged
create Cylinder height { 2*R } radius { 2*r }
subtract volume 6 from volume 4 keep
subtract volume 7 from volume 4 keep
delete volume 7 4
subtract volume 6 from volume 5 keep
subtract volume 9 from volume 5 keep
delete volume 9 5
subtract volume all except volume 6 from volume 6 keep
delete volume 6
webcut volume all with plane yplane offset 0 
delete volume all with y_coord < 0
webcut volume all with plane xplane offset 0 
delete volume all with x_coord < 0
webcut volume 17 with sheet extended from surface 110
webcut volume all with sheet extended from surface 132
webcut volume 17 with plane zplane offset {d/2} 
webcut volume 17 with plane zplane offset {d/2+l} 
webcut volume 29 with plane zplane offset {-d/2} 
webcut volume 31 with plane zplane offset {-d/2-l}



# imprint & merge to create unique volumes
imprint volume all 
merge volume all 




# mesh
delete mesh


# inner conductor (feedline)
curve 190 188 interval 5
curve 190 188  scheme bias factor 1.3
#volume 15 27 26 28 16 size 5e-3
mesh curve 190 188
curve 192 255 230 interval 6
mesh curve 192 255 230
surface 133 scheme pave
mesh surface 133

# plates
curve 264 262 interval 10
curve 264 262  scheme bias factor 1.1
mesh curve 264 262 

# surrounding air
curve 251 254 interval 8
mesh curve 251 254 


surface 176 scheme map
mesh surface 176

surface 170 scheme map
mesh surface 170


curve 337 265 74 187 185 261 335 374 256 84 203 201 258 375  interval 5
curve 337 265 74 187 185 261 335 374 256 84 203 201 258 375  scheme bias factor 1
mesh curve 337 265 74 187 185 261 335 374 256 84 203 201 258 375 


curve 342 49 284 153 282 155 343 367 171 298 169 300 61 369  interval 5
curve 342 49 284 153 282 155 343 367 171 298 169 300 61 369  scheme bias factor 1
mesh curve 342 49 284 153 282 155 343 367 171 298 169 300 61 369  

curve 351 37 268 137 266 139 350  interval 5
curve 351 37 268 137 266 139 350  scheme bias factor 1
mesh curve 351 37 268 137 266 139 350 


volume 25 redistribute nodes off
volume 25 scheme sweep source surface 176 target surface 151 sweep transform least squares propagate bias
volume 25 autosmooth target off
mesh volume 25

volume 13 redistribute nodes off
volume 13 scheme sweep source surface 151 target surface 183 sweep transform least squares propagate bias
volume 13 autosmooth target off
mesh volume 13

volume 12 redistribute nodes off
volume 12 scheme sweep source surface 183 target surface 181 sweep transform least squares propagate bias
volume 12 autosmooth target off
mesh volume 12

volume 14 redistribute nodes off
volume 14 scheme sweep source surface 181 target surface 153 sweep transform least squares propagate bias
volume 14 autosmooth target off
mesh volume 14

volume 24 redistribute nodes off
volume 24 scheme sweep source surface 153 target surface 174 sweep transform least squares propagate bias
volume 24 autosmooth target off
mesh volume 24

volume 15 redistribute nodes off
volume 15 scheme sweep source surface 133 target surface 131 sweep transform least squares propagate bias
volume 15 autosmooth target off
mesh volume 15

volume 27 redistribute nodes off
volume 27 scheme sweep source surface 131 target surface 186 sweep transform least squares propagate bias
volume 27 autosmooth target off
mesh volume 27

volume 26 redistribute nodes off
volume 26 scheme sweep source surface 186 target surface 188 sweep transform least squares propagate bias
volume 26 autosmooth target off
mesh volume 26

volume 28 redistribute nodes off
volume 28 scheme sweep source surface 188 target surface 143 sweep transform least squares propagate bias
volume 28 autosmooth target off
mesh volume 28

volume 16 redistribute nodes off
volume 16 scheme sweep source surface 143 target surface 141 sweep transform least squares propagate bias
volume 16 autosmooth target off
mesh volume 16



mesh volume 17 30 29 31 32 



# regions
block 1 add volume 12 26
block 1 name "V_dielec"
block 2 add volume 25 17 30 29 31 32 24 
block 2 name "V_air"
block 3 add volume 13 27
block 3 name "V_electrode_top"
block 4 add volume 15
block 4 name "V_feed_top"
block 5 add volume 14 28
block 5 name "V_electrode_bottom"
block 6 add volume 16
block 6 name "V_feed_bottom"



nodeset 1 add surface 223 225 230 243 245 
nodeset 1 name "S_air_outer"
nodeset 2 add surface 170 176
nodeset 2 name "S_air_top" 
nodeset 3 add surface 168 174
nodeset 3 name "S_air_bottom" 
nodeset 4 add surface 133
nodeset 4 name "S_electrode_top"
nodeset 5 add surface 141
nodeset 5 name "S_electrode_bottom"
nodeset 6 add surface all with y_coord=0
nodeset 6 name "S_symmetry_y"
nodeset 7 add surface all with x_coord=0
nodeset 7 name "S_symmetry_x"


volume all scale 1e-3

# export
export ansys cdb "capacitor_quarter.cdb"  overwrite 






















