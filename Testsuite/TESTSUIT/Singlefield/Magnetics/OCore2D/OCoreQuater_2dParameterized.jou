#!python
cubit.cmd('Journal Off');
import os;
import sys;
sys.path.append( os.path.realpath("..") );
from params import *;
cubit.cmd('create surface circle radius %f zplane ' % r_domain );
cubit.cmd('create surface circle radius %f zplane ' % r_core_outer );
cubit.cmd('subtract surface 2 from surface 1 ')
cubit.cmd('create surface circle radius %f zplane ' % r_core_outer );
cubit.cmd('create surface circle radius %f zplane ' % r_core_inner );
cubit.cmd('subtract surface 5 from surface 4 ')
cubit.cmd('create surface circle radius %f zplane ' % r_core_inner );
cubit.cmd('create surface circle radius %f zplane ' % r_wire );
cubit.cmd('subtract surface 8 from surface 7 ')
cubit.cmd('create surface circle radius %f zplane ' % r_wire );
cubit.cmd('merge curve all ');
cubit.cmd('webcut body all with plane xplane offset 0 merge ');
cubit.cmd('delete Body 8 9 10 11');
cubit.cmd('webcut body all with plane yplane offset 0 merge ');
cubit.cmd('delete Body 1 3 5 7');
cubit.cmd('set duplicate block elements off')
cubit.cmd('block 1 add surface 20 24 ')
cubit.cmd('block 1 name "air"')
cubit.cmd('set duplicate block elements off')
cubit.cmd('block 2 add surface 26 ')
cubit.cmd('block 2 name "wire"')
cubit.cmd('set duplicate block elements off')
cubit.cmd('block 3 add surface 22 ')
cubit.cmd('block 3 name "core"')
cubit.cmd('nodeset 1 add curve 43  ')
cubit.cmd('nodeset 1 name "fluxParallel"')
# mesh core compendium
cubit.cmd('surface 22  size 5.0e-3');
#reasonable mesh size
#cubit.cmd('surface 22  size auto factor 3');
cubit.cmd('mesh surface 22 ');
# mesh wire compendium
cubit.cmd('surface 26  size 1.5e-3');
#cubit.cmd('surface 26  size auto factor 9');
cubit.cmd('mesh surface 26 ');
# mesh air compendium
cubit.cmd('surface 24  size 5.0e-3');
#cubit.cmd('surface 24  size auto factor 7');
#reasonable mesh size
#cubit.cmd('surface 24  size auto factor 4');
cubit.cmd('mesh surface 24 ');
cubit.cmd('surface 20  size 8.0e-3');
#reasonable mesh size
#cubit.cmd('surface 20  size 1.5e-3');
cubit.cmd('mesh surface 20 ');
wd = os.getcwd();
#cubit.cmd('save trelis "%s/quater2d_parameterized.trelis" overwrite journal' % wd );
cubit.cmd('export ansys cdb "%s/OCoreQuater_2dParameterized.cdb"  overwrite ' % wd );
cubit.cmd('exit');
