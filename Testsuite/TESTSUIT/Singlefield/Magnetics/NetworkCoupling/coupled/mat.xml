<?xml version="1.0"?>

<cfsMaterialDataBase xmlns="http://www.cfs++.org/material">
  <!-- STANDARD LINEAR MATERIALS -->
  <material name="copper">
    <magnetic>
      <electricConductivity>
        <linear>
          <isotropic>
            <real>1/(pi*1)</real>
          </isotropic>
        </linear>
      </electricConductivity>
      <permeability>
        <linear>
          <isotropic>
            <real>(4*pi*1e-7)</real>
          </isotropic>
        </linear>
      </permeability>
    </magnetic>
  </material>

    <material name="air">
    <magnetic>
      <electricConductivity>
        <linear>
          <isotropic>
            <real>0</real>
          </isotropic>
        </linear>
      </electricConductivity>
      <permeability>
        <linear>
          <isotropic>
            <real>20000/pi*(4*pi*1e-7)</real>
          </isotropic>
        </linear>
      </permeability>
    </magnetic>
  </material>
 
</cfsMaterialDataBase>
