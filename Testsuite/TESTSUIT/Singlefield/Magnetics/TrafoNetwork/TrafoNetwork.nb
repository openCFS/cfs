Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"solve", " ", "for", " ", "a", " ", "non"}], "-", 
    RowBox[{"linear", " ", "BH", " ", 
     RowBox[{"curve", ":", " ", 
      RowBox[{"ploy", "-", "2"}]}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\[Nu]", " ", "=", " ", 
    RowBox[{
     RowBox[{"1", "/", "2"}], "+", 
     RowBox[{"B", "[", "t", "]"}]}]}], "\[IndentingNewLine]", 
   RowBox[{"solPoly2", " ", "=", " ", 
    RowBox[{"DSolve", "[", 
