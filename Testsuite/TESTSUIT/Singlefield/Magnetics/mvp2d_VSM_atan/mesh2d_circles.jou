reset
#
##############################
# GEOMETRY
##############################
# Circles
create surface circle radius 0.5 zplane
create surface circle radius 1 zplane
create surface circle radius 1.3 zplane
create surface circle radius 1.6 zplane
# Boolean operations
subtract surface 1 2 3 from surface 4 keep_tool
subtract surface 1 2 from surface 3 keep_tool
subtract surface 1 from surface 2 keep_tool
imprint all
merge all
##############################
# MESH
##############################
surface 1 7 6 5  scheme trimesh size 0.25
mesh surface 1 7 6 5
##############################
# BLOCKS AND NODESETS
##############################
block 1 add surface 1
block 1 name "S_1"
block 2 add surface 7
block 2 name "S_2"
block 3 add surface 6
block 3 name "S_3"
block 4 add surface 5
block 4 name "S_4"
nodeset 1 add curve 4
nodeset 1 name "L_outer"
##############################
# EXPORT
##############################
export ansys cdb "mesh2d_circles.cdb"  overwrite
