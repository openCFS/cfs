<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/simulation
  https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

  <documentation>
    <title>3D Lift Magnet with Energy-Based Hysteresis Model</title>
    <authors>
      <author>Manfred Kaltenbacher</author>
    </authors>
    <date>2025-01-23</date>
    <keywords>
      <keyword>magneticEdge</keyword>
      <keyword>transient</keyword>
      <keyword>hysteresis</keyword>
      <keyword>EBHysteresisModel</keyword>
    </keywords>
    <references>
      No references, functionality test.
    </references>
    <isVerified>yes</isVerified>
    <description>
      Two-step transient magnetic simulation of a lift magnet with hysteresis.
      Step 1: Compute source field using magneticEdge with mixedSFG formulation.
      Step 2: Solve magnetic scalar potential (Psi formulation) with EBHysteresisModel
      for the hysteretic iron regions (plate and core).
    </description>
  </documentation>

  <!-- define which files are needed for simulation input & output-->
  <fileFormats>
    <input>
      <hdf5 fileName="LiftMagnet_HystEBS.h5ref"/>
    </input>
    <output>
      <hdf5 id="hdf5"/>
      <text id="txt"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <variableList>
      <var name="i" value="1e7"/>
      <var name="N" value="1"/>
      <var name="A" value="1"/>
    </variableList>
    <regionList>
      <region name="V_plate" material="iron_hyst_EB1" />
      <region name="V_core" material="iron_hyst_EB2" />
      <region name="V_coil1" material="air"/>
      <region name="V_coil2" material="air"/>
      <region name="V_air" material="air"/>
    </regionList>
    <nodeList>
      <nodes name="N_gauge">
        <coord x="0" y="0.01e-3" z="0"/>
      </nodes>
    </nodeList>
  </domain>

  <fePolynomialList>
    <Legendre id="Hcurl">
      <isoOrder> 2 </isoOrder>
    </Legendre>
    <Lagrange id="H1">
      <isoOrder>1</isoOrder>
    </Lagrange>
    <Lagrange id="H11">
      <isoOrder>1</isoOrder>
    </Lagrange>
  </fePolynomialList>

  <sequenceStep index="1">
    <analysis>
      <transient>
        <numSteps>2</numSteps>
        <deltaT>0.2</deltaT>
        <allowPostProc>yes</allowPostProc>
      </transient>
    </analysis>

    <pdeList>
      <magneticEdge formulation="mixedSFG">
        <regionList>
          <region name="V_plate" VecPolyId="Hcurl" ScaPolyId="H1"/>
          <region name="V_core" VecPolyId="Hcurl" ScaPolyId="H1"/>
          <region name="V_coil1" VecPolyId="Hcurl" ScaPolyId="H1"/>
          <region name="V_coil2" VecPolyId="Hcurl" ScaPolyId="H1"/>
          <region name="V_air" VecPolyId="Hcurl" ScaPolyId="H1"/>
        </regionList>

        <coilList>
          <coil id="coil1">
            <source type="current" value="i*N*sin(t)"/>
            <part id="1">
              <regionList>
                <region name="V_coil1"/>
              </regionList>
              <direction>
                <analytic>
                  <comp dof="z" value="1.0"/>
                </analytic>
              </direction>
              <wireCrossSection area="A"/>
            </part>
          </coil>
          <coil id="coil2">
            <source type="current" value="i*N*sin(t)"/>
            <part id="1">
              <regionList>
                <region name="V_coil2"/>
              </regionList>
              <direction>
                <analytic>
                  <comp dof="z" value="-1.0"/>
                </analytic>
              </direction>
              <wireCrossSection area="A"/>
            </part>
          </coil>
        </coilList>
        <storeResults>
          <elemResult type="magFieldIntensity">
            <allRegions outputIds="hdf5"/>
          </elemResult>
        </storeResults>
      </magneticEdge>
    </pdeList>
  </sequenceStep>

  <sequenceStep index="2">
    <analysis>
      <transient initialTime="zero">
        <numSteps>2</numSteps>
        <deltaT>0.2</deltaT>
      </transient>
    </analysis>


    <pdeList>
      <magnetic formulation="Psi">
        <regionList>
          <region name="V_plate" polyId="H11" nonLinIds="nl1"/>
          <region name="V_core" polyId="H11" nonLinIds="nl1"/>
          <region name="V_coil1" polyId="H11"/>
          <region name="V_coil2" polyId="H11"/>
          <region name="V_air" polyId="H11"/>
        </regionList>

        <nonLinList>
          <permeability id="nl1" model="EBHysteresisModel" />
        </nonLinList>

        <bcsAndLoads>
          <potential name="N_gauge" value="0"/>
          <fieldIntensity name="V_plate">
            <sequenceStep index="1">
              <quantity name="magFieldIntensity" pdeName="magneticEdgeMixedSFG" />
              <timeFreqMapping>
                <continuous  interpolation="linear"/>
              </timeFreqMapping>
            </sequenceStep>
          </fieldIntensity>
          <fieldIntensity name="V_core">
            <sequenceStep index="1">
              <quantity name="magFieldIntensity" pdeName="magneticEdgeMixedSFG" />
              <timeFreqMapping>
                <continuous  interpolation="linear"/>
              </timeFreqMapping>
            </sequenceStep>
          </fieldIntensity>

          <fieldIntensity name="V_coil1">
            <sequenceStep index="1">
              <quantity name="magFieldIntensity" pdeName="magneticEdgeMixedSFG" />
              <timeFreqMapping>
                <continuous  interpolation="linear"/>
              </timeFreqMapping>
            </sequenceStep>
          </fieldIntensity>
          <fieldIntensity name="V_coil2">
            <sequenceStep index="1">
              <quantity name="magFieldIntensity" pdeName="magneticEdgeMixedSFG" />
              <timeFreqMapping>
                <continuous  interpolation="linear"/>
              </timeFreqMapping>
            </sequenceStep>
          </fieldIntensity>

          <fieldIntensity name="V_air">
            <sequenceStep index="1">
              <quantity name="magFieldIntensity" pdeName="magneticEdgeMixedSFG" />
              <timeFreqMapping>
                <continuous  interpolation="linear"/>
              </timeFreqMapping>
            </sequenceStep>
          </fieldIntensity>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="magPotential">
           <allRegions />
          </nodeResult>
          <elemResult type="magFluxDensity">
           <allRegions />
          </elemResult>
          <elemResult type="magFieldIntensity">
           <allRegions />
          </elemResult>
        </storeResults>
      </magnetic>
    </pdeList>
    <linearSystems>
      <system>
      <solutionStrategy>
        <standard>
          <nonLinear logging="yes" method="fixPoint" >
                <lineSearch type="minEnergy"/>
                <incStopCrit>100000</incStopCrit>
                <resStopCrit>1e-5</resStopCrit>
                <maxNumIters>100</maxNumIters>
                <abortOnMaxNumIters>no</abortOnMaxNumIters>
          </nonLinear>
        </standard>
      </solutionStrategy>
      </system>
    </linearSystems>
  </sequenceStep>

</cfsSimulation>
