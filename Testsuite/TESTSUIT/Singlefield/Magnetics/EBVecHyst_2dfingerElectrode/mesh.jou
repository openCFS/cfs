

reset
undo on

create surface rectangle width 1 height 1 zplane 
# electrode right
create vertex location 0.5 -0.5 0 
create vertex location 0.5 0.5 0 
create vertex location -0.25 0.5 0 
create vertex location -0.25 0.375 0 
create vertex location 0.375 0.375 0 
create vertex location 0.375 0 0 
create vertex location -0.25 0 0 
create vertex location -0.25 -0.125 0 
create vertex location 0.375 -0.125 0 
create vertex location 0.375 -0.5 0 
#electrode left
create vertex location -0.5 -0.5 0 
create vertex location -0.5 0.25 0 
create vertex location 0.25 0.25 0 
create vertex location 0.25 0.125 0 
create vertex location -0.375 0.125 0 
create vertex location -0.375 -0.25 0 
create vertex location 0.25 -0.25 0
create vertex location 0.25 -0.375 0  
create vertex location -0.375 -0.375 0  
create vertex location -0.375 -0.5 0  

create surface vertex 4 1 7 8 9 10 11 12 13 14
create surface vertex 3 16 17 18 19 20 21 22 23 24
delete Vertex 5 6 15

subtract surface 2 from surface 1 keep_tool 
subtract surface 3 from surface 4 keep_tool 

delete Body 2 3


surface all scheme trimesh size 0.05
mesh surface all


	
nodeset 1 add curve 26 36
nodeset 1 name "S_out"
nodeset 2 add curve 34
nodeset 2 name "S_in"


block 3 add surface 5 
block 3 name "S_probe"

export ansys cdb "mesh.cdb" overwrite
