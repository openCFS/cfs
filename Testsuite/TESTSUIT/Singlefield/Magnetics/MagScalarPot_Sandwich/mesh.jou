reset
undo on


brick x 3 y 3 z 3
webcut volume all with zplane offset 0.5
webcut volume all with zplane offset -0.5


merge all
imprint all


volume all scheme map
volume all size 1
mesh volume all

block 1 add volume 1 
block 1 name "V_air_top"

block 3 add volume 3 
block 3 name "V_air_bottom"

block 2 add volume 2
block 2 name "V_core"


nodeset 1 add surface 1
nodeset 1 name "S_z_pos"

nodeset 2 add surface 2
nodeset 2 name "S_z_neg"

nodeset 3 add surface 23 21 8 
nodeset 3 name "S_y_pos"

nodeset 4 add surface 10 19 25 
nodeset 4 name "S_y_neg"

nodeset 5 add surface 11 20 24 
nodeset 5 name "S_x_pos"

nodeset 6 add surface 26 18 9 
nodeset 6 name "S_x_neg"


export ansys cdb "mesh.cdb" overwrite











