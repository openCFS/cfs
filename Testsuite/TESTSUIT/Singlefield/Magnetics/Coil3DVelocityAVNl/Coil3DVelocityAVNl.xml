<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
  <documentation>
    <title>nonlinear Permeability for A-V-Formulation</title>
    <authors>
      <author>Isabella Singer</author>
    </authors>
    <date>2025-08-10</date>
    <keywords>
      <keyword>magneticEdge</keyword>
    </keywords>
    <references>Diploma Thesis; Lukas Schafferhofer</references>
    <isVerified>yes</isVerified>
    <description> derived testcase from Coil3DVelocityAV: testcase for the implementation of nonlinear permeability for static analysis in MagEdgeMixedAVPDE.cc
    </description>
  </documentation>
    <fileFormats>
        <input>
            <!-- Only Necessary to read in a finer mesh for the validation-->
            <!--gmsh fileName="Coil3DVelocityAV.msh"/-->
            <hdf5 fileName="Coil3DVelocityAVNl.h5ref"/>
        </input>
        <output>
            <hdf5/>
            <text id="txt"/>
            <csv id="csv"/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>
    <domain geometryType="3d">
        <variableList>
          <var name="H_R" value="0.01"/>
          <var name="W_R" value="0.01"/>
          <var name="L" value="0.2"/>
        </variableList>
        <regionList>
            <region name="Rail" material="steel"></region>
            <region name="Core" material="steel"> </region>
            <region name="Coil1" material="copper" ></region>
            <region name="Coil2" material="copper" ></region>
            <region name="Air_Coarse" material="air" ></region>
            <region name="Air_Fine" material="air" ></region>
        </regionList>
        <surfRegionList>
            <surfRegion name="schiene_vorne" />
            <surfRegion name="schiene_hinten" />
            <surfRegion name="luft_aussen" />
            <surfRegion name="luft_vertikal_sym" />
            <surfRegion name="schiene_vertikal_sym" />
            <surfRegion name="Kern_vertikal_sym" />
            <surfRegion name="Spule1_ground" />
            <surfRegion name="Spule1_voltage" />
            <surfRegion name="Spule2_ground" />
            <surfRegion name="Spule2_voltage" />
            <surfRegion name="flux" />
            <surfRegion name="current" />
        </surfRegionList>        
    </domain>

    <fePolynomialList>
        <Legendre id="Hcurl">
            <isoOrder>0</isoOrder>
        </Legendre>
        <Lagrange id="H1">
            <isoOrder>1</isoOrder>
        </Lagrange>
    </fePolynomialList>
    
    <sequenceStep index="1">
        <analysis>
            <static/>
        </analysis>
        <pdeList>
            <magneticEdge formulation="A-V">
                <regionList>
                    <region name="Rail" nonLinIds="p" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="true" velocityId="velId1"/>
                    <region name="Core" nonLinIds="p" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false"/>
                    <region name="Coil1" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false" />
                    <region name="Coil2" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false"/>
                    <region name="Air_Coarse" magVecPolyId="Hcurl" elecScalPolyId="H1"/>
                    <region name="Air_Fine" magVecPolyId="Hcurl" elecScalPolyId="H1"/>  
                </regionList>
                <nonLinList>
                    <permeability id="p"/>
                </nonLinList>
                <velocityList>
                    <velocity name="velId1">
                        <comp dof="x" value="0"/>
                        <comp dof="y" value="0"/>
                        <comp dof="z" value="1"/>
                    </velocity>
                </velocityList>
                <bcsAndLoads>
                    <!-- outer regions -->
                    <fluxParallel name="schiene_vorne"/>
                    <fluxParallel name="schiene_hinten"/>
                    <fluxParallel name="luft_aussen"/>
                    <fluxParallel name="Spule1_voltage"/>
                    <fluxParallel name="Spule2_voltage"/>
                    <elecPotential name="schiene_vorne" value="0" />
                    <elecPotential name="schiene_hinten" value="0"/>
                    <!-- vertical symmetry -->
                    <fluxParallel name="Spule1_ground"/>
                    <fluxParallel name="Spule2_ground"/>
                    <fluxParallel name="luft_vertikal_sym"/>
                    <fluxParallel name="schiene_vertikal_sym"/>
                    <fluxParallel name="Kern_vertikal_sym"/>
                    <elecPotential name="schiene_vertikal_sym" value="0"/>
                </bcsAndLoads>
                <coilList>
                    <coil id="coil1">
                        <source type="current" value="1E9"/>
                        <part id="SPULE_1">
                            <regionList>
                                <region name="Coil1"/>
                            </regionList>
                            <direction>
                              <analytic>
                                <comp dof="x" value="1" />
                              </analytic>
                            </direction>
                            <wireCrossSection area="1"/>
                            <resistance value="0"/>
                        </part>
                    </coil>
                    <coil id="coil2">
                        <source type="current" value="1E9"/>
                        <part id="SPULE_2">
                            <regionList>
                                <region name="Coil2"/>
                            </regionList>
                            <direction>
                              <analytic>
                                <comp dof="x" value="-1" />
                              </analytic>
                            </direction>
                            <wireCrossSection area="1"/>
                            <resistance value="0"/>
                        </part>
                    </coil>
                </coilList>
                <storeResults>
                    <sensorArray fileName="sensorArray/flux_rail_v1.csv" type="magFluxDensity" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="W_R/4" stop="W_R/4" inc="0"/>
                          <list comp="y" start="H_R/2-1E-3" stop="H_R/2-1E-3" inc="0"/>
                          <list comp="z" start="-L/2" stop="L/2" inc="0.5E-3" />
                        </parametric>
                    </sensorArray>
                    <sensorArray fileName="sensorArray/current_rail_v1.csv" type="magTotalCurrentDensity" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="W_R/4" stop="W_R/4" inc="0"/>
                          <list comp="y" start="H_R/2-1E-3" stop="H_R/2-1E-3" inc="0"/>
                          <list comp="z" start="-L/2" stop="L/2" inc="0.5E-3" />
                        </parametric>
                    </sensorArray>
                    <elemResult type="magFluxDensity">
                        <allRegions/>
                    </elemResult>
                    <elemResult type="magTotalCurrentDensity">
                        <allRegions/>
                    </elemResult>
                    <nodeResult type="elecPotential">
                        <allRegions />
                    </nodeResult>
                    <!--The following results are only necessary for the validation-->
                    <!--surfRegionResult type="magTotalCurrent">
                        <surfRegionList>
                            <surfRegion name="current" outputIds="csv"/>
                        </surfRegionList>
                    </surfRegionResult>
                    <surfRegionResult type="magFlux">
                        <surfRegionList>
                            <surfRegion name="flux" outputIds="csv"/>
                        </surfRegionList>
                    </surfRegionResult>
                    <sensorArray fileName="sensorArray/flux_rail.csv" type="magFluxDensity" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="W_R/4" stop="W_R/4" inc="0"/>
                          <list comp="y" start="H_R/2-1E-3" stop="H_R/2-1E-3" inc="0"/>
                          <list comp="z" start="-L/2" stop="L/2" inc="0.5E-3" />
                        </parametric>
                    </sensorArray>
                    <sensorArray fileName="sensorArray/current_rail.csv" type="magTotalCurrentDensity" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="W_R/4" stop="W_R/4" inc="0"/>
                          <list comp="y" start="H_R/2-1E-3" stop="H_R/2-1E-3" inc="0"/>
                          <list comp="z" start="-L/2" stop="L/2" inc="0.5E-3" />
                        </parametric>
                    </sensorArray-->
                </storeResults>
            </magneticEdge>
        </pdeList>  
        <linearSystems>
            <system>
              <solutionStrategy>
                <standard>
                    <nonLinear logging="yes" method="newton">
                        <lineSearch type="minEnergy"/>
                        <incStopCrit> 1e-3</incStopCrit>
                        <resStopCrit> 1e-3</resStopCrit>
                        <maxNumIters> 100 </maxNumIters>
                    </nonLinear>
                </standard>
              </solutionStrategy>
            </system>
        </linearSystems>  
    </sequenceStep>
</cfsSimulation>
