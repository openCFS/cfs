<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
  <documentation>
    <title>Considering EMF term in the A-V,A magnetics</title>
    <authors>
      <author>Lukas Schafferhofer</author>
    </authors>
    <date>2023-09-10</date>
    <keywords>
      <keyword>magneticEdge</keyword>
    </keywords>
    <references>Diploma Thesis; Lukas Schafferhofer</references>
    <isVerified>yes</isVerified>
    <description>A ferromagnetic (linear material) and conducting body is moving with constant velocity through a magnetic field caused by two current driven coils,
    which leads to motion-induced eddy currents in the moving conductor. Since the geometry of the moving conductor is invariant to the velocity the problem can be 
    solved with a static formulation which includes the velocity term.
    This testcase is validated with the commercial software Opera from Dassault Systemes. For the validation the magnetic flux through the pole face, the current in the 
    moving conductor through a defined surface and the field results in the moving conductor along a line in velocity direction are compared. The comparison can be found 
    in "Validation.ipynb". In order to do the simulation with Opera, one can use the script "preprocessingOpera.comi" in the modeller of Opera to create the geometry of 
    this testcase and define the boundary conditions, the velocity, the materials and the mesh. Afterwards the necessary results for the comparison can be obtained with 
    the script "postprocessingOpera.comi" using Opera's postprocessor.
    </description>
  </documentation>
    <fileFormats>
        <input>
            <!-- Only Necessary to read in a finer mesh for the validation-->
            <!--gmsh fileName="Coil3DVelocityAV.msh"/-->
            <hdf5 fileName="Coil3DVelocityAV.h5ref"/>
        </input>
        <output>
            <hdf5/>
            <text id="txt"/>
            <csv id="csv"/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>
    <domain geometryType="3d">
        <variableList>
          <var name="H_R" value="0.01"/>
          <var name="W_R" value="0.01"/>
          <var name="L" value="0.2"/>
          <var name="A" value="0.002"/>
          <var name="H_I" value="0.002"/>
          <var name="L_I" value="0.01"/>
          <var name="W_C" value="0.002"/>
          <var name="DELTA" value="0.00001"/>
          <var name="DELTA_2" value="0.0001"/>
          <var name="NP_RAIL" value="300"/>
          <var name="NP_CORE" value="150"/>
          <var name="P" value="-0.03"/>
        </variableList>
        <regionList>
            <region name="Rail" material="steel"></region>
            <region name="Core" material="steel"> </region>
            <region name="Coil1" material="copper" ></region>
            <region name="Coil2" material="copper" ></region>
            <region name="Air_Coarse" material="air" ></region>
            <region name="Air_Fine" material="air" ></region>
        </regionList>
        <surfRegionList>
            <surfRegion name="schiene_vorne" />
            <surfRegion name="schiene_hinten" />
            <surfRegion name="luft_aussen" />
            <surfRegion name="luft_vertikal_sym" />
            <surfRegion name="schiene_vertikal_sym" />
            <surfRegion name="schiene_horizontal_sym" />
            <surfRegion name="Kern_vertikal_sym" />
            <surfRegion name="Spule1_ground" />
            <surfRegion name="Spule1_voltage" />
            <surfRegion name="Spule2_ground" />
            <surfRegion name="Spule2_voltage" />
            <surfRegion name="flux" />
            <surfRegion name="current" />
        </surfRegionList>
        <coordSysList>
            <cylindric id="coord_cyl">
                <origin x="0" y="0" z="0"/>
                <zAxis x="0" y="1" z="0"/>
                <rAxis x="1" y="0" z="0"/>
            </cylindric>
        </coordSysList>
        
        
    </domain>

    <fePolynomialList>
        <Legendre id="Hcurl">
            <isoOrder>0</isoOrder>
        </Legendre>
        <Lagrange id="H1">
            <isoOrder>1</isoOrder>
        </Lagrange>
    </fePolynomialList>
    
    <sequenceStep index="1">
        <analysis>
            <static/>
        </analysis>
        <pdeList>
            <magneticEdge formulation="A-V">
                <regionList>
                    <region name="Rail" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="true" velocityId="velId1"/>
                    <region name="Core" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false"/>
                    <region name="Coil1" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false" />
                    <region name="Coil2" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false"/>
                    <region name="Air_Coarse" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false"/>
                    <region name="Air_Fine" magVecPolyId="Hcurl" elecScalPolyId="H1" isConducRegion="false"/>                    
                </regionList>
                <velocityList>
                    <velocity name="velId1">
                        <comp dof="x" value="0"/>
                        <comp dof="y" value="0"/>
                        <comp dof="z" value="1"/>
                    </velocity>
                </velocityList>
                <bcsAndLoads>
                    <!-- outer regions -->
                    <fluxParallel name="schiene_vorne"/>
                    <fluxParallel name="schiene_hinten"/>
                    <fluxParallel name="luft_aussen"/>
                    <fluxParallel name="Spule1_voltage"/>
                    <fluxParallel name="Spule2_voltage"/>
                    <elecPotential name="schiene_vorne" value="0" />
                    <elecPotential name="schiene_hinten" value="0"/>


                    <!-- vertical symmetry -->
                    <fluxParallel name="Spule1_ground"/>
                    <fluxParallel name="Spule2_ground"/>
                    <fluxParallel name="luft_vertikal_sym"/>
                    <fluxParallel name="schiene_vertikal_sym"/>
                    <fluxParallel name="Kern_vertikal_sym"/>

                    <elecPotential name="schiene_vertikal_sym" value="0"/>

                </bcsAndLoads>
                <coilList>
                    <coil id="coil1">
                        <source type="current" value="2E8"/>
                        <part id="SPULE_1">
                            <regionList>
                                <region name="Coil1"/>
                            </regionList>
                            <direction>
                              <analytic>
                                <comp dof="x" value="1" />
                              </analytic>
                            </direction>
                            <wireCrossSection area="1"/>
                            <resistance value="0"/>
                        </part>
                    </coil>
                    <coil id="coil2">
                        <source type="current" value="2E8"/>
                        <part id="SPULE_2">
                            <regionList>
                                <region name="Coil2"/>
                            </regionList>
                            <direction>
                              <analytic>
                                <comp dof="x" value="-1" />
                              </analytic>
                            </direction>
                            <wireCrossSection area="1"/>
                            <resistance value="0"/>
                        </part>
                    </coil>
                </coilList>
                <storeResults>
                    <elemResult type="magFluxDensity">
                        <allRegions/>
                    </elemResult>
                    <elemResult type="magTotalCurrentDensity">
                        <allRegions/>
                    </elemResult>
                    <!--The following results are only necessary for the validation-->
                    <!--surfRegionResult type="magTotalCurrent">
                        <surfRegionList>
                            <surfRegion name="current" outputIds="csv"/>
                        </surfRegionList>
                    </surfRegionResult>
                    <surfRegionResult type="magFlux">
                        <surfRegionList>
                            <surfRegion name="flux" outputIds="csv"/>
                        </surfRegionList>
                    </surfRegionResult>
                    <sensorArray fileName="sensorArray/flux_rail.csv" type="magFluxDensity" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="W_R/4" stop="W_R/4" inc="0"/>
                          <list comp="y" start="H_R/2-1E-3" stop="H_R/2-1E-3" inc="0"/>
                          <list comp="z" start="-L/2" stop="L/2" inc="0.5E-3" />
                        </parametric>
                    </sensorArray>
                    <sensorArray fileName="sensorArray/current_rail.csv" type="magTotalCurrentDensity" csv="yes" delimiter=",">
                        <parametric>
                          <list comp="x" start="W_R/4" stop="W_R/4" inc="0"/>
                          <list comp="y" start="H_R/2-1E-3" stop="H_R/2-1E-3" inc="0"/>
                          <list comp="z" start="-L/2" stop="L/2" inc="0.5E-3" />
                        </parametric>
                    </sensorArray-->
                </storeResults>
            </magneticEdge>
        </pdeList>     
    </sequenceStep>
</cfsSimulation>
