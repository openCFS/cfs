FILTER TYPE=FACE
FILTER COMMAND=PICK
PICK OPTION=TOGGLE TYPE=FACE UNIQUEBODYNAME='ModelBody' IDENTIFIER=CT.00006
PICK OPTION=TOGGLE TYPE=FACE UNIQUEBODYNAME='ModelBody' IDENTIFIER=CV.00006
