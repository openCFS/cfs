/layer rail
FILTER TYPE=FACE
FILTER COMMAND=PICK
PICK OPTION=TOGGLE TYPE=FACE UNIQUEBODYNAME='ModelBody' IDENTIFIER=CT.00007
PICK OPTION=TOGGLE TYPE=FACE UNIQUEBODYNAME='ModelBody' IDENTIFIER=CV.00007
