PICK OPTION=TOGGLE TYPE=FACE UNIQUEBODYNAME='ModelBody' IDENTIFIER=CZ.00008
PICK OPTION=TOGGLE TYPE=FACE UNIQUEBODYNAME='ModelBody' IDENTIFIER=CX.00008
FACEDATA OPTION=MODIFY ELEMENTTYPE=Linear FORMETHOD=NONE BACKMETHOD=MESH BACKLAYERS=#ind BACKOFFSET=(#H_R/2)/#ind
PICK OPTION=RESET
/ Create Mesh
/VARIABLE OPTION=CONSTANT NAME=#MAXEDGEHDLPTS  VALUE=256  DESCRIPTION='higher value if you are not interested in local field in the coil'

MESH GENERATOR=AUTOMATIC SIZE=#mesh_air_coarse NORMALTOL=30.0 SURFACETOL=0.0 TOLERANCE=1.0E-06 TYPE=MOSAIC
/MESH GENERATOR=AUTOMATIC SIZE=#mesh_air_coarse NORMALTOL=30.0 SURFACETOL=0.0 TOLERANCE=1.0E-06 TYPE=TETRAHEDRAL
FILL TOL=1.0E-06

SAVE OPTION=MESH FILE='Coil_Velocity.opcb'
SOLVERS ELEMENT=LINEAR,| SOLVERS SOLVENOW=NO SAVEMODEL=YES, | SOLVERS OPTION=OVERWRITE FILE='Coil_Velocity.op3' UNITS=METRE SURFACE=LINEAR | COMMENT CLEAR=YES TYPE=DBTITLE | SOLVERS OPTION=OVERWRITE

$FOR #velocity 10 1 0
VOLUME PICK 'Rail'
VOLUME OPTION=MODIFY THETA=0 PHI=0 PSI=0 VZ=#velocity
VOLUME UNPICK
SOLVERS SOLVENOW=NO SAVEMODEL=YES OPTION=ADD,  | COMMENT CLEAR=YES TYPE=ADDTITLE | SOLVERS FILE='Coil_Velocity.op3'

$END FOR


$OS OPERAANL WRD2=SOLVE WRD4=BACK WRD3='Coil_Velocity.op3'

