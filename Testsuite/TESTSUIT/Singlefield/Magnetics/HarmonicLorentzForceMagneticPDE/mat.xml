<?xml version="1.0" encoding="UTF-8"?>
<cfsMaterialDataBase
	xmlns="http://www.cfs++.org/material"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.cfs++.org/material 
https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd">
	<material name="air">
		<elecConduction>
			<electricConductivity>
				<linear>
					<isotropic>
						<real>1.2566E-06</real>
					</isotropic>
				</linear>
			</electricConductivity>
		</elecConduction>
		<magnetic>
			<electricConductivity>
				<linear>
					<isotropic>
						<real>1.2566E-06</real>
					</isotropic>
				</linear>
			</electricConductivity>
			<permeability>
				<linear>
					<isotropic>
						<real>1.256637565e-6</real>
					</isotropic>
				</linear>
			</permeability>
		</magnetic>
	</material>
  
  <material name="copper">
    <mechanical>
      <density>
        <linear>
          <real>8960</real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <isotropic>
            <elasticityModulus>
              <real>100E+9</real>
            </elasticityModulus>
            <poissonNumber>
              <real>0.33</real>
            </poissonNumber>
          </isotropic>
        </linear>
      </elasticity>
    </mechanical>
    <elecConduction>
      <electricConductivity>
        <linear>
          <isotropic>
            <real>5.96e+7</real>
          </isotropic>
        </linear>
      </electricConductivity>
    </elecConduction>
    <magnetic>
      <electricConductivity>
        <linear>
          <isotropic>
            <real>5.96e+7</real>
          </isotropic>
        </linear>
      </electricConductivity>
      <permeability>
        <linear>
          <isotropic>
            <real>1.25662902e-6</real>
          </isotropic>
        </linear>
      </permeability>
    </magnetic>
  </material>
  
</cfsMaterialDataBase>
