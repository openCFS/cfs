<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.cfs++.org/simulation" xsi:schemaLocation="http://www.cfs++.org/simulation ../../../../../share/xml/CFS-Simulation/CFS.xsd">
  <documentation>
    <title>Pyramid as HEX-TET interface</title>
    <authors>
      <author>Klaus Roppert</author>
    </authors>
    <date>2025-07-14</date>
    <keywords>
      <keyword>coil</keyword>
      <keyword>static</keyword>
    </keywords>
    <references>none</references>
    <isVerified>no</isVerified>
    <description>
      The geometry consists of two quadratic bricks, upper one meshed with HEX and the lower one
      with TET (and cubit generates the pyramids in the TET region automatically).
      The current density has a constant value in negative y direction, resulting (right hand side
      rule) in a circulating field through the two bricks (and through the pyra layer
      between the HEX and TET).
      There is no analytic solution available for this problem.
      The first two steps generate the uniform current field in the upper and lower block.
      Steps 3-6 use pyras of increasing order from 0 to 3.
      In step 3 the current density is applied anaytically just to check if there is a difference between specifying the analytical field and using results from elecConduction.
    </description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="Pyra3DCube.h5ref"/>
    </input>
    <output>
      <hdf5 />
      <text id="txt" />
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="3d">
    <variableList>
      <var name="J_i" value="10000000" />

    </variableList>

    <regionList>
      <region name="V_Upper" material="copper" />
      <region name="V_Lower" material="copper" />
    </regionList>
  </domain>


  <fePolynomialList>
    <Legendre id="poly0">
      <isoOrder>0</isoOrder>
    </Legendre>
    <Legendre id="poly1">
      <isoOrder>1</isoOrder>
    </Legendre>
    <Legendre id="poly2">
      <isoOrder>2</isoOrder>
    </Legendre>
    <Legendre id="poly3">
      <isoOrder>3</isoOrder>
    </Legendre>
  </fePolynomialList>


  <sequenceStep index="1">
    <analysis>
      <static />
    </analysis>
    <pdeList>
      <elecConduction>
        <regionList>
          <region name="V_Lower" />
        </regionList>
        <bcsAndLoads>
          <ground name="S_CurrentOut_lower" />
          <potential name="S_CurrentIn_lower" value="1" />
        </bcsAndLoads>
        <storeResults>
          <elemResult type="elecCurrentDensity">
            <allRegions />
          </elemResult>
        </storeResults>
      </elecConduction>
    </pdeList>
  </sequenceStep>

  <sequenceStep index="2">
    <analysis>
      <static />
    </analysis>
    <pdeList>
      <elecConduction>
        <regionList>
          <region name="V_Upper" />
        </regionList>
        <bcsAndLoads>
          <ground name="S_CurrentOut_upper" />
          <potential name="S_CurrentIn_upper" value="1" />
        </bcsAndLoads>
        <storeResults>
          <elemResult type="elecCurrentDensity">
            <allRegions />
          </elemResult>
        </storeResults>
      </elecConduction>
    </pdeList>
  </sequenceStep>


  <!-- Poly order 0 -->
  <sequenceStep index="3">
    <analysis>
      <static />
    </analysis>

    <pdeList>
      <magneticEdge formulation="A" >
        <regionList>
          <region name="V_Upper" polyId="poly0" />
          <region name="V_Lower" polyId="poly0" />
        </regionList>

        <bcsAndLoads>
          <fluxParallel name="S_Outer" />
        </bcsAndLoads>

        <coilList>
          <coil id="coil_Lower">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Lower" />
              </regionList>
              <direction>
                <analytic>
                  <comp dof="y" value="-1" />
                </analytic>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>

          <coil id="coil_Upper">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Upper" />
              </regionList>
              <direction>
                <analytic>
                  <comp dof="y" value="-1" />
                </analytic>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>
        </coilList>

        <storeResults>
          <elemResult type="magPotential">
            <allRegions />
          </elemResult>
          <elemResult type="magFluxDensity">
            <allRegions />
          </elemResult>

          <elemResult type="magFieldIntensity">
            <allRegions />
          </elemResult>

          <elemResult type="magTotalCurrentDensity">
            <allRegions />
          </elemResult>

        </storeResults>
      </magneticEdge>
    </pdeList>
  </sequenceStep>



  <!-- Poly order 1 -->
  <sequenceStep index="4">
    <analysis>
      <static />
    </analysis>

    <pdeList>
      <magneticEdge formulation="A" >
        <regionList>
          <region name="V_Upper" polyId="poly1" />
          <region name="V_Lower" polyId="poly1" />
        </regionList>

        <bcsAndLoads>
          <fluxParallel name="S_Outer" />
        </bcsAndLoads>

        <coilList>
          <coil id="coil_Lower">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Lower" />
              </regionList>
              <direction>
                <external normalise="yes">
                  <sequenceStep index="1">
                    <quantity name="elecCurrentDensity"
                      pdeName="elecConduction" />
                    <timeFreqMapping>
                      <constant step="1" />
                    </timeFreqMapping>
                  </sequenceStep>
                </external>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>

          <coil id="coil_Upper">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Upper" />
              </regionList>
              <direction>
                <external normalise="yes">
                  <sequenceStep index="2">
                    <quantity name="elecCurrentDensity"
                      pdeName="elecConduction" />
                    <timeFreqMapping>
                      <constant step="1" />
                    </timeFreqMapping>
                  </sequenceStep>
                </external>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>
        </coilList>

        <storeResults>
          <elemResult type="magPotential">
            <allRegions />
          </elemResult>
          <elemResult type="magFluxDensity">
            <allRegions />
          </elemResult>

          <elemResult type="magFieldIntensity">
            <allRegions />
          </elemResult>

          <elemResult type="magTotalCurrentDensity">
            <allRegions />
          </elemResult>

        </storeResults>
      </magneticEdge>
    </pdeList>
  </sequenceStep>




  <!-- Poly order 2  -->
  <sequenceStep index="5">
    <analysis>
      <static />
    </analysis>

    <pdeList>
      <magneticEdge formulation="A">
        <regionList>
          <region name="V_Upper" polyId="poly2" />
          <region name="V_Lower" polyId="poly2" />
        </regionList>

        <bcsAndLoads>
          <fluxParallel name="S_Outer" />
        </bcsAndLoads>

        <coilList>
          <coil id="coil_Lower">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Lower" />
              </regionList>
              <direction>
                <external normalise="yes">
                  <sequenceStep index="1">
                    <quantity name="elecCurrentDensity"
                      pdeName="elecConduction" />
                    <timeFreqMapping>
                      <constant step="1" />
                    </timeFreqMapping>
                  </sequenceStep>
                </external>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>

          <coil id="coil_Upper">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Upper" />
              </regionList>
              <direction>
                <external normalise="yes">
                  <sequenceStep index="2">
                    <quantity name="elecCurrentDensity"
                      pdeName="elecConduction" />
                    <timeFreqMapping>
                      <constant step="1" />
                    </timeFreqMapping>
                  </sequenceStep>
                </external>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>
        </coilList>

        <storeResults>
          <elemResult type="magPotential">
            <allRegions />
          </elemResult>
          <elemResult type="magFluxDensity">
            <allRegions />
          </elemResult>

          <elemResult type="magFieldIntensity">
            <allRegions />
          </elemResult>

          <elemResult type="magTotalCurrentDensity">
            <allRegions />
          </elemResult>

        </storeResults>
      </magneticEdge>
    </pdeList>
  </sequenceStep>



  <!-- Poly order 3  -->
  <sequenceStep index="6">
    <analysis>
      <static />
    </analysis>

    <pdeList>
      <magneticEdge formulation="A">
        <regionList>
          <region name="V_Upper" polyId="poly3" />
          <region name="V_Lower" polyId="poly3" />
        </regionList>

        <bcsAndLoads>
          <fluxParallel name="S_Outer" />
        </bcsAndLoads>

        <coilList>
          <coil id="coil_Lower">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Lower" />
              </regionList>
              <direction>
                <external normalise="yes">
                  <sequenceStep index="1">
                    <quantity name="elecCurrentDensity"
                      pdeName="elecConduction" />
                    <timeFreqMapping>
                      <constant step="1" />
                    </timeFreqMapping>
                  </sequenceStep>
                </external>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>

          <coil id="coil_Upper">
            <source type="current" value="J_i" />
            <part id="1">
              <regionList>
                <region name="V_Upper" />
              </regionList>
              <direction>
                <external normalise="yes">
                  <sequenceStep index="2">
                    <quantity name="elecCurrentDensity"
                      pdeName="elecConduction" />
                    <timeFreqMapping>
                      <constant step="1" />
                    </timeFreqMapping>
                  </sequenceStep>
                </external>
              </direction>
              <wireCrossSection area="1" />
            </part>
          </coil>
        </coilList>

        <storeResults>
          <elemResult type="magPotential">
            <allRegions />
          </elemResult>
          <elemResult type="magFluxDensity">
            <allRegions />
          </elemResult>

          <elemResult type="magFieldIntensity">
            <allRegions />
          </elemResult>

          <elemResult type="magTotalCurrentDensity">
            <allRegions />
          </elemResult>

        </storeResults>
      </magneticEdge>
    </pdeList>
  </sequenceStep>

</cfsSimulation>