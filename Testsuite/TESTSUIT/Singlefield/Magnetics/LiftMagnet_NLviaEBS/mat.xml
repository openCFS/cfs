<?xml version="1.0"?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/material https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd">

 <material name="air">
  <acoustic>
   <density>
    <linear>
     <real> 1.204 </real>
    </linear>
   </density>
   <compressionModulus>
    <linear>
     <real> 1.41855E+05 </real>
    </linear>
   </compressionModulus>
  </acoustic>
  <magnetic>
   <electricConductivity>
    <linear>
     <isotropic>
      <real>0</real>
     </isotropic>
    </linear>
   </electricConductivity>
   <permeability>
    <linear>
     <isotropic>
      <real> 1.256637061E-06 </real>
     </isotropic>
    </linear>
   </permeability>
  </magnetic>
 </material>

 <material name="iron_linear">
  <magnetic>
   <electricConductivity>
    <linear>
     <isotropic>
      <real>9.17431e5</real>
     </isotropic>
    </linear>
   </electricConductivity>
   <permeability>
    <linear>
     <isotropic>
      <real> 1000*1.256637061E-06 </real>
     </isotropic>
    </linear>
   </permeability>
  </magnetic>
 </material>

 <material name="iron_nonlin_EB">
  <magnetic>
   <electricConductivity>
    <linear>
     <isotropic>
      <real>0</real>
     </isotropic>
    </linear>
   </electricConductivity>
   <permeability>
    <linear>
     <isotropic>
      <real> 1.2566E-06 </real>
     </isotropic>
    </linear>
    <model>
     <isotropic>
      <EBHysteresisModel>
       <Approx_type>approxVPM</Approx_type>
       <Anhysteresis_model>
        <analytic_anhysteresis>
         <atan>
          <Ps>1.23e6</Ps>
          <A>38</A>
         </atan>
        </analytic_anhysteresis>
       </Anhysteresis_model>
       <Jacobian_type>Broyden</Jacobian_type>
       <pinning_forces_weights_file>omega_kappa.txt</pinning_forces_weights_file>
      </EBHysteresisModel>
     </isotropic>
    </model>
   </permeability>
  </magnetic>
 </material>

</cfsMaterialDataBase>
