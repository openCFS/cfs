#!python
cubit.cmd('Journal Off');
import os;
import sys;
sys.path.append( os.path.realpath("..") );
from params import *;
# create compendium
cubit.cmd('create surface circle radius %f zplane ' % r_domain );
cubit.cmd('create surface circle radius %f zplane ' % r_core_outer );
cubit.cmd('subtract surface 2 from surface 1 ')
cubit.cmd('create surface circle radius %f zplane ' % r_core_outer );
cubit.cmd('create surface circle radius %f zplane ' % r_core_inner );
cubit.cmd('subtract surface 5 from surface 4 ')
cubit.cmd('create surface circle radius %f zplane ' % r_core_inner );
cubit.cmd('create surface circle radius %f zplane ' % r_wire );
cubit.cmd('subtract surface 8 from surface 7 ')
cubit.cmd('create surface circle radius %f zplane ' % r_wire );
cubit.cmd('merge curve all ');
cubit.cmd('webcut body all with plane xplane offset 0 merge ');
cubit.cmd('delete Body 8 9 10 11');
cubit.cmd('webcut body all with plane yplane offset 0 merge ');
cubit.cmd('delete Body 1 3 5 7');
# mesh core compendium
cubit.cmd('surface 22  size 5.0e-3');
#reasonable mesh size
#cubit.cmd('surface 22  size auto factor 3');
cubit.cmd('mesh surface 22 ');
# mesh wire compendium
cubit.cmd('surface 26  size 1.5e-3');
#cubit.cmd('surface 26  size auto factor 9');
cubit.cmd('mesh surface 26 ');
# mesh air compendium
cubit.cmd('surface 24  size 5.0e-3');
#cubit.cmd('surface 24  size auto factor 7');
#reasonable mesh size
#cubit.cmd('surface 24  size auto factor 4');
cubit.cmd('mesh surface 24 ');
cubit.cmd('surface 20  size 8.0e-3');
#reasonable mesh size
#cubit.cmd('surface 20  size 1.5e-3');
cubit.cmd('mesh surface 20 ');
# extrude
cubit.cmd('sweep surface 20 22 24 26 vector 0 0 1  distance %f  merge ' % 5.0e-3); #(core_thickness/2));
#cubit.cmd('sweep surface 20 22 24 26 vector 0 0 -1  distance %f  merge ' %5.0e-3); #(core_thickness/2));
#cubit.cmd('merge volume all ');
# define regions
cubit.cmd('block 1 add volume 14 12'); # 18 16');
cubit.cmd('block 1 name "air"');
cubit.cmd('block 2 add volume 15'); # 19 ');
cubit.cmd('block 2 name "wire"');
cubit.cmd('block 3 add volume 13'); # 17 ');
cubit.cmd('block 3 name "core"');
cubit.cmd('nodeset 4 add surface 31 36 41 45  '); #50 56 62 67 29 46  ')
cubit.cmd('nodeset 4 name "fluxParallel"')
cubit.cmd('nodeset 3 add surface 35  '); #55  ');
cubit.cmd('nodeset 3 name "S_Core_XZ"');
cubit.cmd('nodeset 2 add surface 33  '); #53  ');
cubit.cmd('nodeset 2 name "S_Core_YZ"');
# mesh volumes
#cubit.cmd('volume 13  size auto factor 3');
cubit.cmd('volume 13 14 15 12  size 5.0e-3');
cubit.cmd('mesh volume 13 ');
#cubit.cmd('volume 14  size auto factor 3');
cubit.cmd('mesh volume 14 ');
#cubit.cmd('volume 15  size auto factor 3');
cubit.cmd('mesh volume 15 ');
#cubit.cmd('volume 12  size auto factor 3');
cubit.cmd('mesh volume 12 ');
#cubit.cmd('volume 17  size auto factor 3');
#cubit.cmd('mesh volume 17 ');
#cubit.cmd('volume 18  size auto factor 3');
#cubit.cmd('mesh volume 18 ');
#cubit.cmd('volume 19  size auto factor 3');
#cubit.cmd('mesh volume 19 ');
#cubit.cmd('volume 16  size auto factor 3');
#cubit.cmd('mesh volume 16 ');
wd = os.getcwd();
#cubit.cmd('save trelis "%s/quater3d_parameterized_d_air%s.trelis" overwrite journal', % ( wd, air_dist ) );
cubit.cmd('export ansys cdb "%s/OCoreQuater_quasi3dParameterized.cdb"  overwrite ' % wd );
cubit.cmd('exit');
