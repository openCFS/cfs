<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
/home/lukas/Devel/CFS_SRC_Kaltenbacher_LocalMag/cfs/share/xml/CFS-Simulation/CFS.xsd">
    

    <!-- define which files are needed for simulation input & output-->
    <fileFormats>
        <input>
            <cdb fileName="mesh3d_circles.cdb"/>
        </input>
        <output>
            <hdf5 id="hdf5"/>
            <text id="txt"/>
        </output>
        <materialData file="mat_hyst_multidomain.xml" format="xml"/>
    </fileFormats>

    <domain geometryType="3d">
        <regionList>
            <region name="V_1" material="air" />
            <region name="V_2" material="iron_hyst1" />
            <region name="V_3" material="iron_hyst2" />
            <region name="V_4" material="air" />
        </regionList>
        <nodeList>
            <nodes name="N_gauge">
                <coord x="0" y="0.01e-3" z="0"/>
            </nodes>
        </nodeList>
    </domain>

    <fePolynomialList>
        <Legendre id="vP">
            <isoOrder> 0 </isoOrder>
        </Legendre>
        <Lagrange id="H1">
            <isoOrder> 1 </isoOrder>
        </Lagrange>
    </fePolynomialList>

    <sequenceStep index="1">
        <analysis>
            <transient>
                <numSteps>63</numSteps>
                <deltaT>0.1</deltaT>
                <allowPostProc>yes</allowPostProc>
            </transient>
        </analysis>

        <pdeList>
            <magneticEdge formulation="H">
                <regionList>
                    <region name="V_1" VecPolyId="vP" />
                    <region name="V_2" VecPolyId="vP" nonLinIds="nl1"/>
                    <region name="V_3" VecPolyId="vP" nonLinIds="nl1"/>
                    <region name="V_4" VecPolyId="vP" />
                </regionList>

                <nonLinList>
                    <permeability id="nl1" model="EBHysteresisModel"/>
                </nonLinList>


                <coilList>
                    <coil id="coil_S_1">
                        <source type="current" value="1e4*sin(t)"/>
                        <part id="1">
                            <regionList>
                                <region name="V_1"/>
                            </regionList>
                            <direction>
                                <analytic>
                                    <comp dof="z" value="1.0"/>
                                </analytic>
                            </direction>
                            <wireCrossSection area="1"/>
                        </part>
                    </coil>
                </coilList>
    
                <storeResults>
                    <elemResult type="magFieldIntensity">
                        <allRegions outputIds="hdf5"/>
                    </elemResult>
                    <elemResult type="magFluxDensity">
                        <allRegions outputIds="hdf5"/>
                    </elemResult>
                </storeResults>	
            </magneticEdge>
        </pdeList>

        <linearSystems>
            <system>
            <solutionStrategy>
                <standard>
                    <nonLinear logging="yes" method="fixPoint" >
                                <lineSearch type="minEnergy"/>
                                <incStopCrit>100000</incStopCrit>
                                <resStopCrit>1e-5</resStopCrit>
                                <maxNumIters>20</maxNumIters>
                                <abortOnMaxNumIters>yes</abortOnMaxNumIters>
                    </nonLinear>
                </standard>
            </solutionStrategy>
            </system>
        </linearSystems>
    </sequenceStep>

</cfsSimulation>
