<?xml version="1.0"?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/material ../../../../../share/xml/CFS-Material/CFS_Material.xsd">

 <material name="air_quasistatic">
  <magnetic>
   <electricConductivity>
    <linear>
     <isotropic>
      <real>1e2</real>
     </isotropic>
    </linear>
   </electricConductivity>
   <permeability>
    <linear>
     <isotropic>
      <real> 1.256637061E-06 </real>
     </isotropic>
    </linear>
   </permeability>
  </magnetic>
 </material>

 <material name="iron_hyst1_quasistatic">
  <magnetic>
   <electricConductivity>
    <linear>
     <isotropic>
      <real>1e6</real>
     </isotropic>
    </linear>
   </electricConductivity>
   <permeability>
    <linear>
     <isotropic>
      <real> 1.2566E-06 </real>
     </isotropic>
    </linear>
    <model>
     <isotropic>
      <EBHysteresisModel>
       <Approx_type>approxVPM</Approx_type>
       <Anhysteresis_model>
        <analytic_anhysteresis>
         <atan>
          <Ps>1.23e6</Ps>
          <A>38</A>
         </atan>
        </analytic_anhysteresis>
       </Anhysteresis_model>
       <Jacobian_type>BFGS</Jacobian_type>
       <pinning_forces_weights_file>omega_kappa_hyst1.txt</pinning_forces_weights_file>
      </EBHysteresisModel>
     </isotropic>
    </model>
   </permeability>
  </magnetic>
 </material>

 <material name="iron_hyst2_quasistatic">
  <magnetic>
   <electricConductivity>
    <linear>
     <isotropic>
      <real>1e6</real>
     </isotropic>
    </linear>
   </electricConductivity>
   <permeability>
    <linear>
     <isotropic>
      <real> 1.2566E-06 </real>
     </isotropic>
    </linear>
    <model>
     <isotropic>
      <EBHysteresisModel>
       <Approx_type>approxVPM</Approx_type>
       <Anhysteresis_model>
        <analytic_anhysteresis>
         <atan>
          <Ps>1.5e6</Ps>
          <A>100</A>
         </atan>
        </analytic_anhysteresis>
       </Anhysteresis_model>
       <Jacobian_type>BFGS</Jacobian_type>
       <pinning_forces_weights_file>omega_kappa_hyst2.txt</pinning_forces_weights_file>
      </EBHysteresisModel>
     </isotropic>
    </model>
   </permeability>
  </magnetic>
 </material>

</cfsMaterialDataBase>
