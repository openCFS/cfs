reset
#
##############################
# GEOMETRY
##############################
# Circles
create surface circle radius 0.5 zplane
create surface circle radius 1 zplane
create surface circle radius 1.3 zplane
create surface circle radius 1.6 zplane
# Boolean operations
subtract surface 1 2 3 from surface 4 keep_tool
subtract surface 1 2 from surface 3 keep_tool
subtract surface 1 from surface 2 keep_tool
# merge 2d
imprint all
merge all
# sweep to 3d
sweep surface 1 7 6 5  perpendicular distance 0.5  keep  merge
# merge 3d
imprint all
merge all
delete Body 4 1 3 2
##############################
# MESH
##############################
volume 8 7 6 5  scheme tetmesh size 1
mesh volume 8 7 6 5
##############################
# BLOCKS AND NODESETS
##############################
block 1 add volume 5
block 1 name "V_1"
block 2 add volume 6
block 2 name "V_2"
block 3 add volume 7
block 3 name "V_3"
block 4 add volume 8
block 4 name "V_4"
nodeset 1 add surface 19 21 17 13 9 5 6 7 1
nodeset 1 name "S_outer"
##############################
# EXPORT
##############################
export ansys cdb "mesh3d_circles.cdb"  overwrite
