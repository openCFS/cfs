              </Anhysteresis_model>
              <Jacobian_type>Broyden</Jacobian_type>
              <numS>1</numS>
              <chi_factor>0</chi_factor>
            </EBHysteresisModel>
          </isotropic>
        </model>
      </permeability>
    </magnetic>
  </material>


