<?xml version="1.0"?>

<cfsSimulation xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/simulation http://cfs-doc.mdmt.tuwien.ac.at/xml/CFS-Simulation/CFS.xsd"
 xmlns="http://www.cfs++.org/simulation">
  
  
  <fileFormats>
    <input>
      <!--<gmsh fileName="TestGeometry3D.msh"/>-->
      <hdf5 fileName="Geometry3D.h5"/>
    </input>
    <output>
      <hdf5 id="h5"/>
      <text id="txt"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>
  
  <domain geometryType="3d" printGridInfo="yes">
    <regionList>
      <region name="V_8" material="unit"/>
    </regionList>
    <surfRegionList>
      <surfRegion name="S_xy"/>
      <surfRegion name="S_yz"/>
      <surfRegion name="S_xz"/>
      <surfRegion name="S_8"/>
    </surfRegionList>
  </domain>
  
  <fePolynomialList>
    <Lagrange id="default">
      <gridOrder/>
    </Lagrange>
  </fePolynomialList>
 
  <sequenceStep>
    <analysis>
      <static>    
      </static>
    </analysis>
    
    <pdeList>
      <testPDE>
        <regionList>
          <region name="V_8" polyId="default"/>
        </regionList>
        
        <bcsAndLoads>
          <testGround name="S_xy"/>
          <testPotential name="P_origin" value="1.0"/>
        </bcsAndLoads>
        
        <storeResults>
          <nodeResult type="testDof">
            <allRegions/>
          </nodeResult>
          <elemResult type="testField">
            <allRegions/>
          </elemResult>
        </storeResults>
      </testPDE>
    </pdeList>
  </sequenceStep>
</cfsSimulation>
