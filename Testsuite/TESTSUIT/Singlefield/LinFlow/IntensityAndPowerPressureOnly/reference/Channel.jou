reset
undo on

#{d = 1e-2};
#{l1 = 100*d};
#{l2 = 100*d};
#{r = d*0.5};
#{l_PML = 4e-1};
#{h_el = 1e-1/50};

#{tol = 1e-6}

merge tolerance {tol}


# geom


create surface rectangle width {l1} height {d} zplane
move surface 1 x 0 y 0 z 0

create surface rectangle width {l2} height {d} zplane
move surface 2 x {l2/2+l1/2} y 0 z 0


imprint tolerant volume all
merge volume all


# mesh

curve 2 size {d}
mesh curve 2
surface all size {h_el}
mesh surface all


# blocks and nodesets

block 1 add surface 1
block 1 name "Channel_1"

block 2 add surface 2
block 2 name "Channel_2"


nodeset 1 add curve 2
nodeset 1 name "Exc_LF"

nodeset 2 add curve 3 7
nodeset 2 name "Slip_Bot"

nodeset 3 add curve 1 5
nodeset 3 name "Slip_Top"

nodeset 4 add curve 8
nodeset 4 name "NoPenetration_End"

nodeset 5 add curve 4
nodeset 5 name "IF"



Echo on
Warning on

export ansys cdb "Channel.cdb" overwrite
















