reset
undo on

#{w = 1e-4};
#{l = 1e-3};
#{h_el = 1.5e-5};
#{inter = 12};
#{bias_fac = 0.8};

#{tol = 1e-6}

merge tolerance {tol}


# geom

create surface rectangle width {w} height {l} zplane
move surface 1 x {w/2} y {l/2} z 0


# mesh

curve 1 3 interval {inter} 
curve 3 scheme bias factor {bias_fac}
curve 1 scheme bias factor {bias_fac} start vertex 2 
mesh curve 1 3
surface all size {h_el}
mesh surface all


# blocks and nodesets

block 1 add surface 1
block 1 name "Chamber"


nodeset 1 add curve 3
nodeset 1 name "Exc"

nodeset 2 add curve 2
nodeset 2 name "Sym"

nodeset 3 add curve 4
nodeset 3 name "BC_Fix"

nodeset 4 add curve 1
nodeset 4 name "BC_top"




Echo on
Warning on

export ansys cdb "Channel.cdb" overwrite





