reset
undo on

#{w = 1e-4};
#{l = 1e-3};
#{h_el = 1.5e-5};
#{inter = 12};
#{bias_fac = 0.8};

#{tol = 1e-6}

merge tolerance {tol}


# geom

create cylinder height {l} radius {w}
move volume 1 x 0 y 0 z {l/2}
section volume 1 with xplane offset 0 normal
section volume 1 with yplane offset 0 normal


# mesh

curve 12 16 interval {inter} 
curve 12 scheme bias factor {bias_fac}
curve 16 scheme bias factor {bias_fac} start vertex 8
mesh curve 12 16
curve 14 size {h_el/1.5}
mesh curve 14
#surface 12 sizing function linear
surface 12 size {h_el/20}
mesh surface 12

volume all size {h_el}
volume 1 redistribute nodes off
volume 1 scheme Sweep  source surface 12    target surface 10   sweep transform translate propagate bias  
volume 1 autosmooth target off
mesh volume all


# blocks and nodesets

block 1 add volume 1
block 1 name "Chamber"


nodeset 1 add surface 10
nodeset 1 name "Exc"

nodeset 2 add surface 11
nodeset 2 name "Sym_xPlane"

nodeset 3 add surface 8
nodeset 3 name "Sym_yPlane"

nodeset 4 add surface 9
nodeset 4 name "BC_Fix"

nodeset 5 add surface 12
nodeset 5 name "BC_top"




Echo on
Warning on

export ansys cdb "Channel_3D.cdb" overwrite









