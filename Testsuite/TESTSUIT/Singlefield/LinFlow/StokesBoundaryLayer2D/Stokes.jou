undo on 
reset

#{ h = 0.0005 }
#{ w = 0.00002 }

create surface rectangle width { w } height { h } zplane 
move Surface all x 0 y { h/2 } z 0 

surface 1 scheme submap

block 1 add surface 1 
block 1 name "S_flow"

nodeset 1 add curve 3  
nodeset 1 name "L_bottom"

nodeset 2 add curve 1  
nodeset 2 name "L_top"

nodeset 3 add curve 2
nodeset 3 name "L_left"
  
nodeset 4 add curve 4  
nodeset 4 name "L_right"

# y-mesh division
curve 4  scheme bias fine size 1e-6 coarse size 5e-5 
curve 2  scheme bias fine size 5e-5  coarse size 1e-6  

# x-mesh division
curve 1 3 interval 1
curve 1 3 scheme equal

mesh surface 1

export ansys cdb "Stokes.cdb"  overwrite 