reset
brick x 1 y 1 z 1

webcut volume 1 with plane zplane offset 0.0
volume 1 size 0.5
mesh volume 1


webcut volume 2 with plane yplane offset 0.1
webcut volume 2 3 with plane xplane offset 0.1
merge volume 2 3 4 5
volume 2 3 4 5 size 0.5
rotate volume 1 2 3 4 5 angle -90 about x include_merged

mesh volume 2 3 4 5



block 1 add volume 1
block 1 name "V1"

block 2 add volume 2 3 4 5
block 2 name "V2"

nodeset 2 add surface 39 45 33 31
nodeset 2 name "S_2"

nodeset 1 add surface 7
nodeset 1 name "S_1"

rotate volume 2 3 4 5 angle 90 about y include_merged

move volume all y 0.25 include_merged

export ansys cdb "geometry.cdb"  overwrite 

