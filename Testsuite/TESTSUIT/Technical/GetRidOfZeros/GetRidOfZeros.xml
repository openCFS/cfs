<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

  <documentation>
    <title>Get rid of zeros in system matrix</title>
    <authors>
      <author>Vladimir Filkin</author>
    </authors>
    <date>2024-07-23</date>
    <keywords>
      <keyword>nonmatching grids</keyword>
    </keywords>
    <isVerified>yes</isVerified>
    <description>
      We test three different options for GetRidOfZeros function (description in README file) "auto" (default), "yes" and "no".
      Only the system matrices are compared with the reference ones (validated in Python).
    </description>
  </documentation>

  <fileFormats>
    <input>
      <cdb fileName="geometry.cdb"/>
    </input>
    <output>
      <hdf5/>
      <text id="txt"/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="3d">
    <regionList>
      <region name="V1" material="magnet"/>
      <region name="V2" material="magnet"/>
    </regionList>
    <ncInterfaceList>
      <ncInterface name="intface" primarySide="S_1" secondarySide="S_2">
      </ncInterface>
    </ncInterfaceList>  
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/> 
    </analysis>
    <pdeList>
      <magneticEdge>
        <regionList>
          <region name="V1"/>
          <region name="V2"/>
        </regionList>
        <ncInterfaceList>
          <ncInterface name="intface" formulation="Nitsche" nitscheFactor="1.0E2"/>
        </ncInterfaceList>
        <storeResults>
          <elemResult type="magFluxDensity">
            <allRegions/>
          </elemResult>
        </storeResults>
      </magneticEdge>
    </pdeList>
    <linearSystems>
      <system>
        <solutionStrategy>
          <standard>
            <exportLinSys system="true" mass="false" rhs="false" solution="false" baseName="auto"/>
          </standard>
        </solutionStrategy>
      </system>
    </linearSystems>
  </sequenceStep>


  <sequenceStep index="2">
    <analysis>
       <harmonic>
        <frequencyList>
          <freq value="1" />
        </frequencyList>
       </harmonic> 
    </analysis>
    <pdeList>
      <magneticEdge>
        <regionList>
          <region name="V1"/>
          <region name="V2"/>
        </regionList>
        <ncInterfaceList>
          <ncInterface name="intface" formulation="Nitsche" nitscheFactor="1.0E2"/>
        </ncInterfaceList>
        <storeResults>
          <elemResult type="magFluxDensity">
            <allRegions/>
          </elemResult>
        </storeResults>
      </magneticEdge>
    </pdeList>
    <linearSystems getRidOfZeros="yes" getRidOfZerosTolerance="1e-14">
      <system>
        <solutionStrategy>
          <standard>
            <exportLinSys system="true" mass="false" rhs="false" solution="false" baseName="yes"/>
          </standard>
        </solutionStrategy>
      </system>
    </linearSystems>
  </sequenceStep>


  <sequenceStep index="3">
    <analysis>
       <harmonic>
        <frequencyList>
          <freq value="1" />
        </frequencyList>
       </harmonic> 
    </analysis>
    <pdeList>
      <magneticEdge>
        <regionList>
          <region name="V1"/>
          <region name="V2"/>
        </regionList>
        <ncInterfaceList>
          <ncInterface name="intface" formulation="Nitsche" nitscheFactor="1.0E2"/>
        </ncInterfaceList>
        <storeResults>
          <elemResult type="magFluxDensity">
            <allRegions/>
          </elemResult>
        </storeResults>
      </magneticEdge>
    </pdeList>
    <linearSystems getRidOfZeros="no">
      <system>
        <solutionStrategy>
          <standard>
            <exportLinSys system="true" mass="false" rhs="false" solution="false" baseName="no"/>
          </standard>
        </solutionStrategy>
      </system>
    </linearSystems>
  </sequenceStep>
</cfsSimulation>
