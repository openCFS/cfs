<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material">
  <!-- Pseudo-elastic smooth material for the flap "Solid" region. Unused in prescribed mode
       (no solve), but the material-class assignment requires a <smooth><elasticity> material. -->
  <material name="smoothMat">
    <smooth>
      <elasticity>
        <linear>
          <isotropic>
            <elasticityModulus><real>1</real></elasticityModulus>
            <poissonNumber><real>0.3</real></poissonNumber>
          </isotropic>
        </linear>
      </elasticity>
    </smooth>
  </material>
</cfsMaterialDataBase>
