<precice-configuration>

  <!-- REAL OpenFOAM-coupled FSI test (structure taken from the validated full-size
       perpendicular-flap case): parallel-implicit coupling, Stress <-> Displacement on
       the three flap interfaces, IQN-ILS accelerated. Both participants run in the SAME
       working directory (pimpleFoam via -case), so the default (relative) m2n exchange
       directory matches. Profiling/exports off: the test stays below ~1 MB of artifacts.
       Deliberately NO passive one-way data (DisplacementVolume/SmoothPDE channel):
       preCICE 3.4.1 serves passive exchanged data nondeterministically - see the
       reproduction report 'precice-passive-data-read-nondeterminism.md'. -->

  <log>
    <sink filter="%Severity% > debug and %Rank% = 0"
          format="---[precice] %ColorizedSeverity% %Message%"
          enabled="true"/>
  </log>

  <profiling mode="off"/>

  <data:vector name="Stress"/>
  <data:vector name="Displacement"/>

  <mesh name="Fluid-Nodes1" dimensions="3"><use-data name="Displacement"/></mesh>
  <mesh name="Fluid-Nodes2" dimensions="3"><use-data name="Displacement"/></mesh>
  <mesh name="Fluid-Nodes3" dimensions="3"><use-data name="Displacement"/></mesh>

  <mesh name="Solid-Nodes1" dimensions="3"><use-data name="Displacement"/></mesh>
  <mesh name="Solid-Nodes2" dimensions="3"><use-data name="Displacement"/></mesh>
  <mesh name="Solid-Nodes3" dimensions="3"><use-data name="Displacement"/></mesh>

  <mesh name="Fluid-Faces1" dimensions="3"><use-data name="Stress"/></mesh>
  <mesh name="Fluid-Faces2" dimensions="3"><use-data name="Stress"/></mesh>
  <mesh name="Fluid-Faces3" dimensions="3"><use-data name="Stress"/></mesh>

  <mesh name="Solid-Faces1" dimensions="3"><use-data name="Stress"/></mesh>
  <mesh name="Solid-Faces2" dimensions="3"><use-data name="Stress"/></mesh>
  <mesh name="Solid-Faces3" dimensions="3"><use-data name="Stress"/></mesh>

  <participant name="Fluid">
    <provide-mesh name="Fluid-Nodes1"/>
    <provide-mesh name="Fluid-Nodes2"/>
    <provide-mesh name="Fluid-Nodes3"/>
    <provide-mesh name="Fluid-Faces1"/>
    <provide-mesh name="Fluid-Faces2"/>
    <provide-mesh name="Fluid-Faces3"/>
    <receive-mesh name="Solid-Nodes1" from="Solid"/>
    <receive-mesh name="Solid-Nodes2" from="Solid"/>
    <receive-mesh name="Solid-Nodes3" from="Solid"/>
    <write-data name="Stress"        mesh="Fluid-Faces1"/>
    <write-data name="Stress"        mesh="Fluid-Faces2"/>
    <write-data name="Stress"        mesh="Fluid-Faces3"/>
    <read-data  name="Displacement" mesh="Fluid-Nodes1"/>
    <read-data  name="Displacement" mesh="Fluid-Nodes2"/>
    <read-data  name="Displacement" mesh="Fluid-Nodes3"/>
    <!-- consistent: each Fluid node gets the displacement of its nearest Solid node -->
    <mapping:nearest-neighbor direction="read" from="Solid-Nodes1" to="Fluid-Nodes1" constraint="consistent"/>
    <mapping:nearest-neighbor direction="read" from="Solid-Nodes2" to="Fluid-Nodes2" constraint="consistent"/>
    <mapping:nearest-neighbor direction="read" from="Solid-Nodes3" to="Fluid-Nodes3" constraint="consistent"/>
  </participant>

  <participant name="Solid">
    <provide-mesh name="Solid-Nodes1"/>
    <provide-mesh name="Solid-Nodes2"/>
    <provide-mesh name="Solid-Nodes3"/>
    <provide-mesh name="Solid-Faces1"/>
    <provide-mesh name="Solid-Faces2"/>
    <provide-mesh name="Solid-Faces3"/>
    <receive-mesh name="Fluid-Faces1" from="Fluid"/>
    <receive-mesh name="Fluid-Faces2" from="Fluid"/>
    <receive-mesh name="Fluid-Faces3" from="Fluid"/>
    <write-data name="Displacement" mesh="Solid-Nodes1"/>
    <write-data name="Displacement" mesh="Solid-Nodes2"/>
    <write-data name="Displacement" mesh="Solid-Nodes3"/>
    <read-data  name="Stress"       mesh="Solid-Faces1"/>
    <read-data  name="Stress"       mesh="Solid-Faces2"/>
    <read-data  name="Stress"       mesh="Solid-Faces3"/>
    <!-- consistent: each Solid face center gets the stress of its nearest Fluid face center -->
    <mapping:nearest-neighbor direction="read" from="Fluid-Faces1" to="Solid-Faces1" constraint="consistent"/>
    <mapping:nearest-neighbor direction="read" from="Fluid-Faces2" to="Solid-Faces2" constraint="consistent"/>
    <mapping:nearest-neighbor direction="read" from="Fluid-Faces3" to="Solid-Faces3" constraint="consistent"/>
  </participant>

  <!-- both participants run in the test directory -> default (relative) exchange directory -->
  <m2n:sockets acceptor="Fluid" connector="Solid"/>

  <coupling-scheme:parallel-implicit>
    <participants first="Fluid" second="Solid"/>
    <max-time value="0.1"/>
    <time-window-size value="0.01"/>
    <max-iterations value="30"/>
    <exchange data="Stress"        mesh="Fluid-Faces1" from="Fluid" to="Solid"/>
    <exchange data="Stress"        mesh="Fluid-Faces2" from="Fluid" to="Solid"/>
    <exchange data="Stress"        mesh="Fluid-Faces3" from="Fluid" to="Solid"/>
    <exchange data="Displacement" mesh="Solid-Nodes1" from="Solid" to="Fluid"/>
    <exchange data="Displacement" mesh="Solid-Nodes2" from="Solid" to="Fluid"/>
    <exchange data="Displacement" mesh="Solid-Nodes3" from="Solid" to="Fluid"/>
    <relative-convergence-measure data="Displacement" mesh="Solid-Nodes1" limit="1e-4"/>
    <relative-convergence-measure data="Displacement" mesh="Solid-Nodes2" limit="1e-4"/>
    <relative-convergence-measure data="Displacement" mesh="Solid-Nodes3" limit="1e-4"/>
    <acceleration:IQN-ILS>
      <data name="Displacement" mesh="Solid-Nodes1"/>
      <data name="Displacement" mesh="Solid-Nodes2"/>
      <data name="Displacement" mesh="Solid-Nodes3"/>
      <preconditioner type="residual-sum"/>
      <filter type="QR1" limit="1e-6"/>
      <initial-relaxation value="0.5"/>
      <max-used-iterations value="100"/>
      <time-windows-reused value="8"/>
    </acceleration:IQN-ILS>
  </coupling-scheme:parallel-implicit>

</precice-configuration>
