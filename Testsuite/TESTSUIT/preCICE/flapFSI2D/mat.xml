<?xml version="1.0" encoding="utf-8"?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material">
  <!-- Simple isotropic, linear-elastic beam material (steel-like). -->
  <material name="beamMat">
    <mechanical>
      <density>
        <linear>
          <real>2330.0</real>
        </linear>
      </density>
      <elasticity>
        <linear>
          <isotropic>
            <elasticityModulus>
              <real>2.0e11</real>
            </elasticityModulus>
            <poissonNumber>
              <real>0.3</real>
            </poissonNumber>
          </isotropic>
        </linear>
      </elasticity>
    </mechanical>
  </material>
</cfsMaterialDataBase>
