<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.cfs++.org/simulation
                      http://www.cfs++.org/simulation/CFS.xsd">
  <!--
    flapFSI2D - minimal 2D fluid-structure-interaction test for the openCFS
    preCICE adapter.

    A thin cantilever beam (clamped at its left edge) is loaded on its top edge
    by a fluid traction provided through preCICE by the mock "Fluid" partner.
    openCFS is the "Solid" participant: it reads the traction (mechNormalStress)
    as a surface load, solves the mechanic PDE, and writes the resulting
    displacement (mechDisplacement) back to preCICE. The mock ramps the traction
    linearly in time, so the tip deflection grows monotonically over the few
    time windows - easy to sanity-check by eye.
  -->


  <fileFormats>
    <input>
      <hdf5 fileName="flapFSI2D_mesh.h5"/>
    </input>
    <output>
      <hdf5 id="hdf5"/>
    </output>
    <materialData file="mat.xml"/>
    <preciceCoupling>
      <participantName name="Solid"/>
      <participantMeshList>
        <participantMeshName name="Solid-Nodes" region="interface"/>
        <participantMeshName name="Solid-Faces" region="interface"/>
      </participantMeshList>
      <precice_configFile file="precice-config.xml"/>
      <sequenceStep>1</sequenceStep>
    </preciceCoupling>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="beam" material="beamMat"/>
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <transient>
        <numSteps>5</numSteps>
        <deltaT>1.0e-3</deltaT>
      </transient>
    </analysis>

    <pdeList>
      <mechanic subType="planeStrain">
        <regionList>
          <region name="beam"/>
        </regionList>

        <bcsAndLoads>
          <!-- clamp the left edge -->
          <fix name="fixed">
            <comp dof="x"/>
            <comp dof="y"/>
          </fix>
          <!-- fluid traction read from preCICE applied on the top edge -->
          <forceDensity name="interface">
            <grid>
              <defaultGrid quantity="mechNormalStress" dependtype="GENERAL" definedOn="element">
                <globalFactor>1</globalFactor>
              </defaultGrid>
            </grid>
          </forceDensity>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="mechDisplacement">
            <regionList>
              <region name="beam"/>
            </regionList>
          </nodeResult>
          <surfElemResult type="mechNormalStress">
            <surfRegionList>
              <surfRegion name="interface" neighborRegion="beam"/>
            </surfRegionList>
          </surfElemResult>
        </storeResults>
      </mechanic>
    </pdeList>

    <linearSystems>
      <system>
        <solutionStrategy>
          <standard>
            <matrix storage="sparseNonSym"/>
          </standard>
        </solutionStrategy>
        <solverList>
          <pardiso/>
        </solverList>
      </system>
    </linearSystems>
  </sequenceStep>
</cfsSimulation>
