<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

  <documentation>
    <title>Feature Mapping Single Feature with Midpoint Integration</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2025-08-01</date>
    <references>see two_pill.xml</references>
    <isVerified>no</isVerified>
    <description>
      Feature mapping of pill objects native in C++. Single feature and midpoint integration (which does not really make sense!)

      Use e.g. bulk2d mesh from create_mesh.py
    </description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="single_midpoint.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech"/>
    </regionList>
    <nodeList>
      <nodes name="load">
        <list>
          <freeCoord comp="y" stop="0.6" inc="1/100" start="0.4"/>
          <fixedCoord comp="x" value="1"/>
        </list>
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>

        <bcsAndLoads>
           <fix name="left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
           </fix>
           <force name="load" >
             <comp dof="x" value="1"/>
           </force>
           
        </bcsAndLoads>
        <storeResults>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_1">
            <allRegions/>
          </elemResult>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>
    
    <linearSystems>
      <system>
        <solverList>
          <directLDL/>
        </solverList>
      </system>
    </linearSystems>
  </sequenceStep>
    
  <optimization>
    <costFunction type="compliance" task="minimize" sequence="1" linear="false">
      <stopping queue="10" value="0.001" type="relativeCostChange" />
    </costFunction>
    <constraint type="volume" bound="upperBound" value="0.3" mode="constraint" linear="false"/>
   
    <optimizer type="dumas_mma" maxIterations="100">
    </optimizer>
    
    <ersatzMaterial region="mech" material="mechanic" method="featureMapping">
      <featureMapping  transition=".1" combine="max" order="1" >
        <pill>
          <node dof="x" initial="0.2" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.4" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.8" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.6" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
      </featureMapping>
      <design name="density" initial=".5" physical_lower="1e-3" upper="1.0"/>

      <transferFunction type="identity" application="mech" />
      <result value="costGradient" id="optResult_1" /> 
      <export save="all" write="iteration"/>
    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
