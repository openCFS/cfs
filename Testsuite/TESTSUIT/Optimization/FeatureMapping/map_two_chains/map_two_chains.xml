<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
 
  <documentation>
    <title>Feature Mapping with complex variable mapping of two chains of pills</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2025-08-06</date>
    <references>see two_pill.xml</references>
    <isVerified>no</isVerified>
    <description>
      This example uses variable mapping build two chains of pills, where each chain consists of three pills.

      Because of the load case (vertical load on the right center edge), both chains are stretched to a single line.

      Within a chain the center pill maps its start tip point P point to end tip point Q of the previous pill. The third pill maps its start P to the center pill's end Q.

      Use e.g. bulk2d mesh from create_mesh.py - check with --res 40 to have a nice resolution.
    </description>
  </documentation>

  <fileFormats>

    <input>
      <hdf5 fileName="map_two_chains.h5ref"/>
    </input>

    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech"/>
    </regionList>
    <nodeList>
      <nodes name="load">
        <coord x="1" y="0.5"/>
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>

        <bcsAndLoads>
           <fix name="left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
           </fix>
           <force name="load" >
             <comp dof="y" value="-1"/>
           </force>
           
        </bcsAndLoads>
        <storeResults>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>
    
  <optimization>
    <costFunction type="compliance" task="minimize">
      <!-- enforce early stopping for dumas in test case -->   
      <stopping queue="2" value="1e-3" type="relativeCostChange" />
    </costFunction>
    <constraint type="volume" bound="upperBound" value="0.3" mode="constraint" linear="false"/>
   
    <optimizer type="dumas_mma" maxIterations="100"/>
    
    <ersatzMaterial region="mech" material="mechanic" method="featureMapping">
      <featureMapping  transition=".1" order="2" combine="p-norm" p="4" >
  
        <!-- the first chain consists of the pills and uses the variables A (Qx/Qy from the first pill) 
             to be mapped by Px/Py of the second pill. The Variable B (Q from the second pill)
             to be mapped by P from the third pill -->    
        <pill>
          <node dof="x" initial="0.1" lower="0" upper="1" tip="start"/>
          <node dof="y" initial="0.1" lower="0" upper="1" tip="start"/>
          <node dof="x" initial="0.3" lower="0" upper="1"  tip="end" key="Ax"/>
          <node dof="y" initial="0.4" lower="0" upper="1" tip="end" key="Ay"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
        <pill>
          <node dof="x" tip="start" map="Ax" />
          <node dof="y" tip="start" map="Ay" />
          <node dof="x" initial="0.5" upper="1" lower="0" tip="end" key="Bx"/>
          <node dof="y" initial="0.2" upper="1" lower="0" tip="end" key="By"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
        <pill>
          <node dof="x" tip="start" map="Bx" />
          <node dof="y" tip="start" map="By" />
          <node dof="x" initial="0.8" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.8" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>

        <!-- the second chain. The initial position is horizontally flipped. --> 
        <pill>
          <node dof="x" initial="0.1" lower="0" upper="1" tip="start"/>
          <node dof="y" initial="0.9" lower="0" upper="1" tip="start"/>
          <node dof="x" initial="0.3" lower="0" upper="1"  tip="end" key="Cx"/>
          <node dof="y" initial="0.6" lower="0" upper="1" tip="end" key="Cy"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
        <pill>
          <node dof="x" tip="start" map="Cx" />
          <node dof="y" tip="start" map="Cy" />
          <node dof="x" initial="0.5" upper="1" lower="0" tip="end" key="Dx"/>
          <node dof="y" initial="0.8" upper="1" lower="0" tip="end" key="Dy"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
        <pill>
          <node dof="x" tip="start" map="Dx" />
          <node dof="y" tip="start" map="Dy" />
          <node dof="x" initial="0.8" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.2" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>

      </featureMapping>
      <design name="density" initial=".5" physical_lower="1e-3" upper="1.0"/>

      <transferFunction type="identity" application="mech" />
      <export save="all" write="iteration"/>
      
    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
