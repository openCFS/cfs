<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.cfs++.org/simulation
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

  <documentation>
    <title>Feature mapping of two features with the asymmetric Bezier boundary function</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2026-06-14</date>
    <references>Wein, Jung, Moradian, Stingl; Gradient-Based Generation of Feature Mapping Initial
               Designs from SIMP Density Fields; 2026 (to be submitted :))</references>
    <isVerified>no</isVerified>
    <description>
      Two bars with the quintic Bezier transition function and an asymmetric extension,
      The inner transition zone is a = transition/2, the outer is b=a+extension.
      Check with featureviz.py bezier.ref.density.xml --density --detail 2
      Mesh is bulk2d_10.mesh (create_mesh.py --type bulk2d --res 10)
    </description>
  </documentation>


  <fileFormats>
    <input>
      <hdf5 fileName="bezier.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech"/>
    </regionList>
    <nodeList>
      <nodes name="load">
        <coord x="1" y="0.5"/>
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>

        <bcsAndLoads>
           <fix name="left">
              <comp dof="x"/>
              <comp dof="y"/>
           </fix>
           <force name="load">
             <comp dof="y" value="-1"/>
           </force>
        </bcsAndLoads>
        <storeResults>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>

  <optimization>
    <costFunction type="compliance" task="minimize" >
      <stopping type="designChange" queue="2" value="1e-2"/>
    </costFunction>
    <constraint type="volume" bound="upperBound" value="0.3" mode="constraint" linear="false"/>

    <optimizer type="dumas_gcmma" maxIterations="100">
    </optimizer>

    <ersatzMaterial region="mech" material="mechanic" method="featureMapping">
      <featureMapping transition=".1" boundary="bezier" extension=".2" order="2" combine="p-norm" p="4">
        <pill>
          <node dof="x" initial="0.2" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.2" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.8" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.5" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
        <pill>
          <node dof="x" initial="0.2" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.8" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.8" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.5" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
      </featureMapping>
      <design name="density" initial=".5" physical_lower="1e-3" upper="1.0"/>

      <transferFunction type="identity" application="mech" />
      <export save="all" write="iteration"/>

    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
