<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
 
  <documentation>
    <title>Anisotropic Feature Mapping, Two Features</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2025-10-10</date>
    <references></references>
    <isVerified>no</isVerified>
    <description>
      This is the anisotropic variant of feature mapping. Here with two oriented pills.

      We map multiple anisotropic features not by letting the strongest dominate (as Norato and Greifenstein)
      but we average as 

      mc_e = (sum c_e) / (sum rho_e) * m_rho_e

      c_e contains the angle and rho_e, see the ansio_single test

      m_rho_e is the combined rho_e (smooth maximum). Set combine accordingly.

      Our combine is not too aggressiv, therefore we have m_rho_e up to 1.1

      visualize with featureviz.py aniso_two.density.xml --detail 2 --density
    </description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="aniso_two.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="spaghetti_aniso"/>
    </regionList>
    <nodeList>
      <nodes name="load">
        <coord x="1" y="0.5"/>
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStrain">
        <regionList>
          <region name="mech"/>
        </regionList>

        <bcsAndLoads>
           <fix name="left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
           </fix>
           <force name="load" >
             <comp dof="y" value="-1"/>
           </force>
           
        </bcsAndLoads>
        <storeResults>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="mechTensor">
            <allRegions />
          </elemResult>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>
    
    <!-- <linearSystems>
      <system>
        <solverList>
          <cholmod/>
        </solverList>
      </system>
    </linearSystems> -->
  </sequenceStep>
    
  <optimization>
    <costFunction type="compliance" task="minimize" sequence="1" linear="false">
      <stopping queue="2" value="1e-3" type="relativeCostChange" />
    </costFunction>
    <constraint type="volume" bound="upperBound" value="0.5" mode="constraint" linear="false"/>

    <!-- we actually converge after 16 iterations-->
    <optimizer type="dumas_mma" maxIterations="60">
      <!-- for feature mapping a small move limit always helps for mma! -->
      <dumas_mma move_limit="0.05"/>
    </optimizer>
    
    <ersatzMaterial region="mech" material="mechanic" method="featureMappingAniso">
      <!-- the conservative combine results in rho up to 1.1 -->
      <featureMapping transition=".1" order="3" combine="p-norm" p="5" >
        <pill>
          <node dof="x" initial="0.05" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.3" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.95" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.55" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper=".2" />
        </pill>
        <pill>
          <node dof="x" initial="0.05" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.7" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.95" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.45" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper=".2" />
        </pill>
      </featureMapping>
      <!-- using groundmaterial speeds up anisotropic feature mapping, see aniso_single -->
      <design name="density" initial=".5" physical_lower="0" upper="1.0" groundmaterial="void"/>

      <transferFunction type="identity" application="mech" />
      <export save="all" write="iteration"/>
      
    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
