<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">
  
  <documentation>
    <title>Test and show special results for isotropic feature mapping</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2025-10-23</date>
    <references>Wein, Dunning, Norato; A review on feature-mapping methods for structural optimization; 2020  
               and Greifenstein, Letournel, Stingl, Wein; Efficient spline design via feature-mapping for continuous fiber-reinforced structures; 2023</references>
    <isVerified>no</isVerified>
    <description>
      Some of the results are also for the anisotropic case (distance and projected distance)

      See the results in optimization for a detailed description. Take care to differentiate between elemResult and nodeResult.

      Some results are for illustrative purpose, others are for debugging only.
    </description>
  </documentation>

  <fileFormats>
    <input>
      <hdf5 fileName="iso_results.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech"/>
    </regionList>
    <nodeList>
      <nodes name="load">
        <coord x="1" y="0.5"/>
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>

        <bcsAndLoads>
           <fix name="left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
           </fix>
           <force name="load" >
             <comp dof="y" value="-1"/>
           </force>
           
        </bcsAndLoads>
        <storeResults>
          <!-- element results - make sure to have the optResult_x at the proper result type -->
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="mechDeformEnergyDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_1">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_2">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_3">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_4">
            <allRegions/>
          </elemResult>          
          <elemResult type="optResult_5">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_6">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_7">
            <allRegions/>
          </elemResult>

          <!-- node results -->
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult> 
          <nodeResult type="optResult_8">
            <allRegions/>
          </nodeResult>
          <nodeResult type="optResult_9">
            <allRegions/>
          </nodeResult>
          <nodeResult type="optResult_10">
            <allRegions/>
          </nodeResult>
          <nodeResult type="optResult_11">
            <allRegions/>
          </nodeResult>
          <nodeResult type="optResult_12">
            <allRegions/>
          </nodeResult>
          <nodeResult type="optResult_13">
            <allRegions/>
          </nodeResult>
          <nodeResult type="optResult_14">
            <allRegions/>
          </nodeResult>
          <nodeResult type="optResult_15">
            <allRegions/>
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>
    
    <!-- <linearSystems>
      <system>
        <solverList>
          <cholmod/>
        </solverList>
      </system>
    </linearSystems> -->
  </sequenceStep>
    
  <optimization>
    <costFunction type="compliance" task="minimize" sequence="1" linear="false">
      <stopping queue="99" value="1e-3" type="relativeCostChange" />
    </costFunction>

    <constraint type="volume" bound="upperBound" value="0.3" mode="constraint" linear="false"/>

    <optimizer type="evaluate" maxIterations="50" />
    
    <ersatzMaterial region="mech" material="mechanic" method="featureMapping">
      <!-- combine (mrho) with p-norm 3 is rather small -->
      <featureMapping  transition=".1" order="3" combine="p-norm" p="3" >
        <pill>
          <node dof="x" initial="0.1" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.9" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="1" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.5" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
        <pill>
          <node dof="x" initial="0.1" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.3" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.95" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.5" upper="1" lower="0" tip="end"/>
          <profile initial="0.1" lower="0.05" upper="0.2" />
        </pill>
      </featureMapping>
      <design name="density" initial=".5" physical_lower="1e-3" upper="1.0"/>

      <transferFunction type="identity" application="mech" />
      <!-- we have the elemResults first as they come first in the pde's storeResults section -->
      <!-- d_J/d_s with J is compliance where s is defined by feature (0-based idx in 'generic' and variable in 'design')
           d_J/d_s = d_J/d_mrho * d_mrho/d_rho_f * d_rho_f/d_s --> 
      <result value="featureGrad"      detail="compliance"   design="feature_var_Px" generic="1" id="optResult_1" />
      <!-- d_J/d_s with J is volume -->       
      <result value="featureGrad"      detail="volume"       design="feature_var_Px" generic="1" id="optResult_2" />
      <!-- d_mrho/d_rho_f where mrho is combined (aggregated) rho derived rho of feature f, given in 'generic'  -->
      <result value="featureGrad"      detail="combine"      design="feature"        generic="0" id="optResult_3" />
      <result value="featureGrad"      detail="combine"      design="feature"        generic="1" id="optResult_4" />
      <!-- d_mrho/d_s which is d_mrho/d_rho_f * d_rho_f/d_s  -->
      <result value="featureGrad"      detail="combine"      design="feature_var_Px" generic="1" id="optResult_5" />
      <!-- d_rho_f/d_s -->
      <result value="featureGrad"      detail="featureRho"   design="feature_var_Px" generic="1" id="optResult_6" />      

      <!-- d_J/d_mrho the standard simp gradient with rho = mrho from feature mapping (here compliance) -->
      <result value="costGradient"                           design="density"                    id="optResult_7"  />

      <!-- nodeResult options. Take care to use properly in the pde's storeResult section! -->

      <!-- technically we have this information at each integration point. We write it here at the mesh nodes,
       which means mean we need at least order 2 and skip all values for higher orders (the center point of our order 3 in this case) -->

       <!-- 'detail' default is 'none' and 'generic' default is "" -->

      <!-- min_f d(s_f): the hard minimum of all corner point distances over all features -->
      <result value="featureDistance"                        design="allFeatures"                id="optResult_8" /> 
      <!-- d(s_f) the distance function for a specific feature given by 0-based index in 'generic' -->
      <result value="featureDistance"                        design="feature"        generic="1" id="optResult_9" />
      <!-- the boundary projection function min_f H(d(s^f)). The integral of it is mechPseudoDensity! -->
      <result value="featureProjected"                       design="allFeatures"                id="optResult_10" />
      <!-- the boundary projection H(d(s^f)) for a given feature -->
      <result value="featureProjected"                       design="feature"        generic="1" id="optResult_11" />
      <!-- d_dist/d_s for a variable of the feature in 'generic'-->
      <result value="featureDistance"  detail="gradDistance" design="feature_var_Py" generic="1" id="optResult_12" />
      <!-- d_H(dist(s))/d_s this is base for the elemResult d_rho_f/d_s  -->
      <result value="featureProjected" detail="gradDistance" design="feature_var_Py" generic="1" id="optResult_13" />
      <!-- this is pure technical and debug stuff. The distance to a feature is the shortest to a feature part (tip P, inner, end Q).
           with the values 0, 1, 2 for the given feature -->
      <result value="featureDistance"  detail="featurePart"  design="feature"        generic="1" id="optResult_15" />            
      <!-- pure technical and debug information for the closest feature -->
      <result value="featureDistance"  detail="featurePart"  design="allFeatures"    generic="1" id="optResult_14" />
      <export save="all" write="iteration"/>
    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
