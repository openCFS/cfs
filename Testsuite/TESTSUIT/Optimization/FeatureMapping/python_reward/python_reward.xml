<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.cfs++.org/simulation
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

  <documentation>
    <title>Feature mapping design reward (Python objective) with native ipopt optimizer</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2026-06-17</date>
    <references>Wein, Jung, Moradian, Stingl; Gradient-Based Generation of Feature Mapping Initial
                Designs from SIMP Density Fields; 2026 (to be submitted :))</references>
    <isVerified>no</isVerified>
    <description>
      Pre-step for density tracking to optimize feature mapping variables. J_reward = -sum_e rho*_e rho_e (share/python/tracking.py).
      See the paper and python_tracking.xml.

      This is also a test for dumas_gcmma with multiple and sparse constraints.
    </description>
  </documentation>

  <!-- the reward objective and gradient are implemented in the reusable share/python kernel -->
  <python file="tracking.py" path="cfs:share:python" />

  <fileFormats>
    <input>
      <hdf5 fileName="python_reward.h5ref"/>
    </input>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml"/>
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech"/>
    </regionList>
    <nodeList>
      <nodes name="load">
        <coord x="1" y="0.5"/>
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>

        <bcsAndLoads>
           <fix name="left">
              <comp dof="x"/>
              <comp dof="y"/>
           </fix>
           <force name="right">
             <comp dof="x" value="1"/>
           </force>
        </bcsAndLoads>
        <storeResults>
          <!-- only the geometric pseudo density is deterministic; no mechDisplacement (FE is dummy) -->
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
        </storeResults>
      </mechanic>
    </pdeList>

    <!-- Dummy FE-Part -->
    <linearSystems>
      <system>
        <solverList>
          <cg>
            <maxIter>1</maxIter>
          </cg>
        </solverList>
      </system>
    </linearSystems>
  </sequenceStep>

  <optimization>
    <!-- reward objective J_reward = -sum_e rho*_e rho_e, implemented in share/python/tracking.py -->
    <costFunction type="python" task="minimize">
      <!-- because of (gc)mma we need a stopping criteria -->
      <stopping type="relativeCostChange" queue="2" value="1e-2"/>
      <python name="reward" init="track_init" eval="reward_eval" grad="reward_grad" script="kernel">
        <!-- the target field rho* whose overlap with the features is maximized -->
        <option key="target" value="bar_10.density.xml"/>
      </python>
    </costFunction>

    <!-- reward likes to overlap - we prevent this by short pills (plus the hughe radius at the ends)
         By this we hope for a more unique solution for the test  -->
    <constraint type="distance" design="node" bound="upperBound" value="0.17"/>

    <!-- lower bounds are always good to prevent singularities (gradients for feature mapping has length in denominator) -->
    <constraint type="distance" design="node" bound="lowerBound" value="0.05"/>

    <!-- much faster than mma! -->
    <optimizer type="dumas_gcmma" maxIterations="50">
    </optimizer>

    <ersatzMaterial region="mech" material="mechanic" method="featureMapping">
      <featureMapping transition=".1" boundary="poly" order="5" combine="p-norm" p="3">
        <pill>
          <node dof="x" initial="0.1"  upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.2" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.3" upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.8" upper="1" lower="0" tip="end"/>
          <profile fixed="0.2"/>
        </pill>
        <pill>
          <node dof="x" initial="0.8" upper="1" lower="0" tip="start"/>
          <node dof="y" initial="0.3" upper="1" lower="0" tip="start"/>
          <node dof="x" initial="0.7"  upper="1" lower="0" tip="end"/>
          <node dof="y" initial="0.9" upper="1" lower="0" tip="end"/>
          <profile fixed="0.2"/>
        </pill>
      </featureMapping>
      <design name="density" initial=".5" physical_lower="1e-3" upper="1.0"/>

      <transferFunction type="identity" application="mech"/>
      <export save="last" write="iteration"/>
    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
