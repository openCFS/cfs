<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation">
 <documentation>
    <title>ShapeMap slope</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2016-04-13</date>
    <keywords>
      <keyword>SIMP</keyword>
    </keywords>
    <references>Fabian Wein</references>
    <isVerified>no</isVerified>
    <description>Add local periodic constraints which are first shape element - last shape element. Only implemented for shape mapping.
    The design does not look periodic as the rhos are interpolated but the nodal values are identical. euqal bound 0 is no problem, even for scpip</description>
  </documentation>

  <fileFormats>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="99lines"/>
    </regionList>
    <nodeList>
      <nodes name="center">
        <coord x="0.5" y="0.5" />
      </nodes>
      <nodes name="right_center">
        <coord x="1" y="0.5" />
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech" />
        </regionList>

        <bcsAndLoads>
         <fix name="west">
           <comp dof="x"/> <comp dof="y"/>
         </fix>
         <force name="right_center">
           <comp dof="x" value="1"/>
         </force>
        </bcsAndLoads>
        
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions />
          </nodeResult>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>          
          <elemResult type="optResult_1">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_2">
            <allRegions/>
          </elemResult>
        </storeResults>
      </mechanic>
    </pdeList>

    <linearSystems>
      <system>
        <solutionStrategy>
          <standard>
          </standard>
        </solutionStrategy>
      </system>
    </linearSystems>
  </sequenceStep>


  <optimization>
    <costFunction type="compliance" task="minimize">
      <stopping queue="999" value="0.001" type="designChange"/>
    </costFunction>
    
    <constraint type="slope" bound="upperBound" value="1/nx" design="profile" linear="true"/>
    <constraint type="curvature" bound="upperBound" value=".25/nx" design="profile" linear="true"/>
    <constraint type="periodic" bound="equal" value="0" design="profile" linear="true"/>
    
    <constraint type="volume" linear="false" mode="constraint" bound="upperBound" value="0.3"/>    
    
    <optimizer type="snopt" maxIterations="10"/>

    <ersatzMaterial region="mech" material="mechanic" method="shapeMap">
      <shapeMap beta="140" overlap="max" enforce_bounds="true" >
        <node dof="y" lower="0.5" upper=".5" initial="0.5"/>
        <profile lower="0.05" upper="0.25" initial=".1"/>
      </shapeMap>
    
      <design name="density" initial="1.0" lower="1e-3" upper="1.0" />
      
      <transferFunction type="identity" application="mech"/>
      <result value="shapeMapGrad" id="optResult_1" design="density" detail="node"/>
      <result value="shapeMapGrad" id="optResult_2" design="density" detail="profile"/>
      <export write="iteration" save="all"/>
    </ersatzMaterial>
    <commit stride="100"/>
  </optimization> 
</cfsSimulation>


