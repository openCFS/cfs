<?xml version="1.0" encoding="UTF-8"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation">

 <documentation>
    <title>ShapeMap with symmetric mapped shapes</title>
    <authors>
      <author>Fabian Wein</author>
    </authors>
    <date>2016-06-20</date>
    <keywords>
      <keyword>SIMP</keyword>
    </keywords>
    <references>Fabian Wein</references>
    <isVerified>no</isVerified>
    <description>Makes use of symmetry. Here the x_symmetry of two horizontal shapes is tested. The left side is mapped to the right side.
    The problem is kind of tricky w.r.t local optima.</description>
  </documentation>

  <fileFormats>
    <output>
      <hdf5/>
      <info/>
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="99lines"/>
    </regionList>
    <nodeList>
      <nodes name="center">
        <coord x="0.5" y="0.5" />
      </nodes>
      <nodes name="right_center">
        <coord x="1" y="0.5" />
      </nodes>
    </nodeList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech" />
        </regionList>

        <bcsAndLoads>
         <fix name="west">
           <comp dof="x"/> <comp dof="y"/>
         </fix>
         <force name="right_lower">
           <comp dof="y" value="-1"/>
         </force>
        </bcsAndLoads>
        
        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions />
          </nodeResult>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>          
          <elemResult type="optResult_1">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_2">
            <allRegions/>
          </elemResult>
       </storeResults>
      </mechanic>
    </pdeList>

    <linearSystems>
      <system>
        <solutionStrategy>
          <standard>
          </standard>
        </solutionStrategy>
      </system>
    </linearSystems>
  </sequenceStep>

  <optimization>
    <costFunction type="compliance" task="minimize" >
      <stopping queue="999" value="0.001" type="designChange" />
    </costFunction>
    
    
    <constraint type="slope" bound="upperBound" value="1.5/nx" design="node" linear="false"/>
    <constraint type="slope" bound="upperBound" value="0.5/nx" design="profile" linear="false"/>
    <constraint type="curvature" bound="upperBound" value="0.2/nx" design="node" linear="false" />
    <constraint type="curvature" bound="upperBound" value="0.1/nx" design="profile" linear="false" />
    
    <constraint type="volume" linear="false" mode="constraint" bound="upperBound" value="0.4"/>

    <optimizer type="scpip" maxIterations="40">
      <snopt>
        <option type="integer" name="verify_level" value="-1"/>
      </snopt>
    </optimizer>

    <ersatzMaterial region="mech" material="mechanic" method="shapeMap" >
      <shapeMap beta="60" overlap="tanh_sum" enforce_bounds="true" sensitivity="1e-8" >
        <node dof="x" lower="0.0" upper="1" initial="0.1" left_right_sym="none"/>
        <node dof="y" lower="0" upper=".5" initial="0" left_right_sym="mirror"/>
        <node dof="y" lower="0.0" upper=".5" initial="0.2" left_right_sym="mirror"/>
        <profile lower="0.05" upper="0.1" initial="0.075"/>
      </shapeMap>
    
      <design name="density" initial="1.0" lower="1e-3" upper="1.0" />
      
      <transferFunction type="identity" application="mech"/>
      <result value="shapeMapIntOrder" id="optResult_1" />
      <result value="shapeMapMinMaxCorner" id="optResult_2"/>
      <export write="iteration" save="last"/>
    </ersatzMaterial>
    <commit stride="99"/>
  </optimization> 
</cfsSimulation>


