<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title>Acoustic Optimization - Output</title>
        <authors>
            <author>Felix Huber</author>
        </authors>
        <date>2025-02-27</date>
        <description>This file is used to maximize the dynamic output of an acoustic structure.</description>
    </documentation>

    <fileFormats>
        <!--<input>
            <hdf5 fileName="single_dynamic_out.h5ref"/>
        </input>-->
        <output>
            <hdf5 />
            <info id="info"/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>
    <domain geometryType="plane">
        <regionList>
            <region name="S_acou" material="air"/>
            <region name="S_opt" material="air"/>
        </regionList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <harmonic>
                <numFreq>1</numFreq>
                <startFreq>500</startFreq>
                <stopFreq>500</stopFreq>
            </harmonic>
        </analysis>
        <pdeList>
            <acoustic formulation="acouPressure">
                <regionList>
                    <region name="S_acou" complexFluid="yes"/>
                    <region name="S_opt" complexFluid="yes"/>
                </regionList>
                <bcsAndLoads>
                    <normalVelocity name="L_exc_surf" value="1"/>
                    <absorbingBCs name="L_exc_surf" volumeRegion="S_acou"/>
                    <absorbingBCs name="L_out_surf" volumeRegion="S_acou"/>
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="acouPressure">
                        <allRegions/>
                        <nodeList>
                            <nodes name="L_exc" outputIds="info"/>
                        </nodeList>
                    </nodeResult>
                    <elemResult type="pseudoDensity">
                        <allRegions/>
                    </elemResult>
                    <elemResult type="optResult_1">
                        <allRegions/>
                    </elemResult> 
                </storeResults>
            </acoustic>
        </pdeList>
    </sequenceStep>
    <optimization>
        <costFunction type="dynamicOutput" task="maximize" multiple_excitation="false">
            <stopping queue="999" value="0.001" type="designChange"/>
            <output>
                <acoustic name="L_out" value="1"/>
            </output>
        </costFunction>

        <constraint type="volume" value="0.9" bound="upperBound" mode="constraint" />
        <constraint type="volume" access="plain" mode="observation" />
        <constraint type="greyness" access="plain" mode="observation"/>

        <optimizer type="dumas_mma" maxIterations="68"/>

        <ersatzMaterial region="S_opt" material="acoustic" method="simp">
            <designSpace local_element_cache="false"/>
            <filters>
                <filter neighborhood="maxEdge" value="2.4" type="density">
                </filter>
            </filters>

            <design name="density" initial=".5" physical_lower="1e-9" upper="1.0" />
            <transferFunction type="simp" application="acoustic" param="1"/>
            
            <result value="costGradient" id="optResult_1" design="density" access="smart"/>
            <export save="last" write="iteration"/>
        </ersatzMaterial>
        <commit mode="forward" stride="1"/>
    </optimization>
</cfsSimulation>
