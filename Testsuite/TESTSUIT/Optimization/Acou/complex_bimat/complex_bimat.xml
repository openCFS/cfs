<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title>Acoustic Optimization - Complex bimaterial</title>
        <authors>
            <author>Felix Huber</author>
        </authors>
        <date>2026-05-06</date>
        <isVerified>yes</isVerified>
        <description>Test complex valued and frequency dependent bimaterial</description>
    </documentation>

    <fileFormats>
        <!-- create_mesh_acou.py -lin 0.4 -labh 0.6 -win 0.5 -wabh 0.5 -wout 0.5 -tpml 0.1 10 -->
        <output>
            <hdf5 />
            <info id="info"/>
        </output>
        <materialData file="mat.xml"/>
    </fileFormats>

    <domain geometryType="plane">
        <regionList>
            <region name="S_acou" material="air"/>
            <region name="S_opt" material="air"/>
            <region material="air" name="S_pml_in" />
        </regionList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <harmonic>
                <numFreq>1</numFreq>
                <startFreq>500</startFreq>
                <stopFreq>500</stopFreq>
                <sampling>linear</sampling>
            </harmonic>
        </analysis>
        <pdeList>
            <acoustic formulation="acouPressure">
                <regionList>
                    <region name="S_acou" complexFluid="yes"/>
                    <region name="S_opt" complexFluid="yes"/>
                    <region name="S_pml_in" dampingId="pml"/>
                </regionList>
                <dampingList>
                    <pml  id="pml">
                        <type> inverseDist </type>
                        <dampFactor> 1 </dampFactor>
                    </pml>
                </dampingList>
                <bcsAndLoads>
                    <normalVelocity name="L_in_surf" value="1" />
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="acouPressure">
                        <allRegions/>
                    </nodeResult>
                     <elemResult type="pseudoDensity">
                        <allRegions/>
                    </elemResult>
                    <elemResult type="physicalPseudoDensity">
                        <allRegions/>
                    </elemResult>
                </storeResults>
            </acoustic>
        </pdeList> 
    </sequenceStep>
    <optimization>
        <costFunction type="reflectedWave" task="minimize">
            <output>
                <acoustic name="L_in" value="1" surfRegion="L_in_surf" volumeNeighbour="S_acou"/>
            </output>
        </costFunction>

        <constraint type="volume" access="plain" bound="upperBound" value="0.5" linear="false"/>

        <optimizer type="dumas_mma" maxIterations="30" />

        <ersatzMaterial region="S_opt" material="acoustic" method="simp">
            <designSpace local_element_cache="false"/>
            <filters>
                <filter neighborhood="maxEdge" value="3.1" type="density" >
                    <density type="tanh" beta="64" eta="0.5" />
                </filter>
            </filters>

            <design name="density" initial="0.5" physical_lower="1e-9" upper="1" bimaterial="baso"/>

            <transferFunction type="simp" application="acoustic" param="1"/>
            
            <export save="last" write="iteration"/>
        </ersatzMaterial>

        <!-- visualize both load cases -->    
        <commit mode="forward" stride="10" />
    </optimization>
</cfsSimulation>
