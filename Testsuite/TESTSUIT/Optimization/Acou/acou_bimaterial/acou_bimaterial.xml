<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title>Acoustic Optimization - BiMaterial</title>
        <authors>
            <author>Felix Huber</author>
        </authors>
        <date>2025-02-27</date>
        <description>This file is a simple test of an air filled tube, with the optimization region as obstacle.
        It was verified by setting the initial pseudo density to 0(hard) and 1(air) and comparing the results with the two reference simulations.
        (This has to be done manually.)
        </description>
    </documentation>

    <fileFormats>
        <input>
            <hdf5 fileName="acou_bimaterial.h5ref"/>
        </input>
        <output>
            <hdf5 />
            <info id="info"/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>
    <domain geometryType="plane">
        <regionList>
            <region name="S_acou" material="air"/>
            <region name="S_opt" material="air"/>
        </regionList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <harmonic>
                <numFreq>1</numFreq>
                <startFreq>800</startFreq>
                <stopFreq>800</stopFreq>
            </harmonic>
        </analysis>
        <pdeList>
            <acoustic formulation="acouPressure">
                <regionList>
                    <region name="S_acou" complexFluid="yes"/>
                    <region name="S_opt" complexFluid="yes"/>
                </regionList>
                <bcsAndLoads>
                    <normalVelocity name="L_exc_surf" value="1"/>
                    <absorbingBCs volumeRegion="S_acou" name="L_exc_surf" />
                    <absorbingBCs volumeRegion="S_acou" name="L_out_surf" />
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="acouPressure">
                        <allRegions/>
                        <nodeList>
                            <nodes name="L_exc" outputIds="info"/>
                        </nodeList> 
                    </nodeResult>
                </storeResults>
            </acoustic>
        </pdeList>
    </sequenceStep>
    <optimization>
        <costFunction type="dynamicOutput" task="maximize" multiple_excitation="false">
            <output>
                <acoustic name="L_out" value="1"/>
            </output>
        </costFunction>

        <optimizer type="evaluate" maxIterations="1"/>

        <ersatzMaterial region="S_opt" material="acoustic" method="simp">
            <designSpace local_element_cache="false"/>

            <design name="density" initial="0.5" lower="0" upper="1" bimaterial="hard"/>

            <transferFunction type="simp" application="acoustic" param="1"/>
        </ersatzMaterial>
        <commit mode="forward" stride="1"/>
    </optimization>
</cfsSimulation>
