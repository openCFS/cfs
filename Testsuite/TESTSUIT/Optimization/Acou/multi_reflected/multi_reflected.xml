<?xml version="1.0" encoding="UTF-8"?>
<cfsSimulation xmlns="http://www.cfs++.org/simulation" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.cfs++.org/simulation 
https://opencfs.gitlab.io/cfs/xml/CFS-Simulation/CFS.xsd">

    <documentation>
        <title>Acoustic Optimization - Multiload Reflected</title>
        <authors>
            <author>Felix Huber</author>
        </authors>
        <date>2025-02-27</date>
        <description>This file is used to minimize the reflected wave of an acoustic structure.
        It is a multiload optimization for two frequencies used for testing small problems.
        This is a complex problem - This test is unstable for larger frequency steps.
        This test uses the same mesh as single_dynamic_out.</description>
    </documentation>

    <fileFormats>
        <input>
            <hdf5 fileName="multi_reflected.h5ref"/>
        </input>
        <output>
            <hdf5 />
            <info id="info"/>
        </output>
        <materialData file="mat.xml" format="xml"/>
    </fileFormats>
    <domain geometryType="axi">
        <regionList>
            <region name="S_acou" material="air"/>
            <region name="S_opt" material="air"/>
        </regionList>
    </domain>

    <sequenceStep index="1">
        <analysis>
            <harmonic>
                <numFreq>2</numFreq>
                <startFreq>400</startFreq>
                <stopFreq>420</stopFreq>
            </harmonic>
        </analysis>
        <pdeList>
            <acoustic formulation="acouPressure">
                <regionList>
                    <region name="S_acou" complexFluid="yes"/>
                    <region name="S_opt" complexFluid="yes"/>
                </regionList>
                <bcsAndLoads>
                    <normalVelocity name="L_exc_surf" value="0.5"/>
                    <absorbingBCs name="L_exc_surf" volumeRegion="S_acou"/>
                    <absorbingBCs name="L_out_surf" volumeRegion="S_acou"/>
                </bcsAndLoads>
                <storeResults>
                    <nodeResult type="acouPressure">
                        <allRegions/>
                        <nodeList>
                            <nodes name="L_exc" outputIds="info"/>
                            <nodes name="L_out" outputIds="info"/>
                        </nodeList>
                    </nodeResult>
                    <elemResult type="pseudoDensity">
                        <allRegions/>
                    </elemResult>
                    <elemResult type="optResult_1">
                        <allRegions/>
                    </elemResult> 
                </storeResults>
            </acoustic>
        </pdeList>
        <!-- This option can be used to export the linear systems -->
        <!--<linearSystems>
            <system>
                <solutionStrategy>
                    <standard>
                        <exportLinSys rhs="true"/>
                    </standard>
                </solutionStrategy>
            </system>
        </linearSystems>-->
    </sequenceStep>
    <optimization>
        <!-- multiple_excitation will in this case be used for individual frequency steps --> 
        <costFunction type="reflectedWave" task="minimize" multiple_excitation="true">
            <stopping queue="999" value="0.001" type="designChange"/>
            <output>
                <acoustic name="L_exc" value="1" surfRegion="L_exc_surf" volumeNeighbour="S_acou"/>
            </output>
        </costFunction>

        <constraint type="volume" value="0.5" bound="upperBound" mode="constraint" />
        <constraint type="volume" access="physical" mode="observation" />
        <constraint type="greyness" access="plain" mode="observation"/>
        <constraint type="greyness" access="physical" mode="observation"/>

        <optimizer type="dumas_mma" maxIterations="100">
            <snopt>
                <!-- value of 3 enables the gradient check of snopt -->
                <option name="verify_level" type="integer" value="-1"/>
            </snopt>
        </optimizer>

        <ersatzMaterial region="S_opt" material="acoustic" method="simp">
            <designSpace local_element_cache="false"/>
            <filters>
                <filter neighborhood="maxEdge" value="2.4" type="density"></filter>
            </filters>

            <design name="density" initial=".5" physical_lower="1e-9" upper="1.0" />
            <design name="slack" initial="50000" lower="0" upper="100000"/>

            <transferFunction type="simp" application="acoustic" param="1"/>
            
            <result value="costGradient" id="optResult_1" design="density" access="smart"/>
            <export save="all" write="iteration"/>
        </ersatzMaterial>
        <commit mode="each_forward" stride="1"/>
    </optimization>
</cfsSimulation>
