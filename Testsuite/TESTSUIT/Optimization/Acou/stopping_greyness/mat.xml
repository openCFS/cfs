<?xml version='1.0' encoding='utf-8'?>
<cfsMaterialDataBase xmlns="http://www.cfs++.org/material"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://www.cfs++.org/material 
https://opencfs.gitlab.io/cfs/xml/CFS-Material/CFS_Material.xsd" >
  <material name="air">
    <acoustic>
      <!-- Data obtained from : www.wikipedia.de -> "Luft" und "Kompressionsmodul"
      Reference(s) :  -->
      <!-- Remarks : Standardbedingungen bei Temp. T=20 degree und Druckp=1013 hPa"
                     Kompressionsmodul aus Adiabatenexponent gamma = 1,40 berechnet -->
      <density>
        <linear>
          <real> 1.204 </real>
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real> 0.142e+6 </real>
        </linear>
      </compressionModulus>
    </acoustic>
  </material>
  <material name="hard">
    <acoustic>
      <!-- Special "soundhard" material from 
      Lee and Kim, Rigid body modeling issue in acoustical topology optimization-->
      <density>
        <linear>
          <real> 1.204*1e5 </real> <!-- 1e5 * rho_air -->
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real> 0.142e+13 </real> <!-- 1e7 * K_air-->
        </linear>
      </compressionModulus>
    </acoustic>
  </material>
  <material name="alu">
    <acoustic>
      <!-- Data obtained from : www.wikipedia.org -> "Aluminium"
      Reference(s) :  https://en.wikipedia.org/wiki/Aluminium -->
      <density>
        <linear>
          <real> 2700 </real>
        </linear>
      </density>
      <compressionModulus>
        <linear>
          <real> 76e+9 </real>
        </linear>
      </compressionModulus>
    </acoustic>
  </material>
</cfsMaterialDataBase>
