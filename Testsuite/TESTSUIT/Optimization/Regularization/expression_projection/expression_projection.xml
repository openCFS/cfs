<?xml version="1.0" encoding="UTF-8"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation">
  <documentation>
    <title>Expression Projection</title>
    <authors><author>Fabian Wein</author></authors>
    <date>2024-08-08</date>
    <references>Wang and Sigmund 2011</references>
    <isVerified>yes</isVerified>
    <description>For a three field topology optimization we use a math parser expression
    for the projection function. This is a variant of the inbuilt tanh with the properties
    that for input 0 it is 0 and for 1 it is 1. The tanh function is much cheaper to evaluate,
    by our automatic nonlinear scaling it is (as the expression) scaled to physical lower bound
    and upper bound but beta has a different meaning (factor less then 2).
    
    The expression is not parallel implemented and slow due to a critical section. Enhance if you
    really want to use it for large problems.
    </description>
  </documentation>
  
  <fileFormats>
    <output>
      <hdf5 />
      <info />
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech" />
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStrain">
        <regionList>
          <region name="mech" />
        </regionList>

        <bcsAndLoads>
           <fix name="left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
           </fix>
           <force name="bottom_right" >
             <comp dof="y" value="-1" />
           </force>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <nodeResult type="mechRhsLoad">
            <allRegions/>
          </nodeResult>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="physicalPseudoDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_1">
            <allRegions/>
          </elemResult>
          <regionResult type="mechTotalEnergy">
            <allRegions/>
          </regionResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>

    
  <optimization>
    <costFunction type="compliance" task="minimize" >
      <stopping value="0.01" type="belowFunction" function="greyness" condition="necessary" />
      <stopping value="1e-5" type="relativeCostChange" queue="1" condition="necessary" />
      <stopping value="300" type="oscillations" condition="sufficient" />
    </costFunction>

    <!-- filtered and projected but not penalized -->
    <constraint type="volume" access="filtered" value=".5" bound="upperBound" linear="false"/>
    <constraint type="greyness" access="filtered" mode="observation"/>
    
    <optimizer type="ocm" maxIterations="5">
      <ocm move_limit="0.2" />
    </optimizer>

    <ersatzMaterial region="mech" material="mechanic" method="simp" >
      <filters>
        <filter neighborhood="maxEdge" value="3" type="density" >
          <density type="expression" beta="2" eta="0.5">
            <!-- see Wang and Sigmund 2011, our own tanh is simlar and faster as it has only two exp evals -->
            <expression function="(tanh(b*e) + tanh(b*(x-e))) / (tanh(b*e) + tanh(b*(1-e)))"
                        derivative="b/(cosh(b*(x-e))^2 *(sinh(b*e)/cosh(b*e) + sinh(b-b*e)/cosh(b-b*e)))" /> 
          </density>
        </filter>
     </filters>

      <design name="density" initial=".5" physical_lower="1e-9" upper="1.0"/>
      <transferFunction type="simp" application="mech" param="3" />
      <!-- the filtered and projection desing -->
      <result value="design" id="optResult_1" access="smart"/>
      <export save="last" write="iteration" />
    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
