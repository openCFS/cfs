<?xml version="1.0" encoding="UTF-8"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation">
  <documentation>
    <title>Python beta tune</title>
    <authors><author>Fabian Wein</author></authors>
    <date>2024-08-08</date>
    <references>Dunning and Wein 2024</references>
    <isVerified>yes</isVerified>
    <description>For a three field topology optimization we increase beta based on the
    objective change for a tanh three field optimization.
    
    This is the original Python implementation, there is a native implementation to come.
    </description>
  </documentation>

  <python file="auto_filter.py" path=".">
    <callback hook="opt_post_init" function="my_opt_post_init" >
      <option key="adapt_move_limits" value="1"/>
      <option key="delta_beta_max_factor" value="0.2"/>
      <!-- common value is 1e-4, here so fast to converge within the test -->
      <option key="gamma" value="1e-1"/>
      <option key="auto_divider" value="0"/>
      <option key="tz_divider" value="5"/>
      <option key="halt_on_osc" value="0"/>
      <option key="max_beta" value="256"/>
    </callback>
    <callback hook="opt_post_iter" function="opt_post_iter_dunning_auto_filter" />
  </python>
  
  <fileFormats>
    <output>
      <hdf5 />
      <info />
    </output>
    <materialData file="mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region material="99lines" name="mech" />
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static/>
    </analysis>

    <pdeList>
      <mechanic subType="planeStrain">
        <regionList>
          <region name="mech" />
        </regionList>

        <bcsAndLoads>
           <fix name="left"> 
              <comp dof="x"/> 
              <comp dof="y"/> 
           </fix>
           <force name="bottom_right" >
             <comp dof="y" value="-1" />
           </force>
        </bcsAndLoads>

        <storeResults>
          <nodeResult type="mechDisplacement">
            <allRegions/>
          </nodeResult>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="physicalPseudoDensity">
            <allRegions/>
          </elemResult>
          <elemResult type="optResult_1">
            <allRegions/>
          </elemResult>
          <regionResult type="mechTotalEnergy">
            <allRegions/>
          </regionResult>
        </storeResults>
      </mechanic>
    </pdeList>

  </sequenceStep>

    
  <optimization>
    <costFunction type="compliance" task="minimize" >
      <stopping value="0.05" type="belowFunction" function="greyness" condition="necessary" />
      <stopping value="1e-3" type="relativeCostChange" queue="1" condition="necessary" />
      <stopping value="300" type="oscillations" condition="sufficient" />
    </costFunction>

    <!-- filtered and projection but not penalized -->
    <constraint type="volume" access="filtered" value=".5" bound="upperBound" linear="false"/>
    <constraint type="greyness" access="filtered" mode="observation"/>
    
    <optimizer type="ocm" maxIterations="30"/>

    <ersatzMaterial region="mech" material="mechanic" method="simp" >
      <filters>
        <filter neighborhood="maxEdge" value="3" type="density" >
          <density type="tanh" beta="1" eta="0.5"/>
        </filter>
     </filters>

      <design name="density" initial=".5" physical_lower="1e-9" upper="1.0"/>
      <transferFunction type="simp" application="mech" param="3" />
      <result value="costGradient" id="optResult_1" design="density" access="smart"/>
      <result value="design" access="smart" id="optResult_1"/>
      <export save="last" write="iteration" />
    </ersatzMaterial>
    <commit mode="forward" stride="1"/>
  </optimization>
</cfsSimulation>
