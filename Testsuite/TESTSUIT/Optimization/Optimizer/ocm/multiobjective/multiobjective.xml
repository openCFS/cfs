<?xml version="1.0" encoding="UTF-8"?>

<cfsSimulation xmlns="http://www.cfs++.org/simulation" id="0">
  <documentation>
    <title>multiobjective OCM test</title>
    <authors>
      <author>Daniel Huebner</author>
    </authors>
    <date>2022-12-06</date>
    <keywords>
      <keyword>optimization</keyword>
    </keywords>
    <references></references>
    <isVerified>no</isVerified>
    <description>
    </description>
  </documentation>
  <fileFormats>
    <output>
      <hdf5 />
    </output>
    <materialData file="./mat.xml" format="xml" />
  </fileFormats>

  <domain geometryType="plane">
    <regionList>
      <region name="mech" material="strong" />
    </regionList>
  </domain>

  <sequenceStep index="1">
    <analysis>
      <static />
    </analysis>
    <pdeList>
      <mechanic subType="planeStress">
        <regionList>
          <region name="mech"/>
        </regionList>
        <bcsAndLoads>
          <fix name="bottom">
            <comp dof="y"/>
          </fix>
          <force name="top">
            <comp dof="y" value="-1"/>
          </force>
        </bcsAndLoads>
        <storeResults>
          <elemResult type="mechPseudoDensity">
            <allRegions/>
          </elemResult>
          <nodeResult type="mechDisplacement">
            <allRegions />
          </nodeResult>
        </storeResults>
      </mechanic>
    </pdeList>
  </sequenceStep>
  
  <optimization>
    <costFunction type="compliance" task="minimize" linear="false"/>
    <constraint type="perimeter" parameter="0.5" bound="upperBound" value="0" mode="constraint"/>
    <constraint type="volume" bound="upperBound" value="0.5" mode="constraint"/>
    <optimizer type="ocm" maxIterations="5">
      <ocm move_limit="0.2">
        <framed checkErr="false" lower="0" upper="1e9" enlargeLower="1e-4" enlargeUpper="1e4"/>
        <multiObjective constraint="volume" beta="10" multiObjectiveWeight="0.5"/>
      </ocm>
    </optimizer>
    <ersatzMaterial material="mechanic" method="simp" region="mech">
      <filters>
        <filter neighborhood="maxEdge" value="1.6" type="density"/>
      </filters>
     <design name="density" initial="0.5" physical_lower="1e-9" upper="1.0" />
     <transferFunction application="mech" type="simp" param="3"/>
     <export save="all" write="iteration"/>
    </ersatzMaterial>
    <commit stride="99"/>
  </optimization>

</cfsSimulation>
