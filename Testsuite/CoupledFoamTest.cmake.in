# -*- mode: cmake; coding: utf-8; indent-tabs-mode: nil; -*-
# kate: syntax cmake; space-indent on; indent-width 2; encoding utf-8;
#-------------------------------------------------------------------------------
# CoupledFoamTest.cmake - run a preCICE-coupled openCFS<->OpenFOAM test.
#
# Like CoupledTest.cmake, but the coupling partner is a real OpenFOAM solver
# using the cfsdeps OpenFOAM + openfoam-adapter (USE_OPENFOAM builds). Tests
# using this driver are only registered when the build provides openfoam-env.sh
# (gated in TESTSUIT/preCICE/CMakeLists.txt), so e.g. the CI test stage without
# OpenFOAM simply skips them.
#
# A test registers itself via (see TESTSUIT/preCICE/PerpendicularFlapSmoothFoam):
#   ADD_TEST(<name> ${CMAKE_COMMAND}
#     -DEPSILON:STRING=1e-3
#     -DCURRENT_TEST_DIR=${CMAKE_CURRENT_SOURCE_DIR}
#     [-DFOAM_SOLVER:STRING=pimpleFoam]
#     [-DFOAM_CASE_DIR:STRING=fluid-openfoam]
#     -P ${CFS_COUPLED_FOAM_TEST})
#-------------------------------------------------------------------------------
SET(USE_OPENMP "@USE_OPENMP@")
SET(USE_PETSC "@USE_PETSC@")
SET(CFS_BINARY_DIR "@CFS_BINARY_DIR@")
SET(CMAKE_EXECUTABLE_SUFFIX "@CMAKE_EXECUTABLE_SUFFIX@")
set(TESTSUITE_CFSTOOL_MODE "@TESTSUITE_CFSTOOL_MODE@")
# a test may pin its cfs thread count via -DTESTSUITE_THREADS in ADD_TEST;
# default is the suite-wide setting
if(NOT DEFINED TESTSUITE_THREADS)
  set(TESTSUITE_THREADS "@TESTSUITE_THREADS@")
endif()

# Paths to the binaries used by a coupled test.
SET(CFS_BINARY     "${CFS_BINARY_DIR}/bin/cfs${CMAKE_EXECUTABLE_SUFFIX}")
SET(CFSTOOL_BINARY "${CFS_BINARY_DIR}/bin/cfstool${CMAKE_EXECUTABLE_SUFFIX}")

# OpenFOAM runtime environment of this build (solvers + adapter in FOAM_LIBBIN),
# generated by cfsdeps/openfoam-adapter/External_OpenFOAMAdapter.cmake.
SET(OPENFOAM_ENV_SCRIPT "@OPENFOAM_ENV_SCRIPT@")

# Path to testsuite source / output directories.
SET(TESTSUITE_SRC_DIR "@TESTSUITE_DIR@")
SET(TESTSUITE_BIN_DIR "@TESTSUITE_BIN_DIR@")

INCLUDE("${TESTSUITE_SRC_DIR}/TestMacros.cmake")

# defaults for the per-test variables (can be overridden via -D in ADD_TEST)
IF(NOT FOAM_SOLVER)
  SET(FOAM_SOLVER "pimpleFoam")
ENDIF()
IF(NOT FOAM_CASE_DIR)
  SET(FOAM_CASE_DIR "fluid-openfoam")
ENDIF()

#-------------------------------------------------------------------------------
# Macro with the coupled CFS++/OpenFOAM test routine: copy inputs, run the
# OpenFOAM solver + cfs concurrently, then compare results_hdf5/*.h5 against
# *.h5ref via cfstool.
#-------------------------------------------------------------------------------
MACRO(CFS_COUPLED_FOAM_TEST)
  GENERATE_TEST_NAME_AND_FILE("${CURRENT_TEST_DIR}")
  DETERMINE_TEST_FILE_LIST()
  CLEANUP_TEST_DIR()
  COPY_TEST_FILES("${TEST_FILE_LIST}" "${SKIP_H5REF}")

  # run cfs with the configured number of testsuite threads
  IF(TESTSUITE_THREADS LESS 2 AND USE_OPENMP)
    MESSAGE("You are using USE_OPENMP but test only with 1 thread.")
  ENDIF()
  SET(CFS_ARGS ${CFS_ARGS} "-t${TESTSUITE_THREADS}")

  # use default cfstool mode if not specified
  IF("${CFSTOOL_MODE}" STREQUAL "")
    SET(CFSTOOL_MODE ${TESTSUITE_CFSTOOL_MODE})
  ENDIF()

  RUN_COUPLED_FOAM_SIMULATION()
  DIFF_TEST_RESULTS_CFSTOOL("${EPSILON}" "${CFSTOOL_MODE}")
ENDMACRO(CFS_COUPLED_FOAM_TEST)

CFS_COUPLED_FOAM_TEST()
