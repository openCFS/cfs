#!/bin/sh

ErrorCheck () {  if [ ! $? -eq 0 ]; then echo "An error occurred!"; exit 1; fi }

if [ ! $# -eq 3 ]; then
    echo "Usage:"
    echo "hdf5_concat.sh DEST_H5_FILE SOURCE_H5_FILE MODE"
    exit 1
fi

H5FILE1=$1
H5FILE2=$2
MODE=$3
MASTERFILENAME=`basename $H5FILE1`
DIR1=`dirname $H5FILE1`
DIR2=`dirname $H5FILE2`
H5IMPORT=@CFSDEPS_ROOT_DIR@/bin/h5import
H5DUMP=@CFSDEPS_ROOT_DIR@/bin/h5dump
H5CFSHELPER=@CFS_BINARY_DIR@/bin/h5tool

BASEPATH=`dirname $0`
if [ -e $BASEPATH/import_cfsdeps.sh ]
then
    source $BASEPATH/import_cfsdeps.sh $BASEPATH
fi

if [ ! -d $WORKDIR ]
then
    echo "$WORKDIR is no directory!"
    exit 1
fi

if [ ! -e $H5IMPORT ]
then
    H5IMPORT=$CFSDEPS_ROOT/bin/h5import

    if [ ! -e $H5IMPORT ]
    then
	echo "Could not find h5import executable!"
	exit 1
    fi
fi

if [ ! -e $H5CFSHELPER ]
then
    H5CFSHELPER=$BASEPATH/h5tool

    if [ ! -e $H5CFSHELPER ]
    then
	echo "Could not find h5tool executable!"
	exit 1
    fi
fi

# echo "h5tool: $H5CFSHELPER" 
# echo "h5import: $H5IMPORT" 

# echo "Input type: $INPUTTYPE"
# rm -f $H5FILE;

export LANG=en_US.UTF-8

AVAIL_RESULTS=`$H5DUMP --group=/Results/Mesh/MultiStep_1/ResultDescription $H5FILE2 | grep '   GROUP "' | sed -e 's/   GROUP "//g' | sed -e 's/" {//g'`
RESULT=`echo $AVAIL_RESULTS | cut -d' ' -f1`

$H5DUMP --dataset="/Results/Mesh/MultiStep_1/ResultDescription/$RESULT/StepNumbers" -y --output=out.txt $H5FILE1 > /dev/null;
STEP_NUMBERS1=`cat out.txt | sed -e 's/,//g'`
$H5DUMP --dataset="/Results/Mesh/MultiStep_1/ResultDescription/$RESULT/StepValues" -y --output=out.txt $H5FILE1 > /dev/null;
STEP_VALUES1=`cat out.txt | sed -e 's/,//g'`
NUM_STEPS1=`echo $STEP_NUMBERS1 | wc -w`
echo "NUM_STEPS1: $NUM_STEPS1"
LAST_STEP_VALUE=`echo $STEP_VALUES1 | cut -d' ' -f$NUM_STEPS1`
echo "LAST_STEP_VALUE: $LAST_STEP_VALUE"

$H5DUMP --dataset="/Results/Mesh/MultiStep_1/ResultDescription/$RESULT/StepNumbers" -y --output=out.txt $H5FILE2 > /dev/null;
STEP_NUMBERS2=`cat out.txt | sed -e 's/,//g'`
$H5DUMP --dataset="/Results/Mesh/MultiStep_1/ResultDescription/$RESULT/StepValues" -y --output=out.txt $H5FILE2 > /dev/null;
STEP_VALUES2=`cat out.txt | sed -e 's/,//g'`
T1=`echo $STEP_VALUES2 | cut -d' ' -f1`
T1=`echo $T1 | awk -F"e" 'BEGIN{OFMT="%20.12f"} {print $1 * (10 ^ $2)}'`
T2=`echo $STEP_VALUES2 | cut -d' ' -f2`
T2=`echo $T2 | awk -F"e" 'BEGIN{OFMT="%20.12f"} {print $1 * (10 ^ $2)}'`
DT=`echo "$T2 - $T1" | bc`
echo "DT: $DT"

echo $STEP_NUMBERS1 | sed -e 's/\x20/\x0a/g' > StepNumbers.dat
echo $STEP_VALUES1 | sed -e 's/\x20/\x0a/g' > StepValues.dat

i=1

for STEP_NUM in $STEP_NUMBERS2; do
    STEP_NUM_NEW=$((NUM_STEPS1 + STEP_NUM))
    OLD_FILENAME="TimeStep_$STEP_NUM.h5"
    NEW_FILENAME="TimeStep_$STEP_NUM_NEW.h5"
    OLD_PATH="$DIR2/$OLD_FILENAME"
    NEW_PATH="$DIR1/$NEW_FILENAME"

    if [ "$MODE" = "mv" ]; then
	echo "Moving $OLD_PATH -> $NEW_PATH...";
	mv $OLD_PATH $NEW_PATH
	ErrorCheck
    else
	echo "Copying $OLD_PATH -> $NEW_PATH...";
	cp $OLD_PATH $NEW_PATH
	ErrorCheck
    fi

    CMDSTR="attribute\ncreate\n$NEW_PATH\n/\nstring\nMasterHDF5FileName\noverwrite\n$MASTERFILENAME\n"
    printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck
    CMDSTR="group\ncreate\n$H5FILE1\n/Results/Mesh/MultiStep_1\nStep_$STEP_NUM_NEW\nignore\n"
    printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck
    CMDSTR="attribute\ncreate\n$H5FILE1\n/Results/Mesh/MultiStep_1/Step_$STEP_NUM_NEW\nstring\nExtHDF5FileName\nignore\n$NEW_FILENAME\n"
    printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck

    echo $STEP_NUM_NEW >> StepNumbers.dat
    echo "$LAST_STEP_VALUE + ($i * $DT)" | bc >> StepValues.dat
    ErrorCheck

    i=$(( i + 1 ))
done

CMDSTR="attribute\ncreate\n$H5FILE1\n/Results/Mesh/MultiStep_1\nuint\nLastStepNum\noverwrite\n`tail -1 StepNumbers.dat`\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck

CMDSTR="attribute\ncreate\n$H5FILE1\n/Results/Mesh/MultiStep_1\ndouble\nLastStepValue\noverwrite\n`tail -1 StepValues.dat`\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck


for RESULT in $AVAIL_RESULTS; do
    echo "Writing step numbers for result $RESULT..."

    CMDSTR="dataset\ndelete\n$H5FILE1\n/Results/Mesh/MultiStep_1/ResultDescription/$RESULT\nStepNumbers\n"
    printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck

    CFGFILE=StepNumbers.cfg
    echo "PATH /Results/Mesh/MultiStep_1/ResultDescription/$RESULT/StepNumbers" > $CFGFILE
    echo "INPUT-CLASS TEXTUIN" >> $CFGFILE
    echo "INPUT-SIZE 32" >> $CFGFILE
    echo "RANK 1" >> $CFGFILE
    echo "DIMENSION-SIZES `wc -l StepNumbers.dat | cut -d' ' -f1`" >> $CFGFILE
    echo "OUTPUT-CLASS UIN" >> $CFGFILE
    echo "OUTPUT-SIZE 32" >> $CFGFILE
    echo "OUTPUT-ARCHITECTURE STD" >> $CFGFILE
    echo "OUTPUT-BYTE-ORDER LE" >> $CFGFILE
    $H5IMPORT StepNumbers.dat -c $CFGFILE -o $H5FILE1
    ErrorCheck

    echo "Writing step values for result $RESULT..."

    CMDSTR="dataset\ndelete\n$H5FILE1\n/Results/Mesh/MultiStep_1/ResultDescription/$RESULT\nStepValues\n"
    printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck

    CFGFILE=StepValues.cfg
    echo "PATH /Results/Mesh/MultiStep_1/ResultDescription/$RESULT/StepValues" > $CFGFILE
    echo "INPUT-CLASS TEXTFP" >> $CFGFILE
    echo "INPUT-SIZE 64" >> $CFGFILE
    echo "RANK 1" >> $CFGFILE
    echo "DIMENSION-SIZES `wc -l StepValues.dat | cut -d' ' -f1`" >> $CFGFILE
    echo "OUTPUT-CLASS FP" >> $CFGFILE
    echo "OUTPUT-SIZE 64" >> $CFGFILE
    echo "OUTPUT-ARCHITECTURE IEEE" >> $CFGFILE
    echo "OUTPUT-BYTE-ORDER LE" >> $CFGFILE
    $H5IMPORT StepValues.dat -c $CFGFILE -o $H5FILE1
    ErrorCheck

done


rm -f StepNumbers.dat
rm -f StepValues.dat
rm -f StepNumbers.cfg
rm -f StepValues.cfg
rm -f out.txt
