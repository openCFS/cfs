#!/bin/sh

ErrorCheck () {  if [ ! $? -eq 0 ]; then echo "An error occurred!"; exit 1; fi }

WORKDIR=$1
H5FILE=$WORKDIR/$2
H5IMPORT=@CFSDEPS_ROOT_DIR@/bin/h5import
H5CFSHELPER=@CFS_BINARY_DIR@/bin/h5tool
INPUTTYPE=$3

BASEPATH=`dirname $0`
if [ -e $BASEPATH/import_cfsdeps.sh ]
then
    . $BASEPATH/import_cfsdeps.sh $BASEPATH
fi

if [ ! -d $WORKDIR ]
then
    echo "$WORKDIR is no directory!"
    exit 1
fi

if [ ! -e $H5IMPORT ]
then
    H5IMPORT=$CFSDEPS_ROOT/bin/h5import

    if [ ! -e $H5IMPORT ]
    then
	echo "Could not find h5import executable!"
	exit 1
    fi
fi

if [ ! -e $H5CFSHELPER ]
then
    H5CFSHELPER=$BASEPATH/h5tool

    if [ ! -e $H5CFSHELPER ]
    then
	echo "Could not find h5tool executable!"
	exit 1
    fi
fi

# echo "h5tool: $H5CFSHELPER" 
# echo "h5import: $H5IMPORT" 

# rm -f $H5FILE;

echo "Writing point coordinates..."
NUM_NODES=`fgrep DIMENSION-SIZES $WORKDIR/Coordinates.cfg | cut -d' ' -f2`

$H5IMPORT $WORKDIR/Coordinates.dat -c $WORKDIR/Coordinates.cfg -o $H5FILE
ErrorCheck

echo "Writing element connectivity..."
NUM_ELEMS=`fgrep DIMENSION-SIZES $WORKDIR/Connectivity.cfg | cut -d' ' -f2`
ErrorCheck

MAX_NUM_ELEM_NODES=`fgrep DIMENSION-SIZES $WORKDIR/Connectivity.cfg | cut -d' ' -f3`
ErrorCheck

$H5IMPORT $WORKDIR/Connectivity.dat -c $WORKDIR/Connectivity.cfg -o $H5FILE
ErrorCheck

$H5IMPORT $WORKDIR/Types.dat -c $WORKDIR/Types.cfg -o $H5FILE
ErrorCheck

ELEM_TYPES=`cat $WORKDIR/Types.dat`
NUM_ET_POINT=`  echo $ELEM_TYPES | grep [^1]1 | wc -w`; ErrorCheck
NUM_ET_LINE2=`	echo $ELEM_TYPES | grep [^1]2 | wc -w`; ErrorCheck
NUM_ET_LINE3=`	echo $ELEM_TYPES | grep [^1]3 | wc -w`; ErrorCheck
NUM_ET_TRIA3=`	echo $ELEM_TYPES | grep [^1]4 | wc -w`; ErrorCheck
NUM_ET_TRIA6=`	echo $ELEM_TYPES | grep [^1]5 | wc -w`; ErrorCheck
NUM_ET_QUAD4=`	echo $ELEM_TYPES | grep [^1]6 | wc -w`; ErrorCheck
NUM_ET_QUAD8=`	echo $ELEM_TYPES | grep [^1]7 | wc -w`; ErrorCheck
NUM_ET_QUAD9=`	echo $ELEM_TYPES | grep [^1]8 | wc -w`; ErrorCheck
NUM_ET_TET4=`	echo $ELEM_TYPES | grep [^1]9 | wc -w`; ErrorCheck
NUM_ET_TET10=`	echo $ELEM_TYPES | grep 10 | wc -w`; ErrorCheck
NUM_ET_HEXA8=`	echo $ELEM_TYPES | grep 11 | wc -w`; ErrorCheck
NUM_ET_HEXA20=` echo $ELEM_TYPES | grep 12 | wc -w`; ErrorCheck
NUM_ET_HEXA27=` echo $ELEM_TYPES | grep 13 | wc -w`; ErrorCheck
NUM_ET_PYRA5=`	echo $ELEM_TYPES | grep 14 | wc -w`; ErrorCheck
NUM_ET_PYRA13=` echo $ELEM_TYPES | grep 15 | wc -w`; ErrorCheck
NUM_ET_WEDGE6=` echo $ELEM_TYPES | grep 16 | wc -w`; ErrorCheck
NUM_ET_WEDGE15=`echo $ELEM_TYPES | grep 17 | wc -w`; ErrorCheck

NUM_LIN1D_ELEMS=$NUM_ET_LINE2
NUM_LIN2D_ELEMS=$(($NUM_ET_TRIA3+$NUM_ET_QUAD4))
NUM_LIN3D_ELEMS=$(($NUM_ET_TET4+$NUM_ET_HEXA8+$NUM_ET_PYRA5+$NUM_ET_WEDGE6))

NUM_QUAD1D_ELEMS=$NUM_ET_LINE3
NUM_QUAD2D_ELEMS=$(($NUM_ET_TRIA6+$NUM_ET_QUAD8+$NUM_ET_QUAD9))
NUM_QUAD3D_ELEMS=$(($NUM_ET_TET10+$NUM_ET_HEXA20+$NUM_ET_HEXA27+$NUM_ET_PYRA13+$NUM_ET_WEDGE15))

QUAD_ELEMS=$(($NUM_QUAD1D_ELEMS+$NUM_QUAD2D_ELEMS+$NUM_QUAD3D_ELEMS))

if [ ! "$QUAD_ELEMS" -eq 0 ]
then
    QUAD_ELEMS=1
    NUM_1D_ELEMS=$NUM_QUAD1D_ELEMS
    NUM_2D_ELEMS=$NUM_QUAD2D_ELEMS
    NUM_3D_ELEMS=$NUM_QUAD3D_ELEMS
else
    NUM_1D_ELEMS=$NUM_LIN1D_ELEMS
    NUM_2D_ELEMS=$NUM_LIN2D_ELEMS
    NUM_3D_ELEMS=$NUM_LIN3D_ELEMS
fi

if [ ! "$NUM_1D_ELEMS" -eq 0 ]
then
    DIM=1
fi

if [ ! "$NUM_2D_ELEMS" -eq 0 ]
then
    DIM=2
fi

if [ ! "$NUM_3D_ELEMS" -eq 0 ]
then
    DIM=3
fi

echo "Dimension: $DIM"

echo "Writing global attributes..."
CMDSTR="group\ncreate\n$H5FILE\n/Mesh\nGroups\nfail\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh\nuint\nDimension\nfail\n$DIM\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNumElems\nfail\n$NUM_ELEMS\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nQuadraticElems\nfail\n$QUAD_ELEMS\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck                   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum1DElems\nfail\n$NUM_1D_ELEMS\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum2DElems\nfail\n$NUM_2D_ELEMS\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum3DElems\nfail\n$NUM_3D_ELEMS\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_UNDEF\nfail\n0\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_POINT\nfail\n$NUM_ET_POINT\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_LINE2\nfail\n$NUM_ET_LINE2\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_LINE3\nfail\n$NUM_ET_LINE3\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_TRIA3\nfail\n$NUM_ET_TRIA3\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck		   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_TRIA6\nfail\n$NUM_ET_TRIA6\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck			   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_QUAD4\nfail\n$NUM_ET_QUAD4\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck			   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_QUAD8\nfail\n$NUM_ET_QUAD8\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck			   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_QUAD9\nfail\n$NUM_ET_QUAD9\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck			   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_TET4\nfail\n$NUM_ET_TET4\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck			   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_TET10\nfail\n$NUM_ET_TET10\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck			   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_HEXA8\nfail\n$NUM_ET_HEXA8\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck			   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_HEXA20\nfail\n$NUM_ET_HEXA20\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_HEXA27\nfail\n$NUM_ET_HEXA27\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_PYRA5\nfail\n$NUM_ET_PYRA5\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_PYRA13\nfail\n$NUM_ET_PYRA13\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_WEDGE6\nfail\n$NUM_ET_WEDGE6\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck				   
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Elements\nuint\nNum_WEDGE15\nfail\n$NUM_ET_WEDGE15\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck                    
CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Nodes\nuint\nNumNodes\nfail\n$NUM_NODES\n"
printf $CMDSTR | $H5CFSHELPER > /dev/null; ErrorCheck                    

echo "Writing regions..."
REGION_ELEM_FILE_LIST=`ls $WORKDIR/RegionElems_*.dat`

for FILE in $REGION_ELEM_FILE_LIST; do
    FILE=`basename $FILE | cut -d'_' -f2`; ErrorCheck
    REGION_NAME=`echo $FILE | cut -d'.' -f1`; ErrorCheck
    ELEM_FILE="$WORKDIR/RegionElems_$FILE"
    NODE_FILE="$WORKDIR/RegionNodes_$FILE"
    DIM_FILE="$WORKDIR/RegionDim_$FILE"
    NUM_REGION_ELEMS=`wc -w $ELEM_FILE | cut -d' ' -f1`; ErrorCheck
    cat $NODE_FILE | sed -e 's/[\t ]/\n/g' | sort -unb > $WORKDIR/region_nodes.dat
    ErrorCheck
    NODE_FILE=$WORKDIR/region_nodes.dat
    NUM_REGION_NODES=`wc -w $NODE_FILE | cut -d' ' -f1`; ErrorCheck
    REGION_DIM=`cat $DIM_FILE`; ErrorCheck

    echo "Writing region $REGION_NAME..."

    if [ $(( $NUM_REGION_ELEMS > 1000 )) -eq 1 ]
    then
	CHUNKED_DIM_SIZES=1000
    else
	CHUNKED_DIM_SIZES=$NUM_REGION_ELEMS
    fi

    CFGFILE=$WORKDIR/RegionElems_$REGION_NAME.cfg
    echo "Number of Elems in region $REGION_NAME: $NUM_REGION_ELEMS"
    echo "PATH /Mesh/Regions/$REGION_NAME/Elements" > $CFGFILE
    echo "INPUT-CLASS TEXTUIN" >> $CFGFILE
    echo "INPUT-SIZE 32" >> $CFGFILE
    echo "RANK 1" >> $CFGFILE
    echo "DIMENSION-SIZES $NUM_REGION_ELEMS" >> $CFGFILE
    echo "OUTPUT-CLASS UIN" >> $CFGFILE
    echo "OUTPUT-SIZE 32" >> $CFGFILE
    echo "OUTPUT-ARCHITECTURE STD" >> $CFGFILE
    echo "OUTPUT-BYTE-ORDER LE" >> $CFGFILE
    echo "CHUNKED-DIMENSION-SIZES $CHUNKED_DIM_SIZES" >> $CFGFILE
    echo "COMPRESSION-TYPE GZIP" >> $CFGFILE
    echo "COMPRESSION-PARAM 9" >> $CFGFILE
    $H5IMPORT $ELEM_FILE -c $CFGFILE -o $H5FILE
    ErrorCheck

    if [ $(( $NUM_REGION_NODES > 1000 )) -eq 1 ]
    then
	CHUNKED_DIM_SIZES=1000
    else
	CHUNKED_DIM_SIZES=$NUM_REGION_NODES
    fi

    CFGFILE=$WORKDIR/RegionNodes_$REGION_NAME.cfg
    echo "Number of Nodes in region $REGION_NAME: $NUM_REGION_NODES"
    echo "PATH /Mesh/Regions/$REGION_NAME/Nodes" > $CFGFILE
    echo "INPUT-CLASS TEXTUIN" >> $CFGFILE
    echo "INPUT-SIZE 32" >> $CFGFILE
    echo "RANK 1" >> $CFGFILE
    echo "DIMENSION-SIZES $NUM_REGION_NODES" >> $CFGFILE
    echo "OUTPUT-CLASS UIN" >> $CFGFILE
    echo "OUTPUT-SIZE 32" >> $CFGFILE
    echo "OUTPUT-ARCHITECTURE STD" >> $CFGFILE
    echo "OUTPUT-BYTE-ORDER LE" >> $CFGFILE
    echo "CHUNKED-DIMENSION-SIZES $CHUNKED_DIM_SIZES" >> $CFGFILE
    echo "COMPRESSION-TYPE GZIP" >> $CFGFILE
    echo "COMPRESSION-PARAM 9" >> $CFGFILE
    $H5IMPORT $NODE_FILE -c $CFGFILE -o $H5FILE
    ErrorCheck

    echo "Writing region attributes..."
    CMDSTR="attribute\ncreate\n$H5FILE\n/Mesh/Regions/$REGION_NAME\nuint\nDimension\nfail\n$REGION_DIM\n"
    printf $CMDSTR | $H5CFSHELPER > /dev/null
done

rm -f test.cfg
echo "Done!"