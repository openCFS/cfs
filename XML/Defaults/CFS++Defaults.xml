<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org">

  <analysis type="static"/>
  <geometry type="3d"/>
  <input/>
  <output/>
  <materialData/>

  <domain>
    <region name="dummyRegion" material="dummyMaterial"/>
  </domain>

  <pdeList>

    <!-- Template for mechanics PDE -->
    <mechanic>
  
      <region name="dummyRegion"/>

      <nonLinear>
        <lineSearch/>
        <incStopCrit>1</incStopCrit>
        <resStopCrit>1</resStopCrit>
        <maxNumIters>1</maxNumIters>
      </nonLinear>

      <solver>
        <matrix/>
      </solver>
  
    </mechanic>

    <!-- Template for piezo PDE -->
    <piezo>
  
      <region name="dummyRegion"/>

      <nonLinear>
        <lineSearch/>
        <incStopCrit>1</incStopCrit>
        <resStopCrit>1</resStopCrit>
        <maxNumIters>1</maxNumIters>
      </nonLinear>

      <solver>
        <matrix/>
      </solver>

    </piezo>


    <!-- Template for magnetics PDE -->
    <magnetic>
      <region name="dummyRegion"/>
      <region name="dummyRegion"/>
      <bcsAndLoads>
        <dirichletHom name="dummyRegion"/>
      </bcsAndLoads>

      <coils>

        <measurementCoil2d name="dummyRegion">
          <windingCrossSection>1</windingCrossSection>
          <saveFileL/>
          <saveFileU/>
          <id>1</id>
        </measurementCoil2d>

        <measurementCoil3d name="dummyRegion">
          <windingCrossSection>1</windingCrossSection>
          <saveFileL/>
          <saveFileU/>
        </measurementCoil3d>

        <currentCoil2d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <id>    1 </id>
        </currentCoil2d>

        <currentCoil3d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <currentFlow>yDir</currentFlow>
        </currentCoil3d>

        <voltageCoil2d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <resistance>1</resistance>
          <id>    1 </id>
        </voltageCoil2d>

        <voltageCoil3d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <resistance>1</resistance>
        </voltageCoil3d>

      </coils>

    </magnetic>

  </pdeList>

  <transient>
    <numSteps>    1  </numSteps>
    <firstDt>     1  </firstDt>
    <stepSaveBeg> 1  </stepSaveBeg>
    <stepSaveEnd> 1  </stepSaveEnd>
    <stepSaveInc> 1  </stepSaveInc>
    <timeDataFile/>
  </transient>

  <integRules>
    <line      />
    <rectangle />
    <triangle  />
    <hexa      />
    <pyra      />
    <tetra     />
    <wedge     />
  </integRules>

</cfsSimulation>
