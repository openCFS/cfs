<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org">

<!-- ==========================================================================
     NOTE: Despite its name, this file is NOT the place for setting default
           parameters. This file is used to bring ELEMENTS which have default
           values or optional attributes into EXISTENCE. The default values
           themselves are set in the Schema definition
=========================================================================== -->

  <analysis type="static"/>
  <geometry type="3d"/>
  <input/>
  <output/>
  <database>
    <hostName/>
    <port/>
    <databaseName/>
    <materialDatabaseName/>
    <userName/>
    <password/>
  </database>
  <gmv>
    <fixedGrid/>
    <binaryFormat/>
  </gmv>
  <materialData/>

  <domain>
    <region name="dummyRegion" material="dummyMaterial"/>
  </domain>

  <pdeList>

    <!-- Template for mechanics PDE -->
    <mechanic>
  
      <region name="dummyRegion"/>

      <nonLinear>
        <lineSearch/>
        <incStopCrit>1</incStopCrit>
        <resStopCrit>1</resStopCrit>
        <maxNumIters>1</maxNumIters>
      </nonLinear>

      <solver>
        <matrix/>
        <stoppingRule/>
      </solver>
  
    </mechanic>

    <!-- Template for electrostatics PDE -->
    <electrostatic>
      <region name="dummyRegion"/>

      <nonLinear>
        <lineSearch/>
        <incStopCrit>1</incStopCrit>
        <resStopCrit>1</resStopCrit>
        <maxNumIters>1</maxNumIters>
      </nonLinear>

      <solver>
        <matrix/>
        <stoppingRule/>
      </solver>
  
    </electrostatic>

    <!-- Template for piezo PDE -->
    <piezo>
  
      <region name="dummyRegion"/>

      <nonLinear>
        <lineSearch/>
        <incStopCrit>1</incStopCrit>
        <resStopCrit>1</resStopCrit>
        <maxNumIters>1</maxNumIters>
      </nonLinear>

      <solver>
        <matrix/>
        <stoppingRule/>
      </solver>

    </piezo>


    <!-- Template for magnetics PDE -->
    <magnetic>
      <region name="dummyRegion"/>
      <region name="dummyRegion"/>
      <bcsAndLoads>
        <dirichletHom name="dummyRegion"/>
      </bcsAndLoads>

      <coils>

        <measurementCoil2d name="dummyRegion">
          <windingCrossSection>1</windingCrossSection>
          <saveFileL/>
          <saveFileU/>
          <id>1</id>
        </measurementCoil2d>

        <measurementCoil3d name="dummyRegion">
          <windingCrossSection>1</windingCrossSection>
          <saveFileL/>
          <saveFileU/>
        </measurementCoil3d>

        <currentCoil2d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <id>    1 </id>
        </currentCoil2d>

        <currentCoil3d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <currentFlow>yDir</currentFlow>
        </currentCoil3d>

        <voltageCoil2d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <resistance>1</resistance>
          <id>    1 </id>
        </voltageCoil2d>

        <voltageCoil3d name="dummyRegion">
          <windingCrossSection>  1 </windingCrossSection>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <resistance>1</resistance>
        </voltageCoil3d>

      </coils>

      <solver>
        <matrix/>
        <stoppingRule/>
      </solver>

    </magnetic>

    <!-- Template for acoustic PDE -->
    <acoustic>
  
      <region name="dummyRegion">
       <damping/>
      </region>
      <timeSteppingFormulation/>

      <solver>
        <matrix/>
        <stoppingRule/>
      </solver>

    </acoustic> 

    <!-- Template for smooth PDE -->
    <smooth>
  
      <region name="dummyRegion"/>

      <solver>
        <matrix/>
        <stoppingRule/>
      </solver>

    </smooth>

  </pdeList>

  

  <integRules>
    <line      />
    <rectangle />
    <triangle  />
    <hexa      />
    <pyra      />
    <tetra     />
    <wedge     />
  </integRules>

</cfsSimulation>
