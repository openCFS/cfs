<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org">

  <analysis type="static"/>
  <geometry type="3d"/>
  <input/>
  <output/>
  <materialData/>

  <domain>
    <region name="dummyRegion" material="dummyMaterial"/>
  </domain>

  <pdeList>

    <!-- Template for mechanics PDE -->
    <mechanic>
  
      <region name="dummyRegion"/>

      <nonLinear>
        <lineSearch/>
        <incStopCrit>1</incStopCrit>
        <resStopCrit>1</resStopCrit>
        <maxNumIters>1</maxNumIters>
      </nonLinear>
  
    </mechanic>

    <!-- Template for magnetics PDE -->
    <magnetic>
      <region name="dummyRegion"/>
      <region name="dummyRegion"/>
      <bcsAndLoads>
        <dirichletHom name="dummyRegion"/>
      </bcsAndLoads>

      <coils>
        <currentCoil2d name="dummyRegion">
          <area>  1 </area>
          <value> 1 </value>
          <dynamics/>
          <phase/>
          <id>    1 </id>
        </currentCoil2d>
      </coils>

    </magnetic>

  </pdeList>

  <integRules>
    <line      />
    <rectangle />
    <triangle  />
    <hexa      />
    <pyra      />
    <tetra     />
    <wedge     />
  </integRules>

</cfsSimulation>
