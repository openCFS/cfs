<?xml version="1.0"?>
<cfsSimulation xmlns="http://www.cfs++.org">
	
	<!--	 ============================================================= -->
	<!--   		NUMERICAL SIMULATION OF THERMAL PIEZOELECTRIC FIELDS   -->
	<!--		Simulation of a PZT-4 plate with a heat source in the
			top of the plate and its inverse piezoelectric effect.
			
			Heat Source = 50 grad K (bottom of the plate)
			Voltaje Source = 1 A (top of the plate)
			============================================================= -->	
	
	
	<fileFormats>
		<output>
			<!--<unv/>-->
			<gid/>
		</output>
		<materialData file="mat.xml" format="xml"/>
	</fileFormats>
	
	<!--DOMAIN PARAMETERS-->
	
	<domain geometryType="plane">
		<regionList>
			<region name="piezoPlate" material="examplepiezo" />
		</regionList>
	</domain>
	
	<!--ANALYSIS PARAMETERS-->
	
	<sequenceStep>
		<analysis>
<!--			<transient>
				<numSteps> 50 </numSteps>
				<deltaT>    1  </deltaT>
			</transient>-->
			<static/>
		</analysis>
		
		<!--PDE FIELDS-->
		
		<pdeList>
			
			<!--HEAT CONDUCTION-->
			<heatConduction>
				<regionList>
					<region name="piezoPlate"/>
				</regionList>
				
				<bcsAndLoads>
					<dirichletInhom name="hot" value="273.15"/>
					<!--<dirichletInhom name="gnd" value="1.0 * sample1D('sinRise.dat',t,1)"/>-->
					<dirichletInhom name="gnd" value="50"/>
					
					
				</bcsAndLoads>
				
				<storeResults>
					<nodeResult type="heatTemperature">
						<allRegions/>
						<nodeList>
							<!--<nodes name="historyNode"/>-->
							<nodes name="trace1"/>
							<nodes name="trace2"/>
							<nodes name="trace3"/>
							<nodes name="trace4"/>
						</nodeList>
					</nodeResult>
				</storeResults>
			</heatConduction>
			
			<!--MECHANIC FIELD-->
			<mechanic subType="planeStrain">
				<regionList>
					<region name="piezoPlate"/>
				</regionList>
				
				<bcsAndLoads>
					<dirichletHom name="fix-ux" dof="x" />
					<dirichletHom name="fix-uy" dof="y" />
				</bcsAndLoads>
				
				<storeResults>
					<nodeResult type="mechDisplacement">
						<allRegions/>
						<nodeList>
							<!--<nodes name="historyNode"/>-->
							<nodes name="trace1"/>
							<nodes name="trace2"/>
							<nodes name="trace3"/>
							<nodes name="trace4"/>
						</nodeList>
					</nodeResult>
				</storeResults>
			</mechanic>
			
			<!--ELECTRIC FIELD-->
			<electrostatic>
				<regionList>
					<region name="piezoPlate"/>
				</regionList>
				
				<bcsAndLoads>
					<dirichletHom name="gnd"  />
					<dirichletInhom name="hot"  value="100"/>
				</bcsAndLoads>
				
				<storeResults>
					<nodeResult type="elecPotential">
						<allRegions/>
						<nodeList>
							<!--<nodes name="historyNode"/>-->
							<nodes name="trace1"/>
							<nodes name="trace2"/>
							<nodes name="trace3"/>
							<nodes name="trace4"/>
						</nodeList>
					</nodeResult>
					<!--					<elemResult type="elecFieldIntensity">
						<allRegions/>
					</elemResult>-->
					
				</storeResults>
			</electrostatic>
			
			
		</pdeList> 
		
		<!--COUPLING PARAMETERS-->
		<couplingList>
			<direct>
				<!--THERMO-MECHANICAL COUPLING-->
				<thermoMechDirect> 
					<regionList>
						<region name="piezoPlate" /> 
					</regionList>
					
				</thermoMechDirect>
				
				<!--THERMO-ELECTRIC COUPLING  -->
				<thermoElectricDirect> 
					<regionList>
						<region name="piezoPlate" /> 
					</regionList>
				</thermoElectricDirect>
				
				<!--PIEZOELECTRIC COUPLING    -->
				<piezoDirect> 
					<regionList>
						<region name="piezoPlate" /> 
					</regionList>
				</piezoDirect>
				
				
				
			</direct>
		</couplingList>
		
	</sequenceStep>
</cfsSimulation>
