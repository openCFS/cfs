<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org">

<!-- ==========================================================================
     NOTE: Despite its name, this file is NOT the place for setting default
           parameters. This file is used to bring ELEMENTS which have default
           values or optional attributes into EXISTENCE. The default values
           themselves are set in the Schema definition
=========================================================================== -->

  <geometry type="3d"/>
  <input/>
  <output/>
   <materialData/>

  <domain>
    <region name="dummyRegion" material="dummyMaterial"/>
  </domain>

  <sequenceStep index="1">

    <analysis>
      <static/>
    </analysis>
    
    <pdeList>
      
      
      <!-- ***************************************************************** -->
      <!-- Template for mechanics PDE -->
      <!-- ***************************************************************** -->
      <mechanic>
        
        <region name="dummyRegion"/>
        
        <timeSteppingFormulation/>

        <nonLinear>
          <lineSearch/>
          <incStopCrit>1</incStopCrit>
          <resStopCrit>1</resStopCrit>
          <maxNumIters>1</maxNumIters>
        </nonLinear>
        
      </mechanic>


      <!-- ***************************************************************** -->
      <!-- Template for electrostatics PDE -->
      <!-- ***************************************************************** -->
      <electrostatic>
        <region name="dummyRegion"/>

        <nonLinear>
          <lineSearch/>
          <incStopCrit>1</incStopCrit>
          <resStopCrit>1</resStopCrit>
          <maxNumIters>1</maxNumIters>
        </nonLinear>

      </electrostatic>


      <!-- ***************************************************************** -->
      <!-- Template for magnetics PDE -->
      <!-- ***************************************************************** -->
      <magnetic>
        <region name="dummyRegion"/>

        <coils>

          <measurementCoil2d name="dummyRegion">
            <windingCrossSection>1</windingCrossSection>
            <saveFileL/>
            <saveFileU/>
            <id>1</id>
          </measurementCoil2d>

          <measurementCoil3d name="dummyRegion">
            <windingCrossSection>1</windingCrossSection>
            <saveFileL/>
            <saveFileU/>
          </measurementCoil3d>

          <currentCoil2d name="dummyRegion">
            <windingCrossSection>  1 </windingCrossSection>
            <value> 1 </value>
            <phase/>
            <id>    1 </id>
            <saveFileL/>
          </currentCoil2d>

          <currentCoil3d name="dummyRegion">
            <windingCrossSection>  1 </windingCrossSection>
            <value> 1 </value>
            <phase/>
            <currentFlow>yDir</currentFlow>
          </currentCoil3d>

          <voltageCoil2d name="dummyRegion">
            <windingCrossSection>  1 </windingCrossSection>
            <value> 1 </value>
            <phase/>
            <resistance>1</resistance>
            <id>    1 </id>
          </voltageCoil2d>

          <voltageCoil3d name="dummyRegion">
            <windingCrossSection>  1 </windingCrossSection>
            <value> 1 </value>
            <phase/>
            <resistance>1</resistance>
          </voltageCoil3d>

        </coils>

      </magnetic>


      <!-- ***************************************************************** -->
      <!-- Template for acoustic PDE -->
      <!-- ***************************************************************** -->
      <acoustic>
        
        <region name="dummyRegion">
          <damping/>
        </region>
        <timeSteppingFormulation/>
        <nonLinear>
          <lineSearch/>
          <incStopCrit>1</incStopCrit>
          <resStopCrit>1</resStopCrit>
          <maxNumIters>1</maxNumIters>
        </nonLinear>

      </acoustic> 



      <!-- ***************************************************************** -->
      <!-- Template for acousticXYZ PDE -->
      <!-- ***************************************************************** -->
      <acousticXYZ>
        
        <region name="dummyRegion">
          <damping/>
        </region>
        <timeSteppingFormulation/>

      </acousticXYZ> 


      <!-- ***************************************************************** -->
      <!-- Template for smooth PDE -->
      <!-- ***************************************************************** -->
      <smooth>
        <region name="dummyRegion"/>
      </smooth>


      <!-- ***************************************************************** -->
      <!-- Template for mpcci PDE -->
      <!-- ***************************************************************** -->
      <mpcci>
        
        <region name="dummyRegion" type="solid"/>

      </mpcci>

      <!-- ***************************************************************** -->
      <!-- Template for mpcci PDE -->
      <!-- ***************************************************************** -->
      <stokesFluid>
        <region name="dummyRegion"/>
      </stokesFluid>

    </pdeList>
    
    <linearSystems>
      <system name="acoustic">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="acousticXYZ">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="direct">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="electrostatic">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="magnetic">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="mechanic">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="mpcci">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="piezo">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="smooth">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="nrbc">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="heatConduction">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="stokesFluid">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
      <system name="bubble">
        <setup/>
        <matrix/>
        <eigenSolver/>
        <solver><stoppingRule/></solver>
      </system>
    </linearSystems>
  </sequenceStep>

  <integRules>
    <line      />
    <rectangle />
    <triangle  />
    <hexa      />
    <pyra      />
    <tetra     />
    <wedge     />
  </integRules>

  <expert/>

</cfsSimulation>
