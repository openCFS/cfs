<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org">

  <analysis type="static"/>
  <geometry type="3d"/>
  <output format="gmv"/>
  <materialData file="isoMat.dat"/>

  <domain>
    <region name="mech3d" material="P4"/>
    <nodes name="ux-lSide"/>
    <nodes name="uy-lSide"/>
    <nodes name="uz-lSide"/>
    <nodes name="ux-rSide"/>
    <nodes name="uy-rSide"/>
    <nodes name="uz-rSide"/>

     <!-- Definition of local coordinate systems -->
    <coordSys>

      <cylindric name="mid-Coil"> 
        <origin x="-5" y="0" z="0"/>
        <hAxis  x="-5" y="3"/>
        <rAxis  x="8" />
      </cylindric>

      <cylindric name="right-Coil"> 
        <origin/>
        <hAxis node="ux-lSide"/>
        <rAxis x="-1" y="0" z="0"/>
      </cylindric>
    </coordSys>
  </domain>

  <pdeList>
    <mechanic subType="3d">

      <region name="mech3d"/>

      <bcsAndLoads>
        <dirichletHom name="ux-lSide" dof="ux"/>
        <dirichletHom name="uy-lSide" dof="uy"/>
        <dirichletHom name="uz-lSide" dof="uz"/>

        <load name="ux-rSide" dof="ux" value="1e7"/>
        <load name="ux-rSide" dof="uy" value="1e7"/>
        <load name="ux-rSide" dof="uz" value="1e7"/>
        
        <!-- Referencing local coordinate system -->
        <regionLoad name="mech3d" refCoordSys="right-Coil" 
          dof="urad" value="1e-7"/>
      </bcsAndLoads>

      <storeResults>
        <nodeResults type="mechDisplacement"/>
      </storeResults>

    </mechanic>
  </pdeList>

</cfsSimulation>
