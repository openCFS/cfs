<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org">

  <analysis type="static"/>
  <geometry type="3d"/>
  <input format="mesh"/>
  <output format="unv"/>
  <materialData file="mat.dat"/>

  <domain>
    <region name="mech3d" material="silizium"/>
    <nodes name="ux-bound"/>
    <nodes name="uy-bound"/>
    <nodes name="uz-bound"/>
    <nodes name="uz-cente"/>
  </domain>

  <pdeList>
    <mechanic subType="3d">

      <region name="mech3d"/>

      <bcsAndLoads>
        <dirichletHom name="ux-bound" dof="ux"/>
        <dirichletHom name="uy-bound" dof="uy"/>
        <dirichletHom name="uz-bound" dof="uz"/>
        <load name="uz-cente" dof="uz" value="-1e-3"/>
      </bcsAndLoads>

      <storeResults>
        <nodeResults type="mechDisplacement"/>
      </storeResults>

      <!-- == PARDISO == -->
      <!--solver type="pardiso">
        <matrix eqnNumbering="scalar" entry="double" storage="sparseSym"
         reordering="noReordering"/>
        <pardiso>
          <posDef>     yes </posDef>
          <hermitean>   no </hermitean>
          <symStruct>  yes </symStruct>
          <ndOrdering>  no </ndOrdering>
          <logging>    yes </logging>
        </pardiso>
      </solver-->

      <!-- == DIRECT LU == -->
      <!--solver type="directLU">
        <matrix eqnNumbering="scalar" entry="double" storage="sparseNonSym"/>
      </solver-->

      <!-- == DIRECT LDL == -->
      <solver type="directLDL" precond="Id">
        <matrix eqnNumbering="scalar" entry="double" storage="sparseSym"/>
      </solver>

    </mechanic>
  </pdeList>

  <expert override="no"/>

</cfsSimulation>
