<?xml version="1.0"?>

<cfsSimulation xmlns="http://www.cfs++.org">

  <analysis type="bubbleDynamic"/>
  <geometry type="plane"/>

  <domain>
    <region name="fluid" material="water"/>
    <nodes name="vp-restr"/>
  </domain>

  <pdeList>
    <acoustic formulation="acouPressure">
      <region name="fluid">
         <damping type="rayleigh"/>
     </region>

     <bubbles>
       <bubbleType>KellerMiksis</bubbleType>
       <bubbleNumDensity>10.5</bubbleNumDensity>
     </bubbles>

     <bcsAndLoads>
       <dirichletInhom name="vp-restr" value="1.0" phase="45"/>
     </bcsAndLoads>

     <solver type="gmres">
       <exportLinSys baseName="harmchannel2d"/>
     </solver>

    </acoustic>
  </pdeList>

  <bubbleDynamic>
    <initRadius> 0.9 </initRadius>
    <initVel>  100</initVel>
    <density>  4.3333</density>
    <sonicVel>  10 </sonicVel>
    <pStatic>  1.2</pStatic>
    <pVapour>  132</pVapour>
    <surfaceTension>13  </surfaceTension>
    <polytrop>  13</polytrop>
    <viscosity> 13 </viscosity>
  </bubbleDynamic>

  <!-- This block is only required for a stand-alone bubble simulation.
       Otherwise the relevant data come from the acoustic PDE, while
       the bubbleType is specified in the <acoustic> block -->
  <bubbleDriver>
    <bubbleType>Gilmore</bubbleType>
    <pressure>  123 </pressure>
    <frequency> 50.9563 </frequency>
  </bubbleDriver>

  <harmonic>
    <numFreq>    1   </numFreq>
    <startFreq>  1e6 </startFreq>
    <stopFreq>   1e6 </stopFreq>
  </harmonic>

</cfsSimulation>
